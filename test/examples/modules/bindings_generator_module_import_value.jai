#import "Basic";
#import "Bindings_Generator";
#import "File";

#run {
    output := "out/test/openjai/bindings_generator_existing_output.jai";
    write_entire_file(output, "// existing generated bindings\n");

    opts: Generate_Bindings_Options;
    array_add(*opts.libpaths, ".");
    array_add(*opts.libnames, "openjai-test");
    array_add(*opts.include_paths, "include");
    array_add(*opts.source_files, "test.h");
    array_add(*opts.system_include_paths, GENERATOR_DEFAULT_SYSTEM_INCLUDE_PATH);
    array_add(*opts.extra_clang_arguments, "-x", "c++");
    opts.strip_flags = .INLINED_FUNCTIONS;
    opts.header = "// generated by test\n";

    generated := generate_bindings(opts, output);
    contents, read_ok := read_entire_file(output);

    print(
        "bindings:% % % % % % % % %\n",
        generated,
        read_ok,
        contents.count,
        opts.libpaths.count,
        opts.libnames.count,
        opts.include_paths.count,
        opts.source_files.count,
        opts.extra_clang_arguments.count,
        opts.strip_flags == .INLINED_FUNCTIONS
    );
}

main :: () {}
