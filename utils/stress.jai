----------------------------------------------------------------
== 604a. Enum range / #specified bit
----------------------------------------------------------------

-- Ranges
  PE6_Color range = [0, 3]
  PE6_Tone range = [0, 3]
  PE6_Day range = [0, 6]
  PE6_Month range = [1, 12]
  PE6_Phase range = [0, 3]

-- #specified bit
  PE6_Color    specified? false
  PE6_Tone     specified? false
  PE6_Day      specified? true
  PE6_Month    specified? true
  PE6_Compass  specified? false
  PE6_Phase    specified? false

----------------------------------------------------------------
== 604b. enum_flags bitwise ops
----------------------------------------------------------------

-- PE6_Permission combinations
  start: 0
  after |= READ: READ
  after |= WRITE: READ | WRITE
  after |= EXEC: READ | WRITE | EXEC
  flags: READ=true WRITE=true EXEC=true SPECIAL=false
  after &= ~WRITE: READ | EXEC
  after ^= SPECIAL: READ | EXEC | SPECIAL
  after ^= SPECIAL again: READ | EXEC

-- PE6_Capability combinations
  start (NETWORK|DISK|GPU): NETWORK | DISK | GPU
  add USB: NETWORK | DISK | GPU | USB
  drop DISK: NETWORK | GPU | USB
  full PE6_Permission = READ | WRITE | EXEC | SPECIAL

-- PE6_Build combinations
  initial: DEBUG_BUILD | PROFILE_BUILD
  after | TEST: DEBUG_BUILD | PROFILE_BUILD | TEST_BUILD
  drop DEBUG: PROFILE_BUILD | TEST_BUILD

----------------------------------------------------------------
== 604c. Flag combo decomposition
----------------------------------------------------------------
  READ|EXEC -> ["READ", "EXEC"]
  ALL -> ["READ", "WRITE", "EXEC", "SPECIAL"]
  NONE -> []
  NETWORK|GPU|BLUETOOTH -> ["NETWORK", "GPU", "BLUETOOTH"]
  DISK|USB|DMA|AUDIO|VIDEO -> ["DISK", "AUDIO", "VIDEO", "DMA", "USB"]
  DEBUG|TEST|BENCHMARK -> ["DEBUG_BUILD", "TEST_BUILD", "BENCHMARK_BUILD"]

