    x := 0b10102;
    print("%\n", x);
}
SRC},

.{ "exponent in integer literal", #string SRC
#import "Basic";
main :: () {
    x: int = 1e5;
    print("%\n", x);
}
SRC},

// ===========================================================================
// SECTION CG. Boolean / null / pointer abuse.
// ===========================================================================

.{ "true used where integer expected without cast", #string SRC
#import "Basic";
main :: () {
    x: int = true;
    print("%\n", x);
}
SRC},

.{ "boolean and integer added directly", #string SRC
#import "Basic";
main :: () {
    x := true + 1;
    print("%\n", x);
}
SRC},

.{ "null assigned to non-pointer integer", #string SRC
#import "Basic";
main :: () {
    x: int = null;
    print("%\n", x);
}
SRC},

.{ "null assigned to struct value", #string SRC
#import "Basic";
S :: struct { a: int; }
main :: () {
    s: S = null;
    print("%\n", s);
}
SRC},

.{ "compare pointer with non-null integer", #string SRC
#import "Basic";
main :: () {
    x: int = 5;
    p: *int = *x;
    if p == 1234 { print("eq\n"); }
}
SRC},

.{ "cast pointer to unrelated pointer type via plain cast", #string SRC
#import "Basic";
A :: struct { x: int; }
B :: struct { y: float; }
main :: () {
    a: A;
    p: *A = *a;
    q: *B = cast(*B) p;
    print("%\n", q.y);
}
SRC},

.{ "pointer arithmetic on non-pointer", #string SRC
#import "Basic";
main :: () {
    x: int = 5;
    y := x + cast(*void) null;
    print("%\n", y);
}
SRC},

.{ "indexing a pointer with brackets directly", #string SRC
#import "Basic";
main :: () {
    x: int = 5;
    p: *int = *x;
    y := p[0];
    print("%\n", y);
}
SRC},

// ===========================================================================
// SECTION CH. Range / loop value problems.
// ===========================================================================

.{ "range operator with non-integer endpoints", #string SRC
#import "Basic";
main :: () {
    for i: "a".."z" { print("%\n", i); }
}
SRC},

.{ "range with descending int bounds", #string SRC
#import "Basic";
main :: () {
    for i: 10..0 { print("%\n", i); }
}
SRC},

.{ "for with float endpoints", #string SRC
#import "Basic";
main :: () {
    for i: 0.0..5.0 { print("%\n", i); }
}
SRC},

.{ "range operator with one missing endpoint", #string SRC
#import "Basic";
main :: () {
    for i: ..10 { print("%\n", i); }
}
SRC},

.{ "range operator standalone in expression", #string SRC
#import "Basic";
main :: () {
    x := 1..10;
    print("%\n", x);
}
SRC},

// ===========================================================================
// SECTION CI. using depth and resolution failures.
// ===========================================================================

.{ "using on a name with no fields (integer)", #string SRC
#import "Basic";
main :: () {
    x: int = 5;
    using x;
    print("%\n", value);
}
SRC},

.{ "using on a name with no fields (string)", #string SRC
#import "Basic";
main :: () {
    s: string = "hello";
    using s;
    print("%\n", garbage);
}
SRC},

.{ "deep using chain referencing nonexistent field at deepest level", #string SRC
#import "Basic";
L1 :: struct { value: int; }
L2 :: struct { using l1: L1; }
L3 :: struct { using l2: L2; }
L4 :: struct { using l3: L3; }
main :: () {
    x: L4;
    print("%\n", x.does_not_exist);
}
SRC},

.{ "anonymous struct field with malformed body", #string SRC
#import "Basic";
S :: struct {
    using nested: struct {
        a: int
        b: int;
    };
}
main :: () { s: S; }
SRC},

.{ "anonymous union with duplicate member name", #string SRC
#import "Basic";
S :: struct {
    using u: union {
        v: int;
        v: float;
    };
}
main :: () { s: S; print("%\n", s.v); }
SRC},

// ===========================================================================
// SECTION CJ. Procedure type fields & polymorph defaults.
// ===========================================================================

.{ "struct field of procedure type with no body and bad signature", #string SRC
#import "Basic";
S :: struct {
    callback: (a: int, b:) -> int;
}
main :: () { s: S; }
SRC},

.{ "struct field default uses polymorphic procedure", #string SRC
#import "Basic";
poly :: (a: $T) -> T { return a; }
S :: struct {
    f: (a: int) -> int = poly;
}
main :: () { s: S; }
SRC},

.{ "constant initializer calls runtime-only procedure", #string SRC
#import "Basic";
