addf :: (a: int, b: int) -> int { return a + b; }
subf :: (a: int, b: int) -> int { return a - b; }
mulf :: (a: int, b: int) -> int { return a * b; }
divf :: (a: int, b: int) -> int { return a / b; }

test_extras_9_937_procptr :: () {
    section("937. Procedure pointers as runtime values");

    BinOp :: #type (a: int, b: int) -> int;
    ops: [..] BinOp;
    array_add(*ops, addf);
    array_add(*ops, subf);
    array_add(*ops, mulf);
    array_add(*ops, divf);

    labels := string.["add", "sub", "mul", "div"];
    for i: 0..ops.count-1 {
        v := ops[i](20, 4);
        print("  % -> %\n", labels[i], v);
    }
}


// ----------------------------------------------------------------------------
// 938. Manual hash function for strings.
// ----------------------------------------------------------------------------

djb2 :: (s: string) -> u64 {
    h: u64 = 5381;
    for c: cast([]u8) s  h = ((h << 5) + h) + cast(u64) c;
    return h;
}

test_extras_9_938_djb2 :: () {
    section("938. djb2 hash");

    inputs := string.["", "a", "ab", "abc", "Hello, World!",
                      "The quick brown fox", "1234567890"];
    for s: inputs {
        h := djb2(s);
        print("  djb2('%') = 0x%\n", s,
            formatInt(h, base=16, minimum_digits=16));
    }
}


// ----------------------------------------------------------------------------
// 939. Conway-like cellular automaton in 1D (Rule 30) for 16 steps.
// ----------------------------------------------------------------------------

test_extras_9_939_rule30 :: () {
    section("939. 1D cellular automaton Rule 30, 16 steps, width 33");

    W :: 33;
    state: [W] u8;
    state[W/2] = 1;

    for step: 0..15 {
        for c: 0..W-1  print(ifx state[c] != 0 then "#" else ".");
        print("\n");
        next: [W] u8;
        for c: 0..W-1 {
            l: u8 = ifx c > 0   then state[c-1] else cast(u8) 0;
            m: u8 = state[c];
            r: u8 = ifx c < W-1 then state[c+1] else cast(u8) 0;
            pattern: u8 = (l << 2) | (m << 1) | r;
            // Rule 30 in binary: 00011110
            next[c] = ifx (0b00011110 & (1 << pattern)) != 0 then cast(u8) 1 else cast(u8) 0;
        }
        state = next;
    }
}


