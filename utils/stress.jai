== 563. Matrix transpose and multiply
----------------------------------------------------------------

-- Matrix A (2x3)
    [ 1 2 3 ]
    [ 4 5 6 ]

-- Transpose of A (3x2)
    [ 1 4 ]
    [ 2 5 ]
    [ 3 6 ]

-- Matrix B (3x2)
    [ 7 8 ]
    [ 9 10 ]
    [ 11 12 ]

-- A * B (2x2)
    [ 58 64 ]
    [ 139 154 ]

-- Identity check: I3 * A^T
    id * a^T:
    [ 1 4 ]
    [ 2 5 ]
    [ 3 6 ]

