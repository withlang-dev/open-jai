// ----------------------------------------------------------------------------
// 920. GCD and LCM tables.
// ----------------------------------------------------------------------------

PE9_gcd :: (a_in: int, b_in: int) -> int {
    a, b := a_in, b_in;
    while b != 0 {
        a, b = b, a % b;
    }
    return a;
}

PE9_lcm :: (a: int, b: int) -> int {
    if a == 0 || b == 0  return 0;
    return (a / PE9_gcd(a, b)) * b;
}

test_extras_9_920_gcd_lcm :: () {
    section("920. GCD / LCM grid");

    inputs := int.[1, 2, 3, 6, 12, 18, 30, 42];
    for a: inputs {
        for b: inputs {
            print("  PE9_gcd(%,%)=%, PE9_lcm(%,%)=%\n",
                a, b, PE9_gcd(a, b), a, b, PE9_lcm(a, b));
        }
    }
}


// ----------------------------------------------------------------------------
// 921. Roman numerals (1..50).
// ----------------------------------------------------------------------------

int_to_roman :: (n_in: int) -> string {
    builder: String_Builder;
    init_string_builder(*builder);
    n := n_in;

    pairs :: int.[1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1];
    syms  :: string.["M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"];

    for i: 0..pairs.count-1 {
        while n >= pairs[i] {
            append(*builder, syms[i]);
            n -= pairs[i];
        }
    }
    return builder_to_string(*builder);
}

test_extras_9_921_roman :: () {
    section("921. Roman numerals 1..50");
    for n: 1..50  print("  % -> %\n", n, int_to_roman(n));
}


// ----------------------------------------------------------------------------
// 922. Conway's Game of Life on a fixed 8x8 grid for 5 steps.
// ----------------------------------------------------------------------------

print_grid :: (g: [8] [8] u8) {
    for r: 0..7 {
        for c: 0..7  print(ifx g[r][c] != 0 then "#" else ".");
        print("\n");
    }
}

step_life :: (g: [8][8] u8) -> [8][8] u8 {
    out: [8][8] u8;
    for r: 0..7 {
        for c: 0..7 {
            count := 0;
            for dr: -1..1 {
                for dc: -1..1 {
                    if dr == 0 && dc == 0  continue;
                    nr := r + dr;
                    nc := c + dc;
                    if nr < 0 || nr > 7  continue;
                    if nc < 0 || nc > 7  continue;
                    count += cast(int) g[nr][nc];
                }
            }
            alive := g[r][c] != 0;
            new_alive := ifx alive then (count == 2 || count == 3) else (count == 3);
            out[r][c] = ifx new_alive then cast(u8) 1 else cast(u8) 0;
        }
    }
    return out;
}

test_extras_9_922_life :: () {
    section("922. Conway's Game of Life (8x8, 5 steps)");

    g: [8][8] u8;
    // Blinker
    g[2][2] = 1; g[2][3] = 1; g[2][4] = 1;
    // Glider
    g[5][5] = 1; g[6][6] = 1; g[6][7] = 1; g[5][7] = 1; g[7][6] = 1;

    print("step 0:\n"); print_grid(g);
    for step: 1..5 {
        g = step_life(g);
        print("step %:\n", step); print_grid(g);
    }
}


// ----------------------------------------------------------------------------
// 923. Run-length encode / decode round-trip.
// ----------------------------------------------------------------------------

PE9_rle_encode :: (input: string) -> string {
    if input.count == 0  return "";
    b: String_Builder;
    init_string_builder(*b);

    cur := input[0];
    count := 1;
    for i: 1..input.count-1 {
        if input[i] == cur  count += 1;
        else {
            print_to_builder(*b, "%", count);
            append(*b, cur);
            cur = input[i];
            count = 1;
        }
    }
    print_to_builder(*b, "%", count);
    append(*b, cur);
    return builder_to_string(*b);
}

test_extras_9_923_rle :: () {
    section("923. RLE encode");

    inputs := string.["", "a", "aaa", "aabb", "aaaabbbcccdde",
                      "ABBBCCDAAA"];
    for s: inputs  print("  '%' -> '%'\n", s, PE9_rle_encode(s));
}


// ----------------------------------------------------------------------------
// 924. Caesar cipher encode/decode round-trip.
// ----------------------------------------------------------------------------

caesar :: (input: string, shift_in: int) -> string {
    shift := shift_in;
    while shift < 0  shift += 26;
    shift = shift % 26;
    out := alloc_string(input.count);
    for i: 0..input.count-1 {
        c := input[i];
        if c >= #char "a" && c <= #char "z" {
            out[i] = cast(u8) (((c - #char "a") + cast(u8) shift) % 26 + #char "a");
        } else if c >= #char "A" && c <= #char "Z" {
            out[i] = cast(u8) (((c - #char "A") + cast(u8) shift) % 26 + #char "A");
        } else {
            out[i] = c;
        }
    }
    return out;
}

test_extras_9_924_caesar :: () {
    section("924. Caesar cipher encode/decode");

    inputs := string.["Hello, World!", "abc XYZ", "shifty"];
    for s: inputs {
        for shift: int.[1, 3, 13, 25, 26, 27] {
            enc := caesar(s, shift);
            dec := caesar(enc, -shift);
            print("  shift=% in='%' enc='%' dec_eq_in=%\n",
                shift, s, enc, dec == s);
        }
    }
}


// ----------------------------------------------------------------------------
// 925. Levenshtein distance.
// ----------------------------------------------------------------------------

PE9_levenshtein :: (a: string, b: string) -> int {
    n := a.count;
    m := b.count;
    if n == 0  return m;
    if m == 0  return n;

    prev: [..] int;
    array_reserve(*prev, m + 1);
    for j: 0..m  array_add(*prev, j);

    curr: [..] int;
    array_reserve(*curr, m + 1);
    for j: 0..m  array_add(*curr, 0);

    for i: 1..n {
        curr[0] = i;
        for j: 1..m {
            cost := ifx a[i-1] == b[j-1] then 0 else 1;
            curr[j] = min(min(curr[j-1] + 1, prev[j] + 1), prev[j-1] + cost);
        }
        for j: 0..m  prev[j] = curr[j];
    }

    return prev[m];
}

test_extras_9_925_levenshtein :: () {
    section("925. Levenshtein distance");

    pairs := string.["kitten", "sitting",
                     "Saturday", "Sunday",
                     "hello", "yellow",
                     "abc", "abc",
                     "", "abc",
                     "abc", ""];
    i := 0;
    while i < pairs.count - 1 {
        a := pairs[i];
        b := pairs[i+1];
        print("  lev('%', '%') = %\n", a, b, PE9_levenshtein(a, b));
        i += 2;
    }
}


// ----------------------------------------------------------------------------
// 926. Fibonacci with memoization.
// ----------------------------------------------------------------------------

fib_memo_inner :: (n: int, cache: *[..] int) -> int {
    while cache.count <= n  array_add(cache, -1);
    if cache.*[n] != -1  return cache.*[n];
    r: int;
    if n < 2  r = n;
    else      r = fib_memo_inner(n-1, cache) + fib_memo_inner(n-2, cache);
    cache.*[n] = r;
    return r;
}

test_extras_9_926_fib_memo :: () {
    section("926. Fibonacci with memoization");

    cache: [..] int;
    for n: 0..30  print("  fib(%) = %\n", n, fib_memo_inner(n, *cache));
}


// ----------------------------------------------------------------------------
// 927. Knuth-Morris-Pratt-ish substring search (simple).
// ----------------------------------------------------------------------------

simple_find :: (haystack: string, needle: string) -> int {
    if needle.count == 0  return 0;
    for i: 0..haystack.count-needle.count {
        match := true;
        for j: 0..needle.count-1 {
            if haystack[i+j] != needle[j] {
                match = false;
                break;
            }
        }
        if match  return i;
    }
    return -1;
}

test_extras_9_927_find :: () {
    section("927. Substring search");

    examples := string.["The quick brown fox jumps over the lazy dog", "quick",
                        "ababababc", "abc",
                        "no needle here", "needles",
                        "", "anything",
                        "haystack", ""];
    i := 0;
    while i < examples.count - 1 {
        h := examples[i];
        n := examples[i+1];
        print("  find('%') in '%' = %\n", n, h, simple_find(h, n));
        i += 2;
    }
}


