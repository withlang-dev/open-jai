== 426. String contains / starts_with / ends_with
----------------------------------------------------------------
contains 'World'  = true
contains 'world'  = false
contains 'Hello'  = true
contains ''       = false
contains full     = true
starts_with 'H'      = true
starts_with 'Hello'  = true
starts_with 'hello'  = false
starts_with ''       = true
starts_with 'Hello, World!Extra' = false
ends_with '!'        = true
ends_with 'World!'   = true
ends_with 'world!'   = false
ends_with ''         = true

-- byte contains
contains 'o' byte = true
contains 'Q' byte = false

----------------------------------------------------------------
== 427. String replace
----------------------------------------------------------------
replace('alpha-beta-gamma-delta','-','+') = 'alpha+beta+gamma+delta' n=3
replace('aaa','a','AA') = 'AAAAAA' n=3
replace('abc','x','Y') = 'abc' n=0
replace('hello world','world','Mars') = 'hello Mars' n=1
replace('------','-','==') = '============' n=6
replace('','-','x') = '' n=0
replace('no replacements here','z','_') = 'no replacements here' n=0

----------------------------------------------------------------
== 428. String split
----------------------------------------------------------------
split('a,b,c,d') count=4 : 'a' | 'b' | 'c' | 'd'
split('a,,c') count=3 : 'a' | '' | 'c'
split(',b,c') count=3 : '' | 'b' | 'c'
split('a,b,') count=3 : 'a' | 'b' | ''
split('abcd') count=1 : 'abcd'
split(',') count=2 : '' | ''
split(',,,') count=4 : '' | '' | '' | ''
split('') count=1 : ''

-- split with string separator
'alpha::beta::gamma' / '::' count=3 : 'alpha' 'beta' 'gamma'
'aa-aa-aa' / 'aa' count=4 : '' '-' '-' ''

----------------------------------------------------------------
== 429. String split_from_left / split_from_right
----------------------------------------------------------------
split_from_left ('alpha-beta-gamma-delta')  found=true left='alpha' right='beta-gamma-delta'
split_from_left ('a-b')  found=true left='a' right='b'
split_from_left ('-leading')  found=true left='' right='leading'
split_from_left ('trailing-')  found=true left='trailing' right=''
split_from_left ('no-dashes-here')  found=true left='no' right='dashes-here'
split_from_left ('')  found=false left='' right=''
split_from_left ('no-separator')  found=true left='no' right='separator'
split_from_right('alpha-beta-gamma-delta') found=true left='alpha-beta-gamma' right='delta'
split_from_right('a-b') found=true left='a' right='b'
split_from_right('-leading') found=true left='' right='leading'
split_from_right('trailing-') found=true left='trailing' right=''
split_from_right('no-dashes-here') found=true left='no-dashes' right='here'
split_from_right('') found=false left='' right=''
split_from_right('no-separator') found=true left='no' right='separator'

----------------------------------------------------------------
== 430. String join
----------------------------------------------------------------
join(['x','y','z'], '-') = 'x-y-z'
join(['x','y','z'], '') = 'xyz'
join(['x','y','z'], ',') = 'x,y,z'
join(['x','y','z'], ' / ') = 'x / y / z'
join(['x','y','z'], '-', before=true) = '-x-y-z'
join(['x','y','z'], '-', after=true)  = 'x-y-z-'
join(['x','y','z'], '-', both)        = '-x-y-z-'

-- join with single element
join(['only'],'-') = 'only'

-- join with empty array
join(empty,'-') = ''

----------------------------------------------------------------
== 431. String trim
----------------------------------------------------------------
trim       ('   hello   ') = 'hello'
trim_left  ('   hello   ') = 'hello   '
trim_right ('   hello   ') = '   hello'
trim       ('hello   ') = 'hello'
trim_left  ('hello   ') = 'hello   '
trim_right ('hello   ') = 'hello'
trim       ('   hello') = 'hello'
trim_left  ('   hello') = 'hello'
trim_right ('   hello') = '   hello'
trim       ('hello') = 'hello'
trim_left  ('hello') = 'hello'
trim_right ('hello') = 'hello'
trim       ('   ') = ''
trim_left  ('   ') = ''
trim_right ('   ') = ''
trim       ('') = ''
trim_left  ('') = ''
trim_right ('') = ''
trim       ('  hello world  ') = 'hello world'
trim_left  ('  hello world  ') = 'hello world  '
trim_right ('  hello world  ') = '  hello world'
trim       ('	hello
') = 'hello'
trim_left  ('	hello
') = 'hello
'
trim_right ('	hello
') = '	hello'

-- Custom trim chars
trim ('-aa-', '-') = 'aa'
trim_left ('-aa-', '-') = 'aa-'
trim_right ('-aa-', '-') = '-aa'
trim ('xyzaXYZ', 'xyzXYZ') = 'a'

