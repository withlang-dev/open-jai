    }
}


// ============================================================================
// 634. Manual interpreter test: small "calculator" sequences with varying
//      arity, to confirm the VM is stable.
// ============================================================================

PE6_test_vm_more :: () {
    section("634. VM more programs");

    sub("Sum of 1..10 unrolled");
    {
        program: [..] PE6_VM_Instruction;
        array_add(*program, .{.PUSH, 0});
        for i: 1..10 {
            array_add(*program, .{.PUSH, cast(s64) i});
            array_add(*program, .{.ADD, 0});
        }
        array_add(*program, .{.PRINT, 0});
        array_add(*program, .{.HALT, 0});

        vm: PE6_VM;
        steps := PE6_vm_run(*vm, program, 200);
        print("  steps=% halted=% sp=%\n", steps, vm.halted, vm.sp);
    }

    sub("Compute 6! via repeated multiply");
    {
        program: [..] PE6_VM_Instruction;
        array_add(*program, .{.PUSH, 1});
        for i: 1..6 {
            array_add(*program, .{.PUSH, cast(s64) i});
            array_add(*program, .{.MUL, 0});
        }
        array_add(*program, .{.PRINT, 0});
        array_add(*program, .{.HALT, 0});

        vm: PE6_VM;
        steps := PE6_vm_run(*vm, program, 200);
        print("  steps=% halted=% sp=%\n", steps, vm.halted, vm.sp);
    }
}


// ============================================================================
// 635. Decomposition of every Permission combo (0..15).
// ============================================================================

PE6_test_all_permission_combos :: () {
    section("635. All Permission combos (raw value 0..15)");
    for v: 0..15 {
        p := cast,no_check(PE6_Permission) cast(u8) v;
        names := PE6_decompose_flag(p);
        print("  raw=% perm=% names=%\n", v, p, names);
    }
