== 141. Tiny lexer: identifiers / ints / operators
----------------------------------------------------------------

lex 'x = 42 + y * 3'
  kind=IDENT text='x'
  kind=OP text='='
  kind=INT text='42' ival=42
  kind=OP text='+'
  kind=IDENT text='y'
  kind=OP text='*'
  kind=INT text='3' ival=3
  kind=END

lex 'if foo > 0 then return foo - 1'
  kind=IDENT text='if'
  kind=IDENT text='foo'
  kind=OP text='>'
  kind=INT text='0' ival=0
  kind=IDENT text='then'
  kind=IDENT text='return'
  kind=IDENT text='foo'
  kind=OP text='-'
  kind=INT text='1' ival=1
  kind=END

lex 'a_b_c123 = (one_two + 99)'
  kind=IDENT text='a_b_c123'
  kind=OP text='='
  kind=SYM text='('
  kind=IDENT text='one_two'
  kind=OP text='+'
  kind=INT text='99' ival=99
  kind=SYM text=')'
  kind=END

lex '1 + 2 = 3 != 4'
  kind=INT text='1' ival=1
  kind=OP text='+'
  kind=INT text='2' ival=2
  kind=OP text='='
  kind=INT text='3' ival=3
  kind=OP text='!'
  kind=OP text='='
  kind=INT text='4' ival=4
  kind=END

