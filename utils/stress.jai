// ============================================================================
// this stress test - EXTRAS 3.
//
// public entry point, run_extras_3, which calls every test_xxx_p3 function in
// order. All output stays deterministic: no addresses, no source paths, no
// timing data, no command-line argument contents, no OS-specific values.
//
// Sections are numbered 200..230-ish to leave room for the other part files.
// ============================================================================


// ============================================================================
// 200. Variadic argument constraints with $T/interface.
// ============================================================================

Some_Number :: struct {
    value: int;
    name:  string;
}

// $T/interface Some_Number says: T must structurally have at least the same
// fields as Some_Number. We accept anything that ducks like Some_Number.
sum_of_values :: (items: ..$T/interface Some_Number) -> int {
    total := 0;
    for items  total += it.value;
    return total;
}

label_of_items :: (items: ..$T/interface Some_Number, sep := ", ") -> string {
    builder: String_Builder;
    init_string_builder(*builder);
    for items {
        if it_index > 0  append(*builder, sep);
        append(*builder, it.name);
    }
    return builder_to_string(*builder);
}

Big_Number :: struct {
    value: int;
    name:  string;
    extra: float = 1.5;
    note:  string = "big";
}

test_variadic_constraints :: () {
    section("200. Variadic constraints with $T/interface");

    a := Some_Number.{value=1, name="one"};
    b := Some_Number.{value=2, name="two"};
    c := Some_Number.{value=3, name="three"};
    total := sum_of_values(a, b, c);
    print("sum_of_values(a,b,c) = %\n", total);

    label := label_of_items(a, b, c, sep=" + ");
    print("label = '%'\n", label);

    sub("Interface accepts a superset struct");
    x := Big_Number.{value=10, name="ten"};
    y := Big_Number.{value=20, name="twenty"};
    total2 := sum_of_values(x, y);
    label2 := label_of_items(x, y);
    print("sum of Big_Number  = %\n", total2);
    print("label of Big_Number= '%'\n", label2);
}


// ============================================================================
// 201. #modify constraints (compile-time predicate on type parameters).
// ============================================================================

only_signed_double :: (x: $T) -> T
#modify {
    ti := cast(*Type_Info) T;
    if ti.type != .INTEGER  return false, "T must be an integer.";
    integer_info := cast(*Type_Info_Integer) ti;
    if !integer_info.signed return false, "T must be a signed integer.";
    return true;
}
{
    return x + x;
}

floats_only :: (x: $T) -> T
#modify {
    ti := cast(*Type_Info) T;
    if ti.type != .FLOAT  return false, "T must be a floating-point type.";
    return true;
}
{
    return x * 2;
}

test_modify_constraints :: () {
    section("201. #modify constraints on polymorphic parameters");

    print("only_signed_double(s8  =  5) = %\n", only_signed_double(cast(s8)  5));
    print("only_signed_double(s16 = 100)= %\n", only_signed_double(cast(s16) 100));
    print("only_signed_double(s32 = 7)  = %\n", only_signed_double(cast(s32) 7));
    print("only_signed_double(s64 = 999)= %\n", only_signed_double(cast(s64) 999));
    print("only_signed_double(int = -3) = %\n", only_signed_double(-3));

    print("floats_only(1.25_f32) = %\n", floats_only(cast(float32) 1.25));
    print("floats_only(2.5_f64)  = %\n", floats_only(cast(float64) 2.5));
}


// ============================================================================
// 202. Spread arguments with `..` operator.
// ============================================================================

sum_int_array :: (xs: ..int) -> int {
    total := 0;
    for xs  total += it;
    return total;
}

product_int_array :: (xs: ..int) -> int {
    total := 1;
    for xs  total *= it;
    return total;
}

test_spread_args :: () {
    section("202. Spread arguments with ..");

    fixed_arr := int.[1, 2, 3, 4, 5];
    print("sum(..fixed)     = %\n", sum_int_array(..fixed_arr));

    dynamic_arr: [..] int;
    array_add(*dynamic_arr, 10);
    array_add(*dynamic_arr, 20);
    array_add(*dynamic_arr, 30);
    array_add(*dynamic_arr, 40);
    print("sum(..dynamic)   = %\n", sum_int_array(..dynamic_arr));

    array_view : [] int = int.[2, 3, 5, 7];
    print("product(..view)  = %\n", product_int_array(..array_view));

    print("sum_int_array(7, 8, 9)        = %\n", sum_int_array(7, 8, 9));
    print("product_int_array(2, 3, 4)    = %\n", product_int_array(2, 3, 4));
}


// ============================================================================
// 203. Baked struct/proc arguments (constant parameters).
// ============================================================================

times_constant :: (x: int, $K: int) -> int {
    return x * K;
}

repeat_string :: (s: string, $N: int) -> string {
    out: [N] u8;
    j := 0;
    for i: 0..N-1  for c: 0..s.count-1 {
        if j >= N  break;
        out[j] = s[c];
        j += 1;
    }
    result: string;
    result.data  = out.data;
    result.count = j;
    return copy_string(result);
}

baked_pair :: ($A: int, $B: int) -> int {
    return A * 100 + B;
}

test_baked_constants :: () {
    section("203. Baked compile-time constants in proc parameters");

    print("times_constant(7, K=3) = %\n", times_constant(7, K=3));
    print("times_constant(7, K=5) = %\n", times_constant(7, K=5));

    s2 := repeat_string("ab", N=5);
    print("repeat 'ab' for N=5 = '%' count=%\n", s2, s2.count);

    print("baked_pair(A=4,B=2)    = %\n", baked_pair(A=4, B=2));
    print("baked_pair(A=9,B=9)    = %\n", baked_pair(A=9, B=9));
}


// ============================================================================
// 204. Tagged union via if/case pattern.
// ============================================================================

PE3_Shape_Tag :: enum {
    CIRCLE;
    RECT;
    TRIANGLE;
}

PE3_Shape :: struct {
    tag: PE3_Shape_Tag;
    union {
        circle  : struct { radius: float; };
        rect    : struct { width: float; height: float; };
        triangle: struct { base: float; height: float; };
    }
}

PE3_area_of_shape :: (s: PE3_Shape) -> float {
    if s.tag == {
        case .CIRCLE;   return 3.14159 * s.circle.radius * s.circle.radius;
        case .RECT;     return s.rect.width * s.rect.height;
        case .TRIANGLE; return 0.5 * s.triangle.base * s.triangle.height;
    }
    return 0.0;
}

PE3_shape_name :: (s: PE3_Shape) -> string {
    if s.tag == {
        case .CIRCLE;   return "circle";
        case .RECT;     return "rect";
        case .TRIANGLE; return "triangle";
    }
    return "unknown";
}

test_tagged_union :: () {
    section("204. Tagged union with if/case dispatch");

    shapes: [3] PE3_Shape;
    shapes[0].tag = .CIRCLE;
    shapes[0].circle.radius = 5;
    shapes[1].tag = .RECT;
    shapes[1].rect.width = 4;
    shapes[1].rect.height = 6;
    shapes[2].tag = .TRIANGLE;
    shapes[2].triangle.base = 3;
    shapes[2].triangle.height = 4;

    for shapes {
        print("  shape % (%): area = %\n", it_index, PE3_shape_name(it), PE3_area_of_shape(it));
    }

    sub("if/case on enum value with explicit fallthrough by relabelling");
    for s: shapes {
        if #complete s.tag == {
            case .CIRCLE;   print("  CIRCLE  tag matched\n");
            case .RECT;     print("  RECT    tag matched\n");
            case .TRIANGLE; print("  TRI     tag matched\n");
        }
    }
}


// ============================================================================
// 205. Tagged unions declared via the tagged_union_bindings mechanism.
// ============================================================================

Event_Kind :: enum u32 {
    NONE  :: 0;
    CLICK :: 1;
    KEY   :: 2;
    SCROLL:: 3;
}

Event :: struct {
    kind: Event_Kind;

    union {
        click  : struct { x, y: int; } #align 8;
        key    : struct { keycode: int; pressed: bool; };
        scroll : struct { delta_x: float; delta_y: float; };
    }
}

describe_event :: (e: Event) -> string {
    if e.kind == {
        case .NONE;   return tprint("NONE");
        case .CLICK;  return tprint("CLICK(x=%, y=%)", e.click.x, e.click.y);
        case .KEY;    return tprint("KEY(code=%, pressed=%)", e.key.keycode, e.key.pressed);
        case .SCROLL; return tprint("SCROLL(dx=%, dy=%)", e.scroll.delta_x, e.scroll.delta_y);
    }
    return "?";
}

test_event_dispatch :: () {
    section("205. Tagged event dispatch");

    events: [..] Event;
    {
        e: Event;
        e.kind = .CLICK;
        e.click.x = 100; e.click.y = 200;
        array_add(*events, e);
    }
    {
        e: Event;
        e.kind = .KEY;
        e.key.keycode = 65;
        e.key.pressed = true;
        array_add(*events, e);
    }
    {
        e: Event;
        e.kind = .SCROLL;
        e.scroll.delta_x = 0;
        e.scroll.delta_y = -1.5;
        array_add(*events, e);
    }
    {
        e: Event;
        e.kind = .NONE;
        array_add(*events, e);
    }

    for events  print("  [%] %\n", it_index, describe_event(it));
}


// ============================================================================
// 206. Code values via #code, plus reuse via #insert.
// ============================================================================

run_three :: (a: Code, b: Code, c: Code) #expand {
    #insert a;
    #insert b;
    #insert c;
}

test_code_values :: () {
    section("206. Code values and #insert reuse");

    {
        x := 5;
        run_three(#code { x += 2; }, #code { x = x * 2; }, #code { x = -x; });
        print("((5+2)*2)*-1 = %\n", x);
    }

    {
        x := 0;
        run_three(#code { x += 2; }, #code { x += 2; }, #code { x = x * 2; });
        print("((0+2)+2)*2 = %\n", x);
    }

    sub("Code can be supplied as inline blocks");
    {
        x := 1;
        run_three(#code { x += 100; }, #code { x = x - 1; }, #code { x = x*x; });
        print("((1+100)-1)*((1+100)-1) = %\n", x);
    }
}


// ============================================================================
// 207. Nested for-loops and outer/inner break targets.
// ============================================================================

test_nested_fors :: () {
    section("207. Nested for-loops with labels");

    sub("Plain nested loop:");
    for i: 0..2 {
        for j: 0..2  print("  (i=%, j=%)\n", i, j);
    }

    sub("Break out of inner only:");
    for i: 0..2 {
        for j: 0..4 {
            if j == 2  break;
            print("  inner-break i=% j=%\n", i, j);
        }
    }

    sub("Continue inner:");
    for i: 0..1 {
        for j: 0..3 {
            if j % 2 == 1  continue;
            print("  even-only i=% j=%\n", i, j);
        }
    }

    sub("Break out of outer loop via flag:");
    done := false;
    for i: 0..3 {
        if done  break;
        for j: 0..3 {
            if i == 1 && j == 2 {
                done = true;
                break;
            }
            print("  flagged i=% j=%\n", i, j);
        }
    }
    print("  done outer-break loop\n");
}


// ============================================================================
// 208. for-loop over Hash_Table.
// ============================================================================

test_for_over_hash_table :: () {
    section("208. for over Hash_Table");

    table: Table(string, int);
    init(*table);
    defer deinit(*table);

    table_add(*table, "alpha", 1);
    table_add(*table, "beta",  2);
    table_add(*table, "gamma", 3);
    table_add(*table, "delta", 4);

    sub("for v, k: table — gather keys then sort for determinism");
    keys: [..] string;
    vals: [..] int;
    for v, k: table {
        array_add(*keys, k);
        array_add(*vals, v);
    }
    print("collected count=%\n", keys.count);

    // sort keys (insertion sort, ascending)
    for i: 1..keys.count-1 {
        j := i;
        while j > 0 {
            a := keys[j-1];
            b := keys[j];
            // compare byte-wise
            less := false;
            n := min(a.count, b.count);
            differed := false;
            for k: 0..n-1 {
                if a[k] != b[k] { less = b[k] < a[k]; differed = true; break; }
            }
            if !differed less = b.count < a.count;
            if less {
                tmp_k := keys[j]; keys[j] = keys[j-1]; keys[j-1] = tmp_k;
                tmp_v := vals[j]; vals[j] = vals[j-1]; vals[j-1] = tmp_v;
                j -= 1;
            } else {
                break;
            }
        }
    }

    for keys  print("  %=%\n", it, vals[it_index]);

    sub("for * (pointer iteration)");
    sum := 0;
    for *pv: table  sum += pv.*;
    print("sum-of-values = %\n", sum);
}


// ============================================================================
// 209. for over Bit_Array.
// ============================================================================

test_for_over_bit_array :: () {
    section("209. for over Bit_Array");

    ba: Bit_Array;
    init_bit_array(*ba, 16);

    set_bit(*ba, 0);
    set_bit(*ba, 2);
    set_bit(*ba, 4);
    set_bit(*ba, 7);
    set_bit(*ba, 15);

    print("listing bits set:\n");
    for bit_is_set: ba  if bit_is_set  print("  bit[%] = 1\n", it_index);

    print("listing bits clear:\n");
    for bit_is_set: ba  if !bit_is_set  print("  bit[%] = 0\n", it_index);

    deinit(*ba);
}


// ============================================================================
// 210. Build a large formatted report into a String_Builder.
// ============================================================================

build_report :: () -> string {
    builder: String_Builder;
    init_string_builder(*builder);
    print_to_builder(*builder, "==== System Report (synthetic) ====\n");
    print_to_builder(*builder, "version: %\n", "1.2.3");
    print_to_builder(*builder, "components: %\n", 7);
    print_to_builder(*builder, "\n");

    for i: 1..5 {
        print_to_builder(*builder, "  [%]:\n", i);
        print_to_builder(*builder, "    name      = component-%\n", i);
        print_to_builder(*builder, "    score     = %\n", i * i);
        print_to_builder(*builder, "    active    = %\n", (i % 2) == 1);
    }
    print_to_builder(*builder, "\n");
    print_to_builder(*builder, "Summary table:\n");
    print_to_builder(*builder, "  | id | value |\n");
    print_to_builder(*builder, "  |----|-------|\n");
    for i: 0..3 {
        print_to_builder(*builder, "  |  % |    % |\n", i, i*7);
    }
    print_to_builder(*builder, "==== End report ====\n");
    return builder_to_string(*builder);
}

test_big_string_builder :: () {
    section("210. Large String_Builder programs");

    report := build_report();
    print("--- begin built report ---\n");
    print("%", report);
    print("--- end built report ---\n");
    print("report length = % bytes\n", report.count);
}


// ============================================================================
// 211. Manual hash table written from scratch using polymorphic structs.
// ============================================================================

Manual_Map :: struct(Key: Type, Value: Type, $N: int) {
    occupied: [N] bool;
    keys:     [N] Key;
    values:   [N] Value;
}

map_djb2 :: (s: string) -> u64 {
    h: u64 = 5381;
    for i: 0..s.count-1 {
        h = h * 33 + s[i];
    }
    return h;
}

manual_map_set :: (m: *$M/Manual_Map, key: M.Key, value: M.Value) -> bool {
    // returns true on insertion, false on update
    h := map_djb2(key);
    idx := cast(s64) (h % cast(u64) M.N);
    for offset: 0..M.N-1 {
        i := (idx + offset) % M.N;
        if !m.occupied[i] {
            m.occupied[i] = true;
            m.keys[i]     = key;
            m.values[i]   = value;
            return true;
        }
        if m.keys[i] == key {
            m.values[i] = value;
            return false;
        }
    }
    return false;
}

manual_map_get :: (m: *$M/Manual_Map, key: M.Key) -> (value: M.Value, ok: bool) {
    h := map_djb2(key);
    idx := cast(s64) (h % cast(u64) M.N);
    for offset: 0..M.N-1 {
        i := (idx + offset) % M.N;
        if !m.occupied[i] {
            empty: M.Value;
            return empty, false;
        }
        if m.keys[i] == key {
            return m.values[i], true;
        }
    }
    empty: M.Value;
    return empty, false;
}

manual_map_count :: (m: *$M/Manual_Map) -> int {
    n := 0;
    for v: m.occupied  if v  n += 1;
    return n;
}

test_manual_hash :: () {
    section("211. Manual hash table from scratch");

    m: Manual_Map(string, int, 16);

    inserted1 := manual_map_set(*m, "apple",  1);
    inserted2 := manual_map_set(*m, "banana", 2);
    inserted3 := manual_map_set(*m, "cherry", 3);
    updated   := manual_map_set(*m, "banana", 22);

    print("inserted apple: %\n", inserted1);
    print("inserted banana: %\n", inserted2);
    print("inserted cherry: %\n", inserted3);
    print("update    banana: % (false = was update)\n", updated);

    v, ok := manual_map_get(*m, "apple");
    print("get apple    -> ok=% v=%\n", ok, v);
    v, ok = manual_map_get(*m, "banana");
    print("get banana   -> ok=% v=%\n", ok, v);
    v, ok = manual_map_get(*m, "cherry");
    print("get cherry   -> ok=% v=%\n", ok, v);
    v, ok = manual_map_get(*m, "missing");
    print("get missing  -> ok=% v=%\n", ok, v);
    print("count = %\n", manual_map_count(*m));
}


// ============================================================================
// 212. Trie (prefix tree) of strings.
// ============================================================================

Trie_Node :: struct {
    has_child: [26] bool;
    children:  [26] *Trie_Node;
    is_end_of_word: bool;
    count_words_through_here: int;
}

trie_make :: () -> *Trie_Node {
    n := New(Trie_Node);
    return n;
}

trie_insert :: (root: *Trie_Node, word: string) {
    cur := root;
    for i: 0..word.count-1 {
        c := word[i];
        // assume lowercase a-z
        if c < #char "a" || c > #char "z"  continue;
        idx := cast(int) (c - #char "a");
        if !cur.has_child[idx] {
            cur.has_child[idx] = true;
            cur.children[idx]  = New(Trie_Node);
        }
        cur = cur.children[idx];
        cur.count_words_through_here += 1;
    }
    cur.is_end_of_word = true;
}

trie_contains :: (root: *Trie_Node, word: string) -> bool {
    cur := root;
    for i: 0..word.count-1 {
        c := word[i];
        if c < #char "a" || c > #char "z"  return false;
        idx := cast(int) (c - #char "a");
        if !cur.has_child[idx]  return false;
        cur = cur.children[idx];
    }
    return cur.is_end_of_word;
}

trie_prefix_count :: (root: *Trie_Node, prefix: string) -> int {
    cur := root;
    for i: 0..prefix.count-1 {
        c := prefix[i];
        if c < #char "a" || c > #char "z"  return 0;
        idx := cast(int) (c - #char "a");
        if !cur.has_child[idx]  return 0;
        cur = cur.children[idx];
    }
    return cur.count_words_through_here;
}

trie_collect :: (node: *Trie_Node, current: string, out: *[..] string) {
    if node.is_end_of_word  array_add(out, copy_string(current));
    for c: 0..25 {
        if node.has_child[c] {
            ch: u8 = cast(u8) (cast(u8) #char "a" + cast(u8) c);
            buf: [256] u8;
            i := 0;
            for k: 0..current.count-1 {
                if i >= 255  break;
                buf[i] = current[k];
                i += 1;
            }
            if i < 255 {
                buf[i] = ch;
                i += 1;
            }
            s: string;
            s.data  = buf.data;
            s.count = i;
            trie_collect(node.children[c], s, out);
        }
    }
}

test_trie :: () {
    section("212. Trie (prefix tree)");

    root := trie_make();

    words := string.["apple", "app", "apricot", "ape", "banana", "band", "bandana", "bandit"];
    for w: words  trie_insert(root, w);

    sub("contains tests");
    print("contains 'apple'  = %\n", trie_contains(root, "apple"));
    print("contains 'app'    = %\n", trie_contains(root, "app"));
    print("contains 'appl'   = %\n", trie_contains(root, "appl"));
    print("contains 'banana' = %\n", trie_contains(root, "banana"));
    print("contains 'ban'    = %\n", trie_contains(root, "ban"));
    print("contains 'bandz'  = %\n", trie_contains(root, "bandz"));

    sub("prefix counts");
    print("prefix 'ap'    -> %\n", trie_prefix_count(root, "ap"));
    print("prefix 'app'   -> %\n", trie_prefix_count(root, "app"));
    print("prefix 'b'     -> %\n", trie_prefix_count(root, "b"));
    print("prefix 'band'  -> %\n", trie_prefix_count(root, "band"));
    print("prefix 'cat'   -> %\n", trie_prefix_count(root, "cat"));

    sub("collect all words in trie (alpha order)");
    out: [..] string;
    empty: string;
    trie_collect(root, empty, *out);
    for out  print("  %\n", it);
}


// ============================================================================
// 213. Expression tree walker (AST built from tagged-struct nodes).
// ============================================================================

AST_Tag :: enum {
    LITERAL;
    ADD;
    SUB;
    MUL;
    DIV;
    NEG;
}

AST :: struct {
    tag: AST_Tag;
    value: int;     // used only for LITERAL
    left:  *AST;
    right: *AST;
}

ast_lit :: (v: int) -> *AST {
    n := New(AST);
    n.tag = .LITERAL;
    n.value = v;
    return n;
}

ast_bin :: (tag: AST_Tag, l: *AST, r: *AST) -> *AST {
    n := New(AST);
    n.tag   = tag;
    n.left  = l;
    n.right = r;
    return n;
}

ast_neg :: (e: *AST) -> *AST {
    n := New(AST);
    n.tag  = .NEG;
    n.left = e;
    return n;
}

ast_eval :: (n: *AST) -> int {
    if n == null  return 0;
    if n.tag == {
        case .LITERAL; return n.value;
        case .ADD; return ast_eval(n.left) + ast_eval(n.right);
        case .SUB; return ast_eval(n.left) - ast_eval(n.right);
        case .MUL; return ast_eval(n.left) * ast_eval(n.right);
        case .DIV;
            r := ast_eval(n.right);
            if r == 0  return 0;
            return ast_eval(n.left) / r;
        case .NEG; return -ast_eval(n.left);
    }
    return 0;
}

ast_print :: (n: *AST, b: *String_Builder) {
    if n == null { append(b, "null"); return; }
    if n.tag == {
        case .LITERAL; print_to_builder(b, "%", n.value);
        case .ADD;
            append(b, "(");
            ast_print(n.left, b);
            append(b, " + ");
            ast_print(n.right, b);
            append(b, ")");
        case .SUB;
            append(b, "(");
            ast_print(n.left, b);
            append(b, " - ");
            ast_print(n.right, b);
            append(b, ")");
        case .MUL;
            append(b, "(");
            ast_print(n.left, b);
            append(b, " * ");
            ast_print(n.right, b);
            append(b, ")");
        case .DIV;
            append(b, "(");
            ast_print(n.left, b);
            append(b, " / ");
            ast_print(n.right, b);
            append(b, ")");
        case .NEG;
            append(b, "(-");
            ast_print(n.left, b);
            append(b, ")");
    }
}

ast_depth :: (n: *AST) -> int {
    if n == null  return 0;
    if n.tag == .LITERAL  return 1;
    l := ast_depth(n.left);
    r := ast_depth(n.right);
    return 1 + max(l, r);
}

ast_count :: (n: *AST) -> int {
    if n == null  return 0;
    return 1 + ast_count(n.left) + ast_count(n.right);
}

test_ast_walker :: () {
    section("213. AST expression-tree walker");

    // (((1 + 2) * (3 - 4)) + -(5 * 6))
    e := ast_bin(.ADD,
        ast_bin(.MUL,
            ast_bin(.ADD, ast_lit(1), ast_lit(2)),
            ast_bin(.SUB, ast_lit(3), ast_lit(4))),
        ast_neg(ast_bin(.MUL, ast_lit(5), ast_lit(6))));

    b: String_Builder;
    init_string_builder(*b);
    ast_print(e, *b);
    expr_str := builder_to_string(*b);
    print("expr   : %\n", expr_str);
    print("value  : %\n", ast_eval(e));
    print("depth  : %\n", ast_depth(e));
    print("count  : %\n", ast_count(e));

    sub("Another tree: division and zero-guard");
    div_tree := ast_bin(.DIV, ast_lit(100), ast_bin(.SUB, ast_lit(7), ast_lit(7)));
    b2: String_Builder;
    init_string_builder(*b2);
    ast_print(div_tree, *b2);
    print("expr  : %\n", builder_to_string(*b2));
    print("value : %\n", ast_eval(div_tree));
}


// ============================================================================
// 214. Recursive reflection: walk a struct's fields, recursing into nested
//      structs. Emit a flat dump.
// ============================================================================

Address :: struct {
    street: string;
    city:   string;
    zip:    int;
}

PE3_Person :: struct {
    name:    string;
    age:     int;
    address: Address;
    score:   float;
}

reflect_dump_field :: (info: *Type_Info, indent: int) {
    spaces: [32] u8;
    memset(spaces.data, #char " ", 32);
    pad: string;
    pad.data  = spaces.data;
    pad.count = min(indent, 32);

    if info.type == .STRUCT {
        s := cast(*Type_Info_Struct) info;
        print("%STRUCT name='% members=%\n", pad, s.name, s.members.count);
        for s.members {
            print("%  field='%' type='%' offset=%\n", pad, it.name, type_to_string(it.type), it.offset_in_bytes);
            // recurse into nested struct
            if it.type.type == .STRUCT  reflect_dump_field(it.type, indent + 4);
        }
    } else {
        print("%TYPE '%' size=%\n", pad, type_to_string(info), info.runtime_size);
    }
}

test_recursive_reflection :: () {
    section("214. Reflection: recursive struct walk");

    info := cast(*Type_Info) type_info(PE3_Person);
    reflect_dump_field(info, 0);
}


// ============================================================================
// 215. Custom bump allocator implementing Allocator_Proc.
// ============================================================================

Bump_Data :: struct {
    buffer:    *u8;
    capacity:  s64;
    used:      s64;
    alloc_calls:   int;
    resize_calls:  int;
    free_calls:    int;
}

bump_alloc_proc :: (mode: Allocator_Mode, size: s64, old_size: s64, old_memory: *void, allocator_data: *void) -> *void {
    bump := cast(*Bump_Data) allocator_data;

    if mode == {
        case .ALLOCATE;
            bump.alloc_calls += 1;
            // 8-byte align
            aligned := (bump.used + 7) & ~7;
            if aligned + size > bump.capacity  return null;
            p := bump.buffer + aligned;
            bump.used = aligned + size;
            return p;

        case .RESIZE;
            bump.resize_calls += 1;
            // simplest: alloc new and memcpy
            aligned := (bump.used + 7) & ~7;
            if aligned + size > bump.capacity  return null;
            new_p := bump.buffer + aligned;
            bump.used = aligned + size;
            if old_memory != null && old_size > 0 {
                n := old_size;
                if size < n  n = size;
                memcpy(new_p, old_memory, n);
            }
            return new_p;

        case .FREE;
            bump.free_calls += 1;
            // no-op for bump allocator
            return null;

        case .STARTUP;   return allocator_data;
        case .SHUTDOWN;  return null;
        case .CAPS;      return null;
    }
    return null;
}

make_bump_allocator :: (data: *Bump_Data, buffer: *u8, cap: s64) -> Allocator {
    data.buffer   = buffer;
    data.capacity = cap;
    data.used     = 0;
    a: Allocator;
    a.proc = bump_alloc_proc;
    a.data = data;
    return a;
}

test_bump_allocator :: () {
    section("215. Custom bump allocator implementing Allocator_Proc");

    buf: [1024] u8;
    data: Bump_Data;
    a := make_bump_allocator(*data, buf.data, buf.count);

    // Allocate a few arrays through our bump allocator.
    arr1: [..] int;
    arr1.allocator = a;
    for i: 0..4  array_add(*arr1, i*i);

    arr2: [..] int;
    arr2.allocator = a;
    for i: 0..7  array_add(*arr2, i+100);

    print("arr1 = %\n", arr1);
    print("arr2 = %\n", arr2);
    print("alloc_calls    = %\n", data.alloc_calls > 0);
    print("resize_calls>=0= %\n", data.resize_calls >= 0);
    print("used <= cap    = %\n", data.used <= data.capacity);
}


// ============================================================================
// 216. Apollo_Time API surface with a FIXED, deterministic value.
// ============================================================================

test_apollo_fixed :: () {
    section("216. Apollo_Time with fixed values ");

    // Use seconds_to_apollo to construct a deterministic time.
    one_second   :=   seconds_to_apollo(1);
    sixty_secs   :=   seconds_to_apollo(60);
    thousand_ms  :=   milliseconds_to_apollo(1000);

    diff := sixty_secs - one_second;
    print("60s - 1s   in seconds   = %\n", to_float64_seconds(diff));
    print("1000ms == 1s ?           = %\n", to_float64_seconds(thousand_ms) == to_float64_seconds(one_second));

    sub("Compare via compare_apollo_times");
    print("compare(1s, 60s)        = %\n", compare_apollo_times(one_second, sixty_secs));
    print("compare(60s, 1s)        = %\n", compare_apollo_times(sixty_secs, one_second));
    print("compare(1s, 1s)         = %\n", compare_apollo_times(one_second, one_second));

    sub("Construct a Calendar_Time directly and inspect");
    ct: Calendar_Time;
    ct.year = 2024;
    ct.month_starting_at_0        = 5;       // June
    ct.day_of_month_starting_at_0 = 14;      // 15th of the month
    ct.hour       = 12;
    ct.minute     = 30;
    ct.second     = 45;
    ct.millisecond = 250;
    ct.time_zone   = .UTC;
    print("Calendar_Time year=%, month_idx=%, day_idx=%, hour=%, minute=%, second=%, ms=%, tz=%\n",
        ct.year, ct.month_starting_at_0, ct.day_of_month_starting_at_0,
        ct.hour, ct.minute, ct.second, ct.millisecond, ct.time_zone);

    sub("Apollo to_seconds / to_milliseconds round-trip");
    {
        t  := seconds_to_apollo(3600);
        s, ok := to_seconds(t);
        print("3600s -> apollo -> seconds = % ok=%\n", s, ok);
        ms, ok2 := to_milliseconds(t);
        print("3600s -> apollo -> millis  = % ok=%\n", ms, ok2);
    }
}


