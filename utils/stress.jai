}


// ----------------------------------------------------------------------------
// 762. Defer pattern: build cleanup stack for the entire scope.
// ----------------------------------------------------------------------------

run_extras_7_defer_cleanup_stack :: () {
    section("762. Defer cleanup stack");

    log: [..] int;
    defer array_free(log);

    push_step :: (l: *[..] int, v: int) #expand {
        array_add(l, v);
    }

    {
        defer push_step(*log, 99);  // last out
        push_step(*log, 1);
        defer push_step(*log, 88);  // before 99
        push_step(*log, 2);
        defer push_step(*log, 77);  // before 88
        push_step(*log, 3);
        {
            defer push_step(*log, 66);  // inner
            push_step(*log, 4);
            defer push_step(*log, 55);  // inner before 66
            push_step(*log, 5);
        }
        push_step(*log, 6);
        defer push_step(*log, 44);
        push_step(*log, 7);
    }
    for v, idx: log  print("  step %=%\n", idx, v);
}


// ----------------------------------------------------------------------------
// 763. More for_expansion: cartesian product.
// ----------------------------------------------------------------------------

PE7_Cartesian :: struct { a: [] int; b: [] int; }

cartesian :: (h: *PE7_Cartesian, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    for x: h.a {
        for y: h.b {
            `it := PE7_Pair.{x, y};
            #insert body;
            it_index += 1;
        }
    }
}

run_extras_7_iters_cartesian :: () {
    section("763. Cartesian product iterator");

    c := PE7_Cartesian.{int.[1, 2, 3], int.[10, 20, 30]};
    for :cartesian c  print("  idx=% (%, %)\n", it_index, it.a, it.b);

    c2 := PE7_Cartesian.{int.[100, 200], int.[]};
    print("  empty b array:\n");
    for :cartesian c2  print("  idx=% (%, %)\n", it_index, it.a, it.b);
}


// ----------------------------------------------------------------------------
// 764. Print a labeled comparison summary of matrix operations.
// ----------------------------------------------------------------------------

run_extras_7_matrix_summary :: () {
    section("764. Matrix2x2 properties summary");

    sample := PE7_M22.[
        .{1, 2, 3, 4},
        .{0, 1, 1, 0},
        .{2, 0, 0, 2},
        .{1, 1, 1, 1},
        .{3, 2, 5, 4},
        .{-1, 2, 3, -4},
    ];

    for m, idx: sample {
        det := m22_det(m);
        tr  := m22_trace(m);
        // a^2 + b^2 + c^2 + d^2
        n2 := m.a*m.a + m.b*m.b + m.c*m.c + m.d*m.d;
        print("  m%: det=% trace=% frob2=%\n", idx, det, tr, n2);
    }
}


// ----------------------------------------------------------------------------
// 765. Polynomial Horner trace.
// ----------------------------------------------------------------------------

run_extras_7_poly_trace :: () {
    section("765. Polynomial Horner trace");

    p := poly_make(float64.[3, 0, -2, 5]);   // 3 - 2x^2 + 5x^3
    poly_print("p", p);

    for x: float64.[0, 1, 2, 3, 4, 5] {
        acc := p.coeffs[p.coeffs.count - 1];
        i := p.coeffs.count - 2;
        print("  x=% start_acc=%\n", x, acc);
        while i >= 0 {
            acc = acc * x + p.coeffs[i];
            print("    step i=% coef=% new_acc=%\n", i, p.coeffs[i], acc);
            i -= 1;
        }
        print("  final p(%)=%\n", x, acc);
    }
}


