print_any :: (label: string, a: Any) {
    print("  %: type=% size_of_type=%\n",
        label, type_to_string(a.type), a.type.runtime_size);
}

test_any :: () {
    section("17. The Any type");

    print_any("int",    42);
    print_any("float",  3.14);
    print_any("bool",   true);
    print_any("string", "hi");
    print_any("V2",     V2.{1,2});
    arr := int.[1,2,3];
    print_any("[] int",     cast([]int) arr);

    sub("Inspect type-info of an Any");
    a: Any = V2.{1,2};
    info := cast(*Type_Info_Struct) a.type;
    print("Any holds struct '%' with % members:\n", info.name, info.members.count);
    for info.members  print("  '%' at offset %\n", it.name, it.offset_in_bytes);
}


// ============================================================================
// 18. Iterators (for-expansions).
// ============================================================================

// Custom iterator producing only odd numbers up to a limit (the for-loop
// gives the expansion a pointer to the iteration target).
Odd_Limit :: struct { upto: int; }

odd_numbers_below :: (holder: *Odd_Limit, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := 0;
    cur := 1;
    while cur < holder.upto {
        it = cur;
        defer it_index += 1;
        #insert body;
        cur += 2;
    }
}

test_iterators :: () {
    section("18. Custom for-loop expansions");

    print("odd numbers below 12:\n");
    limit := Odd_Limit.{upto = 12};
    for :odd_numbers_below limit {
        print("  it_index=% it=%\n", it_index, it);
    }
}


// ============================================================================
// 19. Tagged unions / variants via #place (memory aliasing).
// ============================================================================

// A simple tagged union using a tag + #place to overlay storage.
Variant :: struct {
    Tag :: enum u8 { INT; FLOAT; STR; }
    tag: Tag;

    union {
        i: int;
        f: float64;
        s: string;
    }
}

print_variant :: (v: Variant) {
    if v.tag == {
      case .INT;   print("  tag=INT   value=%\n", v.i);
      case .FLOAT; print("  tag=FLOAT value=%\n", v.f);
      case .STR;   print("  tag=STR   value='%'\n", v.s);
    }
}

test_unions :: () {
    section("19. Unions (memory overlay)");

    v: Variant;
    v.tag = .INT;
    v.i   = 99;
    print_variant(v);

    v.tag = .FLOAT;
    v.f   = 1.5;
    print_variant(v);

    v.tag = .STR;
    v.s   = "hello";
    print_variant(v);

    print("size_of(Variant) = % (>= max(int,float64,string) plus tag/padding)\n",
        size_of(Variant));
}


// ============================================================================
// 20. Distinct type variants.
// ============================================================================

Meters     :: #type,distinct float;
Seconds    :: #type,distinct float;

test_distinct :: () {
    section("20. Distinct type variants");

    m: Meters  = 5;
    s: Seconds = 3;
    print("m=% (type %) s=% (type %)\n", m, type_of(m), s, type_of(s));

    // m + s would be a type error; we don't write it.
    // We can cast through the underlying type:
    rate := cast(float) m / cast(float) s;
    print("m/s as float = %\n", rate);
}


