----------------------------------------------------------------
== 550. Tiny CSV parser
----------------------------------------------------------------
  case-0 input='a,b,c' rows=1
    row 0:
      cell 0: 'a'
      cell 1: 'b'
      cell 2: 'c'
  case-1 input='a,b,c
1,2,3' rows=2
    row 0:
      cell 0: 'a'
      cell 1: 'b'
      cell 2: 'c'
    row 1:
      cell 0: '1'
      cell 1: '2'
      cell 2: '3'
  case-2 input='one,two,three
four,five,six
seven,eight,nine' rows=3
    row 0:
      cell 0: 'one'
      cell 1: 'two'
      cell 2: 'three'
    row 1:
      cell 0: 'four'
      cell 1: 'five'
      cell 2: 'six'
    row 2:
      cell 0: 'seven'
      cell 1: 'eight'
      cell 2: 'nine'
  case-3 input='"hello, world",foo' rows=1
    row 0:
      cell 0: 'hello, world'
      cell 1: 'foo'
  case-4 input='a,"b
c",d' rows=1
    row 0:
      cell 0: 'a'
      cell 1: 'b
c'
      cell 2: 'd'
  case-5 input='"a""b",c' rows=1
    row 0:
      cell 0: 'a"b'
      cell 1: 'c'
  case-6 input='' rows=0
  case-7 input='single' rows=1
    row 0:
      cell 0: 'single'
  case-8 input='trailing,' rows=1
    row 0:
      cell 0: 'trailing'
      cell 1: ''
  case-9 input=',leading' rows=1
    row 0:
      cell 0: ''
      cell 1: 'leading'

