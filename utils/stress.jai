== 430c. join edge cases
----------------------------------------------------------------

-- Two elements with various seps
sep='' -> 'xy'
sep='-' -> 'x-y'
sep='|' -> 'x|y'
sep=' AND ' -> 'x AND y'
sep='/' -> 'x/y'

-- Many separators
join 'a,b,c'        = 'a,b,c'
join 'a,b,c' before = ',a,b,c'
join 'a,b,c' after  = 'a,b,c,'
join 'a,b,c' both   = ',a,b,c,'

