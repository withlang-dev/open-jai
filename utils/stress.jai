// ============================================================================
// 43. String module: split, join, contains, starts_with, ends_with.
// ============================================================================


test_string_module :: () {
    section("43. String module operations");

    sub("split (on byte)");
    parts := split("alpha,beta,gamma,,delta", cast(u8) #char ",");
    print("split count=%\n", parts.count);
    for p, i: parts  print("  parts[%]='%'\n", i, p);

    sub("join");
    joined := join(..parts, separator="|");
    print("joined = '%'\n", joined);

    sub("contains / starts_with / ends_with");
    s := "Hello, World!";
    print("contains 'World': %\n", contains(s, "World"));
    print("contains 'world': %\n", contains(s, "world"));   // case-sensitive
    print("starts_with 'Hello': %\n", starts_with(s, "Hello"));
    print("starts_with 'World': %\n", starts_with(s, "World"));
    print("ends_with '!'      : %\n", ends_with(s, "!"));

    sub("to_upper / to_lower (in place on a copy)");
    raw := "Mixed CaSe StRiNg";
    cu := copy_string(raw);
    to_upper_in_place(cu);
    cl := copy_string(raw);
    to_lower_in_place(cl);
    print("upper='%'\n", cu);
    print("lower='%'\n", cl);

    sub("replace (simple)");
    rep := replace("a-b-c-d-e", "-", "<>");
    print("replace -> '%'\n", rep);

    sub("trim / trim_left / trim_right");
    t := trim("   hello world   ");
    print("trim='%' count=%\n", t, t.count);
    print("trim_left ='%'\n", trim_left ("   hello   "));
    print("trim_right='%'\n", trim_right("   hello   "));
}


// ============================================================================
// 44. Bit_Array module.
// ============================================================================


test_bit_array :: () {
    section("44. Bit_Array module");

    ba: Bit_Array;
    init_bit_array(*ba, 32);

    set_bit(*ba, 0);
    set_bit(*ba, 5);
    set_bit(*ba, 31);

    print("bits set at 0,5,31; iterating for-loop reports set bits:\n");
    pop := 0;
    for bit_is_set: ba {
        if bit_is_set {
            pop += 1;
            print("  bit[%] set\n", it_index);
        }
    }
    print("popcount = %\n", pop);

    clear_bit(*ba, 5);
    pop = 0;
    for bit_is_set: ba  if bit_is_set  pop += 1;
    print("after clear bit 5, popcount=%\n", pop);

    toggle_bit(*ba, 0);
    pop = 0;
    for bit_is_set: ba  if bit_is_set  pop += 1;
    print("after toggle bit 0, popcount=%\n", pop);

    deinit(*ba);
}


// ============================================================================
// 45. Reflection-driven serialization (struct walk).
// ============================================================================

walk_and_print :: (label: string, any: Any) {
    print("%: type=% (size=%)\n", label, type_to_string(any.type), any.type.runtime_size);
    if any.type.type == .STRUCT {
        info := cast(*Type_Info_Struct) any.type;
        print("  struct '%' with % members:\n", info.name, info.members.count);
        for info.members {
            print("    .% (% bytes) offset=%\n",
                it.name, it.type.runtime_size, it.offset_in_bytes);
        }
    } else if any.type.type == .ARRAY {
        info := cast(*Type_Info_Array) any.type;
        kind := ifx info.array_type == .FIXED     then "FIXED"
                else (ifx info.array_type == .VIEW then "VIEW"  else "RESIZABLE");
        print("  array kind=% element_size=% count=%\n",
            kind, info.element_type.runtime_size, info.array_count);
    } else if any.type.type == .ENUM {
        info := cast(*Type_Info_Enum) any.type;
        print("  enum '%' with % named values\n", info.name, info.names.count);
    }
}

test_reflection :: () {
    section("45. Reflection-driven type walking");

    walk_and_print("V2",        V2.{1,2});
    walk_and_print("Rectangle", Rectangle.{});
    walk_and_print("Color",     Color.RED);
    walk_and_print("Day",       Day.MONDAY);

    fa: [5] s32;
    walk_and_print("[5] s32",   fa);

    av: [] int = int.[1,2,3];
    walk_and_print("[] int",    av);

    ra: [..] int;
    walk_and_print("[..] int",  ra);
}


// ============================================================================
// 46. Print quirks: nested formatting, escaping, multi-line.
// ============================================================================

test_print_quirks :: () {
    section("46. Print formatting quirks");

    sub("Adjacent % with no separator: %1%2");
    print("%1%2\n", "AB", "CD");        // "ABCD"

    sub("Re-use %1 multiple times");
    print("%1 + %1 = %2\n", "x", "2x");

    sub("Print Any");
    any_int : Any = 42;
    any_str : Any = "hello";
    print("Any holding int: %\n", any_int);
    print("Any holding str: %\n", any_str);

    sub("Print struct nested in struct");
    p: Person;
    p.name = "Alan";
    p.age = 41;
    p.address.street = "1 Bletchley Park";
    p.address.city   = "Bletchley";
    print("person nested = %\n", p);

    sub("Format-int with negative");
    print("formatInt(-42, base=10)=%\n", formatInt(-42));
    print("formatInt(-42, base=16)=%\n", formatInt(-42, base=16));

    sub("Format float with widths");
    f := 1.5;
    print("(width=8, trail=3): [%]\n", formatFloat(f, width=8, trailing_width=3));
    print("(width=2, trail=5): [%]\n", formatFloat(f, width=2, trailing_width=5));

    sub("Format float with positive prefix");
    pos: FormatFloat;
    pos.value = 3.5;
    pos.positive_number_prefix = .PLUS;
    print("+prefix: %\n", pos);
    sp: FormatFloat;
    sp.value = 3.5;
    sp.positive_number_prefix = .SPACE;
    print("(space)prefix: '%'\n", sp);
}


// ============================================================================
// 47. Code (compile-time AST values).
// ============================================================================

test_code :: () {
    section("47. Code values (#code, #insert)");

    // A simple Code value:
    body : Code : #code { print("  hello from inserted code\n"); };
    print("invoking inserted code:\n");
    #insert body;
    #insert body;

    // Code can be built up programmatically via tprint and #insert, too:
    sub("#insert of a string literal as code");
    NAME :: "world";
    EXPR :: #string DONE
print("  generated: hello, %\n", NAME);
DONE
    #insert EXPR;
}


// ============================================================================
// 48. Defer with return: cleanup on early return.
// ============================================================================

operation :: (n: int) -> (result: int, ok: bool) {
    print("  enter operation(%)\n", n);
    defer print("  exit  operation(%)\n", n);

    if n < 0 {
        print("  early return for n<0\n");
        return 0, false;
    }

    return n*n, true;
}

test_defer_return :: () {
    section("48. Defer fires on every return path");

    a, ok_a := operation(5);
    print("got: a=% ok=%\n", a, ok_a);

    b, ok_b := operation(-3);
    print("got: b=% ok=%\n", b, ok_b);
}


// ============================================================================
// 49. #bake_arguments and partial application.
// ============================================================================

add3 :: (a: int, b: int, c: int) -> int { return a + b + c; }

add_with_a_baked :: #bake_arguments add3(a=100);

test_bake_arguments :: () {
    section("49. #bake_arguments (partial application)");

    print("add3(1,2,3)               = %\n", add3(1,2,3));
    print("add_with_a_baked(b=2,c=3) = %\n", add_with_a_baked(b=2, c=3));
}


// ============================================================================
// 50. Recursion: factorial, Fibonacci.
// ============================================================================

factorial :: (n: int) -> int {
    if n <= 1  return 1;
    return n * factorial(n - 1);
}

fib :: (n: int) -> int {
    if n < 2  return n;
    return fib(n - 1) + fib(n - 2);
}

test_recursion :: () {
    section("50. Recursion");

    for n: 0..10  print("  factorial(%) = %\n", n, factorial(n));
    for n: 0..12  print("  fib(%) = %\n", n, fib(n));
}


// ============================================================================
// 51. Closures: nested procs capturing constants but NOT runtime locals.
// ============================================================================

test_nested_proc :: () {
    section("51. Nested procedures");

    OUTER_CONST :: 100;

    inner :: () -> int {
        return OUTER_CONST + 1;   // constants are reachable
    }

    // We cannot reach a runtime local from a true nested proc - Jai isn't a
    // closure language. We can emulate captures via explicit parameters:
    add_outer :: (x: int) -> int { return OUTER_CONST + x; }

    print("inner()         = %\n", inner());
    print("add_outer(5)    = %\n", add_outer(5));
}


// ============================================================================
// 52. Generic stack data structure via polymorphic struct.
// ============================================================================

Stack :: struct(T: Type, CAP: int) {
    data: [CAP] T;
    count: int;
}

push :: (s: *Stack($T, $CAP), v: T) -> bool {
    if s.count >= CAP  return false;
    s.data[s.count] = v;
    s.count += 1;
    return true;
}

pop_stack :: (s: *Stack($T, $CAP)) -> (T, bool) {
    if s.count == 0 {
        empty: T;
        return empty, false;
    }
    s.count -= 1;
    return s.data[s.count], true;
}

test_stack :: () {
    section("52. Polymorphic struct: Stack(T, CAP)");

    s: Stack(int, 4);
    print("push 10: %\n", push(*s, 10));
    print("push 20: %\n", push(*s, 20));
    print("push 30: %\n", push(*s, 30));
    print("push 40: %\n", push(*s, 40));
    print("push 50 (over capacity): %\n", push(*s, 50));
    print("count = %\n", s.count);

    while s.count > 0 {
        v, ok := pop_stack(*s);
        if ok  print("  popped %\n", v);
    }
    _, last_ok := pop_stack(*s);
    print("pop empty stack ok? %\n", last_ok);

    sub("Different instantiations are different types");
    s_int :    Stack(int,    4);
    s_str :    Stack(string, 4);
    s_floats : Stack(float,  8);
    print("type(Stack(int,4))    = %\n", type_of(s_int));
    print("type(Stack(string,4)) = %\n", type_of(s_str));
    print("type(Stack(float,8))  = %\n", type_of(s_floats));
}


// ============================================================================
// 53. `using` on procedure parameters & local variables.
// ============================================================================

print_using :: (using r: Rectangle) {
    // We can refer to x0, y0, x1, y1, color_name without the r. prefix.
    print("  rect(%, %)-(%, %) color=%\n", x0, y0, x1, y1, color_name);
}

test_using_more :: () {
    section("53. `using` on parameters and locals");

    r := Rectangle.{1, 2, 3, 4, "red"};
    print_using(r);

    sub("`using` on a local");
    r2 := Rectangle.{10, 20, 30, 40, "blue"};
    using r2;
    print("via using: x0=% y0=% x1=% y1=% color=%\n", x0, y0, x1, y1, color_name);
}


// ============================================================================
// 54. Struct member with #place at a specific offset.
// ============================================================================

Header :: struct {
    magic   : u32;    // offset 0
    version : u16;    // offset 4
    flags   : u16;    // offset 6
    size    : u64;    // offset 8

    // overlay: read 'magic' as 4 bytes (alias)
    #overlay (magic) magic_bytes: [4] u8 = ---;
}

test_header_layout :: () {
    section("54. Header layout with overlay");

    h: Header;
    h.magic = 0xDEAD_BEEF;
    h.version = 1;
    h.flags = 7;
    h.size = 0x1234;

    info := type_info(Header);
    for info.members {
        print("  member '%' off=% size=%\n",
            it.name, it.offset_in_bytes, it.type.runtime_size);
    }

    print("magic = 0x%\n", formatInt(h.magic, base=16));
    print("magic_bytes (host byte order): ");
    for h.magic_bytes  print("0x% ", formatInt(it, base=16, minimum_digits=2));
    print("\n");
}


// ============================================================================
// 55. Type variants via #type,distinct vs #type,isa.
// ============================================================================

UserId :: #type,distinct s64;     // a separate type
RowId  :: #type,distinct s64;     // also separate
NodeId :: #type,isa      s64;     // implicit-convertible

test_distinct_isa :: () {
    section("55. distinct vs isa type variants");

    u: UserId = cast(UserId) 7;
    r: RowId  = cast(RowId)  7;
    n: NodeId = 7;                // isa allows direct init from underlying

    print("UserId type = %  value = %\n", type_of(u), u);
    print("RowId  type = %  value = %\n", type_of(r), r);
    print("NodeId type = %  value = %\n", type_of(n), n);

    // u + r would be a type error (distinct). We won't write that line.
    // n + 1 is allowed because NodeId is isa s64.
    n2 := n + 1;
    print("NodeId + 1 = % (still type %)\n", n2, type_of(n2));
}


// ============================================================================
// 56. Procedure with #symmetric overload.
// ============================================================================

operator + :: (a: V2, n: float) -> V2 #symmetric {
    return V2.{a.x + n, a.y + n};
}

test_symmetric :: () {
    section("56. #symmetric operator");

    v := V2.{1, 2};
    a := v + 3.0;
    b := 3.0 + v;
    print("v + 3 = %\n", a);
    print("3 + v = %\n", b);
}


// ============================================================================
// 57. Macros via #expand: with backtick-quoted local-injection.
// ============================================================================

square_local :: ($x: $T) -> T #expand {
    // $x here is a polymorphic value; this macro inlines the expression.
    return x * x;
}

with_timer :: (label: string, body: Code) #expand {
    // but we demo the structure.
    print("  begin %\n", label);
    #insert body;
    print("  end   %\n", label);
}

test_macros :: () {
    section("57. Macros and #expand");

    a := square_local(7);
    print("square_local(7) = %\n", a);

    with_timer("widget-init", #code {
        print("  doing work...\n");
    });
}


// ============================================================================
// 58. Apollo_Time (we measure elapsed-time DELTAS as zero by trick: use the
//     same time twice). Real timing is non-deterministic, so we just expose
//     the API.
// ============================================================================

test_apollo :: () {
    section("58. Apollo_Time API surface");

    // We won't print actual times; just demonstrate the API exists.
    t1 := current_time_monotonic();
    t2 := t1;     // copy
    delta := t2 - t1;
    secs := to_float64_seconds(delta);
    print("type_of(Apollo_Time current_time_monotonic) = %\n", type_of(t1));
    print("delta-of-same-time-converted-to-seconds = %\n", secs);
}


// ============================================================================
// 59. tuple-like multiple assignment.
// ============================================================================

test_multiple_assign :: () {
    section("59. Multiple assignment");

    a, b, c := 1, 2, 3;
    print("a=% b=% c=%\n", a, b, c);

    a, b = b, a;        // swap
    print("after swap: a=% b=%\n", a, b);

    // Multiple return into existing variables:
    x: int; y: int;
    x, y = divmod(23, 5);
    print("divmod(23,5) = q=% r=%\n", x, y);
}


// ============================================================================
// 60. for-loop expression endpoints and exclusivity.
// ============================================================================

test_for_endpoints :: () {
    section("60. for-loop endpoint behavior");

    sub("for 0..N is INCLUSIVE on both ends");
    for i: 0..3  print("  i=%\n", i);

    sub("for endpoint is evaluated once before the loop");
    n := 3;
    for i: 0..n {
        if i == 1  n = 100;          // does not extend the loop
        print("  body i=% (n=%)\n", i, n);
    }
}


// ============================================================================
// 61. Negative-index iterators via custom for-expansion.
// ============================================================================

Neg_Counter :: struct { from, to: int; }

count_down :: (c: *Neg_Counter, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it       := c.from;
    while it >= c.to {
        defer { it -= 1; it_index += 1; }
        #insert body;
    }
}

test_count_down :: () {
    section("61. Custom for-expansion counting down");

    c := Neg_Counter.{from = 5, to = -2};
    for :count_down c {
        print("  it_index=% it=%\n", it_index, it);
    }
}


// ============================================================================
// 62. Edge cases for print of structs/arrays.
// ============================================================================

Big_Struct :: struct {
    a: int = 1;
    b: int = 2;
    c: int = 3;
    d: int = 4;
    e: int = 5;
    f: int = 6;
    g: int = 7;
    h: int = 8;
}

test_print_edge :: () {
    section("62. Print edge cases");

    sub("Long structs auto-switch to long-form");
    bs: Big_Struct;
    print("default print of 8-member struct: %\n", bs);

    sub("Array of 200 elements (default cap = 100)");
    big: [..] int;
    for i: 0..199  array_add(*big, i);
    print("printed array with default cap:\n  %\n", big);

    sub("Array with cap raised");
    fa: FormatArray;
    fa.value = big;
    fa.stop_printing_after_this_many_elements = 5;
    print("cap=5: %\n", fa);
}


// ============================================================================
// 63. Inline procedure
// ============================================================================

triple :: inline (x: int) -> int { return x*3; }

test_inline :: () {
    section("63. inline procedure declaration");
    print("triple(5)=%\n", triple(5));
    print("type_of(triple)=%\n", type_of(triple));
}


// ============================================================================
// 64. Comma-comma trailing modifier args.
// ============================================================================

test_comma_comma :: () {
    section("64. Comma-comma modifier args (e.g. ,, allocator=temp)");

    // sprint(..., allocator=temp)
    s := sprint("x=%", 42 ,, allocator = temp);
    print("sprint allocator=temp result='%' count=%\n", s, s.count);
}


// ============================================================================
// 65. Memory ops via the standard library.
// ============================================================================

test_memory :: () {
    section("65. memcpy / memset / memcmp");

    a: [16] u8;
    b: [16] u8;
    memset(a.data, 0xCC, a.count);
    memset(b.data, 0xCC, b.count);
    print("after memset, a == b ? %\n", memcmp(a.data, b.data, a.count) == 0);

    b[7] = 0x00;
    print("after mutate b[7]=0, a == b ? %\n", memcmp(a.data, b.data, a.count) == 0);

    src: [4] u8 = u8.[1,2,3,4];
    dst: [4] u8;
    memcpy(dst.data, src.data, src.count);
    print("memcpy: %\n", dst);
}


// ============================================================================
// 66. Strings: subscript + slice variations.
// ============================================================================

test_strings_more :: () {
    section("66. More string operations");

    s := "Lorem ipsum dolor sit amet";
    print("count=% first byte=% last byte=%\n",
        s.count, s[0], s[s.count-1]);

    sub("Building a string via String_Builder with print_to_builder calls");
    b: String_Builder;
    init_string_builder(*b);
    for w: string.["one", "two", "three", "four"]  print_to_builder(*b, "[%]", w);
    out := builder_to_string(*b);
    print("built='%' (% bytes)\n", out, out.count);

    sub("Index in string with byte-equality");
    target: u8 = #char "u";
    for i: 0..s.count-1 {
        if s[i] == target {
            print("  found '%' at index %\n", target, i);
            break;
        }
    }
}


// ============================================================================
// 67. [..] array public interface (count, allocated, data, allocator).
// ============================================================================

test_internal_layout :: () {
    section("67. [..] array public fields behaviour");

    ra: [..] int;
    array_add(*ra, 1);
    array_add(*ra, 2);

    print("count=% allocated>=count=% allocator-proc-non-null=%\n",
        ra.count, ra.allocated >= ra.count, ra.allocator.proc != null);
    print("data-non-null=%\n", ra.data != null);
}


// ============================================================================
// 68. Final summary.
// ============================================================================

test_summary :: () {
    section("68. Summary");

    print("size_of(int)         = %\n", size_of(int));
    print("size_of(s64)         = %\n", size_of(s64));
    print("size_of(float)       = %\n", size_of(float));
    print("size_of(float32)     = %\n", size_of(float32));
    print("size_of(float64)     = %\n", size_of(float64));
    print("size_of(bool)        = %\n", size_of(bool));
    print("size_of(string)      = %\n", size_of(string));
    print("size_of(*void)       = %\n", size_of(*void));
    print("size_of(Type)        = %\n", size_of(Type));
    print("size_of(Any)         = %\n", size_of(Any));
    print("size_of([] u8)       = %\n", size_of([] u8));
    print("size_of([..] u8)     = %\n", size_of([..] u8));
    print("size_of(Allocator)   = %\n", size_of(Allocator));

    print("END OF STRESS TEST\n");
}


