----------------------------------------------------------------
== 812. Union-find (disjoint-set)
----------------------------------------------------------------

-- Initial state
  find(0)=0
  find(1)=1
  find(2)=2
  find(3)=3
  find(4)=4
  find(5)=5
  find(6)=6
  find(7)=7

-- Union (0,1) and (2,3)
  unions performed = true true
  find(0)=0
  find(1)=0
  find(2)=2
  find(3)=2
  find(4)=4
  find(5)=5
  find(6)=6
  find(7)=7

-- Union(1,2): merges {0,1} and {2,3}
  union performed = true
  find(0)=0
  find(1)=0
  find(2)=0
  find(3)=0
  find(4)=4
  find(5)=5
  find(6)=6
  find(7)=7

-- Union(0,3): now they should already be in the same set
  union returned = false

-- Union(4,5) and (6,7), then (5,7)
  find(0)=0
  find(1)=0
  find(2)=0
  find(3)=0
  find(4)=4
  find(5)=4
  find(6)=4
  find(7)=4

-- Bring {0..3} and {4..7} together via union(3,4)
  find(0)=0
  find(1)=0
  find(2)=0
  find(3)=0
  find(4)=0
  find(5)=0
  find(6)=0
  find(7)=0

-- Use DSU to count connected components on a small edge list
  components=3

----------------------------------------------------------------
== 813. Glob-like matching with '*' and '?'
----------------------------------------------------------------
  'abc' matches 'abc' -> got=true expected=true ok=true
  'abc' matches 'abd' -> got=false expected=false ok=true
  'abc' matches 'a?c' -> got=true expected=true ok=true
  'abc' matches 'a?d' -> got=false expected=false ok=true
  'abcde' matches 'a*e' -> got=true expected=true ok=true
  'abcde' matches 'a*x' -> got=false expected=false ok=true
  'abcde' matches '*' -> got=true expected=true ok=true
  '' matches '*' -> got=true expected=true ok=true
  '' matches '?' -> got=false expected=false ok=true
  'a' matches '?' -> got=true expected=true ok=true
  'hello' matches 'h*o' -> got=true expected=true ok=true
  'hello' matches 'h*lo' -> got=true expected=true ok=true
  'hello' matches 'h*lll' -> got=false expected=false ok=true
  'banana' matches '*ana' -> got=true expected=true ok=true
  'banana' matches 'ban*' -> got=true expected=true ok=true
  'banana' matches '*nan*' -> got=true expected=true ok=true
  'banana' matches '*xyz*' -> got=false expected=false ok=true
  'foo.txt' matches '*.txt' -> got=true expected=true ok=true
  'foo.txt' matches '*.txz' -> got=false expected=false ok=true
  'foo.txt' matches 'f??.txt' -> got=true expected=true ok=true
  'foo.txt' matches 'f?.txt' -> got=false expected=false ok=true
  'abc' matches '***' -> got=true expected=true ok=true
  'abc' matches '?*?' -> got=true expected=true ok=true
  'a' matches '?*?' -> got=false expected=false ok=true
  'ab' matches '?*?' -> got=true expected=true ok=true
  'longer_word' matches 'l*g*r_w*d' -> got=true expected=true ok=true
  'longer_word' matches 'l*g*r_w*x' -> got=false expected=false ok=true

----------------------------------------------------------------
== 814. Calculator: tokenize, parse, evaluate
----------------------------------------------------------------
  eval('1') = 1 ok=true  (expected 1 ok=true)
  eval('42') = 42 ok=true  (expected 42 ok=true)
  eval('1+2') = 3 ok=true  (expected 3 ok=true)
  eval('1 + 2') = 3 ok=true  (expected 3 ok=true)
  eval('1+2*3') = 7 ok=true  (expected 7 ok=true)
  eval('(1+2)*3') = 9 ok=true  (expected 9 ok=true)
  eval('2*3+4') = 10 ok=true  (expected 10 ok=true)
  eval('2*(3+4)') = 14 ok=true  (expected 14 ok=true)
  eval('10-3') = 7 ok=true  (expected 7 ok=true)
  eval('10-3-2') = 5 ok=true  (expected 5 ok=true)
  eval('10-(3-2)') = 9 ok=true  (expected 9 ok=true)
  eval('20/4') = 5 ok=true  (expected 5 ok=true)
  eval('20/4/5') = 1 ok=true  (expected 1 ok=true)
  eval('20/(4/5)') = 0 ok=false  (expected 0 ok=false)
  eval('-5') = -5 ok=true  (expected -5 ok=true)
  eval('-5+10') = 5 ok=true  (expected 5 ok=true)
  eval('(-5)*(-3)') = 15 ok=true  (expected 15 ok=true)
  eval('100/5') = 20 ok=true  (expected 20 ok=true)
  eval('100/5/2') = 10 ok=true  (expected 10 ok=true)
  eval('100 / 5 / 2') = 10 ok=true  (expected 10 ok=true)
  eval('1+2+3+4+5') = 15 ok=true  (expected 15 ok=true)
  eval('5*5*5') = 125 ok=true  (expected 125 ok=true)
  eval('((1+2)*3+(4-5))*2') = 16 ok=true  (expected 16 ok=true)
  eval('0') = 0 ok=true  (expected 0 ok=true)
  eval('0+0') = 0 ok=true  (expected 0 ok=true)
  eval('0*123456') = 0 ok=true  (expected 0 ok=true)
  eval('9999') = 9999 ok=true  (expected 9999 ok=true)
  eval('3*3*3*3') = 81 ok=true  (expected 81 ok=true)
  eval('1 - 2 + 3 - 4 + 5') = 3 ok=true  (expected 3 ok=true)

-- malformed inputs
  bad '1+' parsed-ok=false value=1
  bad '+1' parsed-ok=false value=0
  bad '1++2' parsed-ok=false value=1
  bad '1**2' parsed-ok=false value=0
  bad '(1+2' parsed-ok=false value=0
  bad '1+2)' parsed-ok=false value=3
  bad 'abc' parsed-ok=false value=0

