----------------------------------------------------------------
== 729. Defer chains in deep nested loops
----------------------------------------------------------------

-- 729.a 3-level nesting normal flow
      body i=1 j=1 k=1
      defer-inner i=1 j=1 k=1
      body i=1 j=1 k=2
      defer-inner i=1 j=1 k=2
    defer-mid i=1 j=1
      body i=1 j=2 k=1
      defer-inner i=1 j=2 k=1
      body i=1 j=2 k=2
      defer-inner i=1 j=2 k=2
    defer-mid i=1 j=2
  defer-outer i=1
      body i=2 j=1 k=1
      defer-inner i=2 j=1 k=1
      body i=2 j=1 k=2
      defer-inner i=2 j=1 k=2
    defer-mid i=2 j=1
      body i=2 j=2 k=1
      defer-inner i=2 j=2 k=1
      body i=2 j=2 k=2
      defer-inner i=2 j=2 k=2
    defer-mid i=2 j=2
  defer-outer i=2

