----------------------------------------------------------------
== 802. JSON encoder for Any values
----------------------------------------------------------------

-- primitives
  int       -> 
  neg       -> -7
  float     -> 1.5
  bool t    -> true
  bool f    -> false
  string    -> "hello"
  empty str -> ""

-- string escapes
  quote     -> "a\"b"
  backslash -> "a\\b"
  newline   -> "a\nb"
  tab       -> "a\tb"

-- structs
  Person    -> {"name":"Ada","age":,"height_cm":170,"likes_cats":true}
  V2        -> {"x":1,"y":2}
  RGBA      -> {"r":,"g":,"b":,"a":}

-- nested
  Employee  -> {"person":{"name":"Bob","age":,"height_cm":180,"likes_cats":false},"address":{"street":"5 Elm","city":"Springfield","zip":"00000"},"employee_id":,"salary":50000}

-- arrays
  fixed[4]  -> [,,,]
  view[3]   -> [1,2,3]
  dyn[3]    -> [,,]

-- enum
  enum      -> "GREEN"

-- pointer null vs non-null
  ptr non   -> "<ptr>"
  ptr null  -> null

-- array of struct
  Polyline  -> {"name":"poly","closed":true,"pts":[{"label":"a","x":1,"y":2},{"label":"b","x":3,"y":4},{"label":"c","x":5,"y":6}]}

----------------------------------------------------------------
== 803. YAML-like dumper for nested struct trees
----------------------------------------------------------------

-- flat Person
name: "Carl"
age: 41
height_cm: 165
likes_cats: false

-- nested Employee
person: 
  name: "Dora"
  age: 38
  height_cm: 158
  likes_cats: true
address: 
  street: "7 Maple"
  city: "Riverside"
  zip: "11111"
employee_id: 2002
salary: 62000

-- Polyline with array of Point
name: "triangle"
closed: true
pts: 
  - 
    label: "x"
    x: 0
    y: 0
  - 
    label: "y"
    x: 5
    y: 5
  - 
    label: "z"
    x: 10
    y: 0

-- fixed array of ints
- 1
- 2
- 3
- 4
- 5

-- box
width: 3
height: 4
depth: 5

----------------------------------------------------------------
== 804. Field-by-field diff for two structs
----------------------------------------------------------------

-- Person diff (one field differs)
diff 'p1 vs p2':
  EQUAL  name= 'Ada'
  DIFFER age  A=30 B=31
  EQUAL  height_cm= 170
  EQUAL  likes_cats= true

-- Person diff (multiple fields differ)
diff 'p3 vs p4':
  EQUAL  name= 'Bob'
  EQUAL  age= 25
  DIFFER height_cm  A=165 B=180
  DIFFER likes_cats  A=false B=true

-- Person diff (all equal)
diff 'p5 vs p6':
  EQUAL  name= 'Same'
  EQUAL  age= 40
  EQUAL  height_cm= 170
  EQUAL  likes_cats= true

-- Employee diff (nested struct)
diff 'e1 vs e2':
  EQUAL  person.name= 'Carl'
  EQUAL  person.age= 50
  EQUAL  person.height_cm= 175
  DIFFER person.likes_cats  A=false B=true
  DIFFER address.street  A='1 A' B='1 B'
  EQUAL  address.city= 'Town'
  EQUAL  address.zip= '00000'
  EQUAL  employee_id= 1
  DIFFER salary  A=1000 B=1500

-- Box diff (single field)
diff 'b1 vs b2':
  EQUAL  width= 3
  DIFFER height  A=4 B=9
  EQUAL  depth= 5

-- V2 diff (all equal)
diff 'v1 vs v2':
  EQUAL  x= 1
  EQUAL  y= 2

-- V2 diff (both differ)
diff 'v3 vs v4':
  DIFFER x  A=1 B=10
  DIFFER y  A=2 B=20

