== 576. RLE for integer arrays
----------------------------------------------------------------
  case-0 arr=[1, 1, 1, 2, 2, 3] runs:
    run 0: v=1 count=3
    run 1: v=2 count=2
    run 2: v=3 count=1
    decoded=[1, 1, 1, 2, 2, 3] match=true
  case-1 arr=[1, 2, 3, 4, 5] runs:
    run 0: v=1 count=1
    run 1: v=2 count=1
    run 2: v=3 count=1
    run 3: v=4 count=1
    run 4: v=5 count=1
    decoded=[1, 2, 3, 4, 5] match=true
  case-2 arr=[7, 7, 7, 7, 7] runs:
    run 0: v=7 count=5
    decoded=[7, 7, 7, 7, 7] match=true
  case-3 arr=[] runs:
    decoded=[] match=true
  case-4 arr=[99] runs:
    run 0: v=99 count=1
    decoded=[99] match=true
  case-5 arr=[0, 0, 0, 1, 0, 0, 1, 0] runs:
    run 0: v=0 count=3
    run 1: v=1 count=1
    run 2: v=0 count=2
    run 3: v=1 count=1
    run 4: v=0 count=1
    decoded=[0, 0, 0, 1, 0, 0, 1, 0] match=true

