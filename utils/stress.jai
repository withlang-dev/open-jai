    items: [..] Item;
    array_add(*items, .{1, 3.5});
    array_add(*items, .{2, 1.2});
    array_add(*items, .{3, 9.9});
    array_add(*items, .{4, 0.1});
    quick_sort(items, (a: Item, b: Item) -> int {
        if a.weight < b.weight  return -1;
        if a.weight > b.weight  return 1;
        return 0;
    });
