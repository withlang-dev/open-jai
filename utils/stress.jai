    for row: 1..10 {
        curr: [..] int;
        array_add(*curr, 1);
        for i: 1..prev.count-1  array_add(*curr, prev[i-1] + prev[i]);
        array_add(*curr, 1);
        print("  %\n", curr);
        prev = curr;
    }
}


// ----------------------------------------------------------------------------
// 914. Reflection: walk Type_Info_Struct for many types and print summary.
// ----------------------------------------------------------------------------

walk_struct :: ($T: Type) {
    info := type_info(T);
    if info.type != .STRUCT {
        print("  % is not a struct\n", T);
        return;
    }
    sinfo := cast(*Type_Info_Struct) info;
    print("  struct % size=% members=%\n", T, info.runtime_size, sinfo.members.count);
    for m: sinfo.members {
        print("    .% offset=% type-size=%\n",
            m.name, m.offset_in_bytes, m.type.runtime_size);
    }
}

Pair_iss :: struct { a: int; b: string; }
Triple_ifs :: struct { x: int; y: float; z: string; }
Big_struct_for_walk :: struct {
    a: u8;
    b: u16;
    c: u32;
    d: u64;
    e: float;
    f: string;
    g: bool;
}

test_extras_9_914_reflection :: () {
    section("914. Reflection walk over several struct types");

    walk_struct(Pair_iss);
    walk_struct(Triple_ifs);
    walk_struct(Big_struct_for_walk);
}


