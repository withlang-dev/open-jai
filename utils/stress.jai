];

// Additional test batches contributed by parallel work. They append to TESTS
// at compile time via the merge below.

ALL_TESTS :: #run -> [] Test {
    out: [..] Test;
    for TESTS         array_add(*out, it);
    for EXTRA_TESTS   array_add(*out, it);
    for EXTRA_TESTS_2 array_add(*out, it);
    for EXTRA_TESTS_3 array_add(*out, it);
    return out;
};


// We print headers on stderr so they interleave with the compiler's
// own diagnostics (which also go to stderr).
hdr :: (fmt: string, args: .. Any) {
    print(fmt, ..args, to_standard_error = true);
}

run_one :: (using t: Test, index: int) {
    hdr("\n------------------------------------------------------------\n");
    hdr("TEST %: %\n", index, name);
    hdr("------------------------------------------------------------\n");
    hdr("--- source ---\n%", source);
    if source.count == 0 || source[source.count-1] != #char "\n"  hdr("\n");
    hdr("--- diagnostic ---\n");

    w := compiler_create_workspace(name);

    // Build options: no output, no DCE side effects.
    opts := get_build_options(w);
    opts.output_type = .NO_OUTPUT;
    opts.dead_code_elimination = .NONE;
    set_build_options(opts, w);

    compiler_begin_intercept(w);
    add_build_string(source, w);

    while true {
        msg := compiler_wait_for_message();
        if !msg break;
        if msg.workspace != w  continue;
        if msg.kind == .COMPLETE  break;
    }

    compiler_end_intercept(w);
    compiler_set_workspace_status(.OK, w);
}


run_all :: () {
    hdr("============================================================\n");
    hdr(" reference Jai compiler-error catalog\n");
    hdr(" % tests; one workspace per snippet.\n", ALL_TESTS.count);
    hdr("============================================================\n");

    for ALL_TESTS  run_one(it, it_index + 1);

    hdr("\n------------------------------------------------------------\n");
    hdr(" END OF ERROR CATALOG (% tests)\n", ALL_TESTS.count);
    hdr("------------------------------------------------------------\n");
}

#run run_all();

// ============================================================================
// Extra compile-error test entries to be merged into compile_errors_meta.jai.
//
// This file is intended to be #load'ed (or appended) into the main metaprogram.
// It assumes the `Test :: struct { name: string; source: string; }` type is
// already declared by the loader. Do NOT redeclare Test here.
//
// Each entry is a complete, self-contained Jai program that should produce at
// least one diagnostic (Error / Warning / Info). A handful are coverage entries
// that may compile cleanly on certain compiler versions; those are still useful
// for shape-of-diagnostic comparisons.
// ============================================================================

EXTRA_TESTS :: Test.[

// ===========================================================================
// SECTION AM. Overload resolution failures with 3+ candidates.
// ===========================================================================

.{ "no matching overload among three candidates", #string SRC
#import "Basic";
f :: (a: int)    -> int { return 1; }
f :: (a: float)  -> int { return 2; }
f :: (a: string) -> int { return 3; }
main :: () {
    _ := f(true);
}
SRC},

.{ "overload set has none matching variadic", #string SRC
#import "Basic";
f :: (a: int, b: int)             -> int { return 1; }
f :: (a: int, b: int, c: int)     -> int { return 2; }
f :: (a: float, b: float)         -> int { return 3; }
main :: () {
    _ := f("a", "b");
}
SRC},

.{ "ambiguity among polymorphic and concrete overloads", #string SRC
#import "Basic";
f :: (a: int)  -> int { return 1; }
f :: (a: $T)   -> int { return 2; }
f :: (a: $T, b: $U) -> int { return 3; }
main :: () { _ := f(5); }
SRC},

// ===========================================================================
// SECTION AN. using chains and pointers.
// ===========================================================================

.{ "using chain through pointer field with missing name", #string SRC
#import "Basic";
Inner :: struct { value: int; }
Outer :: struct { using inner: *Inner; }
main :: () {
    o: Outer;
    print("%\n", o.absent);
}
SRC},

.{ "using on procedure parameter where struct has no matching name", #string SRC
#import "Basic";
S :: struct { a: int; b: int; }
f :: (using s: S) { print("%\n", c); }
main :: () { f(.{1,2}); }
SRC},

.{ "double using chain conflict", #string SRC
#import "Basic";
A :: struct { v: int; }
B :: struct { v: int; }
C :: struct { using a: A; using b: B; }
main :: () {
    c: C;
    print("%\n", c.v);
}
SRC},

// ===========================================================================
// SECTION AO. Recursive / pathological struct layouts.
// ===========================================================================

.{ "struct containing fixed array of itself", #string SRC
#import "Basic";
S :: struct { children: [3] S; }
main :: () { s: S; }
SRC},

.{ "two structs containing each other by value", #string SRC
#import "Basic";
A :: struct { b: B; }
B :: struct { a: A; }
main :: () { a: A; }
SRC},

.{ "struct with using and unnamed self field", #string SRC
#import "Basic";
S :: struct { using self: S; }
main :: () { s: S; }
SRC},

// ===========================================================================
// SECTION AP. Defaults and side effects.
// ===========================================================================

.{ "struct field default uses non-constant proc call", #string SRC
#import "Basic";
counter := 0;
next :: () -> int { counter += 1; return counter; }
S :: struct { x: int = next(); }
main :: () { s: S; print("%\n", s.x); }
SRC},

.{ "struct field default references later field by name", #string SRC
#import "Basic";
S :: struct {
    a: int = b;
    b: int = 5;
}
main :: () { s: S; }
SRC},

.{ "default value on parameter is a non-constant local", #string SRC
#import "Basic";
n := 5;
f :: (x: int = n) { print("%\n", x); }
main :: () { f(); }
SRC},

// ===========================================================================
// SECTION AQ. for-loop mutation pathologies.
// ===========================================================================

.{ "for * with assignment to it_index", #string SRC
#import "Basic";
main :: () {
    a: [4] int;
    for * v, i: a {
        i = 0;
    }
}
SRC},

.{ "modify it_index inside for body", #string SRC
#import "Basic";
main :: () {
    a: [4] int = .[10,20,30,40];
    for a {
        it_index = 0;
    }
}
SRC},

.{ "for * <  over a string (reverse pointer iteration on string)", #string SRC
#import "Basic";
main :: () {
    s := "hello";
    for * < c: s { print("%\n", c); }
}
SRC},

// ===========================================================================
// SECTION AR. Macros and #expand.
// ===========================================================================

.{ "#expand macro called with wrong number of arguments", #string SRC
#import "Basic";
M :: (a: int, b: int) -> int #expand {
    return a + b;
}
main :: () { _ := M(1); }
SRC},

.{ "macro body uses break without backtick", #string SRC
#import "Basic";
LOOP_BREAK :: () #expand {
    break;
}
main :: () {
    for i: 0..10 {
        LOOP_BREAK();
    }
}
SRC},

.{ "polymorphic macro instantiation failure", #string SRC
#import "Basic";
M :: ($T: Type, x: T) -> T #expand { return x + 1; }
main :: () {
    _ := M(string, "hi");
}
SRC},

// ===========================================================================
// SECTION AS. Bitwise / modulo on floats.
// ===========================================================================

.{ "bitwise AND on floats", #string SRC
#import "Basic";
main :: () {
    a: float = 1.5;
    b: float = 2.5;
    c := a & b;
}
SRC},

.{ "bitwise OR on floats", #string SRC
#import "Basic";
main :: () {
    a: float = 1.5;
    b: float = 2.5;
    c := a | b;
}
SRC},

.{ "bitwise XOR on floats", #string SRC
#import "Basic";
main :: () {
    a: float = 1.5;
    b: float = 2.5;
    c := a ^ b;
}
SRC},

.{ "modulo on floats", #string SRC
#import "Basic";
main :: () {
    a: float = 5.5;
    b: float = 2.0;
    c := a % b;
}
SRC},

.{ "shift on floats", #string SRC
#import "Basic";
main :: () {
    a: float = 8.0;
    c := a << 1;
}
SRC},

// ===========================================================================
// SECTION AT. defer / return interaction.
// ===========================================================================

.{ "return statement inside defer block", #string SRC
#import "Basic";
f :: () -> int {
    defer { return 99; }
    return 1;
}
main :: () { _ := f(); }
SRC},

.{ "multiple defers writing to returned value", #string SRC
#import "Basic";
f :: () -> int {
    x := 0;
    defer x = 1;
    defer x = 2;
    return x;
}
main :: () { print("%\n", f()); }
SRC},

.{ "defer at top level", #string SRC
#import "Basic";
defer print("hi\n");
main :: () { }
SRC},

.{ "defer in #run block", #string SRC
#import "Basic";
#run {
    defer print("late\n");
    print("early\n");
}
main :: () { }
SRC},

// ===========================================================================
// SECTION AU. Array view / element semantic edge cases.
// ===========================================================================

.{ "index array view past .count when count is statically known", #string SRC
#import "Basic";
main :: () {
    a: [3] int;
    v: [] int = a;
    x := v[3];
}
SRC},

.{ "use of `---` (uninitialized) value", #string SRC
#import "Basic";
main :: () {
    x: int = ---;
    print("%\n", x);
}
SRC},

.{ "assign fixed array to differently-sized fixed array", #string SRC
#import "Basic";
main :: () {
    a: [4] int;
    b: [3] int = a;
}
SRC},

.{ "compare fixed arrays of different types with ==", #string SRC
#import "Basic";
main :: () {
    a: [3] int;
    b: [3] float;
    c := a == b;
}
SRC},

.{ "compare fixed array and array view with ==", #string SRC
#import "Basic";
main :: () {
    a: [3] int;
    b: [] int = a;
    c := a == b;
}
SRC},

.{ "assignment between [..] arrays of different element types", #string SRC
#import "Basic";
main :: () {
    a: [..] int;
    b: [..] float = a;
}
SRC},

// ===========================================================================
// SECTION AV. Type-as-value misuse.
// ===========================================================================

.{ "indexing a Type value", #string SRC
#import "Basic";
main :: () {
    t := int;
    x := t[0];
}
SRC},

.{ "call type_info on non-constant Type variable - usually fine but check", #string SRC
#import "Basic";
main :: () {
    t: Type = int;
    info := type_info(t);
    print("%\n", info.*);
}
SRC},

.{ "type_of on a polymorphic procedure", #string SRC
#import "Basic";
poly :: (x: $T) -> T { return x; }
main :: () {
    t := type_of(poly);
}
SRC},

.{ "boolean AND on Type values", #string SRC
#import "Basic";
main :: () {
    c := int && float;
}
SRC},

// ===========================================================================
// SECTION AW. size_of edge cases.
// ===========================================================================

.{ "size_of of a polymorphic type without instantiation", #string SRC
#import "Basic";
Box :: struct(T: Type) { value: T; }
main :: () {
    n := size_of(Box);
    print("%\n", n);
}
SRC},

.{ "size_of of undeclared type", #string SRC
#import "Basic";
main :: () {
    n := size_of(Made_Up_Type);
}
SRC},

.{ "size_of of void", #string SRC
#import "Basic";
main :: () {
    n := size_of(void);
    print("%\n", n);
}
SRC},

// ===========================================================================
// SECTION AX. Switch / case edge cases.
// ===========================================================================

.{ "continue to a name that is a local variable, not a loop label", #string SRC
#import "Basic";
main :: () {
    target := 5;
    for i: 0..3 {
        continue target;
    }
}
SRC},

.{ "break to a name that is a local variable, not a loop label", #string SRC
#import "Basic";
main :: () {
    target := 5;
    for i: 0..3 {
        break target;
    }
}
SRC},

.{ "using inside a switch case binding", #string SRC
#import "Basic";
S :: struct { a: int; }
main :: () {
    n := 0;
    if #complete n == {
      case 0;
        using S.{1};
        print("%\n", a);
    }
}
SRC},

// ===========================================================================
// SECTION AY. inline / polymorphic interactions.
// ===========================================================================

.{ "inline modifier on directly recursive procedure", #string SRC
#import "Basic";
fact :: inline (n: int) -> int {
    if n <= 1 return 1;
    return n * fact(n - 1);
}
main :: () { print("%\n", fact(5)); }
SRC},

.{ "calling inline polymorphic procedure (smoke)", #string SRC
#import "Basic";
add :: inline (a: $T, b: T) -> T { return a + b; }
main :: () { print("%\n", add(1, 2)); }
SRC},

// ===========================================================================
// SECTION AZ. #as misuse.
// ===========================================================================

.{ "multiple #as fields in a single struct", #string SRC
#import "Basic";
S :: struct {
    a: int; #as
    b: int; #as
}
main :: () { s: S; }
SRC},

.{ "#as on a non-struct primitive field is fine - but check int", #string SRC
#import "Basic";
S :: struct {
    using x: int;
}
main :: () { s: S; }
SRC},

.{ "#as using chain through missing type", #string SRC
#import "Basic";
S :: struct { using x: Does_Not_Exist; }
main :: () { s: S; }
SRC},

// ===========================================================================
// SECTION BA. Operator overload misuse.
// ===========================================================================

.{ "operator == overload returning non-bool", #string SRC
#import "Basic";
V :: struct { x: int; }
operator == :: (a: V, b: V) -> int { return 0; }
main :: () {
    v: V; w: V;
    b := v == w;
}
SRC},

.{ "operator + overload with single parameter", #string SRC
#import "Basic";
V :: struct { x: int; }
operator + :: (a: V) -> V { return a; }
main :: () {
    v: V; w: V;
    r := v + w;
}
SRC},

.{ "operator + overload between two ints (primitives)", #string SRC
#import "Basic";
operator + :: (a: int, b: int) -> int { return 0; }
main :: () { _ := 1 + 2; }
SRC},

// ===========================================================================
// SECTION BB. Hash_Table / hashing.
// ===========================================================================

.{ "Hash_Table with non-hashable key (struct without explicit hash)", #string SRC
#import "Basic";
#import "Hash_Table";
K :: struct { x: int; y: int; }
main :: () {
    t: Table(K, int);
    table_add(*t, K.{1,2}, 99);
}
SRC},

// ===========================================================================
// SECTION BC. enum_flags pathology.
// ===========================================================================

.{ "enum_flags with overlapping bit values", #string SRC
#import "Basic";
F :: enum_flags { A :: 0x1; B :: 0x1; C :: 0x2; }
main :: () { f: F = .A | .B; print("%\n", f); }
SRC},

.{ "enum_flags member with value 0", #string SRC
#import "Basic";
F :: enum_flags { NONE :: 0; A :: 1; B :: 2; }
main :: () { f: F = .NONE; print("%\n", f); }
SRC},

.{ "iterating a #specified enum used unspecified", #string SRC
#import "Basic";
E :: enum u32 #specified { A :: 7; B :: 13; C :: 21; }
main :: () {
    for E { print("%\n", it); }
}
SRC},

// ===========================================================================
// SECTION BD. Allocation pathology.
// ===========================================================================

.{ "fixed array of 0 size on stack", #string SRC
#import "Basic";
main :: () {
    a: [0] int;
    print("%\n", a.count);
}
SRC},

.{ "huge fixed array on stack (compile-time check)", #string SRC
#import "Basic";
main :: () {
    a: [2_000_000_000] u8;
    print("%\n", a.count);
}
SRC},

// ===========================================================================
// SECTION BE. Procedure pointer pathology.
// ===========================================================================

.{ "calling a null procedure pointer", #string SRC
#import "Basic";
main :: () {
    p: (a: int) -> int;
    _ := p(5);
}
SRC},

.{ "recursive procedure pointer types", #string SRC
#import "Basic";
F :: #type (f: F) -> int;
main :: () {
    g: F;
    _ := g(g);
}
SRC},

.{ "polymorphic procedure body doesn't return T", #string SRC
#import "Basic";
make :: ($T: Type) -> T {
    return "hello";
}
main :: () {
    n: int = make(int);
    print("%\n", n);
}
SRC},

// ===========================================================================
// SECTION BF. compiler_* called from runtime.
// ===========================================================================

.{ "call compiler_get_nodes from runtime main", #string SRC
#import "Basic";
#import "Compiler";
main :: () {
    nodes := compiler_get_nodes(null);
}
SRC},

.{ "call compiler_create_workspace from runtime main", #string SRC
#import "Basic";
#import "Compiler";
main :: () {
    w := compiler_create_workspace("oops");
}
SRC},

// ===========================================================================
// SECTION BG. main signature variations.
// ===========================================================================

.{ "main with single int parameter", #string SRC
#import "Basic";
main :: (n: int) { print("%\n", n); }
SRC},

.{ "main with string return", #string SRC
#import "Basic";
main :: () -> string { return "done"; }
SRC},

.{ "main with two parameters", #string SRC
#import "Basic";
main :: (argc: int, argv: **u8) { print("%\n", argc); }
SRC},

// ===========================================================================
// SECTION BH. Context misuse.
// ===========================================================================

.{ "assign wrong type to context.allocator", #string SRC
#import "Basic";
main :: () {
    context.allocator = 5;
}
SRC},

.{ "set context.thread_index manually", #string SRC
#import "Basic";
main :: () {
    context.thread_index = 17;
    print("%\n", context.thread_index);
}
SRC},

// ===========================================================================
// SECTION BI. Number literal pathology.
// ===========================================================================

.{ "hex literal with leading underscore", #string SRC
#import "Basic";
main :: () { x := 0x_ff; print("%\n", x); }
SRC},

.{ "hex literal with trailing underscore", #string SRC
#import "Basic";
main :: () { x := 0xff_; print("%\n", x); }
SRC},

.{ "binary literal with non-binary digit", #string SRC
#import "Basic";
main :: () { x := 0b1021; print("%\n", x); }
SRC},

.{ "hex float literal with too few digits (0h)", #string SRC
#import "Basic";
main :: () { x := 0h1; print("%\n", x); }
SRC},

.{ "octal literal with non-octal digit (if supported)", #string SRC
#import "Basic";
main :: () { x := 0o178; print("%\n", x); }
SRC},

.{ "literal: mathematical overflow at compile time", #string SRC
#import "Basic";
N :: 1 << 80;
main :: () { print("%\n", N); }
SRC},

.{ "constant numeric expression: division by zero", #string SRC
#import "Basic";
N :: 1 / 0;
main :: () { print("%\n", N); }
SRC},

.{ "constant numeric expression: modulo by zero", #string SRC
#import "Basic";
N :: 1 % 0;
main :: () { print("%\n", N); }
SRC},

// ===========================================================================
// SECTION BJ. Imports with conflicts.
// ===========================================================================

.{ "two named imports with the same module under conflicting locals", #string SRC
#import "Basic";
Foo :: #import "Basic";
Foo :: #import "Compiler";
main :: () { Foo.print("hi\n"); }
SRC},

// ===========================================================================
// SECTION BK. Scopes and directives.
// ===========================================================================

.{ "#scope_file then attempting external access", #string SRC
#import "Basic";
#scope_file
secret :: () { print("hidden\n"); }
#scope_export
main :: () { secret(); }
SRC},

.{ "procedure with #compiler directive in user code", #string SRC
#import "Basic";
f :: () #compiler { }
main :: () { f(); }
SRC},

.{ "procedure with both #expand and inline", #string SRC
#import "Basic";
M :: () -> int #expand inline { return 1; }
main :: () { _ := M(); }
SRC},

// ===========================================================================
// SECTION BL. memcpy / memset misuse.
// ===========================================================================

.{ "memcpy with mismatched source/dest types passed by value", #string SRC
#import "Basic";
main :: () {
    a: [4] u8;
    b: [4] s32;
    memcpy(a.data, b.data, 16);
    print("%\n", a[0]);
}
SRC},

.{ "memset called with first arg not a pointer", #string SRC
#import "Basic";
main :: () {
    x: int = 5;
    memset(x, 0, 4);
}
SRC},

// ===========================================================================
// SECTION BM. distinct type conversions.
// ===========================================================================

.{ "implicit conversion of distinct to base int", #string SRC
#import "Basic";
ID :: #type,distinct int;
main :: () {
    id: ID;
    n: int = id;
    print("%\n", n);
}
SRC},

.{ "implicit conversion of base int to distinct without cast", #string SRC
#import "Basic";
ID :: #type,distinct int;
main :: () {
    n: int = 5;
    id: ID = n;
    print("%\n", id);
}
SRC},

// ===========================================================================
// SECTION BN. #must annotations.
// ===========================================================================

.{ "#must return value not consumed", #string SRC
#import "Basic";
must_use :: () -> int #must { return 99; }
main :: () { must_use(); }
SRC},

.{ "take address of #must return value", #string SRC
#import "Basic";
must_use :: () -> int #must { return 99; }
main :: () {
    p := *must_use();
    print("%\n", p.*);
}
SRC},

// ===========================================================================
// SECTION BO. Misc final coverage.
// ===========================================================================

.{ "polymorph procedure overloaded with non-polymorph version", #string SRC
#import "Basic";
f :: (a: $T) -> int { return 1; }
f :: (a: int) -> int { return 2; }
main :: () { _ := f(5); }
SRC},

.{ "struct using-inheritance with conflicting base / derived members", #string SRC
#import "Basic";
Base :: struct { value: int; }
Derived :: struct { using base: Base; value: float; }
main :: () { d: Derived; print("%\n", d.value); }
SRC},

.{ "procedure pointer compatibility: signatures differ only in arg names", #string SRC
#import "Basic";
f :: (a: int, b: int) -> int { return a + b; }
main :: () {
    p: (x: int, y: int) -> int = f;
    print("%\n", p(1, 2));
}
SRC},

.{ "casting between distinct variants without explicit conversion", #string SRC
#import "Basic";
A :: #type,distinct int;
B :: #type,distinct int;
main :: () {
    a: A;
    b: B = cast(B) a;
    print("%\n", b);
}
SRC},

];

// ============================================================================
// Extra2 compile-error test entries to be merged into compile_errors_meta.jai.
//
// This file is intended to be #load'ed (or appended) into the main metaprogram.
// It assumes the `Test :: struct { name: string; source: string; }` type is
// already declared by the loader. Do NOT redeclare Test here.
//
// Each entry is a complete, self-contained Jai program that should produce at
// least one diagnostic (Error / Warning / Info). A handful are coverage entries
// that may compile cleanly on certain compiler versions; those are still useful
// for shape-of-diagnostic comparisons.
// ============================================================================

EXTRA_TESTS_2 :: Test.[

// ===========================================================================
// SECTION CA. Float literal parse errors.
// ===========================================================================

.{ "float literal with double dot", #string SRC
#import "Basic";
main :: () {
    f := 1..0;
    print("%\n", f);
}
SRC},

.{ "float literal scientific notation no exponent digits", #string SRC
#import "Basic";
main :: () {
    f := 1.0e;
    print("%\n", f);
}
SRC},

.{ "float literal scientific notation only e", #string SRC
#import "Basic";
main :: () {
    f := 1e;
    print("%\n", f);
}
SRC},

.{ "float literal trailing dot followed by identifier garbage", #string SRC
#import "Basic";
main :: () {
    f := 3.foo;
    print("%\n", f);
}
SRC},

.{ "float literal with two e's", #string SRC
#import "Basic";
main :: () {
    f := 1.0e1e2;
    print("%\n", f);
}
SRC},

.{ "float literal with letter inside mantissa", #string SRC
#import "Basic";
main :: () {
    f := 1.2x3;
    print("%\n", f);
}
SRC},

// ===========================================================================
// SECTION CB. Char / rune / escape literal errors.
// ===========================================================================

.{ "#char with two characters via escape", #string SRC
#import "Basic";
main :: () {
    c := #char "ab";
    print("%\n", c);
}
SRC},

.{ "#char with surrogate-only sequence", #string SRC
#import "Basic";
main :: () {
    c := #char "\\";
    print("%\n", c);
}
SRC},

.{ "string with bad hex escape (non-hex digit)", #string SRC
#import "Basic";
main :: () {
    s := "\\xZZ";
    print("%\n", s);
}
SRC},

.{ "string with bad unicode escape (too few digits)", #string SRC
#import "Basic";
main :: () {
    s := "\\u12";
    print("%\n", s);
}
SRC},

.{ "string with stray backslash before newline", #string SRC
#import "Basic";
main :: () {
    s := "abc\\q";
    print("%\n", s);
}
SRC},

// ===========================================================================
// SECTION CC. Integer arithmetic across types.
// ===========================================================================

.{ "u32 + s32 without cast", #string SRC
#import "Basic";
main :: () {
    a: u32 = 3;
    b: s32 = 4;
    c := a + b;
    print("%\n", c);
}
SRC},

.{ "u64 + s64 without cast", #string SRC
#import "Basic";
main :: () {
    a: u64 = 3;
    b: s64 = 4;
    c := a + b;
    print("%\n", c);
}
SRC},

.{ "s8 + u16 without cast", #string SRC
#import "Basic";
main :: () {
    a: s8 = 3;
    b: u16 = 4;
    c := a + b;
    print("%\n", c);
}
SRC},

.{ "u8 * s8 without cast", #string SRC
#import "Basic";
main :: () {
    a: u8 = 3;
    b: s8 = 4;
    c := a * b;
    print("%\n", c);
}
SRC},

.{ "float + float64 without cast", #string SRC
#import "Basic";
main :: () {
    a: float32 = 1.0;
    b: float64 = 2.0;
    c := a + b;
    print("%\n", c);
}
SRC},

// ===========================================================================
// SECTION CD. Pointer vs int / float comparisons.
// ===========================================================================

.{ "pointer compared with int literal nonzero", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    p: *int = *a;
    if p == 42 print("yes\n");
}
SRC},

.{ "pointer compared with int variable", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    p: *int = *a;
    n: int = 5;
    if p == n print("yes\n");
}
SRC},

.{ "pointer compared with float", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    p: *int = *a;
    f: float = 1.0;
    if p == f print("yes\n");
}
SRC},

.{ "pointer subtracted from int", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    p: *int = *a;
    n: int = 5;
    r := n - p;
    print("%\n", r);
}
SRC},

// ===========================================================================
// SECTION CE. Pointer-to-function vs pointer-to-data mismatch.
// ===========================================================================

.{ "assign function pointer to data pointer", #string SRC
#import "Basic";
f :: () { }
main :: () {
    p: *int = f;
    print("%\n", p);
}
SRC},

.{ "assign data pointer to function pointer", #string SRC
#import "Basic";
main :: () {
    n: int = 0;
    p: () -> () = *n;
    p();
}
SRC},

.{ "compare procedure pointer to *void", #string SRC
#import "Basic";
f :: () { }
main :: () {
    a: int = 0;
    pv: *void = *a;
    if f == pv print("yes\n");
}
SRC},

// ===========================================================================
// SECTION CF. cast misuse.
// ===========================================================================

.{ "cast struct value to int", #string SRC
#import "Basic";
S :: struct { x: int; y: int; }
main :: () {
    s: S;
    n: int = cast(int) s;
    print("%\n", n);
}
SRC},

.{ "cast int to struct", #string SRC
#import "Basic";
S :: struct { x: int; y: int; }
main :: () {
    n: int = 5;
    s: S = cast(S) n;
    print("%\n", s);
}
SRC},

.{ "cast,trunc on string", #string SRC
#import "Basic";
main :: () {
    s := "hello";
    n: int = cast,trunc(int) s;
    print("%\n", n);
}
SRC},

.{ "cast,trunc to bool from float", #string SRC
#import "Basic";
main :: () {
    f: float = 1.5;
    b: bool = cast,trunc(bool) f;
    print("%\n", b);
}
SRC},

.{ "cast unrelated struct pointers", #string SRC
#import "Basic";
A :: struct { x: int; }
B :: struct { y: float; z: float; }
main :: () {
    a: A;
    pa: *A = *a;
    pb: *B = cast(*B) pa;
    print("%\n", pb);
}
SRC},

.{ "cast float to bool without trunc", #string SRC
#import "Basic";
main :: () {
    f: float = 1.5;
    b: bool = cast(bool) f;
    print("%\n", b);
}
SRC},

// ===========================================================================
// SECTION CG. Procedure-pointer signature mismatch.
// ===========================================================================

.{ "function pointer var assigned proc with different return count", #string SRC
#import "Basic";
f :: () -> (int, int) { return 1, 2; }
main :: () {
    p: () -> int = f;
    print("%\n", p());
}
SRC},

.{ "function pointer var assigned proc with different return type", #string SRC
#import "Basic";
f :: () -> string { return "hi"; }
main :: () {
    p: () -> int = f;
    print("%\n", p());
}
SRC},

.{ "function pointer var assigned proc with extra parameter", #string SRC
#import "Basic";
f :: (a: int, b: int) -> int { return a + b; }
main :: () {
    p: (a: int) -> int = f;
    print("%\n", p(3));
}
SRC},

.{ "compare two proc ptrs of different signatures", #string SRC
#import "Basic";
f :: () { }
g :: (n: int) { }
main :: () {
    if f == g print("yes\n");
}
SRC},

// ===========================================================================
// SECTION CH. #c_call and #foreign issues.
// ===========================================================================

.{ "#c_call calling non c-callable jai proc", #string SRC
#import "Basic";
helper :: () { print("hi\n"); }
caller :: () #c_call {
    helper();
}
main :: () {
    caller();
}
SRC},

.{ "#foreign with no library reference", #string SRC
#import "Basic";
extern_proc :: (n: s32) -> s32 #foreign;
main :: () {
    _ := extern_proc(1);
}
SRC},

.{ "#foreign declared with body", #string SRC
#import "Basic";
libc :: #foreign_system_library "libc";
extern_proc :: (n: s32) -> s32 #foreign libc {
    return n;
}
main :: () {
    _ := extern_proc(1);
}
SRC},

// ===========================================================================
// SECTION CI. Scope directives misuse.
// ===========================================================================

.{ "#scope_file inside procedure body", #string SRC
#import "Basic";
main :: () {
    #scope_file;
    print("hi\n");
}
SRC},

.{ "#scope_module inside procedure body", #string SRC
#import "Basic";
main :: () {
    #scope_module;
    print("hi\n");
}
SRC},

.{ "#scope_export inside procedure body", #string SRC
#import "Basic";
main :: () {
    #scope_export;
    print("hi\n");
}
SRC},

// ===========================================================================
// SECTION CJ. Polymorphic struct mismatches.
// ===========================================================================

.{ "cast polymorphic struct between different parameterizations", #string SRC
#import "Basic";
Box :: struct(T: Type) { value: T; }
main :: () {
    a: Box(int);
    b: Box(float);
    b = cast(Box(float)) a;
    print("%\n", b);
}
SRC},

.{ "assign two polymorphic struct instantiations directly", #string SRC
#import "Basic";
Box :: struct(T: Type) { value: T; }
main :: () {
    a: Box(int);
    b: Box(string);
    b = a;
    print("%\n", b);
}
SRC},

.{ "pass Box(int) where Box(string) expected", #string SRC
#import "Basic";
Box :: struct(T: Type) { value: T; }
take :: (b: Box(string)) { print("%\n", b); }
main :: () {
    a: Box(int);
    take(a);
}
SRC},

// ===========================================================================
// SECTION CK. #as using chains.
// ===========================================================================

.{ "#as using chain target has clashing field name", #string SRC
#import "Basic";
Inner :: struct { v: int; }
Mid :: struct {
    #as using inner: Inner;
    v: int;
}
main :: () {
    m: Mid;
    print("%\n", m.v);
}
SRC},

.{ "#as using chain through pointer to struct with missing field", #string SRC
#import "Basic";
Inner :: struct { x: int; }
Outer :: struct {
    #as using inner: *Inner;
}
main :: () {
    o: Outer;
    print("%\n", o.y);
}
SRC},

// ===========================================================================
// SECTION CL. enum_flags / enum corner cases.
// ===========================================================================

.{ "enum_flags member with negative value", #string SRC
#import "Basic";
F :: enum_flags { A :: -1; B :: 2; }
main :: () {
    f: F = .A;
    print("%\n", f);
}
SRC},

.{ "enum_flags non-power-of-two member", #string SRC
#import "Basic";
F :: enum_flags { A :: 3; B :: 4; }
main :: () {
    f: F = .A;
    print("%\n", f);
}
SRC},

.{ "assign enum value to underlying int without cast", #string SRC
#import "Basic";
E :: enum u32 { A :: 0; B :: 1; C :: 2; }
main :: () {
    n: u32 = E.B;
    print("%\n", n);
}
SRC},

.{ "compare enum_flags of two different types", #string SRC
#import "Basic";
F :: enum_flags { A :: 1; B :: 2; }
G :: enum_flags { X :: 1; Y :: 2; }
main :: () {
    f: F = .A;
    g: G = .X;
    if f == g print("yes\n");
}
SRC},

.{ "compare two different enums via ==", #string SRC
#import "Basic";
E :: enum { A; B; }
F :: enum { X; Y; }
main :: () {
    e: E = .A;
    f: F = .X;
    if e == f print("yes\n");
}
SRC},

.{ "compare enum to plain integer literal", #string SRC
#import "Basic";
E :: enum { A; B; }
main :: () {
    e: E = .A;
    if e == 0 print("yes\n");
}
SRC},

.{ "compare enum to plain integer variable", #string SRC
#import "Basic";
E :: enum { A; B; }
main :: () {
    e: E = .A;
    n: int = 0;
    if e == n print("yes\n");
}
SRC},

.{ "enum cast from float", #string SRC
#import "Basic";
E :: enum { A; B; }
main :: () {
    f: float = 1.0;
    e: E = cast(E) f;
    print("%\n", e);
}
SRC},

.{ "struct field access on enum value", #string SRC
#import "Basic";
E :: enum { A; B; }
main :: () {
    e: E = .A;
    print("%\n", e.foo);
}
SRC},

// ===========================================================================
// SECTION CM. Method-style calls on structs (Jai has no methods).
// ===========================================================================

.{ "method-style call on struct without member proc", #string SRC
#import "Basic";
S :: struct { x: int; }
main :: () {
    s: S;
    s.do_it();
}
SRC},

.{ "method-style call on int", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    n.times_two();
}
SRC},

// ===========================================================================
// SECTION CN. Procedure pointer usage gone wrong.
// ===========================================================================

.{ "calling a value typed as Type", #string SRC
#import "Basic";
main :: () {
    t: Type = int;
    t();
}
SRC},

.{ "calling a value typed as enum", #string SRC
#import "Basic";
E :: enum { A; B; }
main :: () {
    e: E = .A;
    e();
}
SRC},

// ===========================================================================
// SECTION CO. Defer issues.
// ===========================================================================

.{ "defer outside any procedure (top level)", #string SRC
#import "Basic";
defer print("late\n");
main :: () { print("hi\n"); }
SRC},

.{ "defer at top of file before imports", #string SRC
defer print("late\n");
#import "Basic";
main :: () { print("hi\n"); }
SRC},

.{ "defer with empty statement", #string SRC
#import "Basic";
main :: () {
    defer;
    print("hi\n");
}
SRC},

// ===========================================================================
// SECTION CP. Return arity in main / declared procs.
// ===========================================================================

.{ "returning more values than declared", #string SRC
#import "Basic";
f :: () -> int { return 1, 2; }
main :: () {
    _ := f();
}
SRC},

.{ "returning fewer values than declared", #string SRC
#import "Basic";
f :: () -> (int, int) { return 5; }
main :: () {
    a, b := f();
    print("% %\n", a, b);
}
SRC},

.{ "return without value where value expected", #string SRC
#import "Basic";
f :: () -> int { return; }
main :: () {
    _ := f();
}
SRC},

.{ "tuple assigned where single value expected", #string SRC
#import "Basic";
f :: () -> (int, int) { return 1, 2; }
main :: () {
    x: int = f();
    print("%\n", x);
}
SRC},

.{ "single return assigned to two variables", #string SRC
#import "Basic";
f :: () -> int { return 5; }
main :: () {
    a, b := f();
    print("% %\n", a, b);
}
SRC},

// ===========================================================================
// SECTION CQ. Uninitialized (---) misuse.
// ===========================================================================

.{ "--- without type", #string SRC
#import "Basic";
main :: () {
    x := ---;
    print("%\n", x);
}
SRC},

.{ "--- as rvalue inside expression", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    x: int = n + ---;
    print("%\n", x);
}
SRC},

.{ "--- passed as argument", #string SRC
#import "Basic";
f :: (n: int) { print("%\n", n); }
main :: () {
    f(---);
}
SRC},

// ===========================================================================
// SECTION CR. inline / #expand issues.
// ===========================================================================

.{ "inline keyword on a recursive call", #string SRC
#import "Basic";
fact :: (n: int) -> int { if n <= 1 return 1; return n * inline fact(n - 1); }
main :: () { print("%\n", fact(5)); }
SRC},

.{ "#expand with mismatched return inside", #string SRC
#import "Basic";
my_macro :: () #expand { return; }
caller :: () -> int {
    my_macro();
    return 0;
}
main :: () { print("%\n", caller()); }
SRC},

// ===========================================================================
// SECTION CS. it / it_index outside for loop.
// ===========================================================================

.{ "use it outside any for loop", #string SRC
#import "Basic";
main :: () {
    print("%\n", it);
}
SRC},

.{ "use it_index outside any for loop", #string SRC
#import "Basic";
main :: () {
    print("%\n", it_index);
}
SRC},

.{ "use it after for loop ends", #string SRC
#import "Basic";
main :: () {
    for 0..3 { }
    print("%\n", it);
}
SRC},

// ===========================================================================
// SECTION CT. #if and #run misuse.
// ===========================================================================

.{ "#if with runtime variable", #string SRC
#import "Basic";
main :: () {
    x := 1;
    #if x { print("hi\n"); }
}
SRC},

.{ "#if true but body has undeclared identifier", #string SRC
#import "Basic";
main :: () {
    #if true { print("%\n", does_not_exist_xyz); }
}
SRC},

.{ "#run calls a procedure that uses runtime context state", #string SRC
#import "Basic";
build_value :: () -> int {
    return 42;
}
N :: #run build_value();
main :: () {
    print("%\n", N);
    print("%\n", undeclared_zzz);
}
SRC},

.{ "#run with assert true ", #string SRC
#import "Basic";
#run assert(true, "ok");
main :: () { print("hi\n"); }
SRC},

// ===========================================================================
// SECTION CU. Auto cast (xx) edge cases.
// ===========================================================================

.{ "xx from string to int", #string SRC
#import "Basic";
main :: () {
    s := "hi";
    n: int = xx s;
    print("%\n", n);
}
SRC},

.{ "xx from int to string", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    s: string = xx n;
    print("%\n", s);
}
SRC},

.{ "xx from struct to int", #string SRC
#import "Basic";
S :: struct { a: int; }
main :: () {
    s: S;
    n: int = xx s;
    print("%\n", n);
}
SRC},

.{ "xx negative int to u32", #string SRC
#import "Basic";
main :: () {
    a: s32 = -5;
    u: u32 = xx a;
    print("%\n", u);
}
SRC},

// ===========================================================================
// SECTION CV. Compiler intrinsic misuse.
// ===========================================================================

.{ "memcmp with non-pointer first arg", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    b: int = 0;
    n := memcmp(a, b, 4);
    print("%\n", n);
}
SRC},

.{ "memcpy with non-pointer src", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    pa: *int = *a;
    memcpy(pa, 5, 4);
}
SRC},

// ===========================================================================
// SECTION CW. Multiple defaults / struct member collisions.
// ===========================================================================

.{ "struct member declared twice with default", #string SRC
#import "Basic";
S :: struct { a: int = 1; a: int = 2; }
main :: () {
    s: S;
    print("%\n", s.a);
}
SRC},

.{ "using brings two same-named fields into scope", #string SRC
#import "Basic";
A :: struct { n: int; }
B :: struct { n: int; }
C :: struct { using a: A; using b: B; }
main :: () {
    c: C;
    print("%\n", c.n);
}
SRC},

.{ "using on a pointer field with clashing names", #string SRC
#import "Basic";
A :: struct { x: int; }
B :: struct { x: int; using pa: *A; }
main :: () {
    a: A;
    b: B;
    b.pa = *a;
    print("%\n", b.x);
}
SRC},

// ===========================================================================
// SECTION CX. for loop with pointer over fixed array literal.
// ===========================================================================

.{ "for * over a fixed array literal", #string SRC
#import "Basic";
main :: () {
    for * int.[1, 2, 3] {
        print("%\n", it.*);
    }
}
SRC},

.{ "for over int (non-iterable)", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    for n print("%\n", it);
}
SRC},

.{ "for * over int", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    for * n print("%\n", it);
}
SRC},

// ===========================================================================
// SECTION CY. Misc lexer / parser edge cases.
// ===========================================================================

.{ "two consecutive semicolons inside block", #string SRC
#import "Basic";
main :: () {
    x := 1;;
    print("%\n", x);
}
SRC},

.{ "trailing comma inside argument list (might be allowed)", #string SRC
#import "Basic";
main :: () {
    f :: (a: int, b: int) -> int { return a + b; }
    _ := f(1, 2,);
}
SRC},

.{ "binary literal with invalid digit", #string SRC
#import "Basic";
main :: () {
    n := 0b102;
    print("%\n", n);
}
SRC},

.{ "octal literal with invalid digit (Jai uses 0o or none)", #string SRC
#import "Basic";
main :: () {
    n := 0o89;
    print("%\n", n);
}
SRC},

.{ "underscore at start of number literal", #string SRC
#import "Basic";
main :: () {
    n := _123;
    print("%\n", n);
}
SRC},

.{ "number with multiple underscores in a row", #string SRC
#import "Basic";
main :: () {
    n := 1__000;
    print("%\n", n);
}
SRC},

// ===========================================================================
// SECTION CZ. Procedure pointer field stored in struct.
// ===========================================================================

.{ "proc pointer field with wrong assignment type", #string SRC
#import "Basic";
S :: struct { f: (n: int) -> int; }
main :: () {
    s: S;
    s.f = 5;
    print("%\n", s.f);
}
SRC},

.{ "proc pointer assigned from int", #string SRC
#import "Basic";
main :: () {
    p: () -> int;
    p = 42;
    print("%\n", p());
}
SRC},

// ===========================================================================
// SECTION DA. enum cast checks.
// ===========================================================================

.{ "enum cast int to E without specified - out of range", #string SRC
#import "Basic";
E :: enum { A; B; C; }
main :: () {
    n: int = 99;
    e: E = cast(E) n;
    print("%\n", e);
}
SRC},

.{ "cast int to enum_flags with too many bits", #string SRC
#import "Basic";
F :: enum_flags u8 { A :: 1; B :: 2; }
main :: () {
    n: int = 257;
    f: F = cast(F) n;
    print("%\n", f);
}
SRC},

// ===========================================================================
// SECTION DB. union / type oddities.
// ===========================================================================

.{ "union with overlapping field accessed as both", #string SRC
#import "Basic";
U :: union {
    i: int;
    s: string;
}
main :: () {
    u: U;
    u.i = 5;
    print("%\n", u.s);
}
SRC},

.{ "union assigned struct-literal style with wrong field", #string SRC
#import "Basic";
U :: union { i: int; f: float; }
main :: () {
    u: U = .{ z = 1.0 };
    print("%\n", u);
}
SRC},

// ===========================================================================
// SECTION DC. Type expression / Type misuse.
// ===========================================================================

.{ "pass int as Type parameter", #string SRC
#import "Basic";
takes_type :: (t: Type) { print("%\n", t); }
main :: () {
    n: int = 5;
    takes_type(n);
}
SRC},

.{ "use of Type value as runtime expression in subscript", #string SRC
#import "Basic";
main :: () {
    t: Type = int;
    n := t[0];
    print("%\n", n);
}
SRC},

.{ "polymorphic argument expects Type but gets value", #string SRC
#import "Basic";
make :: ($T: Type) -> T { x: T; return x; }
main :: () {
    n: int = 5;
    _ := make(n);
}
SRC},

// ===========================================================================
// SECTION DD. Comparison / equality oddities.
// ===========================================================================

.{ "string == int", #string SRC
#import "Basic";
main :: () {
    s := "hi";
    n := 1;
    if s == n print("yes\n");
}
SRC},

.{ "bool == int", #string SRC
#import "Basic";
main :: () {
    b := true;
    n := 1;
    if b == n print("yes\n");
}
SRC},

.{ "struct == struct without operator==", #string SRC
#import "Basic";
S :: struct { a: int; b: int; }
main :: () {
    x: S;
    y: S;
    if x == y print("yes\n");
}
SRC},

// ===========================================================================
// SECTION DE. Assignments to read-only / wrong direction.
// ===========================================================================

.{ "modify field of a returned-by-value struct directly", #string SRC
#import "Basic";
S :: struct { a: int; }
get :: () -> S { x: S; return x; }
main :: () {
    get().a = 5;
    print("done\n");
}
SRC},

.{ "modify literal struct field", #string SRC
#import "Basic";
S :: struct { a: int; }
main :: () {
    S.{1}.a = 5;
    print("done\n");
}
SRC},

// ===========================================================================
// SECTION DF. Misc.
// ===========================================================================

.{ "array literal with no element type and no elements", #string SRC
#import "Basic";
main :: () {
    a := .[];
    print("%\n", a);
}
SRC},

.{ "negative array size via expression", #string SRC
#import "Basic";
N :: -3;
main :: () {
    a: [N] int;
    print("%\n", a);
}
SRC},

.{ "subscript with float index", #string SRC
#import "Basic";
main :: () {
    a := int.[1, 2, 3];
    f: float = 1.0;
    print("%\n", a[f]);
}
SRC},

.{ "subscript with bool index", #string SRC
#import "Basic";
main :: () {
    a := int.[1, 2, 3];
    print("%\n", a[true]);
}
SRC},

.{ "if condition uses int (non-bool)", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    if n print("yes\n");
}
SRC},

.{ "while condition uses int (non-bool)", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    while n {
        n = 0;
    }
    print("done\n");
}
SRC},

.{ "if condition uses string", #string SRC
#import "Basic";
main :: () {
    s := "hi";
    if s print("yes\n");
}
SRC},

.{ "if condition uses pointer (no auto-deref)", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    p: *int = *n;
    if p print("yes\n");
}
SRC},

// ===========================================================================
// SECTION DG. logical operators.
// ===========================================================================

.{ "logical && between int and bool", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    b: bool = true;
    r := n && b;
    print("%\n", r);
}
SRC},

.{ "logical || between string and bool", #string SRC
#import "Basic";
main :: () {
    s := "hi";
    b: bool = true;
    r := s || b;
    print("%\n", r);
}
SRC},

.{ "! on int", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    r := !n;
    print("%\n", r);
}
SRC},

// ===========================================================================
// SECTION DH. Negative cast / shift edge cases.
// ===========================================================================

.{ "shift int by negative literal", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    r := n << -1;
    print("%\n", r);
}
SRC},

.{ "shift int by float", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    f: float = 2.0;
    r := n << f;
    print("%\n", r);
}
SRC},

.{ "bitwise & between int and float", #string SRC
#import "Basic";
main :: () {
    n: int = 1;
    f: float = 2.0;
    r := n & f;
    print("%\n", r);
}
SRC},

.{ "bitwise | between string and int", #string SRC
#import "Basic";
main :: () {
    s := "hi";
    n: int = 1;
    r := s | n;
    print("%\n", r);
}
SRC},

// ===========================================================================
// SECTION DI. notes / directives.
// ===========================================================================

.{ "unknown #directive name", #string SRC
#import "Basic";
main :: () {
    #frobnicate;
    print("done\n");
}
SRC},

.{ "#must on void return", #string SRC
#import "Basic";
f :: () #must { print("hi\n"); }
main :: () { f(); }
SRC},

// ===========================================================================
// SECTION DJ. Array operations.
// ===========================================================================

.{ "array_add on fixed array", #string SRC
#import "Basic";
main :: () {
    a: [3] int;
    array_add(*a, 5);
    print("%\n", a);
}
SRC},

.{ "array assign element of wrong type", #string SRC
#import "Basic";
main :: () {
    a: [3] int;
    a[0] = "hi";
    print("%\n", a);
}
SRC},

.{ "array of array with mismatched inner sizes", #string SRC
#import "Basic";
main :: () {
    a: [2] [3] int = .[ .[1,2,3], .[4,5] ];
    print("%\n", a);
}
SRC},
];

// ============================================================================
// Extra compile-error test entries (set 3) to be merged into
// compile_errors_meta.jai.
//
// This file is intended to be #load'ed into the main metaprogram. It assumes
// the `Test :: struct { name: string; source: string; }` type is already
// declared by the loader. Do NOT redeclare Test here.
//
// Each entry is a complete, self-contained Jai program that should produce
// at least one diagnostic. A handful are coverage entries that may compile
// cleanly on some compiler versions; those are still useful for shape-of-
// diagnostic comparisons.
// ============================================================================

EXTRA_TESTS_3 :: Test.[

// ===========================================================================
// SECTION CA. Declaration syntax corruptions.
// ===========================================================================

.{ "declaration with colon and no type or value", #string SRC
#import "Basic";
main :: () {
    x:;
    print("%\n", x);
}
SRC},

.{ "declaration with triple colon and value", #string SRC
#import "Basic";
main :: () {
    x:::5;
    print("%\n", x);
}
SRC},

.{ "top-level assignment without colon-equals", #string SRC
#import "Basic";
x = 5;
main :: () {
    print("%\n", x);
}
SRC},

.{ "declaration mixing colon-type with walrus operator", #string SRC
#import "Basic";
main :: () {
    x: int := 5;
    print("%\n", x);
}
SRC},

.{ "declaration with type after value", #string SRC
#import "Basic";
main :: () {
    x := 5: int;
    print("%\n", x);
}
SRC},

.{ "double-colon then equals instead of walrus", #string SRC
#import "Basic";
main :: () {
    x :: = 5;
    print("%\n", x);
}
SRC},

.{ "declaration with stray comma in list", #string SRC
#import "Basic";
main :: () {
    a, b, := 1, 2;
    print("% %\n", a, b);
}
SRC},

.{ "multiple assignment with too few values", #string SRC
#import "Basic";
main :: () {
    a, b, c := 1, 2;
    print("% % %\n", a, b, c);
}
SRC},

.{ "multiple assignment with too many values", #string SRC
#import "Basic";
main :: () {
    a, b := 1, 2, 3;
    print("% %\n", a, b);
}
SRC},

.{ "multiple declaration colon-equals with too few types", #string SRC
#import "Basic";
main :: () {
    a, b, c: int = 1;
    print("% % %\n", a, b, c);
}
SRC},

.{ "multiple-assign LHS with rhs single value of different arity", #string SRC
#import "Basic";
