----------------------------------------------------------------
== 816. #code and #procedure_of_call
----------------------------------------------------------------

-- Polymorphic id_poly instantiated for multiple types
  type p_id_int   = procedure (s64) -> s64
  type p_id_float = procedure (float32) -> float32
  type p_id_bool  = procedure (bool) -> bool
  type p_id_str   = procedure (string) -> string
  id_int(5)    = 5
  id_float(.5) = 0.5
  id_bool(t)   = true
  id_str('a')  = a

-- Polymorphic add_poly for int and float
  type p_add_int   = procedure (s64, s64) -> s64
  type p_add_float = procedure (float32, float32) -> float32
  add_int(3,4)     = 7
  add_float(.5,1.5)= 2

-- Polymorphic max_poly
  max_int(7,3)     = 7
  max_int(3,7)     = 7
  max_float(.1,.2) = 0.2

-- Polymorphic pair_poly with distinct $A, $B
  type p_pair_ii = procedure (s64, s64) -> (s64, s64)
  type p_pair_if = procedure (s64, float32) -> (s64, float32)
  type p_pair_si = procedure (string, s64) -> (string, s64)
  pair_ii(1,2)    = (1, 2)
  pair_if(3,4.5)  = (3, 4.5)
  pair_si('x',7)  = (x, 7)

-- #code values inserted into multiple places
  before first insert
    [via code] hello
  between inserts
    [via code] hello
  after last insert

-- Build code via tprint and #insert at compile time
  inserted-expr-value=7

-- Insert a switch-case-like block via #expand
    chose ONE
    chose TWO
    chose THREE

