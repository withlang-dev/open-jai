  s=86400 -> apollo.low=12613023705161793536 apollo.high=4 -> s=86400 ok=true
  s=604800 -> apollo.low=14504189641294348288 apollo.high=32 -> s=604800 ok=true
  s=31536000 -> apollo.low=10514378030376288256 apollo.high=1709 -> s=31536000 ok=true
  s=-1 -> apollo.low=18445744073709551616 apollo.high=-1 -> s=-1 ok=true
  s=-60 -> apollo.low=18386744073709551616 apollo.high=-1 -> s=-60 ok=true
