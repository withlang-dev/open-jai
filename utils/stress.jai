    print("  %\n", PE8_json(f64s));

    sub("[5] bool");
    bs : [5] bool = .[true, false, true, false, true];
    print("  %\n", PE8_json(bs));

    sub("[3] string");
    ss : [3] string = .["x", "yy", "zzz"];
    print("  %\n", PE8_json(ss));
}


// ============================================================================
// Section 843. More iterator combinators applied to various ranges.
// ============================================================================

PE8_run_section_843 :: () {
    section("843. Iterator combinator variations");

    sub("Range 0..0 (single element)");
    r := PE8_Range.{0, 0};
    for :PE8_range_iter r  print("  %\n", it);

    sub("Range empty (from > to)");
    r2 := PE8_Range.{5, 4};
    n := 0;
    for :PE8_range_iter r2  n += 1;
    print("  empty range produced n=%\n", n);

    sub("Take 0 elements");
    tr := PE8_Take_Range.{r=.{0, 100}, n=0};
    n2 := 0;
    for :PE8_take_iter tr  n2 += 1;
    print("  take(0) produced n=%\n", n2);

    sub("Take 1 element");
    tr1 := PE8_Take_Range.{r=.{0, 100}, n=1};
    for :PE8_take_iter tr1  print("  %\n", it);

    sub("Take exactly the range size");
    tr2 := PE8_Take_Range.{r=.{0, 4}, n=5};
    for :PE8_take_iter tr2  print("  %\n", it);

    sub("Skip 0");
    sr := PE8_Skip_Range.{r=.{1, 5}, n=0};
    for :PE8_skip_iter sr  print("  %\n", it);

    sub("Skip equal to length");
    sr2 := PE8_Skip_Range.{r=.{1, 3}, n=3};
    n3 := 0;
    for :PE8_skip_iter sr2  n3 += 1;
    print("  skip(=len) produced n=%\n", n3);

    sub("Enumerate empty");
    er := PE8_Enumerate_Range.{r=.{5, 4}};
    n4 := 0;
    for :PE8_enumerate_iter er  n4 += 1;
    print("  enumerate empty produced n=%\n", n4);

    sub("Pairs of three (yields 2 pairs)");
    pr := PE8_Pairs_Range.{r=.{10, 12}};
    for :PE8_pairs_iter pr  print("  (%, %)\n", it.x, it.y);

    sub("Pairs of two (yields 1 pair)");
    pr2 := PE8_Pairs_Range.{r=.{10, 11}};
    for :PE8_pairs_iter pr2  print("  (%, %)\n", it.x, it.y);

    sub("Pairs of one (yields 0 pairs)");
    pr3 := PE8_Pairs_Range.{r=.{10, 10}};
    n5 := 0;
    for :PE8_pairs_iter pr3  n5 += 1;
    print("  pairs of 1 produced n=%\n", n5);
}


// ============================================================================
// Section 844. Calculator integrated with templating.
// ============================================================================

PE8_run_section_844 :: () {
    section("844. Calculator + template integration");

    exprs := string.["2+2", "3*7", "(5-3)*4", "100/4", "1+2+3+4"];
    for exprs {
        v, ok := PE8_calc_eval(it);
        out := PE8_template_render(
            "{expr} = {result} (ok={ok})",
            string.["expr", "result", "ok"],
            string.[it, tprint("%", v), tprint("%", ok)]
        );
        print("  %\n", out);
    }
}


// ============================================================================
// Section 845. UTF-8 + glob: search for glob patterns in UTF-8 strings.
// ============================================================================

PE8_run_section_845 :: () {
    section("845. UTF-8 strings used with byte-level glob");

    Sample :: struct { s: string; p: string; expected: bool; }
    samples := Sample.[
        .{"caf\xC3\xA9",        "caf*",    true},
        .{"caf\xC3\xA9",        "*\xC3\xA9", true},
        .{"\xE2\x98\x83snow",   "*snow",   true},
        .{"\xE2\x98\x83snow",   "?*snow",  true},
        .{"snow\xE2\x98\x83",   "snow*",   true},
        .{"\xE2\x98\x83",       "?",       false},   // single ? matches one byte not one codepoint
        .{"a",                  "?",       true},
        .{"\xE2\x98\x83",       "???",     true},     // 3 bytes
    ];
    for samples {
        got := PE8_glob_match(it.s, it.p);
        print("  match('%','%') = % (expected %, ok=%)\n",
            it.s, it.p, got, it.expected, got == it.expected);
    }
}


// ============================================================================
// Section 846. JSON-emit Any with mixed nesting depth (5 levels).
// ============================================================================

PE8_L1 :: struct { a: int; }
PE8_L2 :: struct { l1: PE8_L1; b: int; }
PE8_L3 :: struct { l2: PE8_L2; c: int; }
PE8_L4 :: struct { l3: PE8_L3; d: int; }
PE8_L5 :: struct { l4: PE8_L4; e: int; }

PE8_run_section_846 :: () {
    section("846. Deep struct nesting");

    v := PE8_L5.{
        l4 = .{
            l3 = .{
                l2 = .{
                    l1 = .{ a = 1 },
                    b = 2
                },
                c = 3
            },
            d = 4
        },
        e = 5
    };
    sub("JSON");
    print("  %\n", PE8_json(v));
    sub("YAML");
    print("%\n", PE8_yaml(v));
    sub("Shape");
    PE8_print_any_shape(v, 0);
}


// ============================================================================
// Section 847. Combined: tree of Person, dumped to JSON via Any.
// ============================================================================

PE8_run_section_847 :: () {
    section("847. Tree of Person (flatten and JSON-dump)");

    root := PE8_tree_make(PE8_Person, .{"Root", 50, 175.0, true});
    a := PE8_tree_make(PE8_Person, .{"A", 30, 170.0, false});
    b := PE8_tree_make(PE8_Person, .{"B", 35, 165.0, true});
    PE8_tree_attach(root, a);
    PE8_tree_attach(root, b);
    PE8_tree_attach(a, PE8_tree_make(PE8_Person, .{"A1", 10, 100.0, false}));
    PE8_tree_attach(b, PE8_tree_make(PE8_Person, .{"B1", 12, 110.0, true}));

    flat: [..] PE8_Person;
    PE8_flatten_tree_persons :: (n: *PE8_Tree(PE8_Person), out: *[..] PE8_Person) {
        array_add(out, n.value);
        for n.children  PE8_flatten_tree_persons(it, out);
    }
    PE8_flatten_tree_persons(root, *flat);

    print("  %\n", PE8_json(flat));
    array_reset(*flat);
}


// ============================================================================
// Section 848. Compound: graph + DSU = connected components via union of
// edges.
// ============================================================================

PE8_run_section_848 :: () {
    section("848. Connected components via DSU on edges");

    Edge :: struct { a: int; b: int; }
    nodes_used: [..] int;

    cases := struct { n: int; edges: [] Edge; }.[
        .{ 6, .[.{0,1},.{1,2},.{3,4}] },
        .{ 8, .[.{0,1},.{1,2},.{2,3},.{4,5},.{5,6}] },
        .{ 5, .[] },
        .{ 4, .[.{0,1},.{1,2},.{2,3},.{3,0}] },
        .{ 7, .[.{0,1},.{2,3},.{4,5}] },
    ];
    for c, i: cases {
        d: PE8_DSU;
        PE8_dsu_init(*d, c.n);
        for e: c.edges  PE8_dsu_union(*d, e.a, e.b);
        comp := 0;
        for x: 0..c.n-1  if PE8_dsu_find(*d, x) == x  comp += 1;
        print("  case[%]: n=% edges=% components=%\n", i, c.n, c.edges.count, comp);
        PE8_dsu_reset(*d);
    }
    array_reset(*nodes_used);
}


// ============================================================================
// Section 849. Many small #insert uses.
// ============================================================================

PE8_run_section_849 :: () {
    section("849. Many small #insert uses");

    sub("Insert constant declarations");
    CONSTS :: #string DONE
A_CONST :: 7;
B_CONST :: 3;
C_CONST :: A_CONST * B_CONST;
DONE
    #insert CONSTS;
    print("  A_CONST=% B_CONST=% C_CONST=%\n", A_CONST, B_CONST, C_CONST);

    sub("Insert array initialization");
    ARR :: #string DONE
arr_in : [5] int = .[1, 2, 3, 4, 5];
DONE
    #insert ARR;
    s := 0;
    for arr_in  s += it;
    print("  sum=%\n", s);

    sub("Nested loops printed directly (avoids capture issue)");
    for i: 0..2 {
        for j: 0..2  print("    i=% j=%\n", i, j);
    }

    sub("Insert based on type via string template");
    INT_PROC :: #string DONE
{
    value := 7;
    print("    int value %\n", value);
}
DONE
    FLOAT_PROC :: #string DONE
{
    value := 1.5;
    print("    float value %\n", value);
}
DONE
    #insert INT_PROC;
    #insert FLOAT_PROC;

    sub("Insert sequences side-by-side");
    PRE :: #string DONE
pre_x := 1;
DONE
    MID :: #string DONE
mid_y := pre_x + 1;
DONE
    POST :: #string DONE
post_z := mid_y + 1;
DONE
    #insert PRE;
    #insert MID;
    #insert POST;
    print("  pre_x=% mid_y=% post_z=%\n", pre_x, mid_y, post_z);
}


