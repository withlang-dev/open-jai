// ============================================================================
// Stress test - extras 10. Adds sections 1000..1099.
//   Topics:
//   - operator precedence matrix
//   - #scope_file / #scope_module / #scope_export
//   - #foreign / #c_call bindings to libc
//   - Atomics (single-thread; deterministic)
//   - compiler_get_nodes / AST inspection via metaprogram (compile-time)
//   - add_build_file / add_data_segment surface (signatures only)
//   - nested block comments
//
// Adds sections 1000..1099.
// ============================================================================


// ----------------------------------------------------------------------------
// 1000. Nested block comments compile cleanly.
// ----------------------------------------------------------------------------

test_extras_10_1000_nested_comments :: () {
    section("1000. Nested block comments");

    /* outer comment
       /* inner comment */
       still in outer
       /* another inner /* with deeper nesting */ */
    */

    print("If you can read this, nested comments parsed correctly.\n");
}


// ----------------------------------------------------------------------------
// 1001. Operator precedence matrix.
// ----------------------------------------------------------------------------
// computed value alongside its fully-parenthesized form so the test can

test_extras_10_1001_operator_precedence :: () {
    section("1001. Operator precedence matrix");

    sub("Arithmetic precedence");
    print("1 + 2 * 3        = %  (expect 7)\n", 1 + 2 * 3);
    print("(1 + 2) * 3      = %  (expect 9)\n", (1 + 2) * 3);
    print("8 / 2 / 2        = %  (left-assoc, expect 2)\n", 8 / 2 / 2);
    print("8 / (2 / 2)      = %  (expect 8)\n", 8 / (2 / 2));
    print("2 + 3 * 4 - 1    = %  (expect 13)\n", 2 + 3 * 4 - 1);
    print("-2 + 3           = %  (unary minus)\n", -2 + 3);
    print("-(2 + 3)         = %\n", -(2 + 3));
    print("2 * -3           = %\n", 2 * -3);
    print("10 mod 3 * 2     = %  (mod tighter than mul? expect 2)\n", 10 % 3 * 2);

    sub("Shift vs arithmetic");
    print("1 << 2 + 3       = %  (expect 32)\n", 1 << 2 + 3);
    print("(1 << 2) + 3     = %  (expect 7)\n", (1 << 2) + 3);
    print("8 >> 1 + 1       = %  (expect 2)\n", 8 >> 1 + 1);

    sub("Bitwise vs arithmetic");
    print("1 | 2 + 4        = %  (expect 7)\n", 1 | 2 + 4);
    print("0b1010 & 0b1100  = %  (expect 8)\n", 0b1010 & 0b1100);
    print("0b1010 ^ 0b0101  = %  (expect 15)\n", 0b1010 ^ 0b0101);
    print("1 | 2 & 4        = %  (& tighter than |, expect 1)\n", 1 | 2 & 4);

    sub("Comparison and logical");
    print("1 < 2 && 3 < 4   = %\n", 1 < 2 && 3 < 4);
    print("1 < 2 || 5 < 3   = %\n", 1 < 2 || 5 < 3);
    print("!(1 < 2)         = %\n", !(1 < 2));
    print("1 + 2 == 3       = %\n", 1 + 2 == 3);
    print("1 == 2 || 3 == 3 = %\n", 1 == 2 || 3 == 3);

    sub("Short-circuit vs arithmetic");
    print("true && (1 + 2)  truthy? = %\n", true && cast(bool)(1 + 2));
    print("false || (1 + 2) truthy? = %\n", false || cast(bool)(1 + 2));

    sub("Member access vs unary");
    p_local := V2.{3, 4};
    print("p.x + p.y          = %\n", p_local.x + p_local.y);
    print("-(p.x + p.y)       = %\n", -(p_local.x + p_local.y));

    sub("Mixed precedence chain");
    print("1 + 2 * 3 << 1     = %  ", 1 + 2 * 3 << 1);
    print("(parses as ((1) + (2*3)) << 1 = 14)\n");
    print("1 << 2 * 3         = %  ", 1 << 2 * 3);
    print("(parses as 1 << (2*3) = 64)\n");
}


// ----------------------------------------------------------------------------
// 1002. #scope_file / #scope_module / #scope_export
// ----------------------------------------------------------------------------

#scope_file
PE10_PRIVATE_CONST :: 42;
PE10_private_double :: (x: int) -> int { return x * 2; }

#scope_export
PE10_call_private :: () -> int {
    return PE10_private_double(PE10_PRIVATE_CONST);
}

test_extras_10_1002_scope_visibility :: () {
    section("1002. #scope_file vs #scope_export");

    print("call_private() = %\n", PE10_call_private());
    print("the private const and proc are NOT visible from outside this scope\n");
    print("(if they were, this section would not compile)\n");
}


// ----------------------------------------------------------------------------
// 1003. #foreign / #c_call -- bind to libc.
// ----------------------------------------------------------------------------

libc :: #system_library "libc";

c_strlen :: (s: *u8) -> u64 #foreign libc "strlen";

// abs of an int as a libc call. Use s32 to match libc's abs() return type.
c_abs :: (x: s32) -> s32 #foreign libc "abs";

c_atoi :: (s: *u8) -> s32 #foreign libc "atoi";

test_extras_10_1003_foreign_bindings :: () {
    section("1003. #foreign bindings (libc)");

    sub("strlen of fixed strings via libc");
    inputs := string.["a", "ab", "Hello, World!", "longer string here"];
    for s: inputs {
        n := c_strlen(s.data);
        print("  strlen('%') = %  (jai count=%, equal=%)\n",
            s, n, s.count, cast(u64) s.count == n);
    }

    sub("abs(s32) via libc");
    for v: s32.[-1, -100, 0, 1, 100] {
        print("  abs(%) = %\n", v, c_abs(v));
    }

    sub("atoi via libc (non-empty literals only)");
    for s: string.["0", "42", "-5", "1000", "abc", "  7", "9999"] {
        print("  atoi('%') = %\n", s, c_atoi(s.data));
    }
}


// ----------------------------------------------------------------------------
// 1004. Atomics (single-thread is deterministic).
// ----------------------------------------------------------------------------

test_extras_10_1004_atomics :: () {
    section("1004. Atomics (single-thread)");

    Atomics :: #import "Atomics";

    counter: s64 = 0;

    sub("atomic_add (one call)");
    prev := Atomics.atomic_add(*counter, 5);
    print("  prev=% counter=%\n", prev, counter);

    sub("atomic_add loop");
    sum_prev: s64 = 0;
    for i: 1..10 {
        p := Atomics.atomic_add(*counter, cast(s64) i);
        sum_prev += p;
    }
    print("  counter after loop = %\n", counter);

    sub("compare_and_swap success and failure");
    counter = 100;
    ok1, old1 := compare_and_swap(*counter, 100, 200);
    print("  swap 100->200 ok=% old=% counter=%\n", ok1, old1, counter);
    ok2, old2 := compare_and_swap(*counter, 100, 300);
    print("  swap 100->300 ok=% old=% counter=%\n", ok2, old2, counter);

    sub("atomic_write / atomic_read");
    Atomics.atomic_write(*counter, 0xCAFE);
    v := Atomics.atomic_read(*counter);
    print("  written value read back = 0x%\n", formatInt(v, base=16));
}


// ----------------------------------------------------------------------------
// 1005. compiler_get_nodes / AST inspection (#run, compile-time only).
// ----------------------------------------------------------------------------

PE10_AST_REPORT :: #run -> string {
    builder: String_Builder;
    init_string_builder(*builder);

    // A small piece of code we will introspect.
    sample :: #code {
        x := 1;
        y := x + 2;
        if y > 0  print("yes\n");
    };

    root, exprs := compiler_get_nodes(sample);
    print_to_builder(*builder, "AST root kind = %\n", root.kind);
    print_to_builder(*builder, "AST has % expression nodes\n", exprs.count);
    for exprs  print_to_builder(*builder, "  expr[%]: kind=%\n", it_index, it.kind);

    return builder_to_string(*builder);
};

test_extras_10_1005_compiler_get_nodes :: () {
    section("1005. compiler_get_nodes / AST snapshot");
    print("%", PE10_AST_REPORT);
}


// ----------------------------------------------------------------------------
// 1006. add_build_file / add_data_segment surface.
// ----------------------------------------------------------------------------
// These are only meaningful at compile time. We just confirm the signatures

test_extras_10_1006_build_api_surface :: () {
    section("1006. Compiler build API - behavioural");
    // The Compiler module's build APIs (add_build_file, add_build_string,
    // add_data_segment, add_global_data, compiler_get_nodes,
    // compiler_modify_procedure, etc.) are driven by the embedded
    // metaprogram in the compile-time half of this file. This section
    // intentionally does not enumerate their signatures.
    print("see embedded metaprogram for behavioural coverage\n");
}

test_extras_10_1007_metaprogram_plugin :: () {
    section("1007. Metaprogram_Plugin - compile-time only");
    print("Metaprogram_Plugin is a compile-time interface; not exercised here.\n");
}

test_extras_10_1008_message_layouts :: () {
    section("1008. Message kinds - exercised by metaprogram");
    print("The embedded metaprogram switches on Message.kind in its event loop.\n");
}

test_extras_10_1009_build_options_subs :: () {
    section("1009. Build_Options sub-types - compile-time only");
    print("Build_Options is set via set_build_options at compile time.\n");
}


run_extras_10 :: () {
    test_extras_10_1000_nested_comments();
    test_extras_10_1001_operator_precedence();
    test_extras_10_1002_scope_visibility();
    test_extras_10_1003_foreign_bindings();
    test_extras_10_1004_atomics();
