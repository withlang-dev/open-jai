----------------------------------------------------------------
== 601. Manual struct serializer (via type_info introspection)
----------------------------------------------------------------

-- Vec2 / Vec3
vec2 -> PE6_Vec2 {x=1.5, y=2.5}
vec3 -> PE6_Vec3 {x=1.5, y=2.5, z=3.5}

-- RGBA
rgba -> PE6_RGBA {r=12, g=34, b=56, a=78}

-- Address / Person
addr -> PE6_Address {street="Main", city="Springfield", zip=42}
person -> PE6_Person {name="Alice", age=30, address=PE6_Address {street="Main", city="Springfield", zip=42}}

-- Company nested two-deep
company -> PE6_Company {name="Acme", founded=1900, boss=PE6_Person {name="Bob", age=50, address=PE6_Address {street="Side", city="Town", zip=99}}}

-- Network nested three-deep
net -> PE6_Network {label="net", primary=PE6_Company {name="A", founded=1, boss=PE6_Person {name="x", age=1, address=PE6_Address {street="s1", city="c1", zip=1}}}, backup=PE6_Company {name="B", founded=2, boss=PE6_Person {name="y", age=2, address=PE6_Address {street="s2", city="c2", zip=2}}}}

-- Many primitive
many -> PE6_Many_Primitive {a_bool=true, a_s8=-1, a_s16=2, a_s32=-3, a_s64=4, a_u8=5, a_u16=6, a_u32=7, a_u64=8, a_f32=1.5, a_f64=2.25, a_str="hi"}

-- Fixed array inside struct
deep -> PE6_Deep_Root {header="head", outer=PE6_Deep_Outer {title="outer", middle=PE6_Deep_Middle {label="mid", inner=PE6_Deep_Inner {n=10, f=1.5, s="x"}, count=4}, extra=PE6_Vec3 {x=1, y=2, z=3}}, rgba=PE6_RGBA {r=1, g=2, b=3, a=4}, nums=[10, 20, 30]}

-- Polymorphic structs
box-int -> PE6_Box {value=99}
box-str -> PE6_Box {value="ninety-nine"}
pair -> PE6_Pair {first=7, second="seven"}
triple -> Triple {first=1, second=2.5, third="three"}
quad -> Quad {a=1, b=2, c=3, d=4}

-- Enums in serialized output
color -> PE6_Color.GREEN
day -> PE6_Day.WED

----------------------------------------------------------------
== 602. Binary blob writer (memcpy round trip)
----------------------------------------------------------------

-- Round trip a Vec3
wrote=12 bytes
read=12 bytes
equal=true original={1.5, 2.5, 3.5} readback={1.5, 2.5, 3.5}

-- Round trip an RGBA
equal=true bytes_buf=[170, 187, 204, 221]

-- Compare bytes between two equal Vec3s
equal-bytes-when-values-equal=true

-- Compare bytes between two unequal Vec3s
equal-bytes-when-values-differ=false

-- Round trip a Many_Primitive (without the string)
scalars-equal=true

-- Round trip a PE6_Person (without strings since strings are pointers)
person-scalar-roundtrip=true

-- Round trip a PE6_Box(int)
box-int roundtrip equal=true original=12345 readback=12345

