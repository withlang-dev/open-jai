        view : [] PE6_RGBA = arr;
        PE6_print_pretty(view);
    }
}


// ============================================================================
// 618. Bigger struct tests for the serializer.
// ============================================================================

PE6_Big_A :: struct {
    a: int;
    b: int;
    c: int;
    d: int;
    e: int;
    f: int;
    g: int;
    h: int;
}

PE6_Big_B :: struct {
    one:   PE6_Big_A;
    two:   PE6_Big_A;
    three: PE6_Big_A;
}

PE6_Big_C :: struct {
    inner: PE6_Big_B;
    extra: PE6_Big_A;
}

PE6_test_big_struct_serialize :: () {
    section("618. Big structs serialized via reflection");

    a := PE6_Big_A.{1,2,3,4,5,6,7,8};
    print("  bigA = %\n", PE6_serialize_to_string(a));

    b := PE6_Big_B.{one=a, two=a, three=a};
    print("  bigB = %\n", PE6_serialize_to_string(b));

    c := PE6_Big_C.{inner=b, extra=a};
    print("  bigC = %\n", PE6_serialize_to_string(c));

    sub("Field walk recursive count");
    {
        s: PE6_Field_Stats;
        PE6_classify_recursive(type_info(PE6_Big_C), *s);
        PE6_print_stats("BigC (recursive)", s);
    }
}


// ============================================================================
// 619. Lots of polymorphic struct combinations to stress the serializer.
// ============================================================================

PE6_test_more_poly_structs :: () {
    section("619. More polymorphic struct combinations");

    sub("Stack of PE6_Box(int)");
    {
        st: PE6_Stack(PE6_Box(int), 4);
        PE6_stack_push(*st, .{value=1});
        PE6_stack_push(*st, .{value=2});
        PE6_stack_push(*st, .{value=3});
        for 0..st.count-1 {
            print("  stack[%]=%\n", it, st.data[it]);
        }
    }

    sub("Queue of Pair(int,string)");
    {
        q: PE6_Queue(PE6_Pair(int, string), 4);
        PE6_queue_push(*q, .{first=1, second="a"});
        PE6_queue_push(*q, .{first=2, second="b"});
        PE6_queue_push(*q, .{first=3, second="c"});
        while q.count > 0 {
            v, _ := PE6_queue_pop(*q);
            print("  popped %\n", v);
        }
    }

    sub("Ring of Triple(int,float,string)");
    {
        r: PE6_Ring(Triple(int, float, string), 3);
        PE6_ring_write(*r, .{first=1, second=1.5, third="one"});
        PE6_ring_write(*r, .{first=2, second=2.5, third="two"});
        PE6_ring_write(*r, .{first=3, second=3.5, third="three"});
        PE6_ring_write(*r, .{first=4, second=4.5, third="four"}); // overwrites 1
        for age: 0..r.count-1 {
            v, _ := PE6_ring_at_age(r, age);
            print("  age %: %\n", age, v);
        }
    }

    sub("Map(int, PE6_Box(string), 3)");
    {
        m: Map(int, PE6_Box(string), 3);
        PE6_map_put(*m, 1, .{value="one"});
        PE6_map_put(*m, 2, .{value="two"});
        PE6_map_put(*m, 3, .{value="three"});
        v, ok := PE6_map_get(*m, 2);
        print("  get 2 -> % ok=%\n", v, ok);
        v, ok  = PE6_map_get(*m, 99);
        print("  get 99 -> % ok=%\n", v, ok);
    }

    sub("Fixed_List of PE6_Vec3");
    {
        l: PE6_Fixed_List(PE6_Vec3, 4);
        PE6_fixed_list_add(*l, .{1,0,0});
        PE6_fixed_list_add(*l, .{0,1,0});
        PE6_fixed_list_add(*l, .{0,0,1});
        for 0..l.count-1 {
            print("  axis[%]=%\n", it, l.data[it]);
        }
    }
}


