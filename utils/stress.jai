  start year=2024-2-29 +-30d -> 2024-1-29
  start year=2024-2-29 +-1d -> 2024-2-28
  start year=2024-2-29 +0d -> 2024-2-29
  start year=2024-2-29 +1d -> 2024-3-1
  start year=2024-2-29 +30d -> 2024-3-30
  start year=2024-2-29 +365d -> 2025-2-28

