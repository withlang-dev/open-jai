----------------------------------------------------------------
== 715. Finite state machine recognizing 'abc' substring
----------------------------------------------------------------
  'abc' -> ACCEPT
  'aabc' -> ACCEPT
  'xabc' -> ACCEPT
  'ab' -> SEEN_AB
  'ac' -> START
  'ba' -> SEEN_A
  'abxc' -> START
  'abccba' -> ACCEPT
  'aaabbbccc' -> START
  'zzabczz' -> ACCEPT
  'ababc' -> ACCEPT
  'abab' -> SEEN_AB
  'abca' -> ACCEPT
  '' -> START
  'c' -> START
  'abcabc' -> ACCEPT

-- 715.a Step-by-step trace for 'aabcab'
  initial state = START
  step 0: START=>SEEN_A on 'a'
  step 1: SEEN_A=>SEEN_A on 'a'
  step 2: SEEN_A=>SEEN_AB on 'b'
  step 3: SEEN_AB=>ACCEPT on 'c'
  step 4: ACCEPT=>ACCEPT on 'a'
  step 5: ACCEPT=>ACCEPT on 'b'
  final = ACCEPT

