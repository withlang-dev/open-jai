----------------------------------------------------------------
== 244. Tiny char-class state machine
----------------------------------------------------------------
scanning 'abc 123 !!':
  switch from INIT to LETTER at 0
  switch from LETTER to SPACE at 3
  switch from SPACE to DIGIT at 4
  switch from DIGIT to SPACE at 7
  switch from SPACE to OTHER at 8
  final state = OTHER
scanning '12abc34 X':
  switch from INIT to DIGIT at 0
  switch from DIGIT to LETTER at 2
  switch from LETTER to DIGIT at 5
  switch from DIGIT to SPACE at 7
  switch from SPACE to LETTER at 8
  final state = LETTER
scanning ' hello world ':
  switch from INIT to SPACE at 0
  switch from SPACE to LETTER at 1
  switch from LETTER to SPACE at 6
  switch from SPACE to LETTER at 7
  switch from LETTER to SPACE at 12
  final state = SPACE
scanning '...':
  switch from INIT to OTHER at 0
  final state = OTHER
scanning 'a1b2c3':
  switch from INIT to LETTER at 0
  switch from LETTER to DIGIT at 1
  switch from DIGIT to LETTER at 2
  switch from LETTER to DIGIT at 3
  switch from DIGIT to LETTER at 4
  switch from LETTER to DIGIT at 5
  final state = DIGIT

