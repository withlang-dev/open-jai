  rpn('3 4 +') = 7 ok=true
  rpn('10 5 -') = 5 ok=true
  rpn('2 3 *') = 6 ok=true
  rpn('20 4 /') = 5 ok=true
  rpn('3 4 + 5 *') = 35 ok=true
  rpn('3 4 5 * +') = 23 ok=true
  rpn('10 2 3 + *') = 50 ok=true
  rpn('1 2 3 4 + + +') = 10 ok=true
  rpn('100 25 5 / -') = 95 ok=true
  rpn('5 1 2 + 4 * + 3 -') = 14 ok=true
  rpn('1 0 /') = 0 ok=false
  rpn('') = 0 ok=false
  rpn('1 +') = 0 ok=false
  rpn('abc') = 0 ok=false

