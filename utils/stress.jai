// ============================================================================
// Stress test - extras 2.
//
//
// addresses, current_workspace, source file paths, OS names, architecture
// ============================================================================


// ----------------------------------------------------------------------------
// Module imports used by extras 2 that the main file doesn't already provide.
// ----------------------------------------------------------------------------

Unicode :: #import "Unicode";

Crc        :: #import "Crc";
md5_mod    :: #import "md5";
xxh        :: #import "xxHash";

IntroSort  :: #import "IntroSort";
Radix      :: #import "RadixSort";

Pool_Mod     :: #import "Pool";
Flat_Pool_Mod:: #import "Flat_Pool";

Process_Mod  :: #import "Process";


// ----------------------------------------------------------------------------
// Local helpers for deterministic output of float-bearing types.
// ----------------------------------------------------------------------------

fp :: (x: float, w: int = -1, trail: int = 3) -> FormatFloat #expand {
    return formatFloat(x, width=w, trailing_width=trail);
}

fp64 :: (x: float64, w: int = -1, trail: int = 3) -> FormatFloat #expand {
    return formatFloat(x, width=w, trailing_width=trail);
}

print_vec2 :: (label: string, v: Vector2) {
    print("  % = (%, %)\n", label, fp(v.x), fp(v.y));
}

print_vec3 :: (label: string, v: Vector3) {
    print("  % = (%, %, %)\n", label, fp(v.x), fp(v.y), fp(v.z));
}

print_vec4 :: (label: string, v: Vector4) {
    print("  % = (%, %, %, %)\n", label, fp(v.x), fp(v.y), fp(v.z), fp(v.w));
}

print_quat :: (label: string, q: Quaternion) {
    print("  % = (x=%, y=%, z=%, w=%)\n",
        label, fp(q.x), fp(q.y), fp(q.z), fp(q.w));
}

print_mat3 :: (label: string, m: Matrix3) {
    print("  %:\n", label);
    print("    [ %, %, % ]\n", fp(m._11), fp(m._12), fp(m._13));
    print("    [ %, %, % ]\n", fp(m._21), fp(m._22), fp(m._23));
    print("    [ %, %, % ]\n", fp(m._31), fp(m._32), fp(m._33));
}

print_mat4 :: (label: string, m: Matrix4) {
    print("  %:\n", label);
    print("    [ %, %, %, % ]\n", fp(m._11), fp(m._12), fp(m._13), fp(m._14));
    print("    [ %, %, %, % ]\n", fp(m._21), fp(m._22), fp(m._23), fp(m._24));
    print("    [ %, %, %, % ]\n", fp(m._31), fp(m._32), fp(m._33), fp(m._34));
    print("    [ %, %, %, % ]\n", fp(m._41), fp(m._42), fp(m._43), fp(m._44));
}

// Print a byte buffer as hex, for hash digests.
hex_of_bytes :: (bytes: [] u8) -> string {
    builder: String_Builder;
    for bytes {
        print_to_builder(*builder, "%", formatInt(it, base=16, minimum_digits=2));
    }
    return builder_to_string(*builder);
}


// ============================================================================
// 100. File I/O via the File module (write + read a deterministic blob).
// ============================================================================

test_file_io :: () {
    section("100. File I/O (write_entire_file / read_entire_file)");

    DIR :: ".tmp_compat_check";
    make_directory_if_it_does_not_exist(DIR);
    print("directory '%' created or already existed\n", DIR);

    PATH :: ".tmp_compat_check/blob_a.bin";
    payload := "this stress extras2 - line 0\nline 1\nline 2\nline 3\n";
    print("payload count = %\n", payload.count);

    ok := write_entire_file(PATH, payload);
    print("write_entire_file ok = %\n", ok);

    sub("Read back the same file and verify length + content");
    data, success := read_entire_file(PATH);
    print("read_entire_file success = % count = %\n", success, data.count);
    if data.count == payload.count {
        print("byte-count match = true\n");
    } else {
        print("byte-count match = false\n");
    }
    same := (data == payload);
    print("content match = %\n", same);

    sub("First 20 bytes (printed as content, deterministic because the input is)");
    first := data;
    if first.count > 20 first.count = 20;
    print("first-20 = '%'\n", first);

    sub("Last 16 bytes");
    last := data;
    if last.count > 16 {
        last.data += last.count - 16;
        last.count = 16;
    }
    print("last-16  = '%'\n", last);

    sub("Overwrite the file with a different payload and re-read");
    payload2 := "second pass - shorter\n";
    ok2 := write_entire_file(PATH, payload2);
    print("write second time ok = %\n", ok2);
    data2, success2 := read_entire_file(PATH);
    print("re-read success = % count = %\n", success2, data2.count);
    print("re-read content = '%'\n", data2);

    sub("Sum of bytes of the file content");
    sum := 0;
    for d: cast([] u8) data2 sum += d;
    print("byte-sum = %\n", sum);

    sub("file_delete and re-read should fail");
    file_delete(PATH);
    data3, success3 := read_entire_file(PATH, log_errors=false);
    print("after delete: read success = % count = %\n", success3, data3.count);
}


// ============================================================================
// 101. File I/O using the file_open / file_write / file_read API.
// ============================================================================

test_file_open_api :: () {
    section("101. File API: file_open / file_write / file_length / file_read");

    DIR  :: ".tmp_compat_check";
    PATH :: ".tmp_compat_check/blob_b.bin";
    make_directory_if_it_does_not_exist(DIR);

    {
        f, ok := file_open(PATH, for_writing=true, keep_existing_content=false);
        print("file_open for_writing ok = %\n", ok);
        chunk := "abc-DEF-123\n";
        wok := file_write(*f, chunk);
        print("file_write chunk ok = %\n", wok);
        more := "tail end\n";
        wok2 := file_write(*f, more);
        print("file_write more  ok = %\n", wok2);
        file_close(*f);
    }

    {
        f, ok := file_open(PATH, for_writing=false);
        print("file_open for_reading ok = %\n", ok);

        len := file_length(f);
        print("file_length = %\n", len);

        buffer := alloc(len);
        defer free(buffer);

        rok := file_read(f, buffer, len);
        print("file_read ok = %\n", rok);

        s: string;
        s.data  = buffer;
        s.count = len;
        print("contents = '%'\n", s);

        file_close(*f);
    }

    file_delete(PATH);
    print("deleted blob_b.bin\n");
}


// ============================================================================
// 102. Vector2 / Vector3 / Vector4 basic operations.
// ============================================================================

test_math_vectors :: () {
    section("102. Math: Vector2/3/4 operations");

    sub("Vector2 add/sub/scale/dot/length");
    a2 := Vector2.{x=3, y=4};
    b2 := Vector2.{x=1, y=2};
    print_vec2("a2",   a2);
    print_vec2("b2",   b2);
    print_vec2("a+b",  a2 + b2);
    print_vec2("a-b",  a2 - b2);
    print_vec2("a*2",  a2 * 2.0);
    print("  dot(a, b)        = %\n", fp(dot_product(a2, b2)));
    print("  length(a2)       = %\n", fp(length(a2)));
    print("  length_sq(a2)    = %\n", fp(length_squared(a2)));

    sub("Vector3 dot/cross/length");
    a3 := Vector3.{x=1, y=0, z=0};
    b3 := Vector3.{x=0, y=1, z=0};
    print_vec3("a3 (X axis)", a3);
    print_vec3("b3 (Y axis)", b3);
    print("  dot(a, b)        = %\n", fp(dot_product(a3, b3)));
    c3 := cross_product(a3, b3);
    print_vec3("cross(a, b)", c3);  // Should be Z axis (0, 0, 1)

    sub("Vector3 normalize");
    d3 := Vector3.{x=3, y=0, z=4};   // length 5
    print_vec3("d3", d3);
    print("  length(d3)       = %\n", fp(length(d3)));
    n3 := unit_vector(d3);
    print_vec3("normalize(d3)", n3);
    print("  length(n3)       = %\n", fp(length(n3)));

    sub("Vector4 ops");
    a4 := Vector4.{x=1, y=2, z=3, w=4};
    b4 := Vector4.{x=5, y=6, z=7, w=8};
    print_vec4("a4", a4);
    print_vec4("b4", b4);
    print_vec4("a+b", a4 + b4);
    print("  dot(a4, b4)      = %\n", fp(dot_product(a4, b4)));

    sub("lerp on Vector3 (t=0.25, 0.5, 0.75)");
    p0 := Vector3.{x=0,  y=0,  z=0};
    p1 := Vector3.{x=10, y=20, z=30};
    print_vec3("lerp(t=0.25)", lerp(p0, p1, 0.25));
    print_vec3("lerp(t=0.50)", lerp(p0, p1, 0.5));
    print_vec3("lerp(t=0.75)", lerp(p0, p1, 0.75));

    sub("Vector3 overlays: xy / yz / xyz aliases");
    v := Vector4.{x=10, y=20, z=30, w=40};
    print_vec2("v.xy",  v.xy);
    print_vec2("v.yz",  v.yz);
    print_vec2("v.zw",  v.zw);
    print_vec3("v.xyz", v.xyz);
    print_vec3("v.yzw", v.yzw);
}


// ============================================================================
// 103. Math: Matrix3 / Matrix4 / Quaternion operations.
// ============================================================================

test_math_matrix :: () {
    section("103. Math: Matrix3/4 and Quaternion");

    sub("Matrix3 identity multiplied by itself stays identity");
    m3 := Matrix3_Identity;
    print_mat3("identity", m3);

    sub("Matrix3 manual construction and indexing");
    m: Matrix3;
    m._11 = 1; m._12 = 2; m._13 = 3;
    m._21 = 4; m._22 = 5; m._23 = 6;
    m._31 = 7; m._32 = 8; m._33 = 9;
    print_mat3("m", m);
    print("  m.coef[1][2]      = %\n", fp(m.coef[1][2]));
    print("  m.v[0]            = (%, %, %)\n",
        fp(m.v[0].x), fp(m.v[0].y), fp(m.v[0].z));

    sub("Matrix4 identity");
    m4 := Matrix4_Identity;
    print_mat4("Matrix4_Identity", m4);

    sub("Quaternion identity properties");
    qi := Quaternion.{x=0, y=0, z=0, w=1};
    print_quat("identity",        qi);
    print("  dot(qi, qi)       = %\n", fp(dot_product(qi, qi)));
    print("  length(qi)        = %\n", fp(length(qi)));

    sub("Quaternion from axis-angle (Z axis, 90 deg)");
    q: Quaternion;
    axis := Vector3.{x=0, y=0, z=1};
    set_from_axis_and_angle(*q, axis, PI / 2.0);
    print_quat("q", q);
    print("  length(q)         = %\n", fp(length(q)));

    sub("Quaternion lerp");
    qb := Quaternion.{x=0, y=0, z=0, w=1};
    qm := lerp(qb, q, 0.5);
    print_quat("lerp(0.5)", qm);
    print("  length(lerp 0.5)  = %\n", fp(length(qm)));

    sub("Quaternion slerp (should preserve unit length)");
    qs := slerp(qb, q, 0.5);
    print_quat("slerp(0.5)", qs);
    print("  length(slerp 0.5) = %\n", fp(length(qs)));

    sub("get_axis_and_angle of axis-angle quaternion (recover original)");
    ax, ay, az, theta := get_axis_and_angle(q);
    print("  recovered axis = (%, %, %)\n",
        fp64(ax), fp64(ay), fp64(az));
    print("  recovered angle = %\n", fp64(theta));
}


// ============================================================================
// 104. Math: clamp, lerp, sqrt, pow, sin/cos, abs.
// ============================================================================

test_math_scalar_more :: () {
    section("104. Math: scalar functions (sqrt/pow/sin/cos/lerp/clamp)");

    print("sqrt(2)              = %\n", fp64(sqrt(2.0)));
    print("sqrt(9)              = %\n", fp64(sqrt(9.0)));
    print("pow(2, 10)           = %\n", fp64(pow(2.0, 10.0)));
    print("pow(2, 0.5)          = %\n", fp64(pow(2.0, 0.5)));
    print("sin(0)               = %\n", fp64(sin(0.0)));
    print("cos(0)               = %\n", fp64(cos(0.0)));
    print("sin(PI/2)            = %\n", fp64(sin(PI64 / 2.0)));
    print("cos(PI)              = %\n", fp64(cos(PI64)));
    print("abs(-3.5)            = %\n", fp64(abs(-3.5)));
    print("abs(3.5)             = %\n", fp64(abs(3.5)));

    sub("lerp scalars");
    print("lerp(0, 10, 0)       = %\n", fp(lerp(cast(float) 0, 10, 0)));
    print("lerp(0, 10, 0.25)    = %\n", fp(lerp(cast(float) 0, 10, 0.25)));
    print("lerp(0, 10, 1)       = %\n", fp(lerp(cast(float) 0, 10, 1)));

    sub("clamp via Basic.clamp");
    c1 := clamp(15, 0, 10);
    c2 := clamp(-5, 0, 10);
    c3 := clamp(5,  0, 10);
    print("clamp(15, 0, 10)     = %\n", c1);
    print("clamp(-5, 0, 10)     = %\n", c2);
    print("clamp( 5, 0, 10)     = %\n", c3);

    sub("Square / min / max");
    print("square(7)            = %\n", square(7));
    print("min(3, 4)            = %\n", min(3, 4));
    print("max(3, 4)            = %\n", max(3, 4));
}


// ============================================================================
// 105. Hash module: sdbm_hash / fnv1a_hash on fixed inputs.
// ============================================================================

test_hash_module :: () {
    section("105. Hash module (sdbm_hash, fnv1a_hash) on fixed inputs");

    Hash :: #import "Hash";

    s1 := "hello world";
    s2 := "Jai this test";
    s3 := "";
    s4 := "abc";

    print("sdbm_hash('%') = %\n", s1, Hash.sdbm_hash(s1.data, s1.count));
    print("sdbm_hash('%') = %\n", s2, Hash.sdbm_hash(s2.data, s2.count));
    print("sdbm_hash('%') = %\n", s3, Hash.sdbm_hash(s3.data, s3.count));
    print("sdbm_hash('%') = %\n", s4, Hash.sdbm_hash(s4.data, s4.count));

    sub("fnv1a_hash on the same inputs");
    print("fnv1a('%') = %\n", s1, Hash.fnv1a_hash(s1.data, s1.count));
    print("fnv1a('%') = %\n", s2, Hash.fnv1a_hash(s2.data, s2.count));
    print("fnv1a('%') = %\n", s3, Hash.fnv1a_hash(s3.data, s3.count));
    print("fnv1a('%') = %\n", s4, Hash.fnv1a_hash(s4.data, s4.count));

    sub("get_hash on strings");
    print("get_hash('%') = %\n", s1, Hash.get_hash(s1));
    print("get_hash('%') = %\n", s2, Hash.get_hash(s2));
    print("get_hash('%') = %\n", s4, Hash.get_hash(s4));
}


// ============================================================================
// 106. CRC64.
// ============================================================================

test_crc :: () {
    section("106. Crc.jai (crc64)");

    inputs := string.[
        "",
        "a",
        "abc",
        "hello",
        "The quick brown fox jumps over the lazy dog",
        "this stress extras2"
    ];

    for s: inputs {
        h := Crc.crc64(s);
        print("crc64('%') = %\n", s, formatInt(h, base=16, minimum_digits=16));
    }
}


// ============================================================================
// 107. xxHash (XXH32 and XXH64 via the streaming API).
// ============================================================================

test_xxhash :: () {
    section("107. xxHash XXH32 / XXH64");

    inputs := string.[
        "",
        "a",
        "abc",
        "hello world",
        "Jai compiler compatibility stress test - second part"
    ];

    sub("XXH32 with seed=0");
    for s: inputs {
        state: xxh.XXH32_state_t;
        xxh.XXH32_reset(*state, 0);
        xxh.XXH32_update(*state, s.data, cast(u32) s.count);
        h := xxh.XXH32_digest(*state);
        print("xxh32('%') = %\n", s, formatInt(h, base=16, minimum_digits=8));
    }

    sub("XXH64 with seed=0");
    for s: inputs {
        st64: xxh.XXH64_state_t;
        xxh.XXH64_reset(*st64, 0);
        xxh.XXH64_update(*st64, s.data, cast(u32) s.count);
        h64 := xxh.XXH64_digest(*st64);
        print("xxh64('%') = %\n", s, formatInt(h64, base=16, minimum_digits=16));
    }

    sub("XXH32 with seed=0xCAFEBABE");
    for s: inputs {
        state: xxh.XXH32_state_t;
        xxh.XXH32_reset(*state, 0xCAFE_BABE);
        xxh.XXH32_update(*state, s.data, cast(u32) s.count);
        h := xxh.XXH32_digest(*state);
        print("xxh32seeded('%') = %\n", s, formatInt(h, base=16, minimum_digits=8));
    }
}


