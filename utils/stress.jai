    combo 0: [0, 1, 2]
  C(4, 2) -> count=6
    combo 0: [0, 1]
    combo 1: [0, 2]
    combo 2: [0, 3]
    combo 3: [1, 2]
    combo 4: [1, 3]
    combo 5: [2, 3]
  C(5, 3) -> count=10
    combo 0: [0, 1, 2]
    combo 1: [0, 1, 3]
    combo 2: [0, 1, 4]
    combo 3: [0, 2, 3]
    combo 4: [0, 2, 4]
    combo 5: [0, 3, 4]
    combo 6: [1, 2, 3]
    combo 7: [1, 2, 4]
    combo 8: [1, 3, 4]
    combo 9: [2, 3, 4]
  C(6, 4) -> count=15
    combo 0: [0, 1, 2, 3]
    combo 1: [0, 1, 2, 4]
    combo 2: [0, 1, 2, 5]
    combo 3: [0, 1, 3, 4]
    combo 4: [0, 1, 3, 5]
    combo 5: [0, 1, 4, 5]
    combo 6: [0, 2, 3, 4]
    combo 7: [0, 2, 3, 5]
    combo 8: [0, 2, 4, 5]
    combo 9: [0, 3, 4, 5]
    combo 10: [1, 2, 3, 4]
    combo 11: [1, 2, 3, 5]
    combo 12: [1, 2, 4, 5]
    combo 13: [1, 3, 4, 5]
    combo 14: [2, 3, 4, 5]

