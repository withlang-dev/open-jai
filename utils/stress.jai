== 703. More `using` patterns
----------------------------------------------------------------

-- 703.a `using` chain through struct of structs
o.px=100 o.py=200 o.cr=10 o.cg=20 o.cb=30 o.label=swatch
via .inner.p.px = 100
via .inner.c.cr = 10

-- 703.b `using` with anonymous nested struct
bb.x=1 bb.y=2 bb.z=3
bb.hi_x=10 bb.hi_y=20 bb.hi_z=30 bb.tag=box-A

-- 703.c `using` on a procedure parameter with #as
  mixin id=77 name='widget'
  via using h: id=77 name='widget' value=999

-- 703.d `using` on a member that's a polymorphic struct
o.head=555 o.count=8 o.tag=poly-using
o3.head='alpha-head' o3.count=4 o3.tag=poly-using-str

