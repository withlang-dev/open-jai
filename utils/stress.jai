// ============================================================================
// Stress test - extras 9. Adds sections 900..999.
//
// ============================================================================


// ----------------------------------------------------------------------------
// 900. All pairwise integer-to-integer casts .
// ----------------------------------------------------------------------------

test_extras_9_900_int_casts :: () {
    section("900. All pairwise int-to-int cast tables (no_check)");

    sub("u8 source");
    src_u8: u8 = 200;
    print("u8(200)  -> u16=%, u32=%, u64=%\n",
        cast(u16) src_u8, cast(u32) src_u8, cast(u64) src_u8);
    print("u8(200)  -> s8(no_check)=%, s16=%, s32=%, s64=%\n",
        cast,no_check(s8) src_u8, cast(s16) src_u8,
        cast(s32) src_u8, cast(s64) src_u8);

    sub("s8 source");
    src_s8: s8 = -100;
    print("s8(-100) -> s16=%, s32=%, s64=%\n",
        cast(s16) src_s8, cast(s32) src_s8, cast(s64) src_s8);
    print("s8(-100) -> u8(no_check)=%, u16(no_check)=%, u32(no_check)=%, u64(no_check)=%\n",
        cast,no_check(u8)  src_s8,
        cast,no_check(u16) src_s8,
        cast,no_check(u32) src_s8,
        cast,no_check(u64) src_s8);

    sub("u16 source");
    src_u16: u16 = 50_000;
    print("u16(50000) -> u32=%, u64=%, s32=%, s64=%\n",
        cast(u32) src_u16, cast(u64) src_u16,
        cast(s32) src_u16, cast(s64) src_u16);

    sub("s16 source");
    src_s16: s16 = -20_000;
    print("s16(-20000) -> s32=%, s64=%, u16(no_check)=%, u32(no_check)=%\n",
        cast(s32) src_s16, cast(s64) src_s16,
        cast,no_check(u16) src_s16,
        cast,no_check(u32) src_s16);

    sub("u32 source");
    src_u32: u32 = 4_000_000_000;
    print("u32(4e9) -> u64=%, s64=%, s32(no_check)=%, u16(no_check)=%\n",
        cast(u64) src_u32, cast(s64) src_u32,
        cast,no_check(s32) src_u32,
        cast,no_check(u16) src_u32);

    sub("s32 source");
    src_s32: s32 = -2_000_000_000;
    print("s32(-2e9) -> s64=%, u32(no_check)=%\n",
        cast(s64) src_s32, cast,no_check(u32) src_s32);

    sub("u64 source");
    src_u64: u64 = 18_000_000_000_000_000_000;
    print("u64(big) -> s64(no_check)=%, u32(no_check)=%\n",
        cast,no_check(s64) src_u64,
        cast,no_check(u32) src_u64);
}


// ----------------------------------------------------------------------------
// 901. Float-int conversions across the range.
// ----------------------------------------------------------------------------

test_extras_9_901_float_int :: () {
    section("901. Float-int conversions ");

    inputs := float.[0.0, 0.5, 0.999, 1.0, 1.5, 2.5, -0.5, -1.5, -2.5,
                     127.0, -128.0, 32767.0, -32768.0, 1.0e9, -1.0e9];

    for f: inputs {
        as_int  := cast(int) f;
        back    := cast(float) as_int;
        print("  f=%  cast(int)=%  round-trip=%\n", f, as_int, back);
    }

    sub("Float to integer rounds toward zero (truncation)");
    print("3.99 -> int = %\n", cast(int) 3.99);
    print("-3.99 -> int = %\n", cast(int) -3.99);
    print("0.5 -> int = %\n", cast(int) 0.5);
    print("-0.5 -> int = %\n", cast(int) -0.5);

    sub("Float64 precision");
    a: float64 = 0.1;
    b: float64 = 0.2;
    print("0.1+0.2 (float64) = %\n", formatFloat(a+b, trailing_width=17));
    print("equal to 0.3?     = %\n", (a+b) == 0.3);
}


// ----------------------------------------------------------------------------
// 902. Exhaustive bitwise ops across u8 inputs (subset).
// ----------------------------------------------------------------------------

test_extras_9_902_bitwise :: () {
    section("902. Bitwise ops on a chosen grid");

    inputs := u8.[0x00, 0x01, 0x55, 0xAA, 0xF0, 0x0F, 0xFF, 0x80];

    for a: inputs {
        for b: inputs {
            print("a=% b=% a&b=% a|b=% a^b=%\n",
                formatInt(a, base=2, minimum_digits=8),
                formatInt(b, base=2, minimum_digits=8),
                formatInt(a & b, base=2, minimum_digits=8),
                formatInt(a | b, base=2, minimum_digits=8),
                formatInt(a ^ b, base=2, minimum_digits=8));
        }
    }

    sub("Shifts");
    for s: 0..7 {
        v: u8 = 0b1011_0011;
        print("v=% v>>%=% v<<%=%\n",
            formatInt(v, base=2, minimum_digits=8), s,
            formatInt(v >> s, base=2, minimum_digits=8), s,
            formatInt(v << s, base=2, minimum_digits=8));
    }
}


// ----------------------------------------------------------------------------
// 903. Integer division and modulo across many input pairs.
// ----------------------------------------------------------------------------

test_extras_9_903_divmod :: () {
    section("903. Integer div/mod across signed inputs");

    a_vals := int.[-13, -1, 0, 1, 7, 13];
    b_vals := int.[-5, -1, 1, 5];

    for a: a_vals {
        for b: b_vals {
            print("a=% b=% a/b=% a-mod-b=% (b!=0)\n", a, b, a/b, a % b);
        }
    }
}


// ----------------------------------------------------------------------------
// 904. Print format coverage matrix.
// ----------------------------------------------------------------------------

test_extras_9_904_format :: () {
    section("904. Print formatting matrix");

    sub("Int in various bases");
    for n: int.[0, 1, 16, 255, 256, 1024, 1_000_000, -1, -255] {
        print("n=% bin=% oct=% hex=% pad8=%\n",
            n,
            formatInt(n, base=2),
            formatInt(n, base=8),
            formatInt(n, base=16),
            formatInt(n, base=10, minimum_digits=8));
    }

    sub("Float with width and trailing_width");
    for f: float.[0.0, 1.0, 3.14159, 1234.5678, 0.0001, 1.0e10] {
        print("f=% (def)  (w=10,t=3)=[%]  (w=20,t=10)=[%]\n",
            f,
            formatFloat(f, width=10, trailing_width=3),
            formatFloat(f, width=20, trailing_width=10));
    }

    sub("Float in scientific and shortest modes");
    for f: float.[0.0, 1.0, 3.14159, 0.00001, 1.0e15] {
        print("f=%  sci=%  short=%\n",
            f,
            formatFloat(f, mode=.SCIENTIFIC),
            formatFloat(f, mode=.SHORTEST));
    }

    sub("Comma-separated integers");
    print("1234567890 commas=% spaces=%\n",
        formatInt(1234567890, base=10, digits_per_comma=3, comma_string=","),
        formatInt(1234567890, base=10, digits_per_comma=3, comma_string=" "));

    sub("Padding chars");
    print("hex pad='0' width=8: %\n",
        formatInt(0xAB, base=16, minimum_digits=8, padding=#char "0"));
    print("hex pad=' ' width=8: '%'\n",
        formatInt(0xAB, base=16, minimum_digits=8, padding=#char " "));
    print("hex pad='*' width=8: %\n",
        formatInt(0xAB, base=16, minimum_digits=8, padding=#char "*"));

    sub("Argument indexing");
    print("%1 %2 %3 %1 %3 %2\n", "A", "B", "C");
    print("%0 %0 %0\n", "X", "Y", "Z");          // each %0 consumes next arg
    print("%1 -- %1 -- %1\n", "same");           // %1 reused
}


// ----------------------------------------------------------------------------
// 905. Power-of-two / log2 / popcount patterns by hand.
// ----------------------------------------------------------------------------

popcount_u8 :: (n_in: u8) -> int {
    n := n_in;
    c := 0;
    while n != 0 {
        c += cast(int) (n & 1);
        n >>= 1;
    }
    return c;
}

trailing_zeros_u8 :: (n_in: u8) -> int {
    if n_in == 0  return 8;
    n := n_in;
    c := 0;
    while (n & 1) == 0 {
        c += 1;
        n >>= 1;
    }
    return c;
}

test_extras_9_905_bittricks :: () {
    section("905. Bit-twiddling helpers ");

    sub("popcount over u8 0..15");
    for n: 0..15  print("  popcount(%) = %\n", n, popcount_u8(cast(u8) n));

    sub("trailing zeros over u8 0..16");
    for n: 0..16  print("  ctz(%) = %\n", n, trailing_zeros_u8(cast(u8) n));

    sub("is power of two (n & (n-1) == 0) over 0..32");
    for n: 0..32 {
        is_pow := n > 0 && (n & (n-1)) == 0;
        print("  %: %\n", n, is_pow);
    }
}


