== 562. Reverse strings and integers
----------------------------------------------------------------
  reverse('') = ''
  reverse('a') = 'a'
  reverse('ab') = 'ba'
  reverse('abc') = 'cba'
  reverse('abcd') = 'dcba'
  reverse('hello') = 'olleh'
  reverse('racecar') = 'racecar'
  reverse('Jai') = 'iaJ'
  reverse(0) = 0
  reverse(1) = 1
  reverse(9) = 9
  reverse(10) = 1
  reverse(12) = 21
  reverse(123) = 321
  reverse(1234) = 4321
  reverse(100) = 1
  reverse(1000) = 1
  reverse(-42) = -24
  reverse(-100) = -1

