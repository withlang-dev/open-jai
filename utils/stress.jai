  enc=00112233445566778899aabbccddeeff
  ok=true count=16
  match=true

----------------------------------------------------------------
== 615. LRU cache over fixed-size circular buffer
----------------------------------------------------------------

-- LRU(int,string,3): basic operations
  put 1=one  evicted=false size=1
  put 2=two  evicted=false size=2
  put 3=three evicted=false size=3
  get 1 -> 'one' ok=true
  put 4=four evicted_key=2 was_evicted=true
  get 1 -> 'one' ok=true
  get 2 -> '' ok=false
  get 3 -> 'three' ok=true
  get 4 -> 'four' ok=true

-- LRU(string,int,2): more rotations
  touch 'a' ok=true
  put 'c'=3 evicted='b' was=true
  get 'a' -> 1 ok=true
  get 'b' -> 0 ok=false
  get 'c' -> 3 ok=true

-- LRU(int,int,4) workload
  after put 1: size=1 next_tick=2
  after put 2: size=2 next_tick=3
  after put 3: size=3 next_tick=4
  after put 4: size=4 next_tick=5
  after put 5: size=4 next_tick=6
  after put 1: size=4 next_tick=7
  after put 6: size=4 next_tick=8
  after put 2: size=4 next_tick=9
  after put 7: size=4 next_tick=10
  after put 1: size=4 next_tick=11
  after put 8: size=4 next_tick=12
    get 1 -> 10 ok=true
    get 2 -> 20 ok=true
    get 3 -> 0 ok=false
    get 4 -> 0 ok=false
    get 5 -> 0 ok=false
    get 6 -> 0 ok=false
    get 7 -> 70 ok=true
    get 8 -> 80 ok=true

