    x: [..] int;
    array_add(*x, 1);
    return x.count;
}
N :: #run runtime_only();
main :: () { print("%\n", N); }
SRC},

// ===========================================================================
// SECTION CK. Import / load failures.
// ===========================================================================

.{ "import with empty string", #string SRC
#import "";
