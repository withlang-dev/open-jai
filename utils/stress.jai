// ============================================================================
// 154. Polymorphic procedure with #modify guard.
// ============================================================================

double_it :: (x: $T) -> T
#modify {
    if T == int    return true;
    if T == s32    return true;
    if T == s64    return true;
    if T == float  return true;
    if T == float64 return true;
    return false;
} {
    return x + x;
}

test_modify_guard :: () {
    section("154. Polymorphic procedure with #modify guard (numeric only)");

    print("double_it(int 7)        = %\n", double_it(7));
    print("double_it(s32 100)      = %\n", double_it(cast(s32) 100));
    print("double_it(float 2.5)    = %\n", fp(double_it(cast(float) 2.5), trail=3));
    print("double_it(float64 4.5)  = %\n", fp64(double_it(cast(float64) 4.5), trail=3));
}


// ============================================================================
// 155. Variadic procedure: print with our own framing.
// ============================================================================

my_log :: (level: string, args: ..Any) {
    print("[%] ", level);
    for args {
        if it_index > 0 print(" ");
        print("%", it);
    }
    print("\n");
}

test_variadic :: () {
    section("155. Variadic procedures");

    my_log("INFO",  "loading", 42, "items");
    my_log("WARN",  "low memory");
    my_log("ERROR", "failed", "to", "open", "file", 3);
    my_log("DEBUG", 1, 2, 3, 4, 5, 6, 7);
    my_log("TRACE");
}


// ============================================================================
// 156. Higher-order function composition.
// ============================================================================

Func :: #type (int) -> int;

inc1 :: (x: int) -> int { return x + 1; }
inc5 :: (x: int) -> int { return x + 5; }
neg  :: (x: int) -> int { return -x; }
sqr  :: (x: int) -> int { return x * x; }

apply :: (f: Func, xs: [] int) -> [..] int {
    out: [..] int;
    for xs array_add(*out, f(it));
    return out;
}

apply_chain :: (xs: [] int, fns: [] Func) -> [..] int {
    out: [..] int;
    for xs {
        v := it;
        for f: fns v = f(v);
        array_add(*out, v);
    }
    return out;
}

test_higher_order :: () {
    section("156. Higher-order: function arrays and chained application");

    data := int.[-3, -1, 0, 1, 2, 3, 5];
    view: [] int = data;

    sub("apply(inc1)");
    a := apply(inc1, view);
    defer array_free(a);
    print("%\n", a);

    sub("apply(sqr)");
    b := apply(sqr, view);
    defer array_free(b);
    print("%\n", b);

    sub("apply(neg)");
    c := apply(neg, view);
    defer array_free(c);
    print("%\n", c);

    sub("apply chain: x -> inc5 -> sqr -> neg");
    chain := Func.[inc5, sqr, neg];
    chain_view: [] Func = chain;
    r := apply_chain(view, chain_view);
    defer array_free(r);
    print("%\n", r);
}


// ============================================================================
// 157. RPN (postfix) calculator.
// ============================================================================

rpn_eval :: (expr: string) -> float64 {
    stack: [..] float64;
    defer array_free(stack);

    // Tokenize on whitespace
    i := 0;
    while i < expr.count {
        // skip space
        while i < expr.count && (expr[i] == #char " " || expr[i] == #char "\t") i += 1;
        if i >= expr.count break;

        start := i;
        while i < expr.count && expr[i] != #char " " && expr[i] != #char "\t" i += 1;
        tok: string;
        tok.data  = expr.data + start;
        tok.count = i - start;

        if tok == "+" {
            if stack.count >= 2 {
                b := stack[stack.count - 1];
                a := stack[stack.count - 2];
                stack.count -= 2;
                array_add(*stack, a + b);
            }
        } else if tok == "-" {
            if stack.count >= 2 {
                b := stack[stack.count - 1];
                a := stack[stack.count - 2];
                stack.count -= 2;
                array_add(*stack, a - b);
            }
        } else if tok == "*" {
            if stack.count >= 2 {
                b := stack[stack.count - 1];
                a := stack[stack.count - 2];
                stack.count -= 2;
                array_add(*stack, a * b);
            }
        } else if tok == "/" {
            if stack.count >= 2 {
                b := stack[stack.count - 1];
                a := stack[stack.count - 2];
                stack.count -= 2;
                if b == 0 array_add(*stack, 0);
                else      array_add(*stack, a / b);
            }
        } else {
            v, ok := PE2_str_to_f64(tok);
            _ = ok;
            array_add(*stack, v);
        }
    }

    if stack.count == 0 return 0;
    return stack[stack.count - 1];
}

test_rpn :: () {
    section("157. RPN (postfix) calculator");

    inputs := string.[
        "1 2 +",
        "3 4 +",
        "1 2 3 + +",
        "2 3 4 + *",      // 2 * (3 + 4) = 14
        "5 1 2 + 4 * + 3 -",  // 5 + ((1+2)*4) - 3 = 14
        "10 2 /",
        "10 0 /",          // div-by-zero -> 0
        "100",
    ];
    for s: inputs {
        v := rpn_eval(s);
        print("rpn('%') = %\n", s, fp64(v, trail=3));
    }
}


// ============================================================================
// 158. Polymorphic Vec(N) for arbitrary fixed N.
// ============================================================================

Vec :: struct(N: int) {
    data: [N] float;
}

vec_add :: (a: Vec($N), b: Vec(N)) -> Vec(N) {
    r: Vec(N);
    for i: 0..N-1 r.data[i] = a.data[i] + b.data[i];
    return r;
}

vec_dot :: (a: Vec($N), b: Vec(N)) -> float {
    s: float = 0;
    for i: 0..N-1 s += a.data[i] * b.data[i];
    return s;
}

vec_scale :: (a: Vec($N), s: float) -> Vec(N) {
    r: Vec(N);
    for i: 0..N-1 r.data[i] = a.data[i] * s;
    return r;
}

vec_print :: (label: string, v: Vec($N)) {
    print("  % = [", label);
    for i: 0..N-1 {
        if i > 0 print(", ");
        print("%", fp(v.data[i], trail=2));
    }
    print("]\n");
}

test_polyvec :: () {
    section("158. Polymorphic Vec(N) for arbitrary fixed N");

    v3a: Vec(3);
    v3a.data = .[1, 2, 3];
    v3b: Vec(3);
    v3b.data = .[4, 5, 6];
    vec_print("v3a", v3a);
    vec_print("v3b", v3b);
    vec_print("v3a+v3b", vec_add(v3a, v3b));
    print("  v3a . v3b = %\n", fp(vec_dot(v3a, v3b), trail=2));
    vec_print("v3a * 2.5", vec_scale(v3a, 2.5));

    sub("Vec(5)");
    v5a: Vec(5);
    v5a.data = .[1, 1, 1, 1, 1];
    v5b: Vec(5);
    v5b.data = .[2, 3, 4, 5, 6];
    vec_print("v5a", v5a);
    vec_print("v5b", v5b);
    vec_print("v5a+v5b", vec_add(v5a, v5b));
    print("  v5a . v5b = %\n", fp(vec_dot(v5a, v5b), trail=2));

    sub("Vec(7)");
    v7a: Vec(7);
    v7a.data = .[1, 2, 3, 4, 5, 6, 7];
    v7b: Vec(7);
    v7b.data = .[7, 6, 5, 4, 3, 2, 1];
    vec_print("v7a", v7a);
    vec_print("v7b", v7b);
    print("  v7a . v7b = %\n", fp(vec_dot(v7a, v7b), trail=2));
}


