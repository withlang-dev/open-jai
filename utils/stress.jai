test_extras_9_945_for_flags :: () {
    section("945. For-loop modifiers behavioural");

    arr := int.[10, 20, 30, 40];

    sub("plain for");
    for arr  print("  v=%\n", it);

    sub("for *  (pointer; mutate)");
    for * v: arr  v.* += 1;
    print("  after mutation: %\n", arr);

    sub("for <  (reverse)");
    for < v: arr  print("  v=%\n", v);

    sub("for *< (reverse pointer)");
    for *< v: arr  v.* *= 2;
    print("  after second mutation: %\n", arr);
}


