// ----------------------------------------------------------------------------
// Helpers (extras4-local)
// ----------------------------------------------------------------------------

bubble_sort_strings :: (arr: *[..] string) {
    n := arr.count;
    if n < 2  return;
    for i: 0..n-2 {
        for j: 0..n-2-i {
            if compare_strings(arr.*[j+1], arr.*[j]) < 0 {
                tmp := arr.*[j];
                arr.*[j] = arr.*[j+1];
                arr.*[j+1] = tmp;
            }
        }
    }
}


