// ============================================================================
// cleanroom_stress_part5.jai
//
// Part 5 of the reference Jai compiler compatibility stress test suite.
//
// Loaded via `#load` from the main file. Exports `run_extras_5 :: ()` which
// invokes every test_xxx procedure declared here in source order so the
// produced output is fully deterministic.
//
// Focus of this part: algorithms.
//   - Exhaustive Apollo_Time arithmetic with fixed inputs.
//   - Recursion (PE5_factorial, fibonacci, Ackermann, Hanoi, mutual recursion).
//   - Sorting (bubble, insertion, selection, merge, quick).
//   - Searching (linear, binary).
//   - Number theory (PE5_gcd, PE5_lcm, primes, factorization, modular exponentiation).
//   - Pascal's triangle, binomial coefficients.
//   - Run-length encoding/decoding.
//   - Persistent linked list.
//   - Binary tree.
//   - Circular-buffer queue.
//   - Binary-heap priority queue.
//   - Small bloom filter.
//   - Arithmetic expression tokenize/parse/eval.
//   - Tiny regex-style pattern matcher.
//   - Levenshtein distance.
//   - Longest common subsequence.
//   - Knuth-Morris-Pratt substring search.
//   - Number-theory utility grids.
//   - Pi computation by a deterministic algorithm.
//   - Big-integer (u64-limb) Fibonacci.
//   - Conway's Game of Life on a fixed grid.
//   - Tiny CSV parser.
//   - Caesar / Vigenere ciphers.
//   - Roman numeral conversion.
//   - Numbers <-> words.
//
// Determinism guarantees:
//   - No file I/O, network, processes, timing, addresses, OS strings.
//   - All inputs are baked into the source.
//   - ASCII output only.
// ============================================================================

// ============================================================================
// 500. Apollo_Time arithmetic with fixed times
// ============================================================================

test_apollo_seconds_round_trip :: () {
    section("500. Apollo_Time seconds round-trip");

    sub("seconds_to_apollo and to_seconds for a grid of values");
    inputs := s64.[0, 1, 2, 5, 10, 60, 3600, 86_400, 604_800, 31_536_000,
                   -1, -60, -3600, -86_400];
    for s : inputs {
        a := seconds_to_apollo(s);
        back, ok := to_seconds(a);
        print("  s=% -> apollo.low=% apollo.high=% -> s=% ok=%\n",
              s, a.low, a.high, back, ok);
    }
}

test_apollo_milliseconds_round_trip :: () {
    section("501. Apollo_Time milliseconds round-trip");

    inputs := s64.[0, 1, 250, 500, 999, 1000, 1500, 60_000, 86_400_000,
                   -1, -250, -1000];
    for m : inputs {
        a := milliseconds_to_apollo(m);
        back, ok := to_milliseconds(a);
        print("  ms=% -> apollo.low=% apollo.high=% -> ms=% ok=%\n",
              m, a.low, a.high, back, ok);
    }
}

test_apollo_microseconds_round_trip :: () {
    section("502. Apollo_Time microseconds round-trip");

    inputs := s64.[0, 1, 500, 1000, 1_000_000, 60_000_000, -1, -500_000];
    for u : inputs {
        a := microseconds_to_apollo(u);
        back, ok := to_microseconds(a);
        print("  us=% -> apollo.low=% apollo.high=% -> us=% ok=%\n",
              u, a.low, a.high, back, ok);
    }
}

test_apollo_nanoseconds_round_trip :: () {
    section("503. Apollo_Time nanoseconds round-trip");

    inputs := s64.[0, 1, 1000, 1_000_000, 1_000_000_000, -1, -1_000_000_000];
    for n : inputs {
        a := nanoseconds_to_apollo(n);
        back, ok := to_nanoseconds(a);
        print("  ns=% -> apollo.low=% apollo.high=% -> ns=% ok=%\n",
              n, a.low, a.high, back, ok);
    }
}

test_apollo_addition :: () {
    section("504. Apollo_Time addition");

    base := seconds_to_apollo(1_000_000);
    print("  base = seconds_to_apollo(1_000_000), low=% high=%\n",
          base.low, base.high);

    deltas := s64.[1, 60, 3600, 86_400, 7 * 86_400, 30 * 86_400];
    for d : deltas {
        delta := seconds_to_apollo(d);
        sum   := base + delta;
        back, _ := to_seconds(sum);
        print("  +%-s -> total-s=%\n", d, back);
    }
}

test_apollo_subtraction :: () {
    section("505. Apollo_Time subtraction");

    a := seconds_to_apollo(10_000);
    b := seconds_to_apollo(   500);
    diff := a - b;
    back, _ := to_seconds(diff);
    print("  a=10000s b=500s a-b=%s\n", back);

    a2 := milliseconds_to_apollo(5_000);
    b2 := milliseconds_to_apollo(2_250);
    d2 := a2 - b2;
    mback, _ := to_milliseconds(d2);
    print("  5000ms-2250ms=%ms\n", mback);

    // Negative result
    c1 := seconds_to_apollo(1);
    c2 := seconds_to_apollo(100);
    d3 := c1 - c2;
    print("  1s-100s low=% high=%\n", d3.low, d3.high);
}

test_apollo_compare :: () {
    section("506. Apollo_Time comparison");

    a := seconds_to_apollo(100);
    b := seconds_to_apollo(200);
    c := seconds_to_apollo(100);

    print("  compare(a=100s, b=200s) = %\n", compare_apollo_times(a, b));
    print("  compare(b=200s, a=100s) = %\n", compare_apollo_times(b, a));
    print("  compare(a=100s, c=100s) = %\n", compare_apollo_times(a, c));
}

test_apollo_calendar :: () {
    section("507. Apollo_Time calendar with fixed times");

    // Construct a fixed Calendar_Time, convert to Apollo, then back.
    ct: Calendar_Time;
    ct.year                       = 2025;
    ct.month_starting_at_0        =    5;   // June
    ct.day_of_month_starting_at_0 =   14;   // 15th
    ct.hour                       =   12;
    ct.minute                     =   30;
    ct.second                     =   45;
    ct.millisecond                =  250;
    ct.time_zone                  = .UTC;

    a := calendar_to_apollo(ct);
    print("  calendar 2025-06-15 12:30:45.250 UTC -> apollo.low=% apollo.high=%\n",
          a.low, a.high);

    back := to_calendar(a, .UTC);
    print("  back -> year=% month0=% day0=% hour=% min=% sec=% ms=% tz=%\n",
          back.year, back.month_starting_at_0, back.day_of_month_starting_at_0,
          back.hour, back.minute, back.second, back.millisecond, back.time_zone);

    s := calendar_to_string(back);
    print("  calendar_to_string='%' count=%\n", s, s.count);

    iso := calendar_to_iso_string(back);
    print("  calendar_to_iso_string='%' count=%\n", iso, iso.count);
}

test_apollo_calendar_grid :: () {
    section("508. Apollo_Time calendar grid");

    Y :: struct { y, m, d, h, mi, se: int; }
    cases := Y.[
        .{1970,  1,  1,  0,  0,  0},
        .{1999, 12, 31, 23, 59, 59},
        .{2000,  1,  1,  0,  0,  0},
        .{2010,  7,  4, 12,  0,  0},
        .{2020,  2, 29, 18, 30,  0},
        .{2024, 12, 25,  9, 15, 30},
        .{2030,  6, 15, 11, 22, 33},
    ];

    for c : cases {
        ct: Calendar_Time;
        ct.year                       = xx c.y;
        ct.month_starting_at_0        = xx (c.m - 1);
        ct.day_of_month_starting_at_0 = xx (c.d - 1);
        ct.hour                       = xx c.h;
        ct.minute                     = xx c.mi;
        ct.second                     = xx c.se;
        ct.millisecond                = 0;
        ct.time_zone                  = .UTC;

        a := calendar_to_apollo(ct);
        b := to_calendar(a, .UTC);
        print("  in =%-%-% %:%:% out=%-%-% %:%:% match=%\n",
              c.y, c.m, c.d, c.h, c.mi, c.se,
              b.year, b.month_starting_at_0 + 1, b.day_of_month_starting_at_0 + 1,
              b.hour, b.minute, b.second,
              (b.year == c.y && b.month_starting_at_0 + 1 == c.m
               && b.day_of_month_starting_at_0 + 1 == c.d
               && b.hour == c.h && b.minute == c.mi && b.second == c.se));
    }
}

test_apollo_invalid :: () {
    section("509. Apollo_Time invalid sentinel");

    a := APOLLO_TIME_INVALID;
    print("  APOLLO_TIME_INVALID.low=% high=0x%\n", a.low,
          formatInt(a.high, base=16));

    zero := Apollo_Time.{0, 0};
    print("  zero.low=% high=%\n", zero.low, zero.high);

    print("  compare(invalid, zero) = %\n", compare_apollo_times(a, zero));
}

// ============================================================================
// 510. Recursion: PE5_factorial, fibonacci, Ackermann
// ============================================================================

PE5_factorial :: (n: int) -> int {
    if n <= 1 return 1;
    return n * PE5_factorial(n - 1);
}

fib_rec :: (n: int) -> int {
    if n < 2 return n;
    return fib_rec(n - 1) + fib_rec(n - 2);
}

PE5_ackermann :: (m: int, n: int) -> int {
    if m == 0 return n + 1;
    if n == 0 return PE5_ackermann(m - 1, 1);
    return PE5_ackermann(m - 1, PE5_ackermann(m, n - 1));
}

test_factorial_basic :: () {
    section("510. Factorial via recursion");

    for i : 0..12 print("  fact(%) = %\n", i, PE5_factorial(i));
}

test_fibonacci_recursive :: () {
    section("511. Fibonacci via plain recursion");

    for i : 0..20 print("  PE5_fib(%) = %\n", i, fib_rec(i));
}

test_ackermann_small :: () {
    section("512. Ackermann for small inputs");

    for m : 0..3 {
        for n : 0..4 {
            v := PE5_ackermann(m, n);
            print("  A(%, %) = %\n", m, n, v);
        }
    }
}

// Tower of Hanoi as a sequence of moves.
HanoiMove :: struct {
    disk: int;
    from: int;
    to:   int;
}

PE5_hanoi :: (n: int, src: int, dst: int, aux: int, moves: *[..] HanoiMove) {
    if n <= 0 return;
    PE5_hanoi(n - 1, src, aux, dst, moves);
    array_add(moves, HanoiMove.{n, src, dst});
    PE5_hanoi(n - 1, aux, dst, src, moves);
}

PE5_test_hanoi :: () {
    section("513. Tower of Hanoi move sequence");

    moves: [..] HanoiMove;
    PE5_hanoi(3, 1, 3, 2, *moves);
    print("  3-disk solution has % moves:\n", moves.count);
    for moves print("    step %: disk % from peg % to peg %\n",
                    it_index + 1, it.disk, it.from, it.to);

    moves4: [..] HanoiMove;
    PE5_hanoi(4, 1, 3, 2, *moves4);
    print("  4-disk solution has % moves\n", moves4.count);

    moves5: [..] HanoiMove;
    PE5_hanoi(5, 1, 3, 2, *moves5);
    print("  5-disk solution has % moves\n", moves5.count);
}

// Mutual recursion.
is_even_mutual :: (n: int) -> bool {
    if n == 0 return true;
    return is_odd_mutual(n - 1);
}
is_odd_mutual :: (n: int) -> bool {
    if n == 0 return false;
    return is_even_mutual(n - 1);
}

test_mutual_recursion :: () {
    section("514. Mutual recursion (is_even/is_odd)");

    for n : 0..10
        print("  n=% even=% odd=%\n", n, is_even_mutual(n), is_odd_mutual(n));
}

// ============================================================================
// 515. Sorting algorithms hand-written
// ============================================================================

clone_int_array :: (src: [] int) -> [..] int {
    out: [..] int;
    for src array_add(*out, it);
    return out;
}

bubble_sort_int :: (a: *[..] int) {
    n := a.count;
    for k : 0..n-1 {
        for j : 0..n-k-2 {
            if a.*[j] > a.*[j+1] {
                tmp := a.*[j];
                a.*[j]   = a.*[j+1];
                a.*[j+1] = tmp;
            }
        }
    }
}

insertion_sort_int :: (a: *[..] int) {
    n := a.count;
    for i : 1..n-1 {
        key := a.*[i];
        j   := i - 1;
        while j >= 0 && a.*[j] > key {
            a.*[j+1] = a.*[j];
            j -= 1;
        }
        a.*[j+1] = key;
    }
}

selection_sort_int :: (a: *[..] int) {
    n := a.count;
    for i : 0..n-2 {
        min_idx := i;
        for j : i+1..n-1
            if a.*[j] < a.*[min_idx] min_idx = j;
        if min_idx != i {
            tmp := a.*[i];
            a.*[i]      = a.*[min_idx];
            a.*[min_idx] = tmp;
        }
    }
}

merge_sort_helper :: (a: [] int, buf: [] int, lo: int, hi: int) {
    if hi - lo <= 1 return;
    mid := (lo + hi) / 2;
    merge_sort_helper(a, buf, lo, mid);
    merge_sort_helper(a, buf, mid, hi);

    i := lo;
    j := mid;
    k := lo;
    while i < mid && j < hi {
        if a[i] <= a[j] {
            buf[k] = a[i];
            i += 1;
        } else {
            buf[k] = a[j];
            j += 1;
        }
        k += 1;
    }
    while i < mid { buf[k] = a[i]; i += 1; k += 1; }
    while j < hi  { buf[k] = a[j]; j += 1; k += 1; }
    for idx : lo..hi-1 a[idx] = buf[idx];
}

merge_sort_int :: (a: [] int) {
    buf: [..] int;
    for 0..a.count-1 array_add(*buf, 0);
    merge_sort_helper(a, buf, 0, a.count);
}

quick_partition :: (a: [] int, lo: int, hi: int) -> int {
    pivot := a[hi];
    i := lo - 1;
    for j : lo..hi-1 {
        if a[j] <= pivot {
            i += 1;
            tmp := a[i]; a[i] = a[j]; a[j] = tmp;
        }
    }
    tmp := a[i+1]; a[i+1] = a[hi]; a[hi] = tmp;
    return i + 1;
}

quick_sort_helper :: (a: [] int, lo: int, hi: int) {
    if lo < hi {
        p := quick_partition(a, lo, hi);
        quick_sort_helper(a, lo, p - 1);
        quick_sort_helper(a, p + 1, hi);
    }
}

quick_sort_int :: (a: [] int) {
    if a.count > 0 quick_sort_helper(a, 0, a.count - 1);
}

test_bubble_sort :: () {
    section("515. Bubble sort");

    inputs : [..][..] int;

    a1: [..] int; for v : int.[5, 2, 8, 1, 9, 3, 7, 4, 6]  array_add(*a1, v);
    a2: [..] int; for v : int.[1, 2, 3, 4, 5]              array_add(*a2, v);
    a3: [..] int; for v : int.[5, 4, 3, 2, 1]              array_add(*a3, v);
    a4: [..] int; for v : int.[7, 7, 7, 7]                 array_add(*a4, v);
    a5: [..] int;                                                          // empty
    a6: [..] int; array_add(*a6, 42);                                      // single
    a7: [..] int; for v : int.[-3, 5, -1, 9, 0, 2, -7]     array_add(*a7, v);

    array_add(*inputs, a1);
    array_add(*inputs, a2);
    array_add(*inputs, a3);
    array_add(*inputs, a4);
    array_add(*inputs, a5);
    array_add(*inputs, a6);
    array_add(*inputs, a7);

    for arr, idx : inputs {
        copy := clone_int_array(arr);
        before_str := tprint("%", copy);
        bubble_sort_int(*copy);
        after_str := tprint("%", copy);
        print("  case-% in=% out=%\n", idx, before_str, after_str);
    }
}

