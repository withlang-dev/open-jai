== 130. Deterministic iteration of Hash_Table by sorting keys
----------------------------------------------------------------
hash table count = 8

-- Collect keys, sort, iterate by sorted key for deterministic output
  alpha -> 1
  beta -> 2
  delta -> 4
  epsilon -> 5
  eta -> 7
  gamma -> 3
  theta -> 8
  zeta -> 6

-- table_find / table_contains tests
find('gamma') ok=true v=3
find('omega') ok=false v=0
