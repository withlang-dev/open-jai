// ============================================================================
// 24. Procedures returning multiple values + destructuring.
// ============================================================================

split_name :: (full: string) -> (first: string, last: string) {
    for i: 0..full.count-1 {
        if full[i] == #char " " {
            return my_slice(full, 0, i), my_slice(full, i+1, full.count - i - 1);
        }
    }
    return full, "";
}

my_slice :: (s: string, start: int, count: int) -> string {
    r: string;
    r.data  = s.data + start;
    r.count = count;
    return r;
}

test_multi_return :: () {
    section("24. Multiple return values + destructuring");

    first, last := split_name("Ada Lovelace");
    print("first='%' last='%'\n", first, last);

    // Ignore individual returns with _
    _, only_last := split_name("Grace Hopper");
    print("only_last='%'\n", only_last);
}


// ============================================================================
// 25. Hash Table basics (Hash_Table module).
// ============================================================================


test_hash_table :: () {
    section("25. Hash_Table basics");

    table: Table(string, int);
    init(*table);
    defer deinit(*table);

    table_add(*table, "alpha", 1);
    table_add(*table, "beta",  2);
    table_add(*table, "gamma", 3);

    print("table.count = %\n", table.count);

    ok_b, v_b := table_find(*table, "beta");
    print("find 'beta'    -> ok=% v=%\n", ok_b, v_b);

    ok_m, v_m := table_find(*table, "missing");
    print("find 'missing' -> ok=% v=%\n", ok_m, v_m);

    sub("Iterate in deterministic-via-sorted-keys-for-test order");
    keys: [..] string;
    for v, k: table  array_add(*keys, k);
    // Sort for determinism (Hash_Table iteration order is not specified).
    bubble_sort(keys);
    for keys {
        ok, v := table_find(*table, it);
        if ok print("  % -> %\n", it, v);
    }
}

str_less :: (a: string, b: string) -> bool {
    n := min(a.count, b.count);
    for i: 0..n-1 {
        if a[i] != b[i]  return a[i] < b[i];
    }
    return a.count < b.count;
}

bubble_sort :: (arr: [..] string) {
    for i: 0..arr.count-2 {
        for j: 0..arr.count-2-i {
            if str_less(arr[j+1], arr[j]) {
                tmp := arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = tmp;
            }
        }
    }
}


