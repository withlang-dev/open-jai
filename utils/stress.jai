----------------------------------------------------------------
== 612. Varint encode/decode
----------------------------------------------------------------

-- Encode various values
  0 -> bytes=1
    [0]=0x00
  1 -> bytes=1
    [0]=0x01
  127 -> bytes=1
    [0]=0x7f
  128 -> bytes=2
    [0]=0x80
    [1]=0x01
  255 -> bytes=2
    [0]=0xff
    [1]=0x01
  300 -> bytes=2
    [0]=0xac
    [1]=0x02
  16383 -> bytes=2
    [0]=0xff
    [1]=0x7f
  16384 -> bytes=3
    [0]=0x80
    [1]=0x80
    [2]=0x01
  1000000 -> bytes=3
    [0]=0xc0
    [1]=0x84
    [2]=0x3d
  1000000000 -> bytes=5
    [0]=0x80
    [1]=0x94
    [2]=0xeb
    [3]=0xdc
    [4]=0x03

-- Round-trip all of them
  0 round-trip=true (got 0, ok=true, consumed=1)
  1 round-trip=true (got 1, ok=true, consumed=1)
  127 round-trip=true (got 127, ok=true, consumed=1)
  128 round-trip=true (got 128, ok=true, consumed=2)
  255 round-trip=true (got 255, ok=true, consumed=2)
  300 round-trip=true (got 300, ok=true, consumed=2)
  16383 round-trip=true (got 16383, ok=true, consumed=2)
  16384 round-trip=true (got 16384, ok=true, consumed=3)
  1000000 round-trip=true (got 1000000, ok=true, consumed=3)
  1000000000 round-trip=true (got 1000000000, ok=true, consumed=5)

-- Concatenate three encoded values and decode in sequence
  read v=7 (ok=true) idx=0 -> 1
  read v=2000 (ok=true) idx=1 -> 3
  read v=123456 (ok=true) idx=3 -> 6
  total bytes consumed=6 (of 6)

-- Truncated input is detected
  truncated ok=false

----------------------------------------------------------------
== 613. Base64 encode/decode
----------------------------------------------------------------

-- Known small cases
  '' -> '' -> '' (ok=true)
  'f' -> 'AA==' -> '␀' (ok=true)
  'fo' -> 'AAA=' -> '␀␀' (ok=true)
  'foo' -> 'AABv' -> '␀␀o' (ok=true)
  'foob' -> 'AABvAA==' -> '␀␀o␀' (ok=true)
  'fooba' -> 'AABvAAA=' -> '␀␀o␀␀' (ok=true)
  'foobar' -> 'AABvAABy' -> '␀␀o␀␀r' (ok=true)
  'hello' -> 'AABsAAA=' -> '␀␀l␀␀' (ok=true)
  '12345' -> 'AAAzAAA=' -> '␀␀3␀␀' (ok=true)

-- Round trip of a longer byte string
  enc='AABlAAB1AABrAAByAABuAABvAABqAABwAABvAAByAABoAABsAAB5AABvAA=='
  dec='␀␀e␀␀u␀␀k␀␀r␀␀n␀␀o␀␀j␀␀p␀␀o␀␀r␀␀h␀␀l␀␀y␀␀o␀' ok=true
  equal=false

-- Detect invalid input length
  len-3 ok=false
  bad-char ok=false

