    random_seed(0xDEADBEEF);
    sub("random_get_within_range as floats");
    for 0..4 {
        v := random_get_within_range(0.0, 1.0);
        // Just print to 4-decimal width to avoid platform-dep nondeterminism.
        print("  v[%]=%\n", it, formatFloat(v, width=8, trailing_width=4));
    }

    random_seed(0xDEADBEEF);
    sub("random_get_zero_to_one");
    for 0..4 {
        v := random_get_zero_to_one();
        print("  z[%]=%\n", it, formatFloat(v, width=8, trailing_width=4));
    }

    random_seed(0xDEADBEEF);
    sub("random_get_zero_to_one_open is in [0, 1)");
