== 222. Boolean conversion patterns
----------------------------------------------------------------

-- Logical NOT
!true   = false
!false  = true

-- Double negation as truthiness coercion
!!0           = false
!!1           = true
!!42          = true
!!(-1)        = true

-- Conditional uses bool conversion
if 5 -> truthy
if !0 -> truthy

-- String/data pointer truthiness via != null
empty string data is null? true
if data == null -> matched

-- Bool from comparison of ints/floats
a > b = true
a == b = false
(1.0 == 1) = true

-- Bool conversions for an Any
Any val type = INTEGER

----------------------------------------------------------------
== 223. Integer division corner cases
----------------------------------------------------------------

-- Signed division: signs and truncation toward zero
  s32:  7 /  3 = 2    7 mod 3  = 1
  s32: -7 /  3 = -2   -7 mod 3 = -1
  s32:  7 / -3 = -2    7 mod -3 = 1
  s32: -7 / -3 = 2   -7 mod -3 = -1

-- s64 corner cases
  s64 max/2 = 4611686018427387903
  s64 (-(max))/2 = -4611686018427387903

-- Unsigned division: behaves like positive math
  u32: 10 / 3 = 3  10 mod 3 = 1
  u32-max / 2 = 2147483647
  u32: 1M / 1M = 1

-- u64 max
  u64-max / 2 = 9223372036854775807
  u64-max / u64-max = 1

-- u8 / s8 mixing within explicit casts
  u8:   200 / 7 = 28  200 mod 7 = 4
  s8:    -7 / 2 = -3    -7 mod 2 = -1

