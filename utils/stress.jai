}

PE6_Build :: enum_flags u32 {
    DEBUG_BUILD      :: 0x1;
    RELEASE_BUILD    :: 0x2;
    PROFILE_BUILD    :: 0x4;
    SHIPPING_BUILD   :: 0x8;
    TEST_BUILD       :: 0x10;
    BENCHMARK_BUILD  :: 0x20;
}


// ============================================================================
// Polymorphic struct zoo. All linear-scan / fixed-size; no allocations.
// ============================================================================

PE6_Box :: struct(T: Type) {
    value: T;
}

PE6_Pair :: struct(A: Type, B: Type) {
    first:  A;
    second: B;
}

Triple :: struct(A: Type, B: Type, C: Type) {
    first:  A;
    second: B;
    third:  C;
}

Quad :: struct(A: Type, B: Type, C: Type, D: Type) {
    a: A;
    b: B;
    c: C;
    d: D;
}

// Fixed-size linear-scan map: explicit capacity, no allocations.
Map :: struct(K: Type, V: Type, CAP: int) {
    count: int;
    keys:  [CAP] K;
    vals:  [CAP] V;
}

PE6_Stack :: struct(T: Type, CAP: int) {
    count: int;
    data:  [CAP] T;
}

PE6_Queue :: struct(T: Type, CAP: int) {
    head:  int;
    tail:  int;
    count: int;
    data:  [CAP] T;
}

PE6_Ring :: struct(T: Type, CAP: int) {
    cursor: int;    // next-write index, wrapping
    count:  int;    // 0..CAP
    data:   [CAP] T;
}

PE6_Fixed_List :: struct(T: Type, N: int) {
    count: int;
    data:  [N] T;
}


// ============================================================================
// 600. Reflection sweep over every type kind we know about.
// ============================================================================

PE6_print_primitive_info :: ($T: Type) {
    info := type_info(T);
    tag_name := info.type;
    print("  primitive % type_tag=% runtime_size=%\n",
          type_to_string(info), tag_name, info.runtime_size);
}

PE6_print_array_info_for :: (label: string, ti: *Type_Info) {
    if ti.type != .ARRAY {
        print("  %: not an array, tag=%\n", label, ti.type);
        return;
    }
    a := cast(*Type_Info_Array) ti;
    kind: string;
    if a.array_type == {
        case .FIXED;     kind = "FIXED";
        case .VIEW;      kind = "VIEW";
        case .RESIZABLE; kind = "RESIZABLE";
    }
    print("  %: kind=% element_tag=% element_size=% count=% array_size=%\n",
          label, kind, a.element_type.type, a.element_type.runtime_size,
          a.array_count, a.runtime_size);
}

PE6_print_struct_info_for :: (label: string, ti: *Type_Info) {
    if ti.type != .STRUCT {
        print("  %: not a struct, tag=%\n", label, ti.type);
        return;
    }
    s := cast(*Type_Info_Struct) ti;
    print("  % struct '%' size=% members=% params=%\n",
          label, s.name, s.runtime_size, s.members.count, s.parameters.count);
    for s.members {
        print("    .% (tag=% size=%) offset=%\n",
              it.name, it.type.type, it.type.runtime_size, it.offset_in_bytes);
    }
}

PE6_print_enum_info_for :: (label: string, ti: *Type_Info) {
    if ti.type != .ENUM {
        print("  %: not an enum, tag=%\n", label, ti.type);
        return;
    }
    e := cast(*Type_Info_Enum) ti;
    is_flags     := (e.enum_type_flags & .FLAGS)     != 0;
    is_specified := (e.enum_type_flags & .SPECIFIED) != 0;
    is_complete  := (e.enum_type_flags & .COMPLETE)  != 0;
    print("  % enum '%' size=% members=% flags=% specified=% complete=%\n",
          label, e.name, e.runtime_size, e.names.count,
          is_flags, is_specified, is_complete);
    for n, i: e.names {
        print("    .% = %\n", n, e.values[i]);
    }
}

PE6_test_reflection_primitive_sweep :: () {
    section("600. Reflection sweep: primitives");

    sub("Integer types");
    PE6_print_primitive_info(s8);
    PE6_print_primitive_info(s16);
    PE6_print_primitive_info(s32);
    PE6_print_primitive_info(s64);
    PE6_print_primitive_info(u8);
    PE6_print_primitive_info(u16);
    PE6_print_primitive_info(u32);
    PE6_print_primitive_info(u64);
    PE6_print_primitive_info(int);

    sub("Float types");
    PE6_print_primitive_info(float32);
    PE6_print_primitive_info(float64);
    PE6_print_primitive_info(float);

    sub("Misc primitives");
    PE6_print_primitive_info(bool);
    PE6_print_primitive_info(string);
    PE6_print_primitive_info(void);
    PE6_print_primitive_info(Type);

    sub("Pointer kinds");
    PE6_print_primitive_info(*void);
    PE6_print_primitive_info(*u8);
    PE6_print_primitive_info(*int);
    PE6_print_primitive_info(*PE6_Vec3);

    sub("Integer signedness via Type_Info_Integer");
    {
        infos: [4] *Type_Info_Integer;
        infos[0] = xx type_info(s32);
        infos[1] = xx type_info(u32);
        infos[2] = xx type_info(s8);
        infos[3] = xx type_info(u64);

        names := string.["s32","u32","s8","u64"];
        for infos {
            print("  % signed=% size=%\n", names[it_index], it.signed, it.runtime_size);
        }
    }
}

PE6_test_reflection_array_sweep :: () {
    section("600a. Reflection sweep: arrays");

    fa_s32 : [5] s32;
