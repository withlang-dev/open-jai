// ============================================================================
// 631. Print the byte representation of small literals .
// ============================================================================

PE6_print_bytes_of :: ($T: Type, label: string, value: T) {
    bytes: [size_of(T)] u8;
    memcpy(bytes.data, *value, size_of(T));
    print("  % size=% bytes=", label, size_of(T));
    for 0..bytes.count-1 {
        print("%", formatInt(bytes[it], base=16, minimum_digits=2));
        if it < bytes.count - 1  print(" ");
    }
    print("\n");
}

PE6_test_print_bytes :: () {
    section("631. Byte representation of small literals");

    PE6_print_bytes_of(u8,  "u8(0xAB)",     0xAB);
    PE6_print_bytes_of(u16, "u16(0x1234)",  0x1234);
    PE6_print_bytes_of(u32, "u32(0xDEADBEEF)", 0xDEADBEEF);
    PE6_print_bytes_of(u64, "u64(0x0102030405060708)", 0x0102030405060708);

    PE6_print_bytes_of(s8,  "s8(-1)",  -1);
    PE6_print_bytes_of(s16, "s16(-1)", -1);
    PE6_print_bytes_of(s32, "s32(-1)", -1);
    PE6_print_bytes_of(s64, "s64(-1)", -1);

    PE6_print_bytes_of(float32, "f32(1.0)", 1.0);
    PE6_print_bytes_of(float32, "f32(0.0)", 0.0);
    PE6_print_bytes_of(float32, "f32(-1.0)", -1.0);

    PE6_print_bytes_of(PE6_Color,    "color(GREEN)",   PE6_Color.GREEN);
    PE6_print_bytes_of(PE6_VM_Opcode,"opcode(PRINT)",  PE6_VM_Opcode.PRINT);
}


// ============================================================================
// 632. Self-test the field walker against expected values.
// ============================================================================

PE6_test_field_walker_assertions :: () {
    section("632. Field walker assertions against known structures");

    {
        s := PE6_classify_top_level(type_info(PE6_Vec3));
        ok := s.floats == 3 && s.integers == 0;
        print("  Vec3 has 3 floats, 0 ints -> %\n", ok);
    }
    {
        s := PE6_classify_top_level(type_info(PE6_RGBA));
        ok := s.integers == 4;
        print("  RGBA has 4 ints -> %\n", ok);
    }
    {
        s := PE6_classify_top_level(type_info(PE6_Address));
        ok := s.strings == 2 && s.integers == 1;
        print("  Address has 2 strings + 1 int -> %\n", ok);
    }
    {
        s := PE6_classify_top_level(type_info(PE6_Person));
        ok := s.strings == 1 && s.integers == 1 && s.structs == 1;
        print("  Person has 1 string + 1 int + 1 struct -> %\n", ok);
    }
    {
        rec: PE6_Field_Stats;
        PE6_classify_recursive(type_info(PE6_Network), *rec);
        // Network -> primary + backup (each Company has name(str), founded(int),
        // boss(Person which has name(str), age(int), address(struct with 2 strs, 1 int)))
        // Recursive expectation: ints =
        //   2*(1 founded + 1 age + 1 zip) = 6
        // strings =
        //   2*(1 cname + 1 name + 1 street + 1 city) + 1 label = 9
        ok := rec.integers == 6 && rec.strings == 9;
        print("  Network recursive ints=6 strings=9 -> %  (got ints=% strings=%)\n",
              ok, rec.integers, rec.strings);
    }
}


// ============================================================================
// 633. Polymorph: Stack of polymorphic PE6_Box of enum.
// ============================================================================

PE6_test_stack_box_enum :: () {
    section("633. Stack(PE6_Box(PE6_Color), 5)");
