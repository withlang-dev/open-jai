    sub("Many bools");
    for it: bool.[true, false]  PE6_print_pretty(it);

    sub("Many enums");
    for it: PE6_Color.[.RED, .GREEN, .BLUE, .ALPHA]  PE6_print_pretty(it);

    sub("Vec3 array");
    {
        v3s : [3] PE6_Vec3 = .[.{1,2,3}, .{4,5,6}, .{7,8,9}];
        PE6_print_pretty(v3s);
    }

    sub("RGBA array view");
