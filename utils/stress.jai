-- YAML view of the order
customer: "Acme"
items: 
  - 
    name: "widget"
    quantity: 3
    unit_price: 2.5
  - 
    name: "gadget"
    quantity: 1
    unit_price: 9.99
  - 
    name: "doohickey"
    quantity: 5
    unit_price: 0.5
total: 19.99

-- JSON view of the order
{"customer":"Acme","items":[{"name":"widget","quantity":3,"unit_price":2.5},{"name":"gadget","quantity":1,"unit_price":9.99},{"name":"doohickey","quantity":5,"unit_price":0.5}],"total":19.99}

-- Same order but different name/quantity (diff)
diff 'o vs o2 (top-level only)':
  DIFFER customer  A='Acme' B='Acme2'
  DIFFER items  A=<?> B=<?>
  DIFFER total  A=19.99 B=30.73

-- Cleanup

