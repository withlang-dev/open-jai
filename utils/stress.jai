        print("  o[%]=% in_range=%\n", it, formatFloat(v, width=8, trailing_width=4), in_range);
    }

    sub("Random integers stay reproducible");
    random_seed(42);
    a := random_get() % 1000;
    random_seed(42);
    b := random_get() % 1000;
    print("seed=42 twice -> same: %\n", a == b);
}


