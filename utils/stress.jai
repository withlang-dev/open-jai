        a="x", b=true, c=1.5, d=.BLUE}));
}


// ============================================================================
// 623. Big sweep of varints from 0..255 (encode counts of bytes used).
// ============================================================================

PE6_test_varint_distribution :: () {
    section("623. Varint byte-count distribution");

    counts: [10] int;
    for v: 0..255 {
        buf: [..] u8;
        PE6_varint_encode(cast(u64) v, *buf);
        counts[buf.count] += 1;
    }
    for i: 0..9 {
        if counts[i] > 0 {
            print("  bytes=%: % values\n", i, counts[i]);
        }
    }

    sub("Spot check");
    spots := u64.[0, 127, 128, 16_383, 16_384, 2_097_151, 2_097_152];
    for v: spots {
        buf: [..] u8;
        PE6_varint_encode(v, *buf);
        print("  v=% bytes=%\n", v, buf.count);
    }
}


// ============================================================================
// 624. Verify all hex chars round-trip through hex_digit_value.
// ============================================================================

PE6_test_hex_chars :: () {
    section("624. Hex character round-trips");

    for ch: u8.[#char "0", #char "1", #char "9", #char "a", #char "A", #char "f", #char "F"] {
        v := PE6_hex_digit_value(ch);
        print("  '%' -> %\n", string.{1, *ch}, v);
    }

    bad := u8.[#char "g", #char "G", #char "z", #char " ", #char "!"];
    for ch: bad {
        v := PE6_hex_digit_value(ch);
        print("  '%' (bad) -> %\n", string.{1, *ch}, v);
    }
}


// ============================================================================
// 625. Walk type_info(Day) and emit names/values pairs as JSON-like text.
// ============================================================================

PE6_emit_enum_as_jsonlike :: ($T: Type) {
    info := type_info(T);
    print("  { \"name\": \"%\", \"values\": {\n", info.name);
    for n, i: info.names {
        comma := ifx i < info.names.count - 1 then "," else "";
        print("      \"%\": %%\n", n, info.values[i], comma);
    }
    print("  } }\n");
}

PE6_test_emit_enum_as_json :: () {
    section("625. Emit enum types as JSON-like text");

    PE6_emit_enum_as_jsonlike(PE6_Color);
    PE6_emit_enum_as_jsonlike(PE6_Day);
    PE6_emit_enum_as_jsonlike(PE6_Compass);
    PE6_emit_enum_as_jsonlike(PE6_Phase);
    PE6_emit_enum_as_jsonlike(PE6_VM_Opcode);
}


