// ----------------------------------------------------------------------------
// 410f. Print formatted vector via FormatStruct
// ----------------------------------------------------------------------------

test_410f_format_vector :: () {
    section("410f. Print Vector3 via FormatStruct");

    v := Vector3.{1.5, 2.5, 3.5};

    print("default        : %\n", v);

    fs: FormatStruct;
    fs.value = v;
    fs.use_long_form_if_more_than_this_many_members = -1;
    print("long form      : %\n", fs);

    fs2: FormatStruct;
    fs2.value = v;
    fs2.draw_type_name = true;
    print("with type name : %\n", fs2);

    fs3: FormatStruct;
    fs3.value = v;
    fs3.begin_string = "<";
    fs3.end_string   = ">";
    fs3.short_form_separator_between_fields = " | ";
    print("custom delims  : %\n", fs3);
}


// ----------------------------------------------------------------------------
// 405c. Printing precision boundary
// ----------------------------------------------------------------------------

test_405c_precision_boundary :: () {
    section("405c. Precision boundary");

    sub("0.1 + 0.2");
    a: float64 = 0.1;
    b: float64 = 0.2;
    s := a + b;
    print("0.1+0.2 tw=2: %\n", formatFloat(s, trailing_width=2));
    print("0.1+0.2 tw=4: %\n", formatFloat(s, trailing_width=4));
    print("0.1+0.2 tw=6: %\n", formatFloat(s, trailing_width=6));
    print("0.1+0.2 tw=10: %\n", formatFloat(s, trailing_width=10));
    print("0.1+0.2 tw=16: %\n", formatFloat(s, trailing_width=16));

    sub("Long division");
    for k: int.[3, 7, 11, 13] {
        v: float64 = 1.0 / cast(float64) k;
        print("1/% tw=10: %\n", k, formatFloat(v, trailing_width=10));
    }
}


// ----------------------------------------------------------------------------
// 434b. Hash table with V2 struct key
// ----------------------------------------------------------------------------

P434b_Point :: struct { x, y: int; }

hash_p434b :: (p: P434b_Point) -> u32 {
    a: u32 = cast,no_check(u32) p.x;
    b: u32 = cast,no_check(u32) p.y;
    return a * 2654435761 + b;
}

eq_p434b :: (a: P434b_Point, b: P434b_Point) -> bool {
    return a.x == b.x && a.y == b.y;
}

test_434b_hash_table_struct_keys :: () {
    section("434b. Hash_Table with V2 (Point) struct keys");

    t: Table(P434b_Point, string, hash_p434b, eq_p434b);
    init(*t);
    defer deinit(*t);

    table_add(*t, .{0, 0}, "origin");
    table_add(*t, .{1, 0}, "east");
    table_add(*t, .{0, 1}, "north");
    table_add(*t, .{-1, 0}, "west");
    table_add(*t, .{0, -1}, "south");

    print("count = %\n", t.count);

    for p: P434b_Point.[.{0,0}, .{1,0}, .{2,3}, .{-1,0}, .{0,1}, .{0,-1}] {
        ok, v := table_find(*t, p);
        print("find (%, %) -> ok=% v='%'\n", p.x, p.y, ok, v);
    }
}


// ----------------------------------------------------------------------------
// 455c. Bit_Array iteration with index
// ----------------------------------------------------------------------------

test_455c_bit_array_indices :: () {
    section("455c. Bit_Array set bits indices");

    ba: Bit_Array;
    init_bit_array(*ba, 100);
    defer deinit(*ba);

    for i: 0..99  if i % 7 == 0  set_bit(*ba, i);

    print("multiples of 7 in 0..99: ");
    first := true;
    for is_set: ba {
        if is_set {
            if !first  print(",");
            print("%", it_index);
            first = false;
        }
    }
    print("\n");
}


// ----------------------------------------------------------------------------
// 451e. Vector operator+/operator-/operator*
// ----------------------------------------------------------------------------

test_451e_vector_ops_full :: () {
    section("451e. Vector operator overloads exhaustive");

    a := Vector3.{1, 2, 3};
    b := Vector3.{4, 5, 6};

    print("a + b      = %\n", format_v3(a + b));
    print("a - b      = %\n", format_v3(a - b));
    print("a * 2      = %\n", format_v3(a * 2.0));
    print("a / 2      = %\n", format_v3(a / 2.0));
    print("-a         = %\n", format_v3(-a));
    print("a + (-b)   = %\n", format_v3(a + (-b)));
    print("dot(a,b)   = %\n", dot_product(a, b));
    print("dot(a,a)   = %\n", dot_product(a, a));
    print("length(a)  = %\n", formatFloat(length(a), trailing_width=4));

    sub("Vector4");
    p := Vector4.{1, 2, 3, 4};
    q := Vector4.{10, 20, 30, 40};
    print("p + q      = %\n", format_v4(p + q));
    print("p * 0.5    = %\n", format_v4(p * 0.5));
    print("dot(p,q)   = %\n", dot_product(p, q));
}


