    print("  %\n", PE8_json(a16));

    sub("[3] u32");
    a32 : [3] u32 = .[100000, 200000, 300000];
    print("  %\n", PE8_json(a32));

    sub("[3] s8");
    s8s : [3] s8 = .[-1, 0, 1];
    print("  %\n", PE8_json(s8s));

    sub("[3] s16");
    s16s : [3] s16 = .[-1000, 0, 1000];
    print("  %\n", PE8_json(s16s));

    sub("[3] s32");
    s32s : [3] s32 = .[-1_000_000, 0, 1_000_000];
    print("  %\n", PE8_json(s32s));

    sub("[3] s64");
    s64s : [3] s64 = .[-9_000_000_000, 0, 9_000_000_000];
    print("  %\n", PE8_json(s64s));

    sub("[3] float32");
    f32s : [3] float32 = .[1.0, 2.0, 3.0];
    print("  %\n", PE8_json(f32s));

    sub("[3] float64");
