    print("members = %\n", info.members.count);
    for info.members
        print("  '%' offset=% size=%\n",
            it.name, it.offset_in_bytes, it.type.runtime_size);
}


// ----------------------------------------------------------------------------
// 466c. enum_flags membership
// ----------------------------------------------------------------------------

test_466c_enum_flag_pop :: () {
    section("466c. enum_flags: popcount");

    flags: Big_Flags = .F00 | .F03 | .F07 | .F11 | .F15 | .F21 | .F27;

    pop := 0;
    for v: enum_values_as_enum(Big_Flags) {
        if (flags & v) != 0  pop += 1;
    }
    print("popcount = %\n", pop);

    sub("Hex");
    print("flags = %\n", formatInt(cast(u64) flags, base=16, minimum_digits=16));
}


// ----------------------------------------------------------------------------
// 444d. log/sqrt edge values
// ----------------------------------------------------------------------------

test_444d_edge_inputs :: () {
    section("444d. sqrt / pow / log edge inputs");

    print("sqrt(0.0)    = %\n", sqrt(0.0));
    print("sqrt(0.0001) = %\n", formatFloat(sqrt(0.0001), trailing_width=10));
    print("pow(0,0)     = %\n", pow(0.0, 0.0));
    print("pow(1, 999)  = %\n", pow(1.0, 999.0));
    print("pow(0, 5)    = %\n", pow(0.0, 5.0));
    print("log(1)       = %\n", log(1.0));
    print("log(1e20)    = %\n", formatFloat(log(1.0e20), trailing_width=4));
}


// ----------------------------------------------------------------------------
// 446c. clamp on float
// ----------------------------------------------------------------------------

test_446c_clamp_float :: () {
    section("446c. clamp on float");

    for x: float.[-2.0, -1.0, 0.0, 0.5, 1.0, 1.5, 2.0]
        print("clamp(%, 0, 1) = %\n", x, clamp(x, 0.0, 1.0));

    sub("clamp(x, -5, 5)");
    for x: float.[-10.0, -5.0, 0.0, 5.0, 10.0]
        print("clamp(%, -5, 5) = %\n", x, clamp(x, -5.0, 5.0));
}


// ----------------------------------------------------------------------------
// 412c. FormatArray on view, fixed, resizable
// ----------------------------------------------------------------------------

test_412c_format_array_types :: () {
    section("412c. FormatArray on different array kinds");

    fa: [5] int = .[1, 2, 3, 4, 5];
    view: [] int = fa;
    ra: [..] int;
    for i: 1..5  array_add(*ra, i * 10);

    f1: FormatArray;
    f1.value = fa;
    f1.separator = "-";
    print("fixed:     %\n", f1);

    f2: FormatArray;
    f2.value = view;
    f2.separator = "-";
    print("view:      %\n", f2);

    f3: FormatArray;
    f3.value = ra;
    f3.separator = "-";
    print("resizable: %\n", f3);
}


