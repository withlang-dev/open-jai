== 140. Polymorphic Ring_Buffer
----------------------------------------------------------------
initial count = 0

-- Push 4, fill capacity
push 10 ok = true
push 20 ok = true
push 30 ok = true
push 40 ok = true
count = 4

-- Try to over-push (should return false)
push 50 ok = false
count after over-push = 4

-- Pop 2 elements
pop -> 10 ok=true
pop -> 20 ok=true
count = 2

-- Push more and wrap around
push 50 ok = true
push 60 ok = true
count = 4

-- Drain the buffer
pop -> 30 ok=true
pop -> 40 ok=true
pop -> 50 ok=true
pop -> 60 ok=true
final count = 0

-- Pop from empty
pop empty: v=0 ok=false

