  encode('') -> count=0
  decode = '' match=true
  encode('a') -> count=1
    pair 0: char='a' n=1
  decode = 'a' match=true
  encode('aaa') -> count=1
    pair 0: char='a' n=3
  decode = 'aaa' match=true
  encode('aabbbcccc') -> count=3
    pair 0: char='a' n=2
    pair 1: char='b' n=3
    pair 2: char='c' n=4
  decode = 'aabbbcccc' match=true
  encode('abcabc') -> count=6
    pair 0: char='a' n=1
    pair 1: char='b' n=1
    pair 2: char='c' n=1
    pair 3: char='a' n=1
    pair 4: char='b' n=1
    pair 5: char='c' n=1
  decode = 'abcabc' match=true
  encode('hello world') -> count=10
    pair 0: char='h' n=1
    pair 1: char='e' n=1
    pair 2: char='l' n=2
    pair 3: char='o' n=1
    pair 4: char=' ' n=1
    pair 5: char='w' n=1
    pair 6: char='o' n=1
    pair 7: char='r' n=1
    pair 8: char='l' n=1
    pair 9: char='d' n=1
  decode = 'hello world' match=true
  encode('aaaaaaaaaaaaaa') -> count=1
    pair 0: char='a' n=14
  decode = 'aaaaaaaaaaaaaa' match=true
  encode('MISSISSIPPI') -> count=8
    pair 0: char='M' n=1
    pair 1: char='I' n=1
    pair 2: char='S' n=2
    pair 3: char='I' n=1
    pair 4: char='S' n=2
    pair 5: char='I' n=1
    pair 6: char='P' n=2
    pair 7: char='I' n=1
  decode = 'MISSISSIPPI' match=true
  encode('AAABBBCCCDDDEEE') -> count=5
    pair 0: char='A' n=3
    pair 1: char='B' n=3
    pair 2: char='C' n=3
    pair 3: char='D' n=3
    pair 4: char='E' n=3
  decode = 'AAABBBCCCDDDEEE' match=true
  encode('X') -> count=1
    pair 0: char='X' n=1
  decode = 'X' match=true

