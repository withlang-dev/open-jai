----------------------------------------------------------------
== 536. Arithmetic expression tokenize/parse/eval
----------------------------------------------------------------

-- expr '1+2'
    token kind=INT value=1
    token kind=PLUS value=0
    token kind=INT value=2
    token kind=END value=0
    ast = (1+2)
    eval = 3

-- expr '1 + 2 * 3'
    token kind=INT value=1
    token kind=PLUS value=0
    token kind=INT value=2
    token kind=STAR value=0
    token kind=INT value=3
    token kind=END value=0
    ast = (1+(2*3))
    eval = 7

-- expr '(1 + 2) * 3'
    token kind=LPAREN value=0
    token kind=INT value=1
    token kind=PLUS value=0
    token kind=INT value=2
    token kind=RPAREN value=0
    token kind=STAR value=0
    token kind=INT value=3
    token kind=END value=0
    ast = ((1+2)*3)
    eval = 9

-- expr '1 + 2 * (3 - 4)'
    token kind=INT value=1
    token kind=PLUS value=0
    token kind=INT value=2
    token kind=STAR value=0
    token kind=LPAREN value=0
    token kind=INT value=3
    token kind=MINUS value=0
    token kind=INT value=4
    token kind=RPAREN value=0
    token kind=END value=0
    ast = (1+(2*(3-4)))
    eval = -1

-- expr '10 - 4 - 2'
    token kind=INT value=10
    token kind=MINUS value=0
    token kind=INT value=4
    token kind=MINUS value=0
    token kind=INT value=2
    token kind=END value=0
    ast = ((10-4)-2)
    eval = 4

-- expr '100 / 5 / 2'
    token kind=INT value=100
    token kind=SLASH value=0
    token kind=INT value=5
    token kind=SLASH value=0
    token kind=INT value=2
    token kind=END value=0
    ast = ((100/5)/2)
    eval = 10

-- expr '2 * 3 * 4'
    token kind=INT value=2
    token kind=STAR value=0
    token kind=INT value=3
    token kind=STAR value=0
    token kind=INT value=4
    token kind=END value=0
    ast = ((2*3)*4)
    eval = 24

-- expr '(1 + 2) * (3 + 4)'
    token kind=LPAREN value=0
    token kind=INT value=1
    token kind=PLUS value=0
    token kind=INT value=2
    token kind=RPAREN value=0
    token kind=STAR value=0
    token kind=LPAREN value=0
    token kind=INT value=3
    token kind=PLUS value=0
    token kind=INT value=4
    token kind=RPAREN value=0
    token kind=END value=0
    ast = ((1+2)*(3+4))
    eval = 21

-- expr '-5 + 3'
    token kind=MINUS value=0
    token kind=INT value=5
    token kind=PLUS value=0
    token kind=INT value=3
    token kind=END value=0
    ast = ((-5)+3)
    eval = -2

-- expr '-(2 + 3)'
    token kind=MINUS value=0
    token kind=LPAREN value=0
    token kind=INT value=2
    token kind=PLUS value=0
    token kind=INT value=3
    token kind=RPAREN value=0
    token kind=END value=0
    ast = (-(2+3))
    eval = -5

-- expr '1 + 2 + 3 + 4 + 5'
    token kind=INT value=1
    token kind=PLUS value=0
    token kind=INT value=2
    token kind=PLUS value=0
    token kind=INT value=3
    token kind=PLUS value=0
    token kind=INT value=4
    token kind=PLUS value=0
    token kind=INT value=5
    token kind=END value=0
    ast = ((((1+2)+3)+4)+5)
    eval = 15

-- expr '8 / 2 + 1'
    token kind=INT value=8
    token kind=SLASH value=0
    token kind=INT value=2
    token kind=PLUS value=0
    token kind=INT value=1
    token kind=END value=0
    ast = ((8/2)+1)
    eval = 5

-- expr '1 - 2 + 3'
    token kind=INT value=1
    token kind=MINUS value=0
    token kind=INT value=2
    token kind=PLUS value=0
    token kind=INT value=3
    token kind=END value=0
    ast = ((1-2)+3)
    eval = 2

-- expr '(((42)))'
    token kind=LPAREN value=0
    token kind=LPAREN value=0
    token kind=LPAREN value=0
    token kind=INT value=42
    token kind=RPAREN value=0
    token kind=RPAREN value=0
    token kind=RPAREN value=0
    token kind=END value=0
    ast = 42
    eval = 42

