  b serial = PE6_Network {label="net-a", primary=PE6_Company {name="P1", founded=1, boss=PE6_Person {name="b1", age=10, address=PE6_Address {street="s1", city="c1", zip=1}}}, backup=PE6_Company {name="P2", founded=2, boss=PE6_Person {name="b2", age=20, address=PE6_Address {street="s2", city="c2", zip=2}}}}
  c serial = PE6_Network {label="net-a", primary=PE6_Company {name="P1", founded=1, boss=PE6_Person {name="b1", age=10, address=PE6_Address {street="s1", city="c1", zip=1}}}, backup=PE6_Company {name="P2", founded=2, boss=PE6_Person {name="b2", age=999, address=PE6_Address {street="s2", city="c2", zip=2}}}}
  a == b -> true
