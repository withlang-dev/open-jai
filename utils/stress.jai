== 753. More polynomial ops (mul, sub, neg)
----------------------------------------------------------------

-- 753.a (1+x)*(1-x) should be 1-x^2
  p1*p2 = [1, 0, -1]

-- 753.b (1+x)^4 via repeated mul
  (1+x)^4 = [1, 4, 6, 4, 1]

-- 753.c (2+3x+4x^2)*(1-x^2)
  p3*p4 = [2, 3, 2, -3, -4]

-- 753.d sub: p3 - p4
  p3-p4 = [1, 3, 5]

-- 753.e neg: -p3
  -p3 = [-2, -3, -4]

-- 753.f eval (1+x)^4 at x=2,3,4
  eval at 2=81
  eval at 3=256
  eval at 4=625

