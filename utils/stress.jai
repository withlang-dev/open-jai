// ----------------------------------------------------------------------------
// 419b. Bit ops on u64 patterns
// ----------------------------------------------------------------------------

test_419b_u64_patterns :: () {
    section("419b. u64 alternating patterns");

    a: u64 = 0xAAAA_AAAA_AAAA_AAAA;
    b: u64 = 0x5555_5555_5555_5555;
    c: u64 = 0xFFFF_FFFF_0000_0000;
    d: u64 = 0x0000_0000_FFFF_FFFF;

    print("a   = %\n", formatInt(a, base=16, minimum_digits=16));
    print("b   = %\n", formatInt(b, base=16, minimum_digits=16));
    print("c   = %\n", formatInt(c, base=16, minimum_digits=16));
    print("d   = %\n", formatInt(d, base=16, minimum_digits=16));

    print("a|b = %\n", formatInt(a | b, base=16, minimum_digits=16));
    print("a&b = %\n", formatInt(a & b, base=16, minimum_digits=16));
    print("a^b = %\n", formatInt(a ^ b, base=16, minimum_digits=16));
    print("c|d = %\n", formatInt(c | d, base=16, minimum_digits=16));
    print("c&d = %\n", formatInt(c & d, base=16, minimum_digits=16));
    print("a&c = %\n", formatInt(a & c, base=16, minimum_digits=16));
}


// ----------------------------------------------------------------------------
// 477b. Iteration: alternating filter
// ----------------------------------------------------------------------------

test_477b_filter_iter :: () {
    section("477b. Filter and reduce");

    arr: [..] int;
    for i: 1..50  array_add(*arr, i);

    sum_even := 0;
    sum_odd  := 0;
    count_div3 := 0;
    for v: arr {
        if v % 2 == 0  sum_even += v;
        else           sum_odd  += v;
        if v % 3 == 0  count_div3 += 1;
    }
    print("sum_even (1..50) = %\n", sum_even);
    print("sum_odd  (1..50) = %\n", sum_odd);
    print("div3 count       = %\n", count_div3);

    sub("Map (multiply) then sum");
    sum_x2 := 0;
    for v: arr  sum_x2 += v * 2;
    print("sum of 2x = %\n", sum_x2);
}


