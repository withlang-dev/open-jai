    a, b := 5;
    print("% %\n", a, b);
}
SRC},

// ===========================================================================
// SECTION CB. Parenthesis / bracket nesting corruption.
// ===========================================================================

.{ "missing closing paren in argument list", #string SRC
#import "Basic";
main :: () {
    print("%\n", 5;
}
SRC},

.{ "extra closing paren in expression", #string SRC
#import "Basic";
main :: () {
    x := (5 + 6));
    print("%\n", x);
}
SRC},

.{ "unbalanced parens in math", #string SRC
#import "Basic";
main :: () {
    x := ((1 + 2) * (3 + 4);
    print("%\n", x);
}
SRC},

.{ "missing closing brace on block", #string SRC
#import "Basic";
