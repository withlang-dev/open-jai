}


// ============================================================================
// 627. Polymorph that takes a baked Type AND a baked $$N.
// ============================================================================

PE6_baked_make_n_of :: ($T: Type, $$N: int) -> [N] T {
    out: [N] T;
    for 0..N-1 {
        v: T;
        out[it] = v;
    }
    return out;
}

PE6_test_baked_baked :: () {
    section("627. Polymorph: baked Type + baked $$N");

    a := PE6_baked_make_n_of(int, 5);
    b := PE6_baked_make_n_of(float, 3);
    c := PE6_baked_make_n_of(PE6_Vec2, 2);

    print("  baked int[5]   = % (size=%)\n", a, size_of(type_of(a)));
    print("  baked float[3] = % (size=%)\n", b, size_of(type_of(b)));
    print("  baked V2[2]    = % (size=%)\n", c, size_of(type_of(c)));
}


// ============================================================================
// 628. Compile-time computation of a constant table via #run.
// ============================================================================

PE6_compute_squares :: ($N: int) -> [N] int {
    out: [N] int;
    for 0..N-1  out[it] = it * it;
    return out;
}

PE6_SQUARES_8 :: #run PE6_compute_squares(8);
PE6_SQUARES_16 :: #run PE6_compute_squares(16);

PE6_test_compile_time_squares :: () {
    section("628. Compile-time constant tables via #run");

    print("  SQUARES_8 = %\n", PE6_SQUARES_8);
    print("  SQUARES_16 = %\n", PE6_SQUARES_16);

    sum8 := 0;
    for PE6_SQUARES_8  sum8 += it;
    print("  sum of squares 0..7 = %\n", sum8);

    sum16 := 0;
    for PE6_SQUARES_16  sum16 += it;
    print("  sum of squares 0..15 = %\n", sum16);
}


// ============================================================================
// 629. Manual hash table on top of PE6_Map with a tiny hash.
// language primitives we already have.)
// ============================================================================

PE6_str_hash :: (s: string) -> u64 {
    h: u64 = 14695981039346656037;       // FNV-1a 64 offset basis
    for 0..s.count-1 {
        h = h ^ cast(u64) s[it];
        h = h *  1099511628211;          // FNV prime
    }
    return h;
}

PE6_test_str_hash :: () {
    section("629. FNV-1a string hashes ");

    samples := string.["", "a", "ab", "abc", "hello", "world", "hello world"];
    for s: samples {
        h := PE6_str_hash(s);
        print("  hash('%') = %\n", s, h);
    }

    sub("Same string -> same hash; different strings -> different hashes (typically)");
    h1 := PE6_str_hash("apple");
    h2 := PE6_str_hash("apple");
    h3 := PE6_str_hash("apply");
    print("  apple==apple : %\n", h1 == h2);
    print("  apple==apply : %\n", h1 == h3);
}


