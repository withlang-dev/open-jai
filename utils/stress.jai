-- Fixed_List(string,3)
  [0]='alpha'
  [1]='beta'
  [2]='gamma'

----------------------------------------------------------------
== 606. Polymorphic procedure forms
----------------------------------------------------------------

-- Variadic polymorph
  sum(int) = 15
  sum(float) = 7
  join(int) = 10/20/30
  join(str) = a-b-c

-- Polymorph with baked Type
  baked int len=3 [0, 0, 0]
  baked flt len=2 [0, 0]
  baked str len=2 ["", ""]

-- Polymorph with named return
  min/max(5,3) = 3, 5
  min/max(2.5,9.5) = 2.5, 9.5
  min/max(s32 7, s32 11) = 7, 11

-- $$T compile-time constant
  baked_value(<3>, 4) = 12
  baked_value(<7>, 6) = 42
  baked_value(<2>, 100) = 200

-- #if T == ... else
  describe(int) = int
  describe(float) = float
  describe(string) = string
  describe(bool) = bool
  describe(PE6_Vec2) = other

----------------------------------------------------------------
== 607. print_pretty via Any/reflection
----------------------------------------------------------------

-- Primitives
int64 = 42
float32 = 3.5
string len=5 "hello"
bool = true
uint32 = 3405705229

-- Pointer (nullity)
pointer null=false
pointer null=true

-- Enum
enum PE6_Color.BLUE (2)
enum PE6_Day.WED (2)
enum PE6_Phase.WANING (2)

-- Fixed array
array count=4
  int64 = 10
  int64 = 20
  int64 = 30
  int64 = 40

-- Array view
array count=3
  int64 = 1
  int64 = 2
  int64 = 3

-- Struct (nested)
struct PE6_Person {
  .name:
    string len=5 "Alice"
  .age:
    int64 = 30
  .address:
    struct PE6_Address {
      .street:
        string len=4 "Main"
      .city:
        string len=4 "Town"
      .zip:
        int64 = 1
    }
}

-- Deeply nested struct
struct PE6_Deep_Root {
  .header:
    string len=3 "hdr"
  .outer:
    struct PE6_Deep_Outer {
      .title:
        string len=6 "otitle"
      .middle:
        struct PE6_Deep_Middle {
          .label:
            string len=6 "mlabel"
          .inner:
            struct PE6_Deep_Inner {
              .n:
                int64 = 10
              .f:
                float32 = 1.5
              .s:
                string len=1 "z"
            }
          .count:
            int64 = 3
        }
      .extra:
        struct PE6_Vec3 {
          .x:
            float32 = 4
          .y:
            float32 = 5
          .z:
            float32 = 6
        }
    }
  .rgba:
    struct PE6_RGBA {
      .r:
        uint8 = 1
      .g:
        uint8 = 2
      .b:
        uint8 = 3
      .a:
        uint8 = 4
    }
  .nums:
    array count=3
      int64 = 7
      int64 = 8
      int64 = 9
}

----------------------------------------------------------------
== 608. Generic recursive equals via Any
----------------------------------------------------------------

-- Primitives
  int 7 == 7 -> true
  int 7 == 9 -> false
  flt 1.5 == 1.5 -> true
  flt 1.5 == 2.5 -> false
  str abc==abc -> true
  str abc==abd -> false

-- Enums
  RED==RED -> true
  RED==BLUE -> false

-- Arrays
  [1,2,3]==[1,2,3] -> true
  [1,2,3]==[1,2,4] -> false

-- Structs
  V3{1,2,3}==V3{1,2,3} -> true
  V3{1,2,3}==V3{1,2,4} -> false

-- Nested structs
  person a==b -> true
  person a==c -> false

-- Different types compare unequal
  int(5)==float(5.0) -> false

----------------------------------------------------------------
== 609. Tiny stack-machine interpreter
----------------------------------------------------------------

-- Program: push 1, push 2, add, print, halt
    [VM-OUT] 3
  steps=5 sp=1 halted=true error=''

-- Program computes (10 + 20) * 3 then prints
    [VM-OUT] 90

-- Program with sub, div, mod
    [VM-OUT] 65
    [VM-OUT] 3
    [VM-OUT] 2

-- DUP / SWAP / NEG
    [VM-OUT] 5
    [VM-OUT] 5
    [VM-OUT] -5

-- Division by zero stops the VM
  halted=true error=div-by-zero

-- Stack underflow on add
  halted=true error=stack-underflow

-- Compute fib of small input using the VM
    [VM-OUT] 128
  sp=2

