PE6_test_reflection_polymorphic_struct_sweep :: () {
    section("600d. Reflection sweep: polymorphic structs");

    sub("PE6_Box(T) with concrete T");
    PE6_print_struct_info_for("PE6_Box(int)",     type_info(PE6_Box(int)));
    PE6_print_struct_info_for("PE6_Box(float)",   type_info(PE6_Box(float)));
    PE6_print_struct_info_for("PE6_Box(string)",  type_info(PE6_Box(string)));
    PE6_print_struct_info_for("PE6_Box(PE6_Vec3)", type_info(PE6_Box(PE6_Vec3)));

    sub("Pair(A,B)");
    PE6_print_struct_info_for("Pair(int,float)",    type_info(PE6_Pair(int, float)));
    PE6_print_struct_info_for("Pair(string,int)",   type_info(PE6_Pair(string, int)));
    PE6_print_struct_info_for("Pair(PE6_Vec2,PE6_Vec2)",
                            type_info(PE6_Pair(PE6_Vec2, PE6_Vec2)));

    sub("Triple(A,B,C)");
    PE6_print_struct_info_for("Triple(int,float,string)",
                            type_info(Triple(int, float, string)));

    sub("Quad(A,B,C,D)");
    PE6_print_struct_info_for("Quad(u8,u16,u32,u64)",
                            type_info(Quad(u8, u16, u32, u64)));

    sub("Fixed_List(T,N)");
    PE6_print_struct_info_for("Fixed_List(int,4)",
                            type_info(PE6_Fixed_List(int, 4)));
    PE6_print_struct_info_for("Fixed_List(float,8)",
                            type_info(PE6_Fixed_List(float, 8)));

    sub("Stack/Queue/Ring");
    PE6_print_struct_info_for("Stack(int,8)",
                            type_info(PE6_Stack(int, 8)));
    PE6_print_struct_info_for("Queue(int,8)",
                            type_info(PE6_Queue(int, 8)));
    PE6_print_struct_info_for("Ring(int,4)",
                            type_info(PE6_Ring(int, 4)));

    sub("Map(K,V,CAP)");
    PE6_print_struct_info_for("Map(int,string,4)",
                            type_info(Map(int, string, 4)));
    PE6_print_struct_info_for("Map(string,int,4)",
                            type_info(Map(string, int, 4)));
}


// Deeply nested struct used by the recursive offset walker.
PE6_Deep_Inner :: struct {
    n: int;
    f: float;
    s: string;
}

PE6_Deep_Middle :: struct {
    label: string;
    inner: PE6_Deep_Inner;
    count: int;
}

PE6_Deep_Outer :: struct {
    title:  string;
    middle: PE6_Deep_Middle;
    extra:  PE6_Vec3;
}

PE6_Deep_Root :: struct {
    header: string;
    outer:  PE6_Deep_Outer;
    rgba:   PE6_RGBA;
    nums:   [3] int;
}

// Recursive walker over nested struct fields. Prints absolute byte offset of
// every leaf field (i.e. each non-struct member, plus the path through the
// struct hierarchy).
PE6_walk_struct_offsets :: (info: *Type_Info_Struct, base_offset: int, prefix: string) {
    for info.members {
        full_offset := base_offset + it.offset_in_bytes;
        path := tprint("%.%", prefix, it.name);
        if it.type.type == .STRUCT {
            inner := cast(*Type_Info_Struct) it.type;
            print("  %  (struct '%' size=%) offset=%\n",
                  path, inner.name, inner.runtime_size, full_offset);
            PE6_walk_struct_offsets(inner, full_offset, path);
        } else {
            print("  %  (tag=% size=%) offset=%\n",
                  path, it.type.type, it.type.runtime_size, full_offset);
        }
    }
}

PE6_test_reflection_deep_struct_offsets :: () {
    section("600e. Recursive offset walk over a deeply nested struct");

    print("walking PE6_Deep_Root (size=%):\n", size_of(PE6_Deep_Root));
    PE6_walk_struct_offsets(type_info(PE6_Deep_Root), 0, "PE6_Deep_Root");

    sub("Walking PE6_Network (Person->Address inside Company twice)");
    print("walking PE6_Network (size=%):\n", size_of(PE6_Network));
    PE6_walk_struct_offsets(type_info(PE6_Network), 0, "PE6_Network");
}


// ============================================================================
// 601. Manual struct serializer that emits a textual rep of any struct via
//      type_info introspection. Output stays deterministic.
// ============================================================================

PE6_append_byte_value :: (builder: *String_Builder, value_ptr: *void, size: int, signed_int: bool) {
    // For ints: read bytes as either signed or unsigned, then append decimal.
    // For floats handled separately. Strings handled separately.
    if size == {
        case 1;
            if signed_int {
                v : s8;
                memcpy(*v, value_ptr, 1);
                print_to_builder(builder, "%", cast(s64) v);
            } else {
                v : u8;
                memcpy(*v, value_ptr, 1);
                print_to_builder(builder, "%", cast(u64) v);
            }
        case 2;
            if signed_int {
                v : s16;
                memcpy(*v, value_ptr, 2);
                print_to_builder(builder, "%", cast(s64) v);
            } else {
                v : u16;
                memcpy(*v, value_ptr, 2);
                print_to_builder(builder, "%", cast(u64) v);
            }
        case 4;
            if signed_int {
                v : s32;
                memcpy(*v, value_ptr, 4);
                print_to_builder(builder, "%", cast(s64) v);
            } else {
                v : u32;
                memcpy(*v, value_ptr, 4);
                print_to_builder(builder, "%", cast(u64) v);
            }
        case 8;
            if signed_int {
                v : s64;
                memcpy(*v, value_ptr, 8);
                print_to_builder(builder, "%", v);
            } else {
                v : u64;
                memcpy(*v, value_ptr, 8);
                print_to_builder(builder, "%", v);
            }
        case;
            print_to_builder(builder, "<int-size=%>", size);
    }
}

PE6_serialize_any_to_builder :: (builder: *String_Builder, ti: *Type_Info, value_ptr: *void) {
    if ti.type == {
        case .INTEGER;
            ii := cast(*Type_Info_Integer) ti;
            PE6_append_byte_value(builder, value_ptr, ti.runtime_size, ii.signed);

        case .FLOAT;
            if ti.runtime_size == 4 {
                f : float32;
                memcpy(*f, value_ptr, 4);
                print_to_builder(builder, "%", f);
            } else if ti.runtime_size == 8 {
                f : float64;
                memcpy(*f, value_ptr, 8);
                print_to_builder(builder, "%", f);
            } else {
                print_to_builder(builder, "<float-size=%>", ti.runtime_size);
            }

        case .BOOL;
            v : bool;
            memcpy(*v, value_ptr, 1);
            print_to_builder(builder, "%", v);

        case .STRING;
            // A jai string is {count: s64, data: *u8}. We read the count and
            // data; for safety we don't dereference the bytes via address
            // arithmetic but instead memcpy the whole string into a local.
            s : string;
            memcpy(*s, value_ptr, size_of(string));
            print_to_builder(builder, "\"%\"", s);

        case .ENUM;
            ei := cast(*Type_Info_Enum) ti;
            // Read the enum value via its underlying integer type.
            v : s64 = 0;
            int_size := ei.internal_type.runtime_size;
            if int_size == 1 {
                if ei.internal_type.signed {
                    raw : s8;  memcpy(*raw, value_ptr, 1); v = raw;
                } else {
                    raw : u8;  memcpy(*raw, value_ptr, 1); v = raw;
                }
            } else if int_size == 2 {
                if ei.internal_type.signed {
                    raw : s16; memcpy(*raw, value_ptr, 2); v = raw;
                } else {
                    raw : u16; memcpy(*raw, value_ptr, 2); v = raw;
                }
            } else if int_size == 4 {
                if ei.internal_type.signed {
                    raw : s32; memcpy(*raw, value_ptr, 4); v = raw;
                } else {
                    raw : u32; memcpy(*raw, value_ptr, 4); v = cast,no_check(s64) raw;
                }
            } else if int_size == 8 {
                memcpy(*v, value_ptr, 8);
            }
            // Try to find a matching name; if not found, print as <int>.
            matched := false;
            for n, i: ei.names {
                if ei.values[i] == v {
                    print_to_builder(builder, "%.%", ei.name, n);
                    matched = true;
                    break;
                }
            }
            if !matched  print_to_builder(builder, "%(%)", ei.name, v);

        case .ARRAY;
            ai := cast(*Type_Info_Array) ti;
            count: int;
            data_ptr: *void;
            if ai.array_type == .FIXED {
                count = ai.array_count;
                data_ptr = value_ptr;
            } else if ai.array_type == .VIEW {
                view : [] u8 = ---;
                memcpy(*view, value_ptr, size_of([] u8));
                count = view.count;
                data_ptr = view.data;
            } else { // RESIZABLE
                ra : [..] u8 = ---;
                memcpy(*ra, value_ptr, size_of([..] u8));
                count = ra.count;
                data_ptr = ra.data;
            }
            elem_size := ai.element_type.runtime_size;
            print_to_builder(builder, "[");
            for 0..count-1 {
                if it > 0  print_to_builder(builder, ", ");
                cursor := cast(*u8) data_ptr + it * elem_size;
                PE6_serialize_any_to_builder(builder, ai.element_type, cursor);
            }
            print_to_builder(builder, "]");

        case .STRUCT;
            si := cast(*Type_Info_Struct) ti;
            print_to_builder(builder, "% {", si.name);
            for si.members {
                if it_index > 0  print_to_builder(builder, ", ");
                print_to_builder(builder, "%=", it.name);
                field_ptr := cast(*u8) value_ptr + it.offset_in_bytes;
                PE6_serialize_any_to_builder(builder, it.type, field_ptr);
            }
            print_to_builder(builder, "}");

        case .POINTER;
            pi : *void;
            memcpy(*pi, value_ptr, size_of(*void));
            if pi == null  print_to_builder(builder, "ptr=null");
            else           print_to_builder(builder, "ptr=non-null");

        case .VOID;
            print_to_builder(builder, "void");

        case .ANY;
            // Read the Any value to get type/pointer.
            a : Any;
            memcpy(*a, value_ptr, size_of(Any));
            if a.value_pointer == null {
                print_to_builder(builder, "any(null)");
            } else if a.type == null {
                print_to_builder(builder, "any(no-type)");
            } else {
                print_to_builder(builder, "any[%](", type_to_string(a.type));
                PE6_serialize_any_to_builder(builder, a.type, a.value_pointer);
                print_to_builder(builder, ")");
            }

        case;
            print_to_builder(builder, "<tag=%>", ti.type);
    }
}

PE6_serialize_to_string :: (a: Any) -> string {
    b : String_Builder;
    PE6_serialize_any_to_builder(*b, a.type, a.value_pointer);
    return builder_to_string(*b);
}

PE6_test_struct_serializer :: () {
    section("601. Manual struct serializer (via type_info introspection)");

    sub("Vec2 / Vec3");
    {
        v2 := PE6_Vec2.{1.5, 2.5};
        v3 := PE6_Vec3.{1.5, 2.5, 3.5};
        print("vec2 -> %\n", PE6_serialize_to_string(v2));
        print("vec3 -> %\n", PE6_serialize_to_string(v3));
    }

    sub("RGBA");
    {
        rgba := PE6_RGBA.{12, 34, 56, 78};
        print("rgba -> %\n", PE6_serialize_to_string(rgba));
    }

    sub("Address / Person");
    {
        a := PE6_Address.{street="Main", city="Springfield", zip=42};
        p := PE6_Person.{name="Alice", age=30, address=a};
        print("addr -> %\n", PE6_serialize_to_string(a));
        print("person -> %\n", PE6_serialize_to_string(p));
    }

    sub("Company nested two-deep");
    {
        c := PE6_Company.{
            name="Acme",
            founded=1900,
            boss=.{name="Bob", age=50, address=.{street="Side", city="Town", zip=99}},
        };
        print("company -> %\n", PE6_serialize_to_string(c));
    }

    sub("Network nested three-deep");
    {
        n := PE6_Network.{
            label="net",
            primary=.{name="A", founded=1, boss=.{name="x", age=1, address=.{street="s1", city="c1", zip=1}}},
            backup =.{name="B", founded=2, boss=.{name="y", age=2, address=.{street="s2", city="c2", zip=2}}},
        };
        print("net -> %\n", PE6_serialize_to_string(n));
    }

    sub("Many primitive");
    {
        m := PE6_Many_Primitive.{
            a_bool=true, a_s8=-1, a_s16=2, a_s32=-3, a_s64=4,
            a_u8=5, a_u16=6, a_u32=7, a_u64=8,
            a_f32=1.5, a_f64=2.25,
            a_str="hi",
        };
        print("many -> %\n", PE6_serialize_to_string(m));
    }

    sub("Fixed array inside struct");
    {
        d := PE6_Deep_Root.{
            header="head",
            outer=.{title="outer", middle=.{label="mid", inner=.{n=10, f=1.5, s="x"}, count=4},
                    extra=.{1,2,3}},
            rgba=.{1,2,3,4},
            nums=.[10, 20, 30],
        };
        print("deep -> %\n", PE6_serialize_to_string(d));
    }

    sub("Polymorphic structs");
    {
        bi := PE6_Box(int).{value=99};
        bs := PE6_Box(string).{value="ninety-nine"};
        print("box-int -> %\n",    PE6_serialize_to_string(bi));
        print("box-str -> %\n",    PE6_serialize_to_string(bs));

        pr := PE6_Pair(int, string).{first=7, second="seven"};
        print("pair -> %\n", PE6_serialize_to_string(pr));

        tr := Triple(int, float, string).{first=1, second=2.5, third="three"};
        print("triple -> %\n", PE6_serialize_to_string(tr));

        qd := Quad(u8, u16, u32, u64).{a=1, b=2, c=3, d=4};
        print("quad -> %\n", PE6_serialize_to_string(qd));
    }

    sub("Enums in serialized output");
    {
        e := PE6_Color.GREEN;
        f := PE6_Day.WED;
        print("color -> %\n", PE6_serialize_to_string(e));
        print("day -> %\n",   PE6_serialize_to_string(f));
    }
}


// ============================================================================
// 602. Manual binary blob writer: memcpy bytes out, then read back and
//      compare equality.
// ============================================================================

PE6_write_struct_bytes :: (dst: [] u8, value_ptr: *void, size: int) -> int {
    assert(dst.count >= size);
    memcpy(dst.data, value_ptr, size);
    return size;
}

PE6_read_struct_bytes :: (src: [] u8, value_ptr: *void, size: int) -> int {
    assert(src.count >= size);
    memcpy(value_ptr, src.data, size);
    return size;
}

PE6_bytes_equal :: (a: [] u8, b: [] u8) -> bool {
    if a.count != b.count  return false;
    for 0..a.count-1 {
        if a[it] != b[it]  return false;
    }
    return true;
}

PE6_test_struct_blob_writer :: () {
    section("602. Binary blob writer (memcpy round trip)");

    sub("Round trip a Vec3");
    {
        original := PE6_Vec3.{1.5, 2.5, 3.5};
        buf: [size_of(PE6_Vec3)] u8;
        wrote := PE6_write_struct_bytes(buf, *original, size_of(PE6_Vec3));
        print("wrote=% bytes\n", wrote);

        readback: PE6_Vec3;
        read_n := PE6_read_struct_bytes(buf, *readback, size_of(PE6_Vec3));
        print("read=% bytes\n", read_n);
        same := (original.x == readback.x && original.y == readback.y && original.z == readback.z);
        print("equal=% original=% readback=%\n", same, original, readback);
    }

    sub("Round trip an RGBA");
    {
        original := PE6_RGBA.{0xAA, 0xBB, 0xCC, 0xDD};
        buf: [size_of(PE6_RGBA)] u8;
        PE6_write_struct_bytes(buf, *original, size_of(PE6_RGBA));

        readback: PE6_RGBA;
        PE6_read_struct_bytes(buf, *readback, size_of(PE6_RGBA));
        same := (original.r==readback.r && original.g==readback.g
                 && original.b==readback.b && original.a==readback.a);
        print("equal=% bytes_buf=%\n", same, buf);
    }

    sub("Compare bytes between two equal Vec3s");
    {
        a := PE6_Vec3.{1.0, 2.0, 3.0};
        b := PE6_Vec3.{1.0, 2.0, 3.0};
        buf_a: [size_of(PE6_Vec3)] u8;
        buf_b: [size_of(PE6_Vec3)] u8;
        PE6_write_struct_bytes(buf_a, *a, size_of(PE6_Vec3));
        PE6_write_struct_bytes(buf_b, *b, size_of(PE6_Vec3));
        eq := PE6_bytes_equal(buf_a, buf_b);
        print("equal-bytes-when-values-equal=%\n", eq);
    }

    sub("Compare bytes between two unequal Vec3s");
    {
        a := PE6_Vec3.{1.0, 2.0, 3.0};
        b := PE6_Vec3.{1.0, 2.0, 4.0};
        buf_a: [size_of(PE6_Vec3)] u8;
        buf_b: [size_of(PE6_Vec3)] u8;
        PE6_write_struct_bytes(buf_a, *a, size_of(PE6_Vec3));
        PE6_write_struct_bytes(buf_b, *b, size_of(PE6_Vec3));
        eq := PE6_bytes_equal(buf_a, buf_b);
        print("equal-bytes-when-values-differ=%\n", eq);
    }

    sub("Round trip a Many_Primitive (without the string)");
    {
        original := PE6_Many_Primitive.{
            a_bool=true, a_s8=-1, a_s16=-2, a_s32=-3, a_s64=-4,
            a_u8=5, a_u16=6, a_u32=7, a_u64=8,
            a_f32=1.5, a_f64=2.25,
            a_str="",      // empty so byte-equality is meaningful across runs
        };
        N :: size_of(PE6_Many_Primitive);
        buf: [N] u8;
        PE6_write_struct_bytes(buf, *original, N);

        readback: PE6_Many_Primitive;
        PE6_read_struct_bytes(buf, *readback, N);

        same := original.a_bool == readback.a_bool
             && original.a_s8   == readback.a_s8
             && original.a_s16  == readback.a_s16
             && original.a_s32  == readback.a_s32
             && original.a_s64  == readback.a_s64
             && original.a_u8   == readback.a_u8
             && original.a_u16  == readback.a_u16
             && original.a_u32  == readback.a_u32
             && original.a_u64  == readback.a_u64
             && original.a_f32  == readback.a_f32
             && original.a_f64  == readback.a_f64;
        print("scalars-equal=%\n", same);
    }

    sub("Round trip a PE6_Person (without strings since strings are pointers)");
    {
        p1 := PE6_Person.{name="", age=99, address=.{street="", city="", zip=42}};
        N :: size_of(PE6_Person);
        buf: [N] u8;
        PE6_write_struct_bytes(buf, *p1, N);

        p2: PE6_Person;
        PE6_read_struct_bytes(buf, *p2, N);
        // count of name is what we care about (since data was null we did NOT
        // touch a heap pointer).
        same := p1.age == p2.age
             && p1.address.zip == p2.address.zip
             && p1.name.count == p2.name.count
             && p1.address.street.count == p2.address.street.count;
        print("person-scalar-roundtrip=%\n", same);
    }

    sub("Round trip a PE6_Box(int)");
    {
        b1 := PE6_Box(int).{value=12345};
        buf: [size_of(PE6_Box(int))] u8;
        PE6_write_struct_bytes(buf, *b1, size_of(PE6_Box(int)));
        b2: PE6_Box(int);
        PE6_read_struct_bytes(buf, *b2, size_of(PE6_Box(int)));
        print("box-int roundtrip equal=% original=% readback=%\n",
              b1.value == b2.value, b1.value, b2.value);
    }
}


// ============================================================================
// 603. Field walker: counts integer/float/string/struct/pointer fields in a
//      struct via reflection. Recursive variant counts at the leaf level.
// ============================================================================

PE6_Field_Stats :: struct {
    integers: int;
    floats:   int;
    strings:  int;
    structs:  int;
    pointers: int;
    arrays:   int;
    enums:    int;
    bools:    int;
    others:   int;
}

PE6_classify_top_level :: (info: *Type_Info_Struct) -> PE6_Field_Stats {
    out: PE6_Field_Stats;
    for info.members {
        if it.type.type == {
            case .INTEGER; out.integers += 1;
            case .FLOAT;   out.floats   += 1;
            case .STRING;  out.strings  += 1;
            case .STRUCT;  out.structs  += 1;
            case .POINTER; out.pointers += 1;
            case .ARRAY;   out.arrays   += 1;
            case .ENUM;    out.enums    += 1;
            case .BOOL;    out.bools    += 1;
            case;          out.others   += 1;
        }
    }
    return out;
}

PE6_classify_recursive :: (info: *Type_Info_Struct, stats: *PE6_Field_Stats) {
    for info.members {
        if it.type.type == {
            case .INTEGER; stats.integers += 1;
            case .FLOAT;   stats.floats   += 1;
            case .STRING;  stats.strings  += 1;
            case .POINTER; stats.pointers += 1;
            case .ARRAY;   stats.arrays   += 1;
            case .ENUM;    stats.enums    += 1;
            case .BOOL;    stats.bools    += 1;
            case .STRUCT;
                stats.structs += 1;
                inner := cast(*Type_Info_Struct) it.type;
                PE6_classify_recursive(inner, stats);
            case;
                stats.others += 1;
        }
    }
}

PE6_print_stats :: (label: string, s: PE6_Field_Stats) {
    print("  % ints=% floats=% strings=% structs=% pointers=% arrays=% enums=% bools=% others=%\n",
          label, s.integers, s.floats, s.strings, s.structs, s.pointers,
          s.arrays, s.enums, s.bools, s.others);
}

PE6_test_field_walker :: () {
    section("603. Field walker: counts by reflection");

    sub("Top-level counts");
    PE6_print_stats("Vec2",            PE6_classify_top_level(type_info(PE6_Vec2)));
    PE6_print_stats("Vec3",            PE6_classify_top_level(type_info(PE6_Vec3)));
    PE6_print_stats("RGBA",            PE6_classify_top_level(type_info(PE6_RGBA)));
    PE6_print_stats("Address",         PE6_classify_top_level(type_info(PE6_Address)));
    PE6_print_stats("Person",          PE6_classify_top_level(type_info(PE6_Person)));
    PE6_print_stats("Company",         PE6_classify_top_level(type_info(PE6_Company)));
    PE6_print_stats("Network",         PE6_classify_top_level(type_info(PE6_Network)));
    PE6_print_stats("Many_Primitive",  PE6_classify_top_level(type_info(PE6_Many_Primitive)));
    PE6_print_stats("Deep_Root",       PE6_classify_top_level(type_info(PE6_Deep_Root)));

    sub("Recursive counts");
    {
        s: PE6_Field_Stats;
        PE6_classify_recursive(type_info(PE6_Network), *s);
        PE6_print_stats("Network (recursive)", s);
    }
    {
        s: PE6_Field_Stats;
        PE6_classify_recursive(type_info(PE6_Deep_Root), *s);
        PE6_print_stats("Deep_Root (recursive)", s);
    }
    {
        s: PE6_Field_Stats;
        PE6_classify_recursive(type_info(PE6_Group), *s);
        PE6_print_stats("Group (recursive)", s);
    }
}


// ============================================================================
// 604. Enum operations: lots of enum types, names, values, ranges,
//      #specified bit, bitwise ops on enum_flags, build a flag combo and
//      decompose it back to a list of names.
// ============================================================================

PE6_print_enum_listing :: ($T: Type, label: string) {
    info := type_info(T);
    print("  enum % name='%' size=% members=% complete=% specified=% flags=%\n",
          label, info.name, info.runtime_size, info.names.count,
          (info.enum_type_flags & .COMPLETE)  != 0,
          (info.enum_type_flags & .SPECIFIED) != 0,
          (info.enum_type_flags & .FLAGS)     != 0);
    print("    names = %\n", info.names);
    print("    values = %\n", info.values);
    print("    typed-values = %\n", enum_values_as_enum(T));
}

PE6_test_enum_listings :: () {
    section("604. Enum listings");
    PE6_print_enum_listing(PE6_Color,      "PE6_Color");
    PE6_print_enum_listing(PE6_Tone,       "PE6_Tone");
    PE6_print_enum_listing(PE6_Day,        "PE6_Day");
    PE6_print_enum_listing(PE6_Month,      "PE6_Month");
    PE6_print_enum_listing(PE6_Compass,    "PE6_Compass");
    PE6_print_enum_listing(PE6_Phase,      "PE6_Phase");
    PE6_print_enum_listing(PE6_Permission, "PE6_Permission");
    PE6_print_enum_listing(PE6_Capability, "PE6_Capability");
    PE6_print_enum_listing(PE6_Build,      "PE6_Build");
}

PE6_test_enum_ranges_and_specified :: () {
    section("604a. Enum range / #specified bit");

    sub("Ranges");
    {
        lo, hi := enum_range(PE6_Color);
        print("  PE6_Color range = [%, %]\n", lo, hi);
    }
    {
        lo, hi := enum_range(PE6_Tone);
        print("  PE6_Tone range = [%, %]\n", lo, hi);
    }
    {
        lo, hi := enum_range(PE6_Day);
        print("  PE6_Day range = [%, %]\n", lo, hi);
    }
    {
        lo, hi := enum_range(PE6_Month);
        print("  PE6_Month range = [%, %]\n", lo, hi);
    }
    {
        lo, hi := enum_range(PE6_Phase);
        print("  PE6_Phase range = [%, %]\n", lo, hi);
    }

    sub("#specified bit");
    print("  PE6_Color    specified? %\n",
          (type_info(PE6_Color).enum_type_flags & .SPECIFIED) != 0);
    print("  PE6_Tone     specified? %\n",
          (type_info(PE6_Tone).enum_type_flags & .SPECIFIED) != 0);
    print("  PE6_Day      specified? %\n",
          (type_info(PE6_Day).enum_type_flags & .SPECIFIED) != 0);
    print("  PE6_Month    specified? %\n",
          (type_info(PE6_Month).enum_type_flags & .SPECIFIED) != 0);
    print("  PE6_Compass  specified? %\n",
          (type_info(PE6_Compass).enum_type_flags & .SPECIFIED) != 0);
    print("  PE6_Phase    specified? %\n",
          (type_info(PE6_Phase).enum_type_flags & .SPECIFIED) != 0);
}

PE6_test_enum_flag_ops :: () {
    section("604b. enum_flags bitwise ops");

    sub("PE6_Permission combinations");
    p: PE6_Permission;
    print("  start: %\n", p);
    p |= .READ;
    print("  after |= READ: %\n", p);
    p |= .WRITE;
    print("  after |= WRITE: %\n", p);
    p |= .EXEC;
    print("  after |= EXEC: %\n", p);
    has_read  := (p & .READ)  != 0;
    has_write := (p & .WRITE) != 0;
    has_exec  := (p & .EXEC)  != 0;
    has_spec  := (p & .SPECIAL) != 0;
    print("  flags: READ=% WRITE=% EXEC=% SPECIAL=%\n",
          has_read, has_write, has_exec, has_spec);
    p &= ~.WRITE;
    print("  after &= ~WRITE: %\n", p);
    p ^= .SPECIAL;
    print("  after ^= SPECIAL: %\n", p);
    p ^= .SPECIAL;
    print("  after ^= SPECIAL again: %\n", p);

    sub("PE6_Capability combinations");
    c: PE6_Capability;
    c |= .NETWORK;
    c |= .DISK;
    c |= .GPU;
    print("  start (NETWORK|DISK|GPU): %\n", c);
    c |= .USB;
    print("  add USB: %\n", c);
    c &= ~.DISK;
    print("  drop DISK: %\n", c);

    // Bitwise combination using literal bit positions.
    full_perm: PE6_Permission = .READ | .WRITE | .EXEC | .SPECIAL;
    print("  full PE6_Permission = %\n", full_perm);

    sub("PE6_Build combinations");
    b: PE6_Build = .DEBUG_BUILD | .PROFILE_BUILD;
    print("  initial: %\n", b);
    b |= .TEST_BUILD;
    print("  after | TEST: %\n", b);
    b &= ~.DEBUG_BUILD;
    print("  drop DEBUG: %\n", b);
}

// Decompose a flag combo back into a list of name strings.
PE6_decompose_flag :: (a: Any) -> [..] string {
    out: [..] string;
    if a.type.type != .ENUM  return out;

    ei := cast(*Type_Info_Enum) a.type;

    // Read the value into an s64 using the internal integer width.
    v : s64 = 0;
    int_size := ei.internal_type.runtime_size;
    if int_size == 1 {
        if ei.internal_type.signed {
            raw : s8;  memcpy(*raw, a.value_pointer, 1); v = raw;
        } else {
            raw : u8;  memcpy(*raw, a.value_pointer, 1); v = raw;
        }
    } else if int_size == 2 {
        if ei.internal_type.signed {
            raw : s16; memcpy(*raw, a.value_pointer, 2); v = raw;
        } else {
            raw : u16; memcpy(*raw, a.value_pointer, 2); v = raw;
        }
    } else if int_size == 4 {
        if ei.internal_type.signed {
            raw : s32; memcpy(*raw, a.value_pointer, 4); v = raw;
        } else {
            raw : u32; memcpy(*raw, a.value_pointer, 4); v = cast,no_check(s64) raw;
        }
    } else if int_size == 8 {
        memcpy(*v, a.value_pointer, 8);
    }

    for n, i: ei.names {
        bit := ei.values[i];
        if bit == 0  continue;
        if (v & bit) == bit {
            array_add(*out, n);
        }
    }
    return out;
}

PE6_test_flag_decomposition :: () {
    section("604c. Flag combo decomposition");

    {
        p: PE6_Permission = .READ | .EXEC;
        names := PE6_decompose_flag(p);
        print("  READ|EXEC -> %\n", names);
    }
    {
        p: PE6_Permission = .READ | .WRITE | .EXEC | .SPECIAL;
        names := PE6_decompose_flag(p);
        print("  ALL -> %\n", names);
    }
    {
        p: PE6_Permission;
        names := PE6_decompose_flag(p);
        print("  NONE -> %\n", names);
    }
    {
        c: PE6_Capability = .NETWORK | .GPU | .BLUETOOTH;
        names := PE6_decompose_flag(c);
        print("  NETWORK|GPU|BLUETOOTH -> %\n", names);
    }
    {
        c: PE6_Capability = .DISK | .USB | .DMA | .AUDIO | .VIDEO;
        names := PE6_decompose_flag(c);
        print("  DISK|USB|DMA|AUDIO|VIDEO -> %\n", names);
    }
    {
        b: PE6_Build = .DEBUG_BUILD | .TEST_BUILD | .BENCHMARK_BUILD;
        names := PE6_decompose_flag(b);
        print("  DEBUG|TEST|BENCHMARK -> %\n", names);
    }
}


// ============================================================================
// 605. Polymorphic struct exercises.
// ============================================================================

PE6_test_box_pair_triple_quad :: () {
    section("605. PE6_Box/Pair/Triple/Quad");

    sub("PE6_Box(T)");
    {
        bi := PE6_Box(int).{value=10};
        bf := PE6_Box(float).{value=2.5};
        bs := PE6_Box(string).{value="hello"};
        bv := PE6_Box(PE6_Vec3).{value=.{1,2,3}};
        print("  box-int   = %\n", bi);
        print("  box-float = %\n", bf);
        print("  box-str   = %\n", bs);
        print("  box-vec3  = %\n", bv);
        print("  type box-int    = %\n", type_to_string(type_info(type_of(bi))));
        print("  type box-vec3   = %\n", type_to_string(type_info(type_of(bv))));
    }

    sub("Pair(A,B)");
    {
        p1 := PE6_Pair(int, string).{first=1, second="one"};
        p2 := PE6_Pair(float, float).{first=1.5, second=2.5};
        p3 := PE6_Pair(PE6_Vec2, PE6_Vec3).{first=.{1,2}, second=.{3,4,5}};
        print("  pair int+str = %\n", p1);
        print("  pair flt+flt = %\n", p2);
        print("  pair v2+v3   = %\n", p3);
    }

    sub("Triple(A,B,C)");
    {
        t := Triple(int, float, string).{first=1, second=2.5, third="three"};
        print("  triple = %\n", t);

        t2 := Triple(string, PE6_Vec2, PE6_Color).{first="lbl", second=.{0,1}, third=.BLUE};
        print("  triple2 = %\n", t2);
    }

    sub("Quad(A,B,C,D)");
    {
        q := Quad(u8, u16, u32, u64).{a=1, b=2, c=3, d=4};
        print("  quad uints = %\n", q);

        q2 := Quad(PE6_Color, PE6_Day, PE6_Compass, PE6_Phase).{
            a=.RED, b=.WED, c=.NORTH, d=.FULL};
        print("  quad enums = %\n", q2);
    }
}

// Map insert / lookup / remove
PE6_map_put :: (m: *Map($K, $V, $CAP), key: K, val: V) -> bool {
    // Look for existing.
    for 0..m.count-1 {
        if m.keys[it] == key {
            m.vals[it] = val;
            return true;
        }
    }
    if m.count >= CAP  return false;
    m.keys[m.count] = key;
    m.vals[m.count] = val;
    m.count += 1;
    return true;
}

PE6_map_get :: (m: *Map($K, $V, $CAP), key: K) -> (V, bool) {
    for 0..m.count-1 {
        if m.keys[it] == key {
            return m.vals[it], true;
        }
    }
    zero: V;
    return zero, false;
}

PE6_map_remove :: (m: *Map($K, $V, $CAP), key: K) -> bool {
    for 0..m.count-1 {
        if m.keys[it] == key {
            // Swap-with-last.
            last := m.count - 1;
            if it != last {
                m.keys[it] = m.keys[last];
                m.vals[it] = m.vals[last];
            }
            m.count -= 1;
            return true;
        }
    }
    return false;
}

PE6_test_map :: () {
    section("605a. Map(K,V,CAP)");

    sub("Map(int,string,4)");
    {
        m: Map(int, string, 4);
        ok := PE6_map_put(*m, 1, "one");      print("  put 1=one: ok=%, count=%\n", ok, m.count);
        ok  = PE6_map_put(*m, 2, "two");      print("  put 2=two: ok=%, count=%\n", ok, m.count);
        ok  = PE6_map_put(*m, 3, "three");    print("  put 3=three: ok=%, count=%\n", ok, m.count);
        ok  = PE6_map_put(*m, 4, "four");     print("  put 4=four: ok=%, count=%\n", ok, m.count);
        ok  = PE6_map_put(*m, 5, "five");     print("  put 5=five (overflow): ok=%, count=%\n", ok, m.count);
        v, found := PE6_map_get(*m, 2);       print("  get 2: '%' found=%\n", v, found);
        v, found  = PE6_map_get(*m, 7);       print("  get 7: '%' found=%\n", v, found);

        ok = PE6_map_put(*m, 2, "TWO");        print("  put 2=TWO (update): ok=%, count=%\n", ok, m.count);
        v, found = PE6_map_get(*m, 2);         print("  get 2: '%' found=%\n", v, found);

        removed := PE6_map_remove(*m, 3);      print("  remove 3: ok=%, count=%\n", removed, m.count);
        removed  = PE6_map_remove(*m, 99);     print("  remove 99: ok=%, count=%\n", removed, m.count);

        for 0..m.count-1 {
            print("    slot[%]: key=% val=%\n", it, m.keys[it], m.vals[it]);
        }
    }

    sub("Map(string,int,4)");
    {
        m: Map(string, int, 4);
        PE6_map_put(*m, "a", 1);
        PE6_map_put(*m, "b", 2);
        PE6_map_put(*m, "c", 3);
        v, found := PE6_map_get(*m, "b");
        print("  get 'b' = % found=%\n", v, found);
        v, found  = PE6_map_get(*m, "z");
        print("  get 'z' = % found=%\n", v, found);
        print("  count = %\n", m.count);
    }
}

PE6_stack_push :: (s: *PE6_Stack($T, $CAP), v: T) -> bool {
    if s.count >= CAP  return false;
    s.data[s.count] = v;
    s.count += 1;
    return true;
}

PE6_stack_pop :: (s: *PE6_Stack($T, $CAP)) -> (T, bool) {
    if s.count == 0 {
        z: T;
        return z, false;
    }
    s.count -= 1;
    return s.data[s.count], true;
}

PE6_stack_peek :: (s: PE6_Stack($T, $CAP)) -> (T, bool) {
    if s.count == 0 {
        z: T;
        return z, false;
    }
    return s.data[s.count - 1], true;
}

PE6_test_stack :: () {
    section("605b. Stack(T,CAP)");

    sub("Stack(int,4)");
    {
        st: PE6_Stack(int, 4);
        for v: int.[10, 20, 30, 40, 50] {
            ok := PE6_stack_push(*st, v);
            print("  push %: ok=% count=%\n", v, ok, st.count);
        }
        top, has := PE6_stack_peek(st);
        print("  peek -> % has=%\n", top, has);
        for 1..5 {
            v, ok := PE6_stack_pop(*st);
            print("  pop -> % ok=% count=%\n", v, ok, st.count);
        }
    }

    sub("Stack(string,3)");
    {
        st: PE6_Stack(string, 3);
        PE6_stack_push(*st, "a");
        PE6_stack_push(*st, "b");
        PE6_stack_push(*st, "c");
        for 1..3 {
            v, ok := PE6_stack_pop(*st);
            print("  pop -> % ok=%\n", v, ok);
        }
    }
}

PE6_queue_push :: (q: *PE6_Queue($T, $CAP), v: T) -> bool {
    if q.count >= CAP  return false;
    q.data[q.tail] = v;
    q.tail = (q.tail + 1) % CAP;
    q.count += 1;
    return true;
}

PE6_queue_pop :: (q: *PE6_Queue($T, $CAP)) -> (T, bool) {
    if q.count == 0 {
        z: T;
        return z, false;
    }
    v := q.data[q.head];
    q.head = (q.head + 1) % CAP;
    q.count -= 1;
    return v, true;
}

PE6_test_queue :: () {
    section("605c. Queue(T,CAP)");

    sub("Queue(int,4) FIFO");
    {
        q: PE6_Queue(int, 4);
        for v: int.[1, 2, 3, 4] {
            ok := PE6_queue_push(*q, v);
            print("  push %: ok=% count=%\n", v, ok, q.count);
        }
        // Overflow
        ok := PE6_queue_push(*q, 5);
        print("  push 5 (overflow): ok=% count=%\n", ok, q.count);

        for 1..4 {
            v, taken := PE6_queue_pop(*q);
            print("  pop -> % taken=% count=%\n", v, taken, q.count);
        }

        // Empty pop
        v, taken := PE6_queue_pop(*q);
        print("  pop empty -> % taken=%\n", v, taken);
    }

    sub("Queue(int,3) wrap around");
    {
        q: PE6_Queue(int, 3);
        PE6_queue_push(*q, 100);
        PE6_queue_push(*q, 200);
        v, _ := PE6_queue_pop(*q);
        print("  popped %\n", v);
        PE6_queue_push(*q, 300);
        PE6_queue_push(*q, 400);
        // Now head/tail have wrapped.
        for 1..3 {
            v, taken := PE6_queue_pop(*q);
            print("  pop -> % taken=%\n", v, taken);
        }
    }
}

PE6_ring_write :: (r: *PE6_Ring($T, $CAP), v: T) {
    r.data[r.cursor] = v;
    r.cursor = (r.cursor + 1) % CAP;
    if r.count < CAP  r.count += 1;
}

PE6_ring_at_age :: (r: PE6_Ring($T, $CAP), age: int) -> (T, bool) {
    if age < 0 || age >= r.count {
        z: T;
        return z, false;
    }
    // Newest written had cursor-1 (mod CAP)
    idx := (r.cursor - 1 - age + 2*CAP) % CAP;
    return r.data[idx], true;
}

PE6_test_ring :: () {
    section("605d. Ring(T,CAP)");

    sub("Ring(int,4) accepts overflow by overwriting oldest");
    {
        r: PE6_Ring(int, 4);
        for v: int.[1, 2, 3, 4, 5, 6] {
            PE6_ring_write(*r, v);
            print("  wrote %: cursor=% count=%\n", v, r.cursor, r.count);
        }
        for age: 0..3 {
            v, ok := PE6_ring_at_age(r, age);
            print("  age %: % ok=%\n", age, v, ok);
        }
        // Out-of-range
        v, ok := PE6_ring_at_age(r, 4);
        print("  age 4 (out): % ok=%\n", v, ok);
    }
}

PE6_fixed_list_add :: (list: *PE6_Fixed_List($T, $N), v: T) -> bool {
    if list.count >= N  return false;
    list.data[list.count] = v;
    list.count += 1;
    return true;
}

PE6_fixed_list_remove_at :: (list: *PE6_Fixed_List($T, $N), idx: int) -> bool {
    if idx < 0 || idx >= list.count  return false;
    last := list.count - 1;
    if idx != last  list.data[idx] = list.data[last];
    list.count -= 1;
    return true;
}

PE6_test_fixed_list :: () {
    section("605e. Fixed_List(T,N)");

    sub("Fixed_List(int,5)");
    {
        l: PE6_Fixed_List(int, 5);
        for v: int.[10, 20, 30, 40, 50, 60] {
            ok := PE6_fixed_list_add(*l, v);
            print("  add %: ok=% count=%\n", v, ok, l.count);
        }
        for 0..l.count-1 {
            print("  [%]=%\n", it, l.data[it]);
        }
        ok := PE6_fixed_list_remove_at(*l, 1);
        print("  remove_at(1): ok=% count=%\n", ok, l.count);
        for 0..l.count-1 {
            print("  [%]=%\n", it, l.data[it]);
        }
    }

    sub("Fixed_List(string,3)");
    {
        l: PE6_Fixed_List(string, 3);
        PE6_fixed_list_add(*l, "alpha");
        PE6_fixed_list_add(*l, "beta");
        PE6_fixed_list_add(*l, "gamma");
        for 0..l.count-1 {
            print("  [%]='%'\n", it, l.data[it]);
        }
    }
}


// ============================================================================
// 606. Polymorphic procedure forms.
// ============================================================================

// Variadic with polymorph type element.
PE6_poly_varargs_sum :: (xs: ..$T) -> T {
    sum: T;
    for xs  sum += it;
    return sum;
}

// Variadic with polymorph and explicit prefix.
PE6_poly_varargs_join :: (sep: string, xs: ..$T) -> string {
    b: String_Builder;
    for xs {
        if it_index > 0  append(*b, sep);
        print_to_builder(*b, "%", it);
    }
    return builder_to_string(*b);
}

// Polymorph with baked Type.
PE6_poly_baked_first :: ($T: Type, count: int) -> [..] T {
    out: [..] T;
    for 1..count {
        v: T;
        array_add(*out, v);
    }
    return out;
}

// Polymorph with named return.
PE6_poly_named_return :: (a: $T, b: T) -> (mn: T, mx: T) {
    if a <= b  return a, b;
    return b, a;
}

// Polymorph using $$T compile-time-only constant value.
PE6_poly_baked_value :: ($$N: int, m: int) -> int {
    return N * m;
}

// Compile-time choice between branches using #if T == ... else.
PE6_poly_describe :: (x: $T) -> string {
    #if T == int   return "int";
    else #if T == float  return "float";
    else #if T == string return "string";
    else #if T == bool   return "bool";
    else return "other";
}

PE6_test_poly_procedures :: () {
    section("606. Polymorphic procedure forms");

    sub("Variadic polymorph");
    print("  sum(int) = %\n",    PE6_poly_varargs_sum(1, 2, 3, 4, 5));
    print("  sum(float) = %\n",  PE6_poly_varargs_sum(1.5, 2.5, 3.0));
    print("  join(int) = %\n",   PE6_poly_varargs_join("/", 10, 20, 30));
    print("  join(str) = %\n",   PE6_poly_varargs_join("-", "a", "b", "c"));

    sub("Polymorph with baked Type");
    {
        a := PE6_poly_baked_first(int,    3);
        b := PE6_poly_baked_first(float,  2);
        c := PE6_poly_baked_first(string, 2);
        print("  baked int len=% %\n", a.count, a);
        print("  baked flt len=% %\n", b.count, b);
        print("  baked str len=% %\n", c.count, c);
    }

    sub("Polymorph with named return");
    {
        mn, mx := PE6_poly_named_return(5, 3);
        print("  min/max(5,3) = %, %\n", mn, mx);
    }
    {
        mn, mx := PE6_poly_named_return(2.5, 9.5);
        print("  min/max(2.5,9.5) = %, %\n", mn, mx);
    }
    {
        mn, mx := PE6_poly_named_return(cast(s32) 7, cast(s32) 11);
        print("  min/max(s32 7, s32 11) = %, %\n", mn, mx);
    }

    sub("$$T compile-time constant");
    print("  baked_value(<3>, 4) = %\n", PE6_poly_baked_value(3, 4));
    print("  baked_value(<7>, 6) = %\n", PE6_poly_baked_value(7, 6));
    print("  baked_value(<2>, 100) = %\n", PE6_poly_baked_value(2, 100));

    sub("#if T == ... else");
    print("  describe(int) = %\n",     PE6_poly_describe(7));
    print("  describe(float) = %\n",   PE6_poly_describe(1.5));
    print("  describe(string) = %\n",  PE6_poly_describe("hi"));
    print("  describe(bool) = %\n",    PE6_poly_describe(true));
    print("  describe(PE6_Vec2) = %\n", PE6_poly_describe(PE6_Vec2.{1,2}));
}


// ============================================================================
// 607. Generic print_pretty via reflection on Any.
// ============================================================================

PE6_print_pretty :: (a: Any, indent: int = 0) {
    if a.type == null {
        for 1..indent print(" ");
        print("<null type>\n");
        return;
    }

    if a.value_pointer == null {
        for 1..indent print(" ");
        print("<null value>\n");
        return;
    }

    for 1..indent print(" ");

    if a.type.type == {
        case .INTEGER;
            ii := cast(*Type_Info_Integer) a.type;
            sz := a.type.runtime_size;
            if sz == 1 {
                if ii.signed {
                    v: s8; memcpy(*v, a.value_pointer, 1);
                    print("int8 = %\n", cast(s64) v);
                } else {
                    v: u8; memcpy(*v, a.value_pointer, 1);
                    print("uint8 = %\n", cast(u64) v);
                }
            } else if sz == 2 {
                if ii.signed {
                    v: s16; memcpy(*v, a.value_pointer, 2);
                    print("int16 = %\n", cast(s64) v);
                } else {
                    v: u16; memcpy(*v, a.value_pointer, 2);
                    print("uint16 = %\n", cast(u64) v);
                }
            } else if sz == 4 {
                if ii.signed {
                    v: s32; memcpy(*v, a.value_pointer, 4);
                    print("int32 = %\n", cast(s64) v);
                } else {
                    v: u32; memcpy(*v, a.value_pointer, 4);
                    print("uint32 = %\n", cast(u64) v);
                }
            } else if sz == 8 {
                if ii.signed {
                    v: s64; memcpy(*v, a.value_pointer, 8);
                    print("int64 = %\n", v);
                } else {
                    v: u64; memcpy(*v, a.value_pointer, 8);
                    print("uint64 = %\n", v);
                }
            } else {
                print("int<sz=%>\n", sz);
            }

        case .FLOAT;
            if a.type.runtime_size == 4 {
                v: float32; memcpy(*v, a.value_pointer, 4);
                print("float32 = %\n", v);
            } else if a.type.runtime_size == 8 {
                v: float64; memcpy(*v, a.value_pointer, 8);
                print("float64 = %\n", v);
            } else {
                print("float<sz=%>\n", a.type.runtime_size);
            }

        case .STRING;
            s: string; memcpy(*s, a.value_pointer, size_of(string));
            print("string len=% \"%\"\n", s.count, s);

        case .BOOL;
            v: bool; memcpy(*v, a.value_pointer, 1);
            print("bool = %\n", v);

        case .POINTER;
            p: *void; memcpy(*p, a.value_pointer, size_of(*void));
            print("pointer null=%\n", p == null);

        case .ENUM;
            ei := cast(*Type_Info_Enum) a.type;
            v : s64 = 0;
            int_size := ei.internal_type.runtime_size;
            if int_size == 1 {
                if ei.internal_type.signed { r: s8;  memcpy(*r, a.value_pointer, 1); v = r; }
                else                       { r: u8;  memcpy(*r, a.value_pointer, 1); v = r; }
            } else if int_size == 2 {
                if ei.internal_type.signed { r: s16; memcpy(*r, a.value_pointer, 2); v = r; }
                else                       { r: u16; memcpy(*r, a.value_pointer, 2); v = r; }
            } else if int_size == 4 {
                if ei.internal_type.signed { r: s32; memcpy(*r, a.value_pointer, 4); v = r; }
                else                       { r: u32; memcpy(*r, a.value_pointer, 4); v = cast,no_check(s64) r; }
            } else if int_size == 8 {
                memcpy(*v, a.value_pointer, 8);
            }
            // Pretty: name if present, else raw.
            label: string;
            for n, i: ei.names {
                if ei.values[i] == v {
                    label = n; break;
                }
            }
            if label.count > 0  print("enum %.% (%)\n", ei.name, label, v);
            else                print("enum %(%)\n",   ei.name, v);

        case .ARRAY;
            ai := cast(*Type_Info_Array) a.type;
            count: int;
            data_ptr: *void;
            if ai.array_type == .FIXED {
                count = ai.array_count;
                data_ptr = a.value_pointer;
            } else if ai.array_type == .VIEW {
                view : [] u8 = ---;
                memcpy(*view, a.value_pointer, size_of([] u8));
                count = view.count;
                data_ptr = view.data;
            } else {
                ra : [..] u8 = ---;
                memcpy(*ra, a.value_pointer, size_of([..] u8));
                count = ra.count;
                data_ptr = ra.data;
            }
            print("array count=%\n", count);
            elem_size := ai.element_type.runtime_size;
            for 0..count-1 {
                inner_a: Any;
                inner_a.type = ai.element_type;
                inner_a.value_pointer = cast(*u8) data_ptr + it * elem_size;
                PE6_print_pretty(inner_a, indent + 2);
            }

        case .STRUCT;
            si := cast(*Type_Info_Struct) a.type;
            print("struct % {\n", si.name);
            for si.members {
                for 1..(indent+2) print(" ");
                print(".%:\n", it.name);
                inner_a: Any;
                inner_a.type = it.type;
                inner_a.value_pointer = cast(*u8) a.value_pointer + it.offset_in_bytes;
                PE6_print_pretty(inner_a, indent + 4);
            }
            for 1..indent print(" ");
            print("}\n");

        case .VOID;
            print("void\n");

        case .ANY;
            inner: Any;
            memcpy(*inner, a.value_pointer, size_of(Any));
            print("any -> ");
            PE6_print_pretty(inner, 0);

        case;
            print("<tag=%>\n", a.type.type);
    }
}

PE6_test_print_pretty :: () {
    section("607. print_pretty via Any/reflection");

    sub("Primitives");
    {
        i := 42;
        f := 3.5;
        s := "hello";
        b := true;
        u : u32 = 0xCAFE_F00D;
        PE6_print_pretty(i);
        PE6_print_pretty(f);
        PE6_print_pretty(s);
        PE6_print_pretty(b);
        PE6_print_pretty(u);
    }

    sub("Pointer (nullity)");
    {
        x := 10;
        px := *x;
        PE6_print_pretty(px);

        pnull : *int = null;
        PE6_print_pretty(pnull);
    }

    sub("Enum");
    {
        PE6_print_pretty(PE6_Color.BLUE);
        PE6_print_pretty(PE6_Day.WED);
        PE6_print_pretty(PE6_Phase.WANING);
    }

    sub("Fixed array");
    {
        nums : [4] int = .[10, 20, 30, 40];
        PE6_print_pretty(nums);
    }

    sub("Array view");
    {
        arr := int.[1, 2, 3];
        view : [] int = arr;
        PE6_print_pretty(view);
    }

    sub("Struct (nested)");
    {
        p := PE6_Person.{name="Alice", age=30, address=.{street="Main", city="Town", zip=1}};
        PE6_print_pretty(p);
    }

    sub("Deeply nested struct");
    {
        d := PE6_Deep_Root.{
            header="hdr",
            outer=.{title="otitle", middle=.{label="mlabel", inner=.{n=10, f=1.5, s="z"}, count=3},
                    extra=.{4,5,6}},
            rgba=.{1,2,3,4},
            nums=.[7,8,9],
        };
        PE6_print_pretty(d);
    }
}


// ============================================================================
// 608. Generic recursive equals via Any.
// ============================================================================

PE6_any_equals :: (a: Any, b: Any) -> bool {
    if a.type == null  return b.type == null;
    if b.type == null  return false;
    if a.type != b.type  return false;
    if a.value_pointer == null && b.value_pointer == null  return true;
    if a.value_pointer == null || b.value_pointer == null  return false;

    ti := a.type;

    if ti.type == {
        case .INTEGER;
            sz := ti.runtime_size;
            for 0..sz-1 {
                if (cast(*u8) a.value_pointer)[it] != (cast(*u8) b.value_pointer)[it]  return false;
            }
            return true;

        case .FLOAT;
            if ti.runtime_size == 4 {
                fa: float32; memcpy(*fa, a.value_pointer, 4);
                fb: float32; memcpy(*fb, b.value_pointer, 4);
                return fa == fb;
            } else if ti.runtime_size == 8 {
                fa: float64; memcpy(*fa, a.value_pointer, 8);
                fb: float64; memcpy(*fb, b.value_pointer, 8);
                return fa == fb;
            } else {
                return false;
            }

        case .BOOL;
            ba: bool; memcpy(*ba, a.value_pointer, 1);
            bb: bool; memcpy(*bb, b.value_pointer, 1);
            return ba == bb;

        case .STRING;
            sa: string; memcpy(*sa, a.value_pointer, size_of(string));
            sb: string; memcpy(*sb, b.value_pointer, size_of(string));
            if sa.count != sb.count  return false;
            for 0..sa.count-1 {
                if sa[it] != sb[it]  return false;
            }
            return true;

        case .ENUM;
            sz := ti.runtime_size;
            for 0..sz-1 {
                if (cast(*u8) a.value_pointer)[it] != (cast(*u8) b.value_pointer)[it]  return false;
            }
            return true;

        case .POINTER;
            pa: *void; memcpy(*pa, a.value_pointer, size_of(*void));
            pb: *void; memcpy(*pb, b.value_pointer, size_of(*void));
            // For determinism we treat two pointers as equal iff both null
            // or both non-null (we don't compare addresses).
            return (pa == null) == (pb == null);

        case .ARRAY;
            ai := cast(*Type_Info_Array) ti;
            ca, cb: int;
            pa, pb: *void;
            if ai.array_type == .FIXED {
                ca = ai.array_count;
                cb = ai.array_count;
                pa = a.value_pointer;
                pb = b.value_pointer;
            } else if ai.array_type == .VIEW {
                va : [] u8 = ---;
                vb : [] u8 = ---;
                memcpy(*va, a.value_pointer, size_of([] u8));
                memcpy(*vb, b.value_pointer, size_of([] u8));
                ca = va.count;  pa = va.data;
                cb = vb.count;  pb = vb.data;
            } else {
                ra : [..] u8 = ---;
                rb : [..] u8 = ---;
                memcpy(*ra, a.value_pointer, size_of([..] u8));
                memcpy(*rb, b.value_pointer, size_of([..] u8));
                ca = ra.count;  pa = ra.data;
                cb = rb.count;  pb = rb.data;
            }
            if ca != cb  return false;
            es := ai.element_type.runtime_size;
            for 0..ca-1 {
                aa: Any;
                aa.type = ai.element_type;
                aa.value_pointer = cast(*u8) pa + it * es;
                bb: Any;
                bb.type = ai.element_type;
                bb.value_pointer = cast(*u8) pb + it * es;
                if !PE6_any_equals(aa, bb)  return false;
            }
            return true;

        case .STRUCT;
            si := cast(*Type_Info_Struct) ti;
            for si.members {
                aa: Any;
                aa.type = it.type;
                aa.value_pointer = cast(*u8) a.value_pointer + it.offset_in_bytes;
                bb: Any;
                bb.type = it.type;
                bb.value_pointer = cast(*u8) b.value_pointer + it.offset_in_bytes;
                if !PE6_any_equals(aa, bb)  return false;
            }
            return true;

        case;
            return false;
    }
}

PE6_test_any_equals :: () {
    section("608. Generic recursive equals via Any");

    sub("Primitives");
    {
        a, b := 7, 7;
        print("  int 7 == 7 -> %\n", PE6_any_equals(a, b));
        c := 9;
        print("  int 7 == 9 -> %\n", PE6_any_equals(a, c));
        x, y := 1.5, 1.5;
        print("  flt 1.5 == 1.5 -> %\n", PE6_any_equals(x, y));
        z := 2.5;
        print("  flt 1.5 == 2.5 -> %\n", PE6_any_equals(x, z));
        s1, s2 := "abc", "abc";
        print("  str abc==abc -> %\n", PE6_any_equals(s1, s2));
        s3 := "abd";
        print("  str abc==abd -> %\n", PE6_any_equals(s1, s3));
    }

    sub("Enums");
    {
        e1, e2 := PE6_Color.RED, PE6_Color.RED;
        print("  RED==RED -> %\n", PE6_any_equals(e1, e2));
        e3 := PE6_Color.BLUE;
        print("  RED==BLUE -> %\n", PE6_any_equals(e1, e3));
    }

    sub("Arrays");
    {
        a := int.[1,2,3];
        b := int.[1,2,3];
        c := int.[1,2,4];
        print("  [1,2,3]==[1,2,3] -> %\n", PE6_any_equals(a, b));
        print("  [1,2,3]==[1,2,4] -> %\n", PE6_any_equals(a, c));
    }

    sub("Structs");
    {
        v1 := PE6_Vec3.{1,2,3};
        v2 := PE6_Vec3.{1,2,3};
        v3 := PE6_Vec3.{1,2,4};
        print("  V3{1,2,3}==V3{1,2,3} -> %\n", PE6_any_equals(v1, v2));
        print("  V3{1,2,3}==V3{1,2,4} -> %\n", PE6_any_equals(v1, v3));
    }

    sub("Nested structs");
    {
        a := PE6_Person.{name="x", age=1, address=.{street="s", city="c", zip=10}};
        b := PE6_Person.{name="x", age=1, address=.{street="s", city="c", zip=10}};
        c := PE6_Person.{name="x", age=1, address=.{street="s", city="c", zip=11}};
        print("  person a==b -> %\n", PE6_any_equals(a, b));
        print("  person a==c -> %\n", PE6_any_equals(a, c));
    }

    sub("Different types compare unequal");
    {
        a := 5;
        b := 5.0;
        print("  int(5)==float(5.0) -> %\n", PE6_any_equals(a, b));
    }
}


// ============================================================================
// 609. Tiny stack-machine interpreter.
// ============================================================================

PE6_VM_Opcode :: enum u8 #specified {
    HALT  :: 0;
    PUSH  :: 1;
    POP   :: 2;
    ADD   :: 3;
    SUB   :: 4;
    MUL   :: 5;
    DIV   :: 6;
    PRINT :: 7;
    DUP   :: 8;
    SWAP  :: 9;
    NEG   :: 10;
    MOD   :: 11;
}

PE6_VM_Instruction :: struct {
    op:      PE6_VM_Opcode;
    operand: s64;
}

PE6_VM :: struct {
    stack: [32] s64;
    sp:    int;     // points at next free slot (top of stack = stack[sp-1])
    pc:    int;
    halted: bool;
    error:  string;
}

PE6_vm_push :: (vm: *PE6_VM, v: s64) {
    if vm.sp >= vm.stack.count {
        vm.error = "stack-overflow";
        vm.halted = true;
        return;
    }
    vm.stack[vm.sp] = v;
    vm.sp += 1;
}

PE6_vm_pop :: (vm: *PE6_VM) -> s64 {
    if vm.sp <= 0 {
        vm.error = "stack-underflow";
        vm.halted = true;
        return 0;
    }
    vm.sp -= 1;
    return vm.stack[vm.sp];
}

PE6_vm_step :: (vm: *PE6_VM, program: [] PE6_VM_Instruction) {
    if vm.halted  return;
    if vm.pc < 0 || vm.pc >= program.count {
        vm.error = "pc-out-of-range";
        vm.halted = true;
        return;
    }
    inst := program[vm.pc];
    vm.pc += 1;

    if inst.op == {
        case .HALT;
            vm.halted = true;
        case .PUSH;
            PE6_vm_push(vm, inst.operand);
        case .POP;
            PE6_vm_pop(vm);
        case .ADD;
            b := PE6_vm_pop(vm);
            a := PE6_vm_pop(vm);
            PE6_vm_push(vm, a + b);
        case .SUB;
            b := PE6_vm_pop(vm);
            a := PE6_vm_pop(vm);
            PE6_vm_push(vm, a - b);
        case .MUL;
            b := PE6_vm_pop(vm);
            a := PE6_vm_pop(vm);
            PE6_vm_push(vm, a * b);
        case .DIV;
            b := PE6_vm_pop(vm);
            a := PE6_vm_pop(vm);
            if b == 0 {
                vm.error = "div-by-zero";
                vm.halted = true;
                return;
            }
            PE6_vm_push(vm, a / b);
        case .MOD;
            b := PE6_vm_pop(vm);
            a := PE6_vm_pop(vm);
            if b == 0 {
                vm.error = "mod-by-zero";
                vm.halted = true;
                return;
            }
            PE6_vm_push(vm, a % b);
        case .NEG;
            a := PE6_vm_pop(vm);
            PE6_vm_push(vm, -a);
        case .DUP;
            if vm.sp <= 0 {
                vm.error = "stack-underflow";
                vm.halted = true;
                return;
            }
            top := vm.stack[vm.sp - 1];
            PE6_vm_push(vm, top);
        case .SWAP;
            b := PE6_vm_pop(vm);
            a := PE6_vm_pop(vm);
            PE6_vm_push(vm, b);
            PE6_vm_push(vm, a);
        case .PRINT;
            if vm.sp <= 0 {
                vm.error = "stack-underflow";
                vm.halted = true;
                return;
            }
            print("    [VM-OUT] %\n", vm.stack[vm.sp - 1]);
    }
}

PE6_vm_run :: (vm: *PE6_VM, program: [] PE6_VM_Instruction, max_steps: int) -> int {
    steps := 0;
    while !vm.halted && steps < max_steps {
        PE6_vm_step(vm, program);
        steps += 1;
    }
    return steps;
}

PE6_test_vm :: () {
    section("609. Tiny stack-machine interpreter");

    sub("Program: push 1, push 2, add, print, halt");
    {
        program := PE6_VM_Instruction.[
            .{.PUSH, 1},
            .{.PUSH, 2},
            .{.ADD,  0},
            .{.PRINT,0},
            .{.HALT, 0},
        ];
        vm: PE6_VM;
        steps := PE6_vm_run(*vm, program, 100);
        print("  steps=% sp=% halted=% error='%'\n", steps, vm.sp, vm.halted, vm.error);
    }

    sub("Program computes (10 + 20) * 3 then prints");
    {
        program := PE6_VM_Instruction.[
            .{.PUSH, 10},
            .{.PUSH, 20},
            .{.ADD,   0},
            .{.PUSH,  3},
            .{.MUL,   0},
            .{.PRINT, 0},
            .{.HALT,  0},
        ];
        vm: PE6_VM;
        PE6_vm_run(*vm, program, 100);
    }

    sub("Program with sub, div, mod");
    {
        program := PE6_VM_Instruction.[
            .{.PUSH, 100},
            .{.PUSH,  35},
            .{.SUB,    0},   // 65
            .{.PRINT,  0},
            .{.PUSH,  20},
            .{.DIV,    0},   // 65 / 20 = 3
            .{.PRINT,  0},
            .{.PUSH, 100},
            .{.PUSH,   7},
            .{.MOD,    0},   // 100 % 7 = 2
            .{.PRINT,  0},
            .{.HALT,   0},
        ];
        vm: PE6_VM;
        PE6_vm_run(*vm, program, 100);
    }

    sub("DUP / SWAP / NEG");
    {
        program := PE6_VM_Instruction.[
            .{.PUSH, 5},
            .{.DUP,  0},
            .{.PRINT,0},  // 5
            .{.PUSH, 7},
            .{.SWAP, 0},
            .{.PRINT,0},  // 5
            .{.NEG,  0},
            .{.PRINT,0},  // -5
            .{.HALT, 0},
        ];
        vm: PE6_VM;
        PE6_vm_run(*vm, program, 100);
    }

    sub("Division by zero stops the VM");
    {
        program := PE6_VM_Instruction.[
            .{.PUSH,  1},
            .{.PUSH,  0},
            .{.DIV,   0},
            .{.HALT,  0},
        ];
        vm: PE6_VM;
        PE6_vm_run(*vm, program, 100);
        print("  halted=% error=%\n", vm.halted, vm.error);
    }

    sub("Stack underflow on add");
    {
        program := PE6_VM_Instruction.[
            .{.ADD, 0},
            .{.HALT,0},
        ];
        vm: PE6_VM;
        PE6_vm_run(*vm, program, 100);
        print("  halted=% error=%\n", vm.halted, vm.error);
    }

    sub("Compute fib of small input using the VM");
    {
        // We hard-code unrolled fib(8) computation as bytecode by repeating
        // adds; for simplicity we emulate fib(8) via a sequence:
        // start with 0, 1 ; for i in 0..7 do dup, swap, add, swap, pop
        program := PE6_VM_Instruction.[
            .{.PUSH, 0},
            .{.PUSH, 1},
            // step 1
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // step 2
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // step 3
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // step 4
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // step 5
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // step 6
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // step 7
            .{.DUP,  0},
            .{.SWAP, 0},
            .{.ADD,  0},
            // print the top
            .{.PRINT,0},
            .{.HALT, 0},
        ];
        vm: PE6_VM;
        PE6_vm_run(*vm, program, 200);
        print("  sp=%\n", vm.sp);
    }
}


// ============================================================================
// 610. Ackermann for small inputs.
// ============================================================================

PE6_ackermann :: (m: int, n: int) -> int {
    if m == 0  return n + 1;
    if n == 0  return PE6_ackermann(m - 1, 1);
    return PE6_ackermann(m - 1, PE6_ackermann(m, n - 1));
}

PE6_test_ackermann :: () {
    section("610. Ackermann function (small inputs)");

    for m: 0..3 {
        for n: 0..3 {
            print("  ack(%, %) = %\n", m, n, PE6_ackermann(m, n));
        }
    }

    sub("Specific known values");
    print("  ack(2,4) = %\n", PE6_ackermann(2, 4));
    print("  ack(3,3) = %\n", PE6_ackermann(3, 3));
    print("  ack(3,4) = %\n", PE6_ackermann(3, 4));
}


// ============================================================================
// 611. Iterate every Type_Info_Tag variant.
// ============================================================================

PE6_test_type_info_tags :: () {
    section("611. Iterate over every Type_Info_Tag variant");

    tags := enum_values_as_enum(Type_Info_Tag);
    print("  total Type_Info_Tag entries = %\n", tags.count);
    for tags {
        print("    Type_Info_Tag.% (%)\n", it, cast(s64) it);
    }

    sub("Cross-check via enum_names");
    names := enum_names(Type_Info_Tag);
    for names {
        print("    name='%'\n", it);
    }
}


// ============================================================================
// 612. Varint encode/decode (unsigned).
// ============================================================================

PE6_varint_encode :: (n: u64, out: *[..] u8) {
    v := n;
    while v >= 0x80 {
        b: u8 = cast(u8) ((v & 0x7F) | 0x80);
        array_add(out, b);
        v >>= 7;
    }
    array_add(out, cast(u8) v);
}

PE6_varint_decode :: (bytes: [] u8, start: int) -> (value: u64, next: int, ok: bool) {
    v: u64 = 0;
    shift: u64 = 0;
    i := start;
    while i < bytes.count {
        b := bytes[i];
        i += 1;
        v |= (cast(u64)(b & 0x7F)) << shift;
        if (b & 0x80) == 0 {
            return v, i, true;
        }
        shift += 7;
        if shift > 63  return 0, i, false; // overflow
    }
    return 0, i, false;
}

PE6_test_varint :: () {
    section("612. Varint encode/decode");

    sub("Encode various values");
    test_values := u64.[0, 1, 127, 128, 255, 300, 16_383, 16_384, 1_000_000, 1_000_000_000];
    for v: test_values {
        buf: [..] u8;
        PE6_varint_encode(v, *buf);
        print("  % -> bytes=%\n", v, buf.count);
        for j: 0..buf.count-1 {
            print("    [%]=0x%\n", j, formatInt(buf[j], base=16, minimum_digits=2));
        }
    }

    sub("Round-trip all of them");
    for v: test_values {
        buf: [..] u8;
        PE6_varint_encode(v, *buf);
        dec, next, ok := PE6_varint_decode(buf, 0);
        print("  % round-trip=% (got %, ok=%, consumed=%)\n",
              v, v == dec, dec, ok, next);
    }

    sub("Concatenate three encoded values and decode in sequence");
    {
        all: [..] u8;
        PE6_varint_encode(7,      *all);
        PE6_varint_encode(2000,   *all);
        PE6_varint_encode(123_456, *all);

        idx := 0;
        for 1..3 {
            v, next, ok := PE6_varint_decode(all, idx);
            print("  read v=% (ok=%) idx=% -> %\n", v, ok, idx, next);
            idx = next;
        }
        print("  total bytes consumed=% (of %)\n", idx, all.count);
    }

    sub("Truncated input is detected");
    {
        buf: [..] u8;
        PE6_varint_encode(1_000_000, *buf);
        // Truncate the last continuation byte intentionally.
        truncated: [..] u8;
        for j: 0..buf.count-2  array_add(*truncated, buf[j]);
        _, _, ok := PE6_varint_decode(truncated, 0);
        print("  truncated ok=%\n", ok);
    }
}


// ============================================================================
// 613. Base64-style encoding from scratch.
// We use the standard Base64 alphabet (A-Z, a-z, 0-9, +, /) but build it
// manually. Padding character is '='.
// ============================================================================

PE6_BASE64_ALPHABET :: "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

PE6_base64_index_of :: (c: u8) -> int {
    if c >= #char "A" && c <= #char "Z"  return cast(int) (c - #char "A");
    if c >= #char "a" && c <= #char "z"  return cast(int) (c - #char "a") + 26;
    if c >= #char "0" && c <= #char "9"  return cast(int) (c - #char "0") + 52;
    if c == #char "+"  return 62;
    if c == #char "/"  return 63;
    return -1;
}

PE6_base64_encode :: (input: [] u8) -> string {
    b: String_Builder;
    i := 0;
    while i + 3 <= input.count {
        a := input[i+0];
        bb := input[i+1];
        c := input[i+2];
        n: u32 = (cast(u32) a << 16) | (cast(u32) bb << 8) | cast(u32) c;
        append(*b, PE6_BASE64_ALPHABET[(n >> 18) & 0x3F]);
        append(*b, PE6_BASE64_ALPHABET[(n >> 12) & 0x3F]);
        append(*b, PE6_BASE64_ALPHABET[(n >>  6) & 0x3F]);
        append(*b, PE6_BASE64_ALPHABET[(n >>  0) & 0x3F]);
        i += 3;
    }
    remaining := input.count - i;
    if remaining == 1 {
        a := input[i+0];
        n: u32 = cast(u32) a << 16;
        append(*b, PE6_BASE64_ALPHABET[(n >> 18) & 0x3F]);
        append(*b, PE6_BASE64_ALPHABET[(n >> 12) & 0x3F]);
        append(*b, "=");
        append(*b, "=");
    } else if remaining == 2 {
        a := input[i+0];
        bb := input[i+1];
        n: u32 = (cast(u32) a << 16) | (cast(u32) bb << 8);
        append(*b, PE6_BASE64_ALPHABET[(n >> 18) & 0x3F]);
        append(*b, PE6_BASE64_ALPHABET[(n >> 12) & 0x3F]);
        append(*b, PE6_BASE64_ALPHABET[(n >>  6) & 0x3F]);
        append(*b, "=");
    }
    return builder_to_string(*b);
}

PE6_base64_decode :: (text: string) -> (out: [..] u8, ok: bool) {
    out: [..] u8;
    if text.count % 4 != 0  return out, false;
    i := 0;
    while i < text.count {
        c0 := text[i+0];
        c1 := text[i+1];
        c2 := text[i+2];
        c3 := text[i+3];
        i += 4;

        i0 := PE6_base64_index_of(c0);
        i1 := PE6_base64_index_of(c1);
        if i0 < 0 || i1 < 0  return out, false;

        pad2 := (c2 == #char "=");
        pad3 := (c3 == #char "=");

        i2 := ifx pad2 then 0 else PE6_base64_index_of(c2);
        i3 := ifx pad3 then 0 else PE6_base64_index_of(c3);
        if !pad2 && i2 < 0  return out, false;
        if !pad3 && i3 < 0  return out, false;

        n: u32 = (cast(u32) i0 << 18) | (cast(u32) i1 << 12) | (cast(u32) i2 << 6) | (cast(u32) i3);
        b0: u8 = cast(u8) ((n >> 16) & 0xFF);
        b1: u8 = cast(u8) ((n >>  8) & 0xFF);
        b2: u8 = cast(u8) ((n >>  0) & 0xFF);
        array_add(*out, b0);
        if !pad2  array_add(*out, b1);
        if !pad3  array_add(*out, b2);
    }
    return out, true;
}

PE6_test_base64 :: () {
    section("613. Base64 encode/decode");

    sub("Known small cases");
    {
        inputs := string.["", "f", "fo", "foo", "foob", "fooba", "foobar", "hello", "12345"];
        for s: inputs {
            bytes := cast([] u8) s;
            enc := PE6_base64_encode(bytes);
            dec, ok := PE6_base64_decode(enc);
            dec_str := cast(string) cast([] u8) dec;
            print("  '%' -> '%' -> '%' (ok=%)\n", s, enc, dec_str, ok);
        }
    }

    sub("Round trip of a longer byte string");
    {
        original := "The quick brown fox jumps over the lazy dog";
        bytes := cast([] u8) original;
        enc := PE6_base64_encode(bytes);
        dec, ok := PE6_base64_decode(enc);
        roundtrip := cast(string) cast([] u8) dec;
        print("  enc='%'\n", enc);
        print("  dec='%' ok=%\n", roundtrip, ok);
        print("  equal=%\n", roundtrip == original);
    }

    sub("Detect invalid input length");
    {
        _, ok := PE6_base64_decode("abc");      // length 3, not multiple of 4
        print("  len-3 ok=%\n", ok);
        _,  ok2 := PE6_base64_decode("ab*z");
        print("  bad-char ok=%\n", ok2);
    }
}


// ============================================================================
// 614. Hex encode/decode of byte arrays.
// ============================================================================

PE6_HEX_DIGITS :: "0123456789abcdef";

PE6_hex_encode :: (input: [] u8) -> string {
    b: String_Builder;
    for input {
        append(*b, PE6_HEX_DIGITS[(it >> 4) & 0xF]);
        append(*b, PE6_HEX_DIGITS[it & 0xF]);
    }
    return builder_to_string(*b);
}

PE6_hex_digit_value :: (c: u8) -> int {
    if c >= #char "0" && c <= #char "9"  return cast(int) (c - #char "0");
    if c >= #char "a" && c <= #char "f"  return cast(int) (c - #char "a") + 10;
    if c >= #char "A" && c <= #char "F"  return cast(int) (c - #char "A") + 10;
    return -1;
}

PE6_hex_decode :: (text: string) -> (out: [..] u8, ok: bool) {
    out: [..] u8;
    if text.count % 2 != 0  return out, false;
    i := 0;
    while i < text.count {
        hi := PE6_hex_digit_value(text[i+0]);
        lo := PE6_hex_digit_value(text[i+1]);
        if hi < 0 || lo < 0  return out, false;
        array_add(*out, cast(u8) ((hi << 4) | lo));
        i += 2;
    }
    return out, true;
}

PE6_test_hex :: () {
    section("614. Hex encode/decode");

    sub("Small examples");
    {
        a := u8.[0x00, 0x01, 0x10, 0xFF];
        as_view : [] u8 = a;
        enc := PE6_hex_encode(as_view);
        print("  bytes [0,1,16,255] -> '%'\n", enc);
        dec, ok := PE6_hex_decode(enc);
        print("  decode -> count=% ok=%\n", dec.count, ok);
        for j: 0..dec.count-1 {
            print("    [%]=%\n", j, dec[j]);
        }
    }

    sub("ASCII round trip");
    {
        s := "Hello";
        bytes := cast([] u8) s;
        enc := PE6_hex_encode(bytes);
        print("  '%' -> '%'\n", s, enc);

        dec, ok := PE6_hex_decode(enc);
        dec_str := cast(string) cast([] u8) dec;
        print("  back -> '%' ok=% equal=%\n", dec_str, ok, dec_str == s);
    }

    sub("Reject odd length / bad chars");
    {
        _, ok := PE6_hex_decode("abc");
        print("  odd-len ok=%\n", ok);
        _,  ok2 := PE6_hex_decode("xy");
        print("  bad-chars ok=%\n", ok2);
    }

    sub("Encode-decode a 16-byte synthetic pattern");
    {
        bytes: [..] u8;
        for i: 0..15  array_add(*bytes, cast(u8) (i * 17));
        view: [] u8 = bytes;
        enc := PE6_hex_encode(view);
        print("  enc=%\n", enc);
        dec, ok := PE6_hex_decode(enc);
        print("  ok=% count=%\n", ok, dec.count);
        match := true;
        if dec.count != bytes.count  match = false;
        else {
            for j: 0..bytes.count-1 {
                if dec[j] != bytes[j] { match = false; break; }
            }
        }
        print("  match=%\n", match);
    }
}


// ============================================================================
// 615. LRU cache over a fixed-size circular buffer.
//
// Implementation: ages keyed by an integer "tick" assigned on every access.
// The slot with the smallest tick is evicted next.
// ============================================================================

PE6_LRU :: struct(K: Type, V: Type, CAP: int) {
    keys:  [CAP] K;
    vals:  [CAP] V;
    ticks: [CAP] s64;     // last-use tick; -1 means slot empty
    next_tick: s64;
}

PE6_lru_init :: (lru: *PE6_LRU($K, $V, $CAP)) {
    for 0..CAP-1  lru.ticks[it] = -1;
    lru.next_tick = 1;
}

PE6_lru_find :: (lru: *PE6_LRU($K, $V, $CAP), key: K) -> int {
    for 0..CAP-1 {
        if lru.ticks[it] != -1 && lru.keys[it] == key  return it;
    }
    return -1;
}

PE6_lru_pick_victim :: (lru: *PE6_LRU($K, $V, $CAP)) -> int {
    // First, return an empty slot if any.
    for 0..CAP-1  if lru.ticks[it] == -1  return it;

    // Else pick the slot with the smallest tick.
    victim := 0;
    for 1..CAP-1 {
        if lru.ticks[it] < lru.ticks[victim]  victim = it;
    }
    return victim;
}

PE6_lru_put :: (lru: *PE6_LRU($K, $V, $CAP), key: K, val: V) -> (evicted_key: K, was_evicted: bool) {
    z: K;
    idx := PE6_lru_find(lru, key);
    if idx >= 0 {
        lru.vals[idx] = val;
        lru.ticks[idx] = lru.next_tick;
        lru.next_tick += 1;
        return z, false;
    }

    idx = PE6_lru_pick_victim(lru);
    evicted: K = lru.keys[idx];
    was_full := lru.ticks[idx] != -1;
    lru.keys[idx] = key;
    lru.vals[idx] = val;
    lru.ticks[idx] = lru.next_tick;
    lru.next_tick += 1;

    if !was_full  return z, false;
    return evicted, true;
}

PE6_lru_get :: (lru: *PE6_LRU($K, $V, $CAP), key: K) -> (V, bool) {
    idx := PE6_lru_find(lru, key);
    if idx < 0 {
        z: V;
        return z, false;
    }
    lru.ticks[idx] = lru.next_tick;
    lru.next_tick += 1;
    return lru.vals[idx], true;
}

PE6_lru_size :: (lru: *PE6_LRU($K, $V, $CAP)) -> int {
    n := 0;
    for 0..CAP-1  if lru.ticks[it] != -1  n += 1;
    return n;
}

PE6_test_lru :: () {
    section("615. LRU cache over fixed-size circular buffer");

    sub("LRU(int,string,3): basic operations");
    {
        cache: PE6_LRU(int, string, 3);
        PE6_lru_init(*cache);

        _, ev := PE6_lru_put(*cache, 1, "one");
        print("  put 1=one  evicted=% size=%\n", ev, PE6_lru_size(*cache));
        _, ev  = PE6_lru_put(*cache, 2, "two");
        print("  put 2=two  evicted=% size=%\n", ev, PE6_lru_size(*cache));
        _, ev  = PE6_lru_put(*cache, 3, "three");
        print("  put 3=three evicted=% size=%\n", ev, PE6_lru_size(*cache));

        // Touch 1 to make it most-recently used
        v, ok := PE6_lru_get(*cache, 1);
        print("  get 1 -> '%' ok=%\n", v, ok);

        evk, evf := PE6_lru_put(*cache, 4, "four");
        print("  put 4=four evicted_key=% was_evicted=%\n", evk, evf);

        for k: 1..4 {
            v, ok := PE6_lru_get(*cache, k);
            print("  get % -> '%' ok=%\n", k, v, ok);
        }
    }

    sub("LRU(string,int,2): more rotations");
    {
        cache: PE6_LRU(string, int, 2);
        PE6_lru_init(*cache);

        _, _ = PE6_lru_put(*cache, "a", 1);
        _, _ = PE6_lru_put(*cache, "b", 2);
        _, ok := PE6_lru_get(*cache, "a");          // touch 'a'
        print("  touch 'a' ok=%\n", ok);
        evk, evf := PE6_lru_put(*cache, "c", 3);    // should evict 'b'
        print("  put 'c'=3 evicted='%' was=%\n", evk, evf);

        for k: string.["a","b","c"] {
            v, ok := PE6_lru_get(*cache, k);
            print("  get '%' -> % ok=%\n", k, v, ok);
        }
    }

    sub("LRU(int,int,4) workload");
    {
        cache: PE6_LRU(int, int, 4);
        PE6_lru_init(*cache);

        seq := int.[1, 2, 3, 4, 5, 1, 6, 2, 7, 1, 8];
        for k: seq {
            _, _ = PE6_lru_put(*cache, k, k * 10);
            print("  after put %: size=% next_tick=%\n", k, PE6_lru_size(*cache), cache.next_tick);
        }

        for k: 1..8 {
            v, ok := PE6_lru_get(*cache, k);
            print("    get % -> % ok=%\n", k, v, ok);
        }
    }
}


// ============================================================================
// 616. Additional reflection: walk Type_Info_Procedure (just to demonstrate).
// ============================================================================

PE6_dummy_proc1 :: (a: int) -> int                  { return a; }
PE6_dummy_proc2 :: (a: int, b: float) -> (string, bool) { return "x", true; }
PE6_dummy_proc3 :: () {}
PE6_dummy_proc4 :: (s: string, v: PE6_Vec3) -> int   { return s.count + cast(int) v.x; }

PE6_print_proc_info_for :: (label: string, ti: *Type_Info_Procedure) {
    print("  proc %: args=% returns=% size=%\n",
          label, ti.argument_types.count, ti.return_types.count, ti.runtime_size);
    for i: 0..ti.argument_types.count-1 {
        a := ti.argument_types[i];
        print("    arg[%] tag=% size=%\n", i, a.type, a.runtime_size);
    }
    for i: 0..ti.return_types.count-1 {
        r := ti.return_types[i];
        print("    ret[%] tag=% size=%\n", i, r.type, r.runtime_size);
    }
}

PE6_test_proc_reflection :: () {
    section("616. Reflection on procedure types");

    p1 := PE6_dummy_proc1;
    p2 := PE6_dummy_proc2;
    p3 := PE6_dummy_proc3;
    p4 := PE6_dummy_proc4;

    PE6_print_proc_info_for("p1 (int -> int)",
        cast(*Type_Info_Procedure) type_info(type_of(p1)));
    PE6_print_proc_info_for("p2 (int,float -> string,bool)",
        cast(*Type_Info_Procedure) type_info(type_of(p2)));
    PE6_print_proc_info_for("p3 (() -> ())",
        cast(*Type_Info_Procedure) type_info(type_of(p3)));
    PE6_print_proc_info_for("p4 (string,V3 -> int)",
        cast(*Type_Info_Procedure) type_info(type_of(p4)));
}


