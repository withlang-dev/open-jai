// ----------------------------------------------------------------------------
// 929. Conditional polymorphism via #if T == ...
// ----------------------------------------------------------------------------

describe_value :: (x: $T) -> string {
    #if T == int       return tprint("int(%)", x);
    else #if T == float  return tprint("float(%)", x);
    else #if T == string return tprint("str('%')", x);
    else #if T == bool   return tprint("bool(%)", x);
    else                 return tprint("unknown-type(%)", type_of(x));
}

test_extras_9_929_conditional_poly :: () {
    section("929. Conditional polymorphism via #if on T");

    print("  %\n", describe_value(5));
    print("  %\n", describe_value(5.5));
    print("  %\n", describe_value("hello"));
    print("  %\n", describe_value(true));

    v: u32 = 99;
    print("  %\n", describe_value(v));
}


// ----------------------------------------------------------------------------
// 930. Demonstration of all kinds of for-loop variable naming.
// ----------------------------------------------------------------------------

test_extras_9_930_for_names :: () {
    section("930. for-loop variable naming forms");

    sub("default 'it' / 'it_index'");
    arr := int.[10, 20, 30];
    for arr  print("  it=% it_index=%\n", it, it_index);

    sub("named single var");
    for n: arr  print("  n=%\n", n);

    sub("named value, index");
    for v, i: arr  print("  v=% i=%\n", v, i);

    sub("for over range with named var");
    for j: 0..3  print("  j=%\n", j);

    sub("for * named var");
    for * p: arr  print("  *p=%\n", p.*);

    sub("for < named var (reverse)");
    for < v: arr  print("  rev v=%\n", v);

    sub("for *< named (reverse pointer)");
    arr2 := int.[1, 2, 3];
    for *< p: arr2  print("  *p=%\n", p.*);
}


// ----------------------------------------------------------------------------
// 931. Manual queue (FIFO) via [..] array.
// ----------------------------------------------------------------------------

test_extras_9_931_queue :: () {
    section("931. Queue (FIFO) on [..]");

    q: [..] int;
    enqueue :: (q: *[..] int, v: int) { array_add(q, v); }
    dequeue :: (q: *[..] int) -> (int, bool) {
        if q.count == 0  return 0, false;
        v := q.*[0];
        for i: 1..q.count-1  q.*[i-1] = q.*[i];
        q.count -= 1;
        return v, true;
    }

    for n: int.[1, 2, 3, 4, 5]  enqueue(*q, n);
    print("  size after enqueues = %\n", q.count);

    while q.count > 0 {
        v, ok := dequeue(*q);
        if ok  print("  dequeue -> %\n", v);
    }

    _, ok := dequeue(*q);
    print("  empty dequeue ok = %\n", ok);
}


// ----------------------------------------------------------------------------
// 932. Manual stack (LIFO) via [..] array.
// ----------------------------------------------------------------------------

test_extras_9_932_stack :: () {
    section("932. Stack (LIFO) on [..]");

    s: [..] int;
    push :: (s: *[..] int, v: int) { array_add(s, v); }
    pop  :: (s: *[..] int) -> (int, bool) {
        if s.count == 0  return 0, false;
        v := s.*[s.count - 1];
        s.count -= 1;
        return v, true;
    }

    for n: int.[1, 2, 3, 4, 5]  push(*s, n);
    print("  size after pushes = %\n", s.count);

    while s.count > 0 {
        v, ok := pop(*s);
        if ok  print("  pop -> %\n", v);
    }
}


