// ============================================================================
// 229. defer ordering in complex nesting.
// ============================================================================

test_defer_ordering :: () {
    section("229. defer ordering in complex nesting");

    sub("Multiple defers in one scope (LIFO)");
    {
        print("  enter\n");
        defer print("  defer A\n");
        defer print("  defer B\n");
        defer print("  defer C\n");
        print("  body\n");
    }

    sub("Defer in nested scopes (inner scope first)");
    {
        defer print("  outer defer\n");
        print("  outer body before inner\n");
        {
            defer print("    inner defer\n");
            print("    inner body\n");
        }
        print("  outer body after inner\n");
    }

    sub("Defer in nested if blocks");
    n := 5;
    {
        defer print("  outer defer (n=%)\n", n);
        if n > 0 {
            defer print("  positive defer\n");
            print("  inside if positive\n");
            if n > 3 {
                defer print("  very positive defer\n");
                print("  inside very-positive\n");
            }
            print("  back to positive scope\n");
        }
        print("  outer continues\n");
    }

    sub("Defer in a loop body fires every iteration");
    for i: 0..2 {
        defer print("    defer iteration % done\n", i);
        print("    body iteration %\n", i);
    }
}


// ============================================================================
// 230. Variadic procedure taking ..Any.
// ============================================================================

print_anys :: (label: string, things: ..Any) {
    print("[%] count=%\n", label, things.count);
    for things {
        info := it.type;
        print("  arg[%]: type=% size=%\n", it_index, info.type, info.runtime_size);
    }
}

count_int_anys :: (things: ..Any) -> int {
    n := 0;
    for things {
        if it.type.type == .INTEGER  n += 1;
    }
    return n;
}

sum_int_anys :: (things: ..Any) -> int {
    total := 0;
    for things {
        if it.type.type != .INTEGER  continue;
        ti := cast(*Type_Info_Integer) it.type;
        if ti.signed {
            if it.type.runtime_size == 1 {
                total += (cast(*s8) it.value_pointer).*;
            } else if it.type.runtime_size == 2 {
                total += (cast(*s16) it.value_pointer).*;
            } else if it.type.runtime_size == 4 {
                total += (cast(*s32) it.value_pointer).*;
            } else if it.type.runtime_size == 8 {
                total += (cast(*s64) it.value_pointer).*;
            }
        } else {
            if it.type.runtime_size == 1 {
                total += cast(int) (cast(*u8) it.value_pointer).*;
            } else if it.type.runtime_size == 2 {
                total += cast(int) (cast(*u16) it.value_pointer).*;
            } else if it.type.runtime_size == 4 {
                total += cast(int) (cast(*u32) it.value_pointer).*;
            } else if it.type.runtime_size == 8 {
                total += cast,no_check(int) (cast(*u64) it.value_pointer).*;
            }
        }
    }
    return total;
}

test_variadic_any :: () {
    section("230. Variadic procedure taking ..Any");

    print_anys("mixed", 42, "hello", 3.14, true);
    print_anys("only ints", 1, 2, 3);
    print_anys("empty");

    sub("count_int_anys / sum_int_anys");
    print("count = %\n", count_int_anys(1, 2, "x", 3.14, 4));
    print("sum   = %\n", sum_int_anys(1, 2, 3, 4, 5));
    print("sum-w-mixed = %\n", sum_int_anys(10, "abc", 20, 3.5, 30));
    print("sum-w-s8/s16 = %\n", sum_int_anys(cast(s8) 1, cast(s16) 2, cast(s32) 3, cast(s64) 4));
    print("sum-w-unsigned = %\n", sum_int_anys(cast(u8) 1, cast(u16) 2, cast(u32) 3, cast(u64) 4));
}


// ============================================================================
// 231. JSON-style encoder using reflection.
// ============================================================================

JSON_Coord :: struct {
    x: int;
    y: int;
    z: int;
}

JSON_Item :: struct {
    name: string;
    count: int;
    price: float;
    in_stock: bool;
}

json_emit_string :: (b: *String_Builder, s: string) {
    append(b, "\"");
    for i: 0..s.count-1 {
        c := s[i];
        if c == #char "\"" {
            append(b, "\\\"");
        } else if c == #char "\\" {
            append(b, "\\\\");
        } else if c == #char "\n" {
            append(b, "\\n");
        } else if c == #char "\t" {
            append(b, "\\t");
        } else {
            ch: [1] u8;
            ch[0] = c;
            ss: string;
            ss.data = ch.data;
            ss.count = 1;
            append(b, ss);
        }
    }
    append(b, "\"");
}

json_emit_value :: (b: *String_Builder, ti: *Type_Info, ptr: *void) {
    if ti.type == {
        case .INTEGER;
            int_info := cast(*Type_Info_Integer) ti;
            if int_info.signed {
                if ti.runtime_size == 1 {
                    print_to_builder(b, "%", (cast(*s8) ptr).*);
                } else if ti.runtime_size == 2 {
                    print_to_builder(b, "%", (cast(*s16) ptr).*);
                } else if ti.runtime_size == 4 {
                    print_to_builder(b, "%", (cast(*s32) ptr).*);
                } else if ti.runtime_size == 8 {
                    print_to_builder(b, "%", (cast(*s64) ptr).*);
                }
            } else {
                if ti.runtime_size == 1 {
                    print_to_builder(b, "%", (cast(*u8) ptr).*);
                } else if ti.runtime_size == 2 {
                    print_to_builder(b, "%", (cast(*u16) ptr).*);
                } else if ti.runtime_size == 4 {
                    print_to_builder(b, "%", (cast(*u32) ptr).*);
                } else if ti.runtime_size == 8 {
                    print_to_builder(b, "%", (cast(*u64) ptr).*);
                }
            }

        case .FLOAT;
            if ti.runtime_size == 4 {
                print_to_builder(b, "%", formatFloat((cast(*float32) ptr).*, trailing_width=3));
            } else {
                print_to_builder(b, "%", formatFloat((cast(*float64) ptr).*, trailing_width=3));
            }

        case .BOOL;
            v := (cast(*bool) ptr).*;
            append(b, ifx v then "true" else "false");

        case .STRING;
            s := (cast(*string) ptr).*;
            json_emit_string(b, s);

        case .STRUCT;
            ts := cast(*Type_Info_Struct) ti;
            append(b, "{");
            for ts.members {
                if it_index > 0  append(b, ", ");
                json_emit_string(b, it.name);
                append(b, ": ");
                field_ptr := cast(*void) (cast(*u8) ptr + it.offset_in_bytes);
                json_emit_value(b, it.type, field_ptr);
            }
            append(b, "}");

        case;
            append(b, "null");
    }
}

json_encode :: (any: Any) -> string {
    b: String_Builder;
    init_string_builder(*b);
    json_emit_value(*b, any.type, any.value_pointer);
    return builder_to_string(*b);
}

test_json_encoder :: () {
    section("231. JSON-style encoder via reflection");

    c := JSON_Coord.{x=1, y=2, z=3};
    print("encoded coord: %\n", json_encode(c));

    item := JSON_Item.{name="Widget", count=42, price=9.95, in_stock=true};
    print("encoded item : %\n", json_encode(item));

    sub("Nested struct");
    Wrapped :: struct {
        label: string;
        coord: JSON_Coord;
        flag:  bool;
    }
    w := Wrapped.{label="alpha", coord=.{x=10, y=20, z=30}, flag=false};
    print("encoded wrapped: %\n", json_encode(w));

    sub("Encode primitives directly");
    n: int = 99;
    print("encoded int  : %\n", json_encode(n));
    s := "hello\tworld";
    print("encoded string: %\n", json_encode(s));
    b1 := true;
    print("encoded bool : %\n", json_encode(b1));
}


// ============================================================================
// 232. Splitting type_to_string and Type values.
// ============================================================================

test_type_to_string :: () {
    section("232. type_to_string / Type as value");

    // Take a Type value and print its name (via type_info).
    print("type_to_string(int)         = %\n", type_to_string(type_info(int)));
    print("type_to_string(string)      = %\n", type_to_string(type_info(string)));
    print("type_to_string(PE3_Person)      = %\n", type_to_string(type_info(PE3_Person)));
    print("type_to_string([..] int)    = %\n", type_to_string(type_info([..] int)));
    print("type_to_string([10] u8)     = %\n", type_to_string(type_info([10] u8)));

    sub("Round-trip: Type_Info -> struct fields");
    ti := cast(*Type_Info) type_info(PE3_Person);
    if ti.type == .STRUCT {
        s := cast(*Type_Info_Struct) ti;
        print("PE3_Person struct has % members\n", s.members.count);
        for s.members {
            print("  member[%] = '%' (offset=%, type=%)\n",
                it_index, it.name, it.offset_in_bytes, type_to_string(it.type));
        }
    }

    sub("Compare Type values for equality");
    print("int == int    : %\n", int == int);
    print("int == s64    : %\n", int == s64);
    print("string == int : %\n", string == int);
}


// ============================================================================
// 233. Polymorphic struct that returns a struct of arrays.
// ============================================================================

Stats :: struct(T: Type) {
    values: [..] T;
}

stats_add :: (s: *$S/Stats, v: S.T) {
    array_add(*s.values, v);
}

stats_sum :: (s: *$S/Stats) -> S.T {
    total: S.T;
    for s.values  total += it;
    return total;
}

stats_mean :: (s: *$S/Stats) -> S.T {
    if s.values.count == 0 {
        empty: S.T;
        return empty;
    }
    sum := stats_sum(s);
    return cast(S.T) (sum / cast(S.T) s.values.count);
}

stats_max :: (s: *$S/Stats) -> S.T {
    if s.values.count == 0 {
        empty: S.T;
        return empty;
    }
    m := s.values[0];
    for s.values  if it > m  m = it;
    return m;
}

stats_min :: (s: *$S/Stats) -> S.T {
    if s.values.count == 0 {
        empty: S.T;
        return empty;
    }
    m := s.values[0];
    for s.values  if it < m  m = it;
    return m;
}

test_polymorph_stats :: () {
    section("233. Polymorphic Stats(T)");

    si: Stats(int);
    for n: int.[3, 1, 4, 1, 5, 9, 2, 6, 5, 3]  stats_add(*si, n);
    print("int sum=% mean=% min=% max=%\n",
        stats_sum(*si), stats_mean(*si), stats_min(*si), stats_max(*si));

    sf: Stats(float);
    for v: float.[1.5, 2.5, 3.5, 4.5, 5.5]  stats_add(*sf, v);
    print("float sum=% mean=% min=% max=%\n",
        stats_sum(*sf), stats_mean(*sf), stats_min(*sf), stats_max(*sf));

    sub("Empty Stats");
    se: Stats(int);
    print("empty sum=% mean=%\n", stats_sum(*se), stats_mean(*se));
}


// ============================================================================
// 234. Pointer tricks (no addresses printed): pointer arithmetic on arrays.
// ============================================================================

test_pointer_tricks :: () {
    section("234. Pointer arithmetic for arrays");

    arr := int.[10, 20, 30, 40, 50];
    p   := arr.data;
    q   := p + 3;
    print("q-p (in elements) = %\n", q - p);
    print("p[0]=% q[0]=%\n", p.*, q.*);

    sub("Walk an array via pointer increment");
    cur := arr.data;
    end := arr.data + arr.count;
    while cur < end {
        print("  *cur = %\n", cur.*);
        cur += 1;
    }

    sub("Pointer math through a struct field");
    Box3 :: struct {
        a: s32;
        b: s64;
        c: u8;
    }
    box: Box3;
    box.a = 11; box.b = 22; box.c = 33;
    pa := *box.a;
    pb := *box.b;
    pc := *box.c;
    delta_ab := cast(s64) (cast(*u8) pb - cast(*u8) pa);
    delta_bc := cast(s64) (cast(*u8) pc - cast(*u8) pb);
    print("offset b-a (bytes) = %\n", delta_ab);
    print("offset c-b (bytes) = %\n", delta_bc);
}


// ============================================================================
// 235. Generic linear search and find_first_index.
// ============================================================================

linear_find :: (arr: [] $T, target: T) -> int {
    for i: 0..arr.count-1 {
        if arr[i] == target  return i;
    }
    return -1;
}

linear_count_if :: (arr: [] $T, predicate: (a: T) -> bool) -> int {
    n := 0;
    for arr  if predicate(it)  n += 1;
    return n;
}

is_positive :: (x: int) -> bool { return x > 0; }
PE3_is_even     :: (x: int) -> bool { return (x & 1) == 0; }
is_short    :: (s: string) -> bool { return s.count <= 3; }

test_generic_search :: () {
    section("235. Generic linear search / count_if");

    nums := int.[5, 2, 8, 1, 9, 3, 7];
    print("find 8     -> index %\n", linear_find(nums, 8));
    print("find 1     -> index %\n", linear_find(nums, 1));
    print("find 100   -> index %\n", linear_find(nums, 100));

    words := string.["a", "fox", "quick", "hi"];
    print("find 'fox' -> index %\n", linear_find(words, "fox"));
    print("find 'cat' -> index %\n", linear_find(words, "cat"));

    sub("count_if");
    print("positive count = %\n", linear_count_if(nums, is_positive));
    print("even count     = %\n", linear_count_if(nums, PE3_is_even));
    print("short strings  = %\n", linear_count_if(words, is_short));
}


// ============================================================================
// 236. Generic stack with push/pop/peek as polymorphic methods.
// ============================================================================

Generic_Stack :: struct(T: Type) {
    data: [..] T;
}

gs_push :: (s: *$S/Generic_Stack, v: S.T) {
    array_add(*s.data, v);
}

gs_pop :: (s: *$S/Generic_Stack) -> (value: S.T, ok: bool) {
    if s.data.count == 0 {
        empty: S.T;
        return empty, false;
    }
    v := s.data[s.data.count - 1];
    s.data.count -= 1;
    return v, true;
}

gs_peek :: (s: *$S/Generic_Stack) -> (value: S.T, ok: bool) {
    if s.data.count == 0 {
        empty: S.T;
        return empty, false;
    }
    return s.data[s.data.count - 1], true;
}

gs_count :: (s: *$S/Generic_Stack) -> int {
    return s.data.count;
}

test_generic_stack :: () {
    section("236. Generic_Stack(T)");

    s: Generic_Stack(int);
    for v: int.[10, 20, 30, 40]  gs_push(*s, v);
    print("count = %\n", gs_count(*s));

    top, ok := gs_peek(*s);
    print("peek -> ok=% top=%\n", ok, top);

    while gs_count(*s) > 0 {
        v, popped := gs_pop(*s);
        if popped  print("  popped %\n", v);
    }

    sub("Stack of strings");
    ss: Generic_Stack(string);
    gs_push(*ss, "alpha");
    gs_push(*ss, "beta");
    gs_push(*ss, "gamma");
    top2, ok2 := gs_peek(*ss);
    print("peek -> %\n", top2);
    while gs_count(*ss) > 0 {
        v, popped := gs_pop(*ss);
        if popped  print("  popped %\n", v);
    }
}


// ============================================================================
// 237. Run Length Encoding / Decoding.
// ============================================================================

PE3_rle_encode :: (s: string) -> string {
    if s.count == 0  return "";
    b: String_Builder;
    init_string_builder(*b);
    i := 0;
    while i < s.count {
        c := s[i];
        run := 1;
        while i + run < s.count && s[i + run] == c {
            run += 1;
        }
        print_to_builder(*b, "%%", run, cast(u8) c);
        i += run;
    }
    return builder_to_string(*b);
}

PE3_rle_decode :: (s: string) -> string {
    b: String_Builder;
    init_string_builder(*b);
    i := 0;
    while i < s.count {
        // parse integer
        run := 0;
        while i < s.count && s[i] >= #char "0" && s[i] <= #char "9" {
            run = run*10 + (s[i] - #char "0");
            i += 1;
        }
        if i < s.count {
            c := s[i];
            i += 1;
            for j: 0..run-1 {
                ch: [1] u8;
                ch[0] = c;
                ss: string;
                ss.data  = ch.data;
                ss.count = 1;
                append(*b, ss);
            }
        }
    }
    return builder_to_string(*b);
}

PE3_test_rle :: () {
    section("237. Run-Length Encoding round trip");

    samples := string.["aaaabbbccda", "x", "yyy", "abcdef", "AAA0001"];
    for s: samples {
        enc := PE3_rle_encode(s);
        dec := PE3_rle_decode(enc);
        print("'%' -> '%' -> '%'  same=%\n", s, enc, dec, dec == s);
    }
}


// ============================================================================
// 238. Roman numeral conversion.
// ============================================================================

to_roman :: (n: int) -> string {
    if n <= 0  return "";
    b: String_Builder;
    init_string_builder(*b);

    Vals    :: int.[1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1];
    Symbols :: string.["M", "CM", "D", "CD", "C", "XC", "L", "XL", "X", "IX", "V", "IV", "I"];

    rem := n;
    for v, idx: Vals {
        while rem >= v {
            append(*b, Symbols[idx]);
            rem -= v;
        }
    }
    return builder_to_string(*b);
}

from_roman :: (s: string) -> int {
    value_of :: (c: u8) -> int {
        if c == #char "I"  return 1;
        if c == #char "V"  return 5;
        if c == #char "X"  return 10;
        if c == #char "L"  return 50;
        if c == #char "C"  return 100;
        if c == #char "D"  return 500;
        if c == #char "M"  return 1000;
        return 0;
    }
    total := 0;
    i := 0;
    while i < s.count {
        v := value_of(s[i]);
        next_v := ifx i + 1 < s.count then value_of(s[i+1]) else 0;
        if next_v > v {
            total += next_v - v;
            i += 2;
        } else {
            total += v;
            i += 1;
        }
    }
    return total;
}

test_roman :: () {
    section("238. Roman numeral conversion");

    for n: int.[1, 2, 3, 4, 5, 9, 10, 40, 44, 49, 90, 99, 400, 444, 949, 1994, 3999] {
        r := to_roman(n);
        back := from_roman(r);
        print("  % -> '%' -> %  match=%\n", n, r, back, back == n);
    }
}


// ============================================================================
// 239. Convert int to base-N string.
// ============================================================================

int_to_base :: (n: int, base: int) -> string {
    if base < 2 || base > 36  return "";
    if n == 0  return "0";

    digits :: "0123456789abcdefghijklmnopqrstuvwxyz";

    buf: [128] u8;
    idx := 0;
    negative := n < 0;
    val: int = ifx negative then -n else n;
    while val > 0 {
        buf[idx] = digits[val % base];
        idx += 1;
        val = val / base;
    }
    if negative {
        buf[idx] = #char "-";
        idx += 1;
    }
    // reverse
    for i: 0..idx/2 - 1 {
        tmp := buf[i];
        buf[i] = buf[idx-1-i];
        buf[idx-1-i] = tmp;
    }
    result: string;
    result.data = buf.data;
    result.count = idx;
    return copy_string(result);
}

test_int_to_base :: () {
    section("239. int_to_base(N, base)");

    for n: int.[0, 1, 2, 7, 8, 15, 16, 255, 256, 1023, 1024] {
        b2  := int_to_base(n,  2);
        b8  := int_to_base(n,  8);
        b16 := int_to_base(n, 16);
        b36 := int_to_base(n, 36);
        print("  %: bin=% oct=% hex=% b36=%\n", n, b2, b8, b16, b36);
    }

    sub("Negative numbers");
    for n: int.[-1, -10, -255, -1024] {
        b10 := int_to_base(n, 10);
        b16 := int_to_base(n, 16);
        print("  %: dec=% hex=%\n", n, b10, b16);
    }
}


// ============================================================================
// 240. Polynomial evaluation (Horner's method).
// ============================================================================

horner_eval :: (coeffs: [] float, x: float) -> float {
    if coeffs.count == 0  return 0.0;
    result := coeffs[0];
    for i: 1..coeffs.count-1 {
        result = result * x + coeffs[i];
    }
    return result;
}

test_horner :: () {
    section("240. Horner's polynomial evaluation");

    // p(x) = 2x^3 - 4x^2 + 5x - 7
    coeffs := float.[2.0, -4.0, 5.0, -7.0];

    for x: float.[0.0, 1.0, 2.0, 3.0, -1.0, -2.0] {
        v := horner_eval(coeffs, x);
        print("p(%) = %\n", x, v);
    }

    sub("Constant polynomial");
    cs := float.[42.0];
    for x: float.[0.0, 1.0, 5.0]  print("const(%) = %\n", x, horner_eval(cs, x));

    sub("Empty polynomial");
    empty: [..] float;
    print("empty(2.0) = %\n", horner_eval(empty, 2.0));
}


// ============================================================================
// 241. Matrix transpose for a small generic matrix.
// ============================================================================

Small_Matrix :: struct ($R: int, $C: int) {
    cells: [R][C] float;
}

matrix_transpose :: (m: $M/Small_Matrix) -> Small_Matrix(M.C, M.R) {
    result: Small_Matrix(M.C, M.R);
    for r: 0..M.R-1 {
        for c: 0..M.C-1 {
            result.cells[c][r] = m.cells[r][c];
        }
    }
    return result;
}

matrix_print :: (m: $M/Small_Matrix, label: string) {
    print("% (%x%):\n", label, M.R, M.C);
    for r: 0..M.R-1 {
        print("  [");
        for c: 0..M.C-1 {
            if c > 0  print(", ");
            print("%", formatFloat(m.cells[r][c], width=5, trailing_width=1));
        }
        print("]\n");
    }
}

test_matrix_transpose :: () {
    section("241. Generic Small_Matrix transpose");

    m: Small_Matrix(2, 3);
    m.cells[0][0] = 1; m.cells[0][1] = 2; m.cells[0][2] = 3;
    m.cells[1][0] = 4; m.cells[1][1] = 5; m.cells[1][2] = 6;
    matrix_print(m, "m");

    t := matrix_transpose(m);
    matrix_print(t, "transpose(m)");

    sub("Transpose of transpose returns original shape");
    tt := matrix_transpose(t);
    matrix_print(tt, "transpose(transpose(m))");
}


