    run_extras_7_m33();
    run_extras_7_roman();
    run_extras_7_base();
    run_extras_7_digits();
    run_extras_7_defer_while_break();
    run_extras_7_caesar();
    run_extras_7_minmax_by();
    run_extras_7_moving_avg();
    run_extras_7_defer_compute();
    run_extras_7_reductions();
    run_extras_7_truth_table();
    run_extras_7_prefix_suffix();
    run_extras_7_complex_arith_table();
    run_extras_7_nested_defer_return();
    run_extras_7_complex_algos();
    run_extras_7_poly_more();
    run_extras_7_rat_series();
    run_extras_7_show_arrays();
    run_extras_7_levenshtein_matrix();
    run_extras_7_sym_stress();
    run_extras_7_keyword_fsm();
    run_extras_7_eval_more();
    run_extras_7_rle_long();
    run_extras_7_seq_arith();
    run_extras_7_defer_cleanup_stack();
    run_extras_7_iters_cartesian();
    run_extras_7_matrix_summary();
    run_extras_7_poly_trace();
    run_extras_7_compose();
    run_extras_7_roman_extended();
    run_extras_7_words();
    run_extras_7_early_return();
    run_extras_7_describe();
    run_extras_7_int_table_stress();
    run_extras_7_end();
}

// ============================================================================
// cleanroom_stress_part8.jai
//
// Continuation of the reference compatibility stress test. This part focuses
// on:
//
//   - Comprehensive Any-handling: variadic functions that walk *Type_Info and
//     dispatch on Type_Info_Tag.
//   - A small JSON encoder for Any values.
//   - A YAML-like indented dumper for nested struct trees.
//   - A field-by-field "diff" for two structs of the same type.
//   - Apollo_Time <-> Calendar_Time round-trips, computed against a FIXED
//     Apollo_Time so output is deterministic.
//   - Date arithmetic by N days on a Calendar_Time, done manually.
//   - Manual UTF-8 encoder/decoder over lists of Unicode codepoints.
//   - UTF-8 length-by-codepoint counter.
//   - Polymorphic tree types where each node has [..] children.
//   - Iterator combinators: chain, take, skip, enumerate, pairs.
//   - A small graph type using indices, with BFS, DFS, and topological sort.
//   - Union-find / disjoint-set, with a sequence of operations.
//   - Simple regex-ish matching of '*' and '?' against many strings.
//   - A tiny calculator that tokenizes, parses, and evaluates expressions.
//   - A small templating engine with named substitutions.
//   - #procedure_of_call applied to many polymorph instantiations.
//   - Many small structs built at compile time via #run.
//   - #insert in many forms: variable declarations, function calls, case
//     dispatch, expression substitution, type construction.
//
// All output is deterministic, ASCII, with no I/O. Pointers are printed by
// nullity only. Apollo_Time samples in this file are FIXED, not "now".
// ============================================================================


// ----------------------------------------------------------------------------
// Sample types used throughout this part.
// ----------------------------------------------------------------------------

PE8_V2 :: struct {
    x: float;
    y: float;
}

PE8_V3 :: struct {
    x: float;
    y: float;
    z: float;
}

PE8_RGBA :: struct {
    r: u8;
    g: u8;
    b: u8;
    a: u8;
}

PE8_Color_Tag :: enum u8 {
    RED;
    GREEN;
    BLUE;
    YELLOW;
}

PE8_Point :: struct {
    label: string;
    x: int;
    y: int;
}

PE8_Polyline :: struct {
    name: string;
    closed: bool;
    pts: [] PE8_Point;
}

PE8_Person :: struct {
    name: string;
    age: s32;
    height_cm: float;
    likes_cats: bool;
}

PE8_Book :: struct {
    title: string;
    pages: int;
    in_stock: bool;
}

PE8_Box :: struct {
    width:  s32;
    height: s32;
    depth:  s32;
}

PE8_Cell :: struct {
    row: s32;
    col: s32;
    value: u8;
}

PE8_Address :: struct {
    street: string;
    city: string;
    zip: string;
}

PE8_Employee :: struct {
    person: PE8_Person;
    address: PE8_Address;
    employee_id: s64;
    salary: float;
}


// ----------------------------------------------------------------------------
// Tiny utility helpers used in many places below.
// ----------------------------------------------------------------------------

PE8_spaces :: (sb: *String_Builder, n: int) {
    for 0..n-1  append(sb, " ");
}

PE8_starts_with :: (s: string, prefix: string) -> bool {
    if s.count < prefix.count  return false;
    for i: 0..prefix.count-1 {
        if s.data[i] != prefix.data[i]  return false;
    }
    return true;
}

PE8_string_eq :: (a: string, b: string) -> bool {
    if a.count != b.count  return false;
    for i: 0..a.count-1 {
        if a.data[i] != b.data[i]  return false;
    }
    return true;
}


// ============================================================================
// Section 801. Any-walking: variadic procedures that print each Any in many
// ways, dispatching on Type_Info_Tag.
// ============================================================================

PE8_describe_any :: (label: string, a: Any) {
    info := a.type;
    if info == null {
        print("  %: <null type>\n", label);
        return;
    }
    tag := info.type;
    print("  %: tag=% runtime_size=%\n", label, tag, info.runtime_size);
    if tag == {
      case .INTEGER;
        ti := cast(*Type_Info_Integer) info;
        print("    INTEGER signed=% size=%\n", ti.signed, ti.runtime_size);
        if      ti.runtime_size == 1  { if ti.signed { p := cast(*s8 ) a.value_pointer; print("    value=%\n", p.*); } else { p := cast(*u8 ) a.value_pointer; print("    value=%\n", p.*); } }
        else if ti.runtime_size == 2  { if ti.signed { p := cast(*s16) a.value_pointer; print("    value=%\n", p.*); } else { p := cast(*u16) a.value_pointer; print("    value=%\n", p.*); } }
        else if ti.runtime_size == 4  { if ti.signed { p := cast(*s32) a.value_pointer; print("    value=%\n", p.*); } else { p := cast(*u32) a.value_pointer; print("    value=%\n", p.*); } }
        else if ti.runtime_size == 8  { if ti.signed { p := cast(*s64) a.value_pointer; print("    value=%\n", p.*); } else { p := cast(*u64) a.value_pointer; print("    value=%\n", p.*); } }
      case .FLOAT;
        if      info.runtime_size == 4  { p := cast(*float32) a.value_pointer; print("    FLOAT 32-bit value=%\n", p.*); }
        else if info.runtime_size == 8  { p := cast(*float64) a.value_pointer; print("    FLOAT 64-bit value=%\n", p.*); }
      case .BOOL;
        p := cast(*bool) a.value_pointer;
        print("    BOOL value=%\n", p.*);
      case .STRING;
        p := cast(*string) a.value_pointer;
        print("    STRING count=% data='%'\n", p.count, p.*);
      case .POINTER;
        p := cast(**void) a.value_pointer;
        nul := p.* == null;
        ti := cast(*Type_Info_Pointer) info;
        print("    POINTER pointer_to_tag=% null=%\n", ti.pointer_to.type, nul);
      case .PROCEDURE;
        ti := cast(*Type_Info_Procedure) info;
        print("    PROCEDURE args=% rets=%\n", ti.argument_types.count, ti.return_types.count);
      case .VOID;
        print("    VOID (no value)\n");
      case .STRUCT;
        ti := cast(*Type_Info_Struct) info;
        print("    STRUCT name='%' members=%\n", ti.name, ti.members.count);
      case .ARRAY;
        ti := cast(*Type_Info_Array) info;
        print("    ARRAY kind=% array_count=% elem_tag=%\n",
            ti.array_type, ti.array_count, ti.element_type.type);
      case .ENUM;
        ti := cast(*Type_Info_Enum) info;
        print("    ENUM name='%' values=%\n", ti.name, ti.values.count);
      case .TYPE;
        p := cast(*Type) a.value_pointer;
        print("    TYPE value tag(of held type)=%\n", (cast(*Type_Info) p.*).type);
      case .CODE;
        print("    CODE (compile-time only)\n");
      case .VARIANT;
        ti := cast(*Type_Info_Variant) info;
        print("    VARIANT name='%' variant_of_tag=% distinct=% isa=%\n",
            ti.name, ti.variant_of.type,
            cast(bool) (ti.variant_flags & .DISTINCT),
            cast(bool) (ti.variant_flags & .ISA));
      case;
        print("    (other tag)\n");
    }
}

PE8_describe_anys :: (label: string, args: ..Any) {
    print("variadic '%' got % arg(s):\n", label, args.count);
    for args  PE8_describe_any(tprint("[%]", it_index), it);
}


PE8_Sample_Enum :: enum u32 {
    A;
    B;
    C;
    D;
}

PE8_sample_proc :: (x: int, y: float) -> bool { return x > 0 && y > 0; }

PE8_run_section_801 :: () {
    section("801. Any-walking: dispatching on Type_Info_Tag");

    sub("INTEGER variants");
    a_u8  : u8  = 42;
    a_u16 : u16 = 4242;
    a_u32 : u32 = 424242;
    a_u64 : u64 = 4242424242;
    a_s8  : s8  = -7;
    a_s16 : s16 = -700;
    a_s32 : s32 = -70000;
    a_s64 : s64 = -7000000000;
    PE8_describe_anys("ints",
        a_u8, a_u16, a_u32, a_u64, a_s8, a_s16, a_s32, a_s64);

    sub("FLOAT variants");
    f32_val : float32 = 1.5;
    f64_val : float64 = 2.5;
    PE8_describe_anys("floats", f32_val, f64_val);

    sub("BOOL variants");
    PE8_describe_anys("bools", true, false);

    sub("STRING variants");
    PE8_describe_anys("strings", "alpha", "beta", "");

    sub("POINTER variants");
    z : int = 99;
    pz := *z;
    pnull : *int = null;
    PE8_describe_anys("pointers", pz, pnull);

    sub("PROCEDURE variants");
    p_call := PE8_sample_proc;
    PE8_describe_anys("procs", p_call);

    sub("VOID variants - reaches via untyped void Any");
    // Direct VOID Anys are tricky to construct; we omit a runtime example.

    sub("STRUCT variants");
    PE8_describe_anys("structs",
        PE8_V2.{1, 2}, PE8_V3.{1, 2, 3}, PE8_Person.{"Ada", 30, 170.0, true});

    sub("ARRAY variants");
    fixed_arr : [4] int = .[10, 20, 30, 40];
    view_arr  : [] int = .[100, 200, 300];
    dyn_arr   : [..] int;
    array_add(*dyn_arr, 1);
    array_add(*dyn_arr, 2);
    array_add(*dyn_arr, 3);
    PE8_describe_anys("arrays", fixed_arr, view_arr, dyn_arr);
    array_reset(*dyn_arr);

    sub("ENUM variants");
    e : PE8_Sample_Enum = .B;
    PE8_describe_anys("enums", e);
    PE8_describe_anys("color-enums", PE8_Color_Tag.RED, PE8_Color_Tag.GREEN);

    sub("TYPE variants");
    t1 : Type = int;
    t2 : Type = string;
    t3 : Type = PE8_V2;
    PE8_describe_anys("types", t1, t2, t3);

    sub("CODE variants");
    code_value : Code : #code { print("inserted code\n"); };
    PE8_describe_anys("code", code_value);

    sub("VARIANT variants");
    // Apollo_Time is declared as `#type,isa S128`.
    fixed_apollo : Apollo_Time;
    fixed_apollo.low  = 0;
    fixed_apollo.high = 0;
    PE8_describe_anys("variant (Apollo_Time)", fixed_apollo);
}


// ============================================================================
// Section 802. JSON encoder that accepts an Any and emits JSON to a
// String_Builder, walking *Type_Info recursively.
// ============================================================================

PE8_json_emit_string :: (sb: *String_Builder, s: string) {
    append(sb, "\"");
    for i: 0..s.count-1 {
        c := s.data[i];
        if c == #char "\""       append(sb, "\\\"");
        else if c == #char "\\"  append(sb, "\\\\");
        else if c == #char "\n"  append(sb, "\\n");
        else if c == #char "\r"  append(sb, "\\r");
        else if c == #char "\t"  append(sb, "\\t");
        else if c < 32 {
            append(sb, "\\u00");
            HEX :: "0123456789abcdef";
            append(sb, HEX[(c >> 4) & 0xF]);
            append(sb, HEX[c & 0xF]);
        } else {
            append(sb, c);
        }
    }
    append(sb, "\"");
}

PE8_json_emit_int :: (sb: *String_Builder, v: int) {
    if v < 0 {
        append(sb, "-");
        // We avoid v = -v overflow on min by using u-format.
        u := cast,no_check(u64) (-v);
        PE8_json_emit_uint(sb, u);
    } else {
        PE8_json_emit_uint(sb, cast,no_check(u64) v);
    }
}

PE8_json_emit_uint :: (sb: *String_Builder, v: u64) {
    if v == 0 { append(sb, "0"); return; }
    digits: [20] u8;
    n := 0;
    x := v;
    while x > 0 {
        digits[n] = cast(u8) ((x % 10) + #char "0");
        x /= 10;
        n += 1;
    }
    for < i: n-1..0  append(sb, digits[i]);
}

PE8_json_emit_any :: (sb: *String_Builder, a: Any) {
    info := a.type;
    if info == null  { append(sb, "null"); return; }
    tag := info.type;
    if tag == {
      case .INTEGER;
        ti := cast(*Type_Info_Integer) info;
        if      ti.runtime_size == 1  { if ti.signed { p := cast(*s8 ) a.value_pointer; PE8_json_emit_int(sb, p.*); } else { p := cast(*u8 ) a.value_pointer; PE8_json_emit_uint(sb, p.*); } }
        else if ti.runtime_size == 2  { if ti.signed { p := cast(*s16) a.value_pointer; PE8_json_emit_int(sb, p.*); } else { p := cast(*u16) a.value_pointer; PE8_json_emit_uint(sb, p.*); } }
        else if ti.runtime_size == 4  { if ti.signed { p := cast(*s32) a.value_pointer; PE8_json_emit_int(sb, p.*); } else { p := cast(*u32) a.value_pointer; PE8_json_emit_uint(sb, p.*); } }
        else if ti.runtime_size == 8  { if ti.signed { p := cast(*s64) a.value_pointer; PE8_json_emit_int(sb, p.*); } else { p := cast(*u64) a.value_pointer; PE8_json_emit_uint(sb, p.*); } }
      case .FLOAT;
        if      info.runtime_size == 4  { p := cast(*float32) a.value_pointer; print_to_builder(sb, "%", p.*); }
        else if info.runtime_size == 8  { p := cast(*float64) a.value_pointer; print_to_builder(sb, "%", p.*); }
      case .BOOL;
        p := cast(*bool) a.value_pointer;
        if p.*  append(sb, "true");
        else    append(sb, "false");
      case .STRING;
        p := cast(*string) a.value_pointer;
        PE8_json_emit_string(sb, p.*);
      case .POINTER;
        // Encode pointers as null or "<ptr>"; we hide nullity rather than addresses.
        pp := cast(**void) a.value_pointer;
        if pp.* == null  append(sb, "null");
        else             append(sb, "\"<ptr>\"");
      case .STRUCT;
        ti := cast(*Type_Info_Struct) info;
        append(sb, "{");
        first := true;
        for ti.members {
            if it.flags & .CONSTANT  continue;
            if it.flags & .IMPORTED  continue;
            if !first  append(sb, ",");
            first = false;
            PE8_json_emit_string(sb, it.name);
            append(sb, ":");
            sub_any : Any;
            sub_any.type = it.type;
            sub_any.value_pointer = (cast(*u8) a.value_pointer) + it.offset_in_bytes;
            PE8_json_emit_any(sb, sub_any);
        }
        append(sb, "}");
      case .ARRAY;
        ti := cast(*Type_Info_Array) info;
        elem := ti.element_type;
        elem_size := elem.runtime_size;
        // Locate count + data based on the array kind.
        base : *u8;
        count: int;
        if ti.array_type == .FIXED {
            base = cast(*u8) a.value_pointer;
            count = ti.array_count;
        } else if ti.array_type == .VIEW {
            // Layout: { count: s64, data: *u8 } at the value_pointer.
            view_p := cast(*Array_Header) a.value_pointer;
            count = view_p.count;
            base = cast(*u8) view_p.data;
        } else {
            // RESIZABLE
            view_p := cast(*Array_Header) a.value_pointer;
            count = view_p.count;
            base = cast(*u8) view_p.data;
        }
        append(sb, "[");
        for i: 0..count-1 {
            if i > 0  append(sb, ",");
            sub_any : Any;
            sub_any.type = elem;
            sub_any.value_pointer = base + i * elem_size;
            PE8_json_emit_any(sb, sub_any);
        }
        append(sb, "]");
      case .ENUM;
        ti := cast(*Type_Info_Enum) info;
        // Read the underlying value depending on internal_type's size.
        v: s64;
        int_info := ti.internal_type;
        sz := int_info.runtime_size;
        sgn := int_info.signed;
        if      sz == 1  { if sgn { p := cast(*s8 ) a.value_pointer; v = p.*; } else { p := cast(*u8 ) a.value_pointer; v = p.*; } }
        else if sz == 2  { if sgn { p := cast(*s16) a.value_pointer; v = p.*; } else { p := cast(*u16) a.value_pointer; v = p.*; } }
        else if sz == 4  { if sgn { p := cast(*s32) a.value_pointer; v = p.*; } else { p := cast(*u32) a.value_pointer; v = p.*; } }
        else if sz == 8  { if sgn { p := cast(*s64) a.value_pointer; v = p.*; } else { p := cast(*u64) a.value_pointer; v = cast,no_check(s64) p.*; } }
        found := false;
        for ti.values {
            if it == v {
                PE8_json_emit_string(sb, ti.names[it_index]);
                found = true;
                break;
            }
        }
        if !found {
            PE8_json_emit_int(sb, v);
        }
      case .TYPE;
        // Just emit a synthetic string indicating "type".
        append(sb, "\"<type>\"");
      case .CODE;
        append(sb, "\"<code>\"");
      case .VARIANT;
        // Encode as if it were the underlying type.
        ti := cast(*Type_Info_Variant) info;
        sub_any : Any;
        sub_any.type = ti.variant_of;
        sub_any.value_pointer = a.value_pointer;
        PE8_json_emit_any(sb, sub_any);
      case;
        append(sb, "null");
    }
}

PE8_json :: (a: Any) -> string {
    sb: String_Builder;
    init_string_builder(*sb);
    PE8_json_emit_any(*sb, a);
    return builder_to_string(*sb);
}

PE8_run_section_802 :: () {
    section("802. JSON encoder for Any values");

    sub("primitives");
    print("  int       -> %\n", PE8_json(42));
    print("  neg       -> %\n", PE8_json(-7));
    print("  float     -> %\n", PE8_json(1.5));
    print("  bool t    -> %\n", PE8_json(true));
    print("  bool f    -> %\n", PE8_json(false));
    print("  string    -> %\n", PE8_json("hello"));
    print("  empty str -> %\n", PE8_json(""));

    sub("string escapes");
    print("  quote     -> %\n", PE8_json("a\"b"));
    print("  backslash -> %\n", PE8_json("a\\b"));
    print("  newline   -> %\n", PE8_json("a\nb"));
    print("  tab       -> %\n", PE8_json("a\tb"));

    sub("structs");
    p := PE8_Person.{"Ada", 30, 170.0, true};
    print("  Person    -> %\n", PE8_json(p));
    v := PE8_V2.{1, 2};
    print("  V2        -> %\n", PE8_json(v));
    rgba := PE8_RGBA.{255, 128, 64, 32};
    print("  RGBA      -> %\n", PE8_json(rgba));

    sub("nested");
    e := PE8_Employee.{
        person  = .{"Bob", 25, 180.0, false},
        address = .{"5 Elm", "Springfield", "00000"},
        employee_id = 1001,
        salary = 50000.0
    };
    print("  Employee  -> %\n", PE8_json(e));

    sub("arrays");
    fixed_arr : [4] int = .[10, 20, 30, 40];
    print("  fixed[4]  -> %\n", PE8_json(fixed_arr));
    view_arr  : [] int = .[1, 2, 3];
    print("  view[3]   -> %\n", PE8_json(view_arr));
    dyn_arr : [..] int;
    array_add(*dyn_arr, 100);
    array_add(*dyn_arr, 200);
    array_add(*dyn_arr, 300);
    print("  dyn[3]    -> %\n", PE8_json(dyn_arr));
    array_reset(*dyn_arr);

    sub("enum");
    color := PE8_Color_Tag.GREEN;
    print("  enum      -> %\n", PE8_json(color));

    sub("pointer null vs non-null");
    a : int = 9;
    pa := *a;
    pnull : *int = null;
    print("  ptr non   -> %\n", PE8_json(pa));
    print("  ptr null  -> %\n", PE8_json(pnull));

    sub("array of struct");
    pts := PE8_Point.[.{"a", 1, 2}, .{"b", 3, 4}, .{"c", 5, 6}];
    pl := PE8_Polyline.{name="poly", closed=true, pts=pts};
    print("  Polyline  -> %\n", PE8_json(pl));
}


// ============================================================================
// Section 803. YAML-like indented dumper for nested struct trees.
// ============================================================================

PE8_yaml_emit_value :: (sb: *String_Builder, a: Any, indent: int) {
    info := a.type;
    if info == null  { append(sb, "null"); return; }
    tag := info.type;
    if tag == {
      case .INTEGER;
        ti := cast(*Type_Info_Integer) info;
        if      ti.runtime_size == 1  { if ti.signed { p := cast(*s8 ) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u8 ) a.value_pointer; print_to_builder(sb, "%", p.*); } }
        else if ti.runtime_size == 2  { if ti.signed { p := cast(*s16) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u16) a.value_pointer; print_to_builder(sb, "%", p.*); } }
        else if ti.runtime_size == 4  { if ti.signed { p := cast(*s32) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u32) a.value_pointer; print_to_builder(sb, "%", p.*); } }
        else if ti.runtime_size == 8  { if ti.signed { p := cast(*s64) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u64) a.value_pointer; print_to_builder(sb, "%", p.*); } }
      case .FLOAT;
        if      info.runtime_size == 4  { p := cast(*float32) a.value_pointer; print_to_builder(sb, "%", p.*); }
        else if info.runtime_size == 8  { p := cast(*float64) a.value_pointer; print_to_builder(sb, "%", p.*); }
      case .BOOL;
        p := cast(*bool) a.value_pointer;
        if p.*  append(sb, "true");
        else    append(sb, "false");
      case .STRING;
        p := cast(*string) a.value_pointer;
        append(sb, "\"");
        append(sb, p.*);
        append(sb, "\"");
      case .POINTER;
        pp := cast(**void) a.value_pointer;
        if pp.* == null  append(sb, "null");
        else             append(sb, "<ptr>");
      case .STRUCT;
        ti := cast(*Type_Info_Struct) info;
        // Each member on its own line.
        any_emitted := false;
        for ti.members {
            if it.flags & .CONSTANT  continue;
            if it.flags & .IMPORTED  continue;
            if any_emitted  append(sb, "\n");
            any_emitted = true;
            PE8_spaces(sb, indent);
            append(sb, it.name);
            append(sb, ": ");
            sub_any : Any;
            sub_any.type = it.type;
            sub_any.value_pointer = (cast(*u8) a.value_pointer) + it.offset_in_bytes;
            // Structs and arrays produce a newline + nested indent.
            inner_tag := it.type.type;
            if inner_tag == .STRUCT || inner_tag == .ARRAY {
                append(sb, "\n");
                PE8_yaml_emit_value(sb, sub_any, indent + 2);
            } else {
                PE8_yaml_emit_value(sb, sub_any, indent + 2);
            }
        }
      case .ARRAY;
        ti := cast(*Type_Info_Array) info;
        elem := ti.element_type;
        elem_size := elem.runtime_size;
        base : *u8;
        count: int;
        if ti.array_type == .FIXED {
            base = cast(*u8) a.value_pointer;
            count = ti.array_count;
        } else {
            view_p := cast(*Array_Header) a.value_pointer;
            count = view_p.count;
            base = cast(*u8) view_p.data;
        }
        for i: 0..count-1 {
            if i > 0  append(sb, "\n");
            PE8_spaces(sb, indent);
            append(sb, "- ");
            sub_any : Any;
            sub_any.type = elem;
            sub_any.value_pointer = base + i * elem_size;
            inner_tag := elem.type;
            if inner_tag == .STRUCT {
                append(sb, "\n");
                PE8_yaml_emit_value(sb, sub_any, indent + 2);
            } else {
                PE8_yaml_emit_value(sb, sub_any, indent + 2);
            }
        }
      case .ENUM;
        ti := cast(*Type_Info_Enum) info;
        v: s64;
        int_info := ti.internal_type;
        sz := int_info.runtime_size;
        sgn := int_info.signed;
        if      sz == 1  { if sgn { p := cast(*s8 ) a.value_pointer; v = p.*; } else { p := cast(*u8 ) a.value_pointer; v = p.*; } }
        else if sz == 2  { if sgn { p := cast(*s16) a.value_pointer; v = p.*; } else { p := cast(*u16) a.value_pointer; v = p.*; } }
        else if sz == 4  { if sgn { p := cast(*s32) a.value_pointer; v = p.*; } else { p := cast(*u32) a.value_pointer; v = p.*; } }
        else if sz == 8  { if sgn { p := cast(*s64) a.value_pointer; v = p.*; } else { p := cast(*u64) a.value_pointer; v = cast,no_check(s64) p.*; } }
        for ti.values {
            if it == v {
                append(sb, ti.names[it_index]);
                return;
            }
        }
        print_to_builder(sb, "%", v);
      case;
        append(sb, "<?>");
    }
}

PE8_yaml :: (a: Any) -> string {
    sb: String_Builder;
    init_string_builder(*sb);
    PE8_yaml_emit_value(*sb, a, 0);
    return builder_to_string(*sb);
}

PE8_run_section_803 :: () {
    section("803. YAML-like dumper for nested struct trees");

    sub("flat Person");
    p := PE8_Person.{"Carl", 41, 165.0, false};
    print("%\n", PE8_yaml(p));

    sub("nested Employee");
    e := PE8_Employee.{
        person  = .{"Dora", 38, 158.0, true},
        address = .{"7 Maple", "Riverside", "11111"},
        employee_id = 2002,
        salary = 62000.0
    };
    print("%\n", PE8_yaml(e));

    sub("Polyline with array of Point");
    pts := PE8_Point.[.{"x", 0, 0}, .{"y", 5, 5}, .{"z", 10, 0}];
    pl := PE8_Polyline.{name="triangle", closed=true, pts=pts};
    print("%\n", PE8_yaml(pl));

    sub("fixed array of ints");
    arr : [5] int = .[1, 2, 3, 4, 5];
    print("%\n", PE8_yaml(arr));

    sub("box");
    b := PE8_Box.{3, 4, 5};
    print("%\n", PE8_yaml(b));
}


// ============================================================================
// Section 804. Field-by-field diff for two structs of the same type.
// ============================================================================

PE8_Diff_Entry :: struct {
    field_path: string;
    kind: enum u8 { EQUAL; DIFFER; }
    a_repr: string;
    b_repr: string;
}

PE8_repr_simple_any :: (sb: *String_Builder, a: Any) {
    info := a.type;
    if info == null  { append(sb, "null"); return; }
    tag := info.type;
    if tag == {
      case .INTEGER;
        ti := cast(*Type_Info_Integer) info;
        if      ti.runtime_size == 1  { if ti.signed { p := cast(*s8 ) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u8 ) a.value_pointer; print_to_builder(sb, "%", p.*); } }
        else if ti.runtime_size == 2  { if ti.signed { p := cast(*s16) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u16) a.value_pointer; print_to_builder(sb, "%", p.*); } }
        else if ti.runtime_size == 4  { if ti.signed { p := cast(*s32) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u32) a.value_pointer; print_to_builder(sb, "%", p.*); } }
        else if ti.runtime_size == 8  { if ti.signed { p := cast(*s64) a.value_pointer; print_to_builder(sb, "%", p.*); } else { p := cast(*u64) a.value_pointer; print_to_builder(sb, "%", p.*); } }
      case .FLOAT;
        if      info.runtime_size == 4  { p := cast(*float32) a.value_pointer; print_to_builder(sb, "%", p.*); }
        else if info.runtime_size == 8  { p := cast(*float64) a.value_pointer; print_to_builder(sb, "%", p.*); }
      case .BOOL;
        p := cast(*bool) a.value_pointer;
        print_to_builder(sb, "%", p.*);
      case .STRING;
        p := cast(*string) a.value_pointer;
        print_to_builder(sb, "'%'", p.*);
      case .ENUM;
        ti := cast(*Type_Info_Enum) info;
        v: s64;
        int_info := ti.internal_type;
        sz := int_info.runtime_size;
        sgn := int_info.signed;
        if      sz == 1  { if sgn { p := cast(*s8 ) a.value_pointer; v = p.*; } else { p := cast(*u8 ) a.value_pointer; v = p.*; } }
        else if sz == 2  { if sgn { p := cast(*s16) a.value_pointer; v = p.*; } else { p := cast(*u16) a.value_pointer; v = p.*; } }
        else if sz == 4  { if sgn { p := cast(*s32) a.value_pointer; v = p.*; } else { p := cast(*u32) a.value_pointer; v = p.*; } }
        else if sz == 8  { if sgn { p := cast(*s64) a.value_pointer; v = p.*; } else { p := cast(*u64) a.value_pointer; v = cast,no_check(s64) p.*; } }
        for ti.values  if it == v { append(sb, ti.names[it_index]); return; }
        print_to_builder(sb, "%", v);
      case .POINTER;
        pp := cast(**void) a.value_pointer;
        if pp.* == null  append(sb, "null");
        else             append(sb, "<ptr>");
      case;
        append(sb, "<?>");
    }
}

PE8_bytes_equal :: (a: *u8, b: *u8, n: int) -> bool {
    for i: 0..n-1  if a[i] != b[i]  return false;
    return true;
}

PE8_struct_diff :: (a: Any, b: Any, prefix: string, out: *[..] PE8_Diff_Entry) {
    if a.type != b.type {
        e: PE8_Diff_Entry;
        e.field_path = copy_string(prefix);
        e.kind = .DIFFER;
        e.a_repr = "<typeA>";
        e.b_repr = "<typeB>";
        array_add(out, e);
        return;
    }
    info := a.type;
    tag := info.type;
    if tag == .STRUCT {
        ti := cast(*Type_Info_Struct) info;
        for ti.members {
            if it.flags & .CONSTANT  continue;
            if it.flags & .IMPORTED  continue;
            sub_a : Any;
            sub_b : Any;
            sub_a.type = it.type;
            sub_b.type = it.type;
            sub_a.value_pointer = (cast(*u8) a.value_pointer) + it.offset_in_bytes;
            sub_b.value_pointer = (cast(*u8) b.value_pointer) + it.offset_in_bytes;
            new_prefix : string;
            if prefix.count == 0  new_prefix = copy_string(it.name);
            else                  new_prefix = tprint("%.%", prefix, it.name);
            PE8_struct_diff(sub_a, sub_b, new_prefix, out);
        }
        return;
    }
    // For non-struct, compare bytes.
    equal := PE8_bytes_equal(cast(*u8) a.value_pointer,
                            cast(*u8) b.value_pointer,
                            info.runtime_size);
    // For strings we compare more carefully: count + char content.
    if tag == .STRING {
        sa := (cast(*string) a.value_pointer).*;
        sb := (cast(*string) b.value_pointer).*;
        equal = PE8_string_eq(sa, sb);
    }
    e: PE8_Diff_Entry;
    e.field_path = copy_string(prefix);
    if equal  e.kind = .EQUAL;
    else      e.kind = .DIFFER;
    sb_a: String_Builder; init_string_builder(*sb_a); PE8_repr_simple_any(*sb_a, a);
    sb_b: String_Builder; init_string_builder(*sb_b); PE8_repr_simple_any(*sb_b, b);
    e.a_repr = builder_to_string(*sb_a);
    e.b_repr = builder_to_string(*sb_b);
    array_add(out, e);
}

PE8_print_diff :: (label: string, a: Any, b: Any) {
    print("diff '%':\n", label);
    entries: [..] PE8_Diff_Entry;
    PE8_struct_diff(a, b, "", *entries);
    for entries {
        if it.kind == .EQUAL {
            print("  EQUAL  %= %\n", it.field_path, it.a_repr);
        } else {
            print("  DIFFER %  A=% B=%\n", it.field_path, it.a_repr, it.b_repr);
        }
    }
    array_reset(*entries);
}

PE8_run_section_804 :: () {
    section("804. Field-by-field diff for two structs");

    sub("Person diff (one field differs)");
    p1 := PE8_Person.{"Ada", 30, 170.0, true};
    p2 := PE8_Person.{"Ada", 31, 170.0, true};
    PE8_print_diff("p1 vs p2", p1, p2);

    sub("Person diff (multiple fields differ)");
    p3 := PE8_Person.{"Bob", 25, 165.0, false};
    p4 := PE8_Person.{"Bob", 25, 180.0, true};
    PE8_print_diff("p3 vs p4", p3, p4);

    sub("Person diff (all equal)");
    p5 := PE8_Person.{"Same", 40, 170.0, true};
    p6 := PE8_Person.{"Same", 40, 170.0, true};
    PE8_print_diff("p5 vs p6", p5, p6);

    sub("Employee diff (nested struct)");
    e1 := PE8_Employee.{
        person  = .{"Carl", 50, 175.0, false},
        address = .{"1 A", "Town", "00000"},
        employee_id = 1,
        salary = 1000.0
    };
    e2 := PE8_Employee.{
        person  = .{"Carl", 50, 175.0, true},      // last field differs
        address = .{"1 B", "Town", "00000"},        // street differs
        employee_id = 1,
        salary = 1500.0                              // salary differs
    };
    PE8_print_diff("e1 vs e2", e1, e2);

    sub("Box diff (single field)");
    b1 := PE8_Box.{3, 4, 5};
    b2 := PE8_Box.{3, 9, 5};
    PE8_print_diff("b1 vs b2", b1, b2);

    sub("V2 diff (all equal)");
    v1 := PE8_V2.{1, 2};
    v2 := PE8_V2.{1, 2};
    PE8_print_diff("v1 vs v2", v1, v2);

    sub("V2 diff (both differ)");
    v3 := PE8_V2.{1, 2};
    v4 := PE8_V2.{10, 20};
    PE8_print_diff("v3 vs v4", v3, v4);
}


// ============================================================================
// Section 805. Apollo_Time <-> Calendar_Time round-trips, against a FIXED
// Apollo_Time and FIXED Calendar_Time so output is deterministic.
//
// We don't call current_time_* anywhere. We construct calendar times by hand,
// convert them to Apollo_Time, convert them back, and verify the result.
// ============================================================================

PE8_make_cal :: (year: s32, month1: s8, day1: s8, hour: s8, minute: s8, second: s8, ms: s16) -> Calendar_Time {
    ct: Calendar_Time;
    ct.year = year;
    ct.month_starting_at_0        = month1 - 1;
    ct.day_of_month_starting_at_0 = day1   - 1;
    ct.day_of_week_starting_at_0  = 0;       // not used by calendar_to_apollo
    ct.hour   = hour;
    ct.minute = minute;
    ct.second = second;
    ct.millisecond = ms;
    ct.time_zone = .UTC;
    return ct;
}

PE8_print_cal :: (label: string, ct: Calendar_Time) {
    print("  % year=% month1=% day1=% hour=% minute=% second=% ms=%\n",
        label,
        ct.year,
        ct.month_starting_at_0 + 1,
        ct.day_of_month_starting_at_0 + 1,
        ct.hour, ct.minute, ct.second, ct.millisecond);
}

PE8_is_leap :: (year: int) -> bool {
    if year % 400 == 0  return true;
    if year % 100 == 0  return false;
    return year % 4 == 0;
}

PE8_days_in_month :: (year: int, month1: int) -> int {
    if month1 == {
      case  1; return 31;
      case  2; return ifx PE8_is_leap(year) then 29 else 28;
      case  3; return 31;
      case  4; return 30;
      case  5; return 31;
      case  6; return 30;
      case  7; return 31;
      case  8; return 31;
      case  9; return 30;
      case 10; return 31;
      case 11; return 30;
      case 12; return 31;
    }
    return 0;
}

PE8_add_days :: (ct: Calendar_Time, days: int) -> Calendar_Time {
    out := ct;
    remaining := days;
    while remaining > 0 {
        m1 := out.month_starting_at_0 + 1;
        dim := PE8_days_in_month(out.year, m1);
        d   := out.day_of_month_starting_at_0 + 1;
        room := dim - d;
        if remaining <= room {
            out.day_of_month_starting_at_0 = cast(s8) (d - 1 + remaining);
            remaining = 0;
        } else {
            // jump to first of next month
            remaining -= (room + 1);
            if m1 == 12 {
                out.year += 1;
                out.month_starting_at_0 = 0;
            } else {
                out.month_starting_at_0 += 1;
            }
            out.day_of_month_starting_at_0 = 0;
        }
    }
    while remaining < 0 {
        d := out.day_of_month_starting_at_0 + 1;
        if d > 1 {
            step := -remaining;
            if step >= d {
                remaining += d;            // d days back lands on day 1, then continues
                if out.month_starting_at_0 == 0 {
                    out.year -= 1;
                    out.month_starting_at_0 = 11;
                } else {
                    out.month_starting_at_0 -= 1;
                }
                dim := PE8_days_in_month(out.year, out.month_starting_at_0 + 1);
                out.day_of_month_starting_at_0 = cast(s8) (dim - 1);
                remaining -= 1;            // we landed on the last day of prev month; account for the step
            } else {
                out.day_of_month_starting_at_0 -= cast(s8) step;
                remaining = 0;
            }
        } else {
            // jump to last day of previous month
            if out.month_starting_at_0 == 0 {
                out.year -= 1;
                out.month_starting_at_0 = 11;
            } else {
                out.month_starting_at_0 -= 1;
            }
            dim := PE8_days_in_month(out.year, out.month_starting_at_0 + 1);
            out.day_of_month_starting_at_0 = cast(s8) (dim - 1);
            remaining += 1;
        }
    }
    return out;
}

PE8_run_section_805 :: () {
    section("805. Apollo_Time <-> Calendar_Time round-trips (FIXED times)");

    sub("Construct calendar times and round-trip them");
    fixed_cals := Calendar_Time.[
        PE8_make_cal(2000,  1,  1,  0,  0,  0,    0),
        PE8_make_cal(2024, 12, 31, 23, 59, 59,  999),
        PE8_make_cal(1970,  1,  1,  0,  0,  0,    0),
        PE8_make_cal(2001,  9, 11, 12, 30, 15,  500),
        PE8_make_cal(2099,  2, 28, 11, 22, 33,  444),
    ];

    for fixed_cals {
        cal := it;
        PE8_print_cal(tprint("before round-trip [%]", it_index), cal);
        apollo := calendar_to_apollo(cal);
        back   := to_calendar(apollo, .UTC);
        // Zero out day_of_week before we display the round-trip; we don't set it on the input.
        // (Many platforms re-derive day_of_week, which would be deterministic; but we print
        // separately for clarity below.)
        PE8_print_cal(tprint(" after round-trip [%]", it_index), back);
        print("  dayofweek0=% same-year=% same-month=% same-day=% same-time=% same-ms=%\n",
            back.day_of_week_starting_at_0,
            back.year   == cal.year,
            back.month_starting_at_0 == cal.month_starting_at_0,
            back.day_of_month_starting_at_0 == cal.day_of_month_starting_at_0,
            back.hour   == cal.hour && back.minute == cal.minute && back.second == cal.second,
            back.millisecond == cal.millisecond);
    }

    sub("FIXED Apollo_Time built manually (low + high)");
    a: Apollo_Time;
    a.low  = 0;
    a.high = 0;
    secs := to_float64_seconds(a);
    print("  zero apollo: low=% high=% to_float64_seconds=%\n", a.low, a.high, secs);

    delta := seconds_to_apollo(60);
    ds := to_float64_seconds(delta);
    print("  60s apollo to_float64_seconds=%\n", ds);

    delta_ms := milliseconds_to_apollo(1500);
    ms_seconds := to_float64_seconds(delta_ms);
    print("  1500ms apollo to_float64_seconds=%\n", ms_seconds);

    sub("Apollo_Time arithmetic");
    one_minute := seconds_to_apollo(60);
    five_min   := one_minute * 5;
    fm_s := to_float64_seconds(five_min);
    print("  five_min seconds=%\n", fm_s);

    diff := five_min - one_minute;
    diff_s := to_float64_seconds(diff);
    print("  five_min - one_minute seconds=%\n", diff_s);
}


// ============================================================================
// Section 806. Date arithmetic: add N days to a Calendar_Time, computed
// manually (no OS calls).
// ============================================================================

PE8_run_section_806 :: () {
    section("806. Date arithmetic by N days (manual)");

    sub("add days within a month");
    c := PE8_make_cal(2024, 1, 10, 12, 0, 0, 0);
    PE8_print_cal("c", c);
    for n: 0..5 {
        out := PE8_add_days(c, n);
        PE8_print_cal(tprint("c+%", n), out);
    }

    sub("cross month boundary");
    c2 := PE8_make_cal(2024, 1, 28, 12, 0, 0, 0);
    PE8_print_cal("c2", c2);
    for n: 0..7 {
        out := PE8_add_days(c2, n);
        PE8_print_cal(tprint("c2+%", n), out);
    }

    sub("February in leap year");
    c3 := PE8_make_cal(2024, 2, 27, 0, 0, 0, 0);
    PE8_print_cal("c3", c3);
    for n: 0..4 {
        out := PE8_add_days(c3, n);
        PE8_print_cal(tprint("c3+%", n), out);
    }

    sub("February in non-leap year");
    c4 := PE8_make_cal(2023, 2, 27, 0, 0, 0, 0);
    PE8_print_cal("c4", c4);
    for n: 0..4 {
        out := PE8_add_days(c4, n);
        PE8_print_cal(tprint("c4+%", n), out);
    }

    sub("year boundary");
    c5 := PE8_make_cal(2023, 12, 30, 23, 30, 0, 0);
    PE8_print_cal("c5", c5);
    for n: 0..3 {
        out := PE8_add_days(c5, n);
        PE8_print_cal(tprint("c5+%", n), out);
    }

    sub("subtract days within month");
    c6 := PE8_make_cal(2024, 3, 10, 0, 0, 0, 0);
    PE8_print_cal("c6", c6);
    for n: 0..5 {
        out := PE8_add_days(c6, -n);
        PE8_print_cal(tprint("c6-%", n), out);
    }

    sub("subtract across month boundary");
    c7 := PE8_make_cal(2024, 3, 1, 0, 0, 0, 0);
    PE8_print_cal("c7", c7);
    for n: 0..5 {
        out := PE8_add_days(c7, -n);
        PE8_print_cal(tprint("c7-%", n), out);
    }

    sub("100 days from Jan 1");
    c8 := PE8_make_cal(2024, 1, 1, 0, 0, 0, 0);
    out := PE8_add_days(c8, 100);
    PE8_print_cal("c8+100", out);

    sub("365 days from Jan 1, 2024 (leap)");
    out2 := PE8_add_days(c8, 365);
    PE8_print_cal("c8+365", out2);

    sub("366 days from Jan 1, 2024 (leap)");
    out3 := PE8_add_days(c8, 366);
    PE8_print_cal("c8+366", out3);
}


// ============================================================================
// Section 807. Manual UTF-8 encoder/decoder.
// ============================================================================

PE8_encode_utf8 :: (cp: u32, sb: *String_Builder) -> int {
    if cp < 0x80 {
        append(sb, cast(u8) cp);
        return 1;
    } else if cp < 0x800 {
        append(sb, cast(u8) (0xC0 | (cp >> 6)));
        append(sb, cast(u8) (0x80 | (cp & 0x3F)));
        return 2;
    } else if cp < 0x10000 {
        append(sb, cast(u8) (0xE0 |  (cp >> 12)));
        append(sb, cast(u8) (0x80 | ((cp >> 6) & 0x3F)));
        append(sb, cast(u8) (0x80 |  (cp & 0x3F)));
        return 3;
    } else if cp < 0x110000 {
        append(sb, cast(u8) (0xF0 |  (cp >> 18)));
        append(sb, cast(u8) (0x80 | ((cp >> 12) & 0x3F)));
        append(sb, cast(u8) (0x80 | ((cp >> 6)  & 0x3F)));
        append(sb, cast(u8) (0x80 |  (cp & 0x3F)));
        return 4;
    }
    return 0;
}

PE8_decode_utf8 :: (bytes: [] u8, i: int) -> (cp: u32, advance: int) {
    if i >= bytes.count  return 0, 0;
    b0 := bytes[i];
    if b0 < 0x80  return cast(u32) b0, 1;
    if (b0 & 0xE0) == 0xC0 {
        if i + 1 >= bytes.count  return 0xFFFD, 1;
        b1 := bytes[i + 1];
        return ((cast(u32) (b0 & 0x1F)) << 6) | (cast(u32) (b1 & 0x3F)), 2;
    }
    if (b0 & 0xF0) == 0xE0 {
        if i + 2 >= bytes.count  return 0xFFFD, 1;
        b1 := bytes[i + 1];
        b2 := bytes[i + 2];
        return ((cast(u32) (b0 & 0x0F)) << 12) | ((cast(u32) (b1 & 0x3F)) << 6) | (cast(u32) (b2 & 0x3F)), 3;
    }
    if (b0 & 0xF8) == 0xF0 {
        if i + 3 >= bytes.count  return 0xFFFD, 1;
        b1 := bytes[i + 1];
        b2 := bytes[i + 2];
        b3 := bytes[i + 3];
        return ((cast(u32) (b0 & 0x07)) << 18) | ((cast(u32) (b1 & 0x3F)) << 12) | ((cast(u32) (b2 & 0x3F)) << 6) | (cast(u32) (b3 & 0x3F)), 4;
    }
    return 0xFFFD, 1;
}

PE8_codepoint_count :: (s: string) -> int {
    n := 0;
    i := 0;
    bs : [] u8;
    bs.data = s.data;
    bs.count = s.count;
    while i < bs.count {
        cp, adv := PE8_decode_utf8(bs, i);
        i += adv;
        if adv == 0  break;
        n += 1;
    }
    return n;
}

PE8_run_section_807 :: () {
    section("807. Manual UTF-8 encode/decode");

    sub("Encode codepoints to UTF-8 bytes");
    cps := u32.[
        cast(u32) #char "A",
        cast(u32) #char "B",
        0xA9,             // copyright sign
        0x2603,           // snowman
        0x1F600,          // grinning face
        cast(u32) #char " ",
        cast(u32) #char "Z"
    ];
    sb: String_Builder;
    init_string_builder(*sb);
    for cps  PE8_encode_utf8(it, *sb);
    encoded := builder_to_string(*sb);

    print("  cp count=%, byte count=%\n", cps.count, encoded.count);
    print("  bytes:");
    for i: 0..encoded.count-1 {
        print(" %", encoded.data[i]);
    }
    print("\n");

    sub("Decode UTF-8 bytes back to codepoints");
    decoded: [..] u32;
    bs : [] u8;
    bs.data = encoded.data;
    bs.count = encoded.count;
    i := 0;
    while i < bs.count {
        cp, adv := PE8_decode_utf8(bs, i);
        array_add(*decoded, cp);
        i += adv;
        if adv == 0  break;
    }
    print("  decoded count=%\n", decoded.count);
    for decoded  print("    [%] = %\n", it_index, it);
    array_reset(*decoded);

    sub("Verify round-trip equality");
    sb2: String_Builder;
    init_string_builder(*sb2);
    bs2 : [] u8;
    bs2.data = encoded.data;
    bs2.count = encoded.count;
    i2 := 0;
    while i2 < bs2.count {
        cp, adv := PE8_decode_utf8(bs2, i2);
        PE8_encode_utf8(cp, *sb2);
        i2 += adv;
        if adv == 0  break;
    }
    round_trip := builder_to_string(*sb2);
    print("  round-trip len equal=% bytes equal=%\n",
        round_trip.count == encoded.count,
        PE8_string_eq(round_trip, encoded));

    sub("Test encoding of boundary codepoints");
    boundary := u32.[0, 0x7F, 0x80, 0x7FF, 0x800, 0xFFFF, 0x10000, 0x10FFFF];
    for boundary {
        b: String_Builder; init_string_builder(*b);
        nbytes := PE8_encode_utf8(it, *b);
        s := builder_to_string(*b);
        print("  cp=% -> bytes=% count=%\n", it, nbytes, s.count);
    }

    sub("UTF-8 length-by-codepoint count for various strings");
    samples := string.[
        "",
        "A",
        "ASCII text",
        "café",
        "naïve",
        "résumé",
        "snow\xE2\x98\x83man",
        "\xF0\x9F\x98\x80",
    ];
    for samples {
        print("  '%' byte_len=% codepoint_count=%\n",
            it, it.count, PE8_codepoint_count(it));
    }
}


// ============================================================================
// Section 808. Large polymorphic types: tree where each node has [..]
// children of the same Type.
// ============================================================================

PE8_Tree :: struct (T: Type) {
    value: T;
    children: [..] *PE8_Tree(T);
}

PE8_tree_make :: ($T: Type, v: T) -> *PE8_Tree(T) {
    n := New(PE8_Tree(T));
    n.value = v;
    return n;
}

PE8_tree_attach :: (parent: *$N/PE8_Tree, child: *N) {
    array_add(*parent.children, child);
}

PE8_tree_print :: (n: *$N/PE8_Tree, indent: int) {
    for 0..indent-1  print(" ");
    print("%\n", n.value);
    for n.children  PE8_tree_print(it, indent + 2);
}

PE8_tree_count :: (n: *$N/PE8_Tree) -> int {
    total := 1;
    for n.children  total += PE8_tree_count(it);
    return total;
}

PE8_tree_depth :: (n: *$N/PE8_Tree) -> int {
    if n.children.count == 0  return 1;
    maxd := 0;
    for n.children {
        d := PE8_tree_depth(it);
        if d > maxd  maxd = d;
    }
    return maxd + 1;
}

PE8_tree_sum_ints :: (n: *PE8_Tree(int)) -> int {
    s := n.value;
    for n.children  s += PE8_tree_sum_ints(it);
    return s;
}

PE8_run_section_808 :: () {
    section("808. Polymorphic tree types");

    sub("Tree of int");
    root := PE8_tree_make(int, 1);
    a := PE8_tree_make(int, 2);
    b := PE8_tree_make(int, 3);
    c := PE8_tree_make(int, 4);
    d := PE8_tree_make(int, 5);
    e := PE8_tree_make(int, 6);
    PE8_tree_attach(root, a);
    PE8_tree_attach(root, b);
    PE8_tree_attach(a, c);
    PE8_tree_attach(a, d);
    PE8_tree_attach(b, e);

    PE8_tree_print(root, 0);
    print("count=%\n", PE8_tree_count(root));
    print("depth=%\n", PE8_tree_depth(root));
    print("sum=%\n",   PE8_tree_sum_ints(root));

    sub("Tree of string");
    sroot := PE8_tree_make(string, "root");
    sa := PE8_tree_make(string, "a");
    sb := PE8_tree_make(string, "b");
    sc := PE8_tree_make(string, "aa");
    sd := PE8_tree_make(string, "ab");
    PE8_tree_attach(sroot, sa);
    PE8_tree_attach(sroot, sb);
    PE8_tree_attach(sa, sc);
    PE8_tree_attach(sa, sd);
    PE8_tree_print(sroot, 0);
    print("count=%\n", PE8_tree_count(sroot));
    print("depth=%\n", PE8_tree_depth(sroot));

    sub("Tree of float (single chain)");
    fr := PE8_tree_make(float, 1.5);
    fa := PE8_tree_make(float, 2.5);
    fb := PE8_tree_make(float, 3.5);
    PE8_tree_attach(fr, fa);
    PE8_tree_attach(fa, fb);
    PE8_tree_print(fr, 0);
    print("count=%\n", PE8_tree_count(fr));
    print("depth=%\n", PE8_tree_depth(fr));

    sub("Tree of V2 (struct payload)");
    vr := PE8_tree_make(PE8_V2, .{0, 0});
    v1 := PE8_tree_make(PE8_V2, .{1, 1});
    v2 := PE8_tree_make(PE8_V2, .{2, 2});
    v3 := PE8_tree_make(PE8_V2, .{3, 3});
    v4 := PE8_tree_make(PE8_V2, .{4, 4});
    PE8_tree_attach(vr, v1);
    PE8_tree_attach(vr, v2);
    PE8_tree_attach(v1, v3);
    PE8_tree_attach(v2, v4);
    PE8_tree_print(vr, 0);
    print("count=%\n", PE8_tree_count(vr));
    print("depth=%\n", PE8_tree_depth(vr));
}


// ============================================================================
// Section 809. Iterator combinators: chain(it1,it2), take(n), skip(n),
// enumerate, pairs.
// ============================================================================

PE8_Range :: struct {
    from, to: int;     // inclusive on both ends
}

PE8_Chain_Range_Range :: struct {
    a, b: PE8_Range;
}

PE8_Take_Range :: struct {
    r: PE8_Range;
    n: int;
}

PE8_Skip_Range :: struct {
    r: PE8_Range;
    n: int;
}

PE8_Enumerate_Range :: struct {
    r: PE8_Range;
}

PE8_Pairs_Range :: struct {
    r: PE8_Range;
}

PE8_range_iter :: (r: *PE8_Range, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := r.from;
    while it <= r.to {
        defer { it += 1; it_index += 1; }
        #insert body;
    }
}

PE8_chain_iter :: (cr: *PE8_Chain_Range_Range, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := 0;
    // first range
    cur := cr.a.from;
    while cur <= cr.a.to {
        it = cur;
        defer { it_index += 1; }
        #insert body;
        cur += 1;
    }
    cur = cr.b.from;
    while cur <= cr.b.to {
        it = cur;
        defer { it_index += 1; }
        #insert body;
        cur += 1;
    }
}

PE8_take_iter :: (tr: *PE8_Take_Range, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := tr.r.from;
    taken := 0;
    while it <= tr.r.to && taken < tr.n {
        defer { it += 1; it_index += 1; taken += 1; }
        #insert body;
    }
}

PE8_skip_iter :: (sr: *PE8_Skip_Range, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := sr.r.from + sr.n;
    while it <= sr.r.to {
        defer { it += 1; it_index += 1; }
        #insert body;
    }
}

PE8_enumerate_iter :: (er: *PE8_Enumerate_Range, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := er.r.from;
    while it <= er.r.to {
        defer { it += 1; it_index += 1; }
        #insert body;
    }
}

PE8_pairs_iter :: (pr: *PE8_Pairs_Range, body: Code, flags: For_Flags) #expand {
    `it_index := 0;
    `it := PE8_V2.{0, 0};
    cur := pr.r.from;
    while cur + 1 <= pr.r.to {
        it.x = cast(float) cur;
        it.y = cast(float) (cur + 1);
        defer { it_index += 1; }
        #insert body;
        cur += 1;
    }
}

PE8_run_section_809 :: () {
    section("809. Iterator combinators");

    sub("plain range");
    r := PE8_Range.{2, 6};
    for :PE8_range_iter r  print("  %\n", it);

    sub("chain two ranges");
    cr := PE8_Chain_Range_Range.{ a=.{1,3}, b=.{10,12} };
    for :PE8_chain_iter cr  print("  [%] %\n", it_index, it);

    sub("take 3 from range");
    tr := PE8_Take_Range.{r=.{0,100}, n=3};
    for :PE8_take_iter tr  print("  [%] %\n", it_index, it);

    sub("take more than range has");
    tr2 := PE8_Take_Range.{r=.{0,2}, n=10};
    for :PE8_take_iter tr2  print("  [%] %\n", it_index, it);

    sub("skip 2 from range");
    sr := PE8_Skip_Range.{r=.{1,7}, n=2};
    for :PE8_skip_iter sr  print("  [%] %\n", it_index, it);

    sub("skip past end of range");
    sr2 := PE8_Skip_Range.{r=.{1,3}, n=5};
    for :PE8_skip_iter sr2  print("  [%] %\n", it_index, it);

    sub("enumerate range");
    er := PE8_Enumerate_Range.{r=.{10, 13}};
    for :PE8_enumerate_iter er  print("  idx=% val=%\n", it_index, it);

    sub("pairs of range");
    pr := PE8_Pairs_Range.{r=.{1, 5}};
    for :PE8_pairs_iter pr  print("  pair[%]=(%,%)\n", it_index, it.x, it.y);

    sub("chain + take composition by hand");
    cr2 := PE8_Chain_Range_Range.{ a=.{1,4}, b=.{20,24} };
    count := 0;
    for :PE8_chain_iter cr2 {
        if count >= 5  break;
        print("  chain_take[%] %\n", count, it);
        count += 1;
    }
}


// ============================================================================
// Section 810. Small graph using indices, with BFS and DFS.
// ============================================================================

PE8_Graph :: struct {
    n: int;
    adj: [..] [..] int;       // adjacency list per node
}

PE8_graph_init :: (g: *PE8_Graph, n: int) {
    g.n = n;
    array_reserve(*g.adj, n);
    for 0..n-1 {
        empty: [..] int;
        array_add(*g.adj, empty);
    }
}

PE8_graph_add_edge :: (g: *PE8_Graph, u: int, v: int, undirected := false) {
    array_add(*g.adj[u], v);
    if undirected  array_add(*g.adj[v], u);
}

PE8_graph_bfs :: (g: *PE8_Graph, start: int, out: *[..] int) {
    visited: [..] bool;
    for 0..g.n-1  array_add(*visited, false);
    queue: [..] int;
    array_add(*queue, start);
    visited[start] = true;
    head := 0;
    while head < queue.count {
        u := queue[head];
        head += 1;
        array_add(out, u);
        for g.adj[u] {
            if !visited[it] {
                visited[it] = true;
                array_add(*queue, it);
            }
        }
    }
    array_reset(*visited);
    array_reset(*queue);
}

PE8_graph_dfs_helper :: (g: *PE8_Graph, u: int, visited: *[..] bool, out: *[..] int) {
    visited.*[u] = true;
    array_add(out, u);
    for g.adj[u] {
        if !visited.*[it]  PE8_graph_dfs_helper(g, it, visited, out);
    }
}

PE8_graph_dfs :: (g: *PE8_Graph, start: int, out: *[..] int) {
    visited: [..] bool;
    for 0..g.n-1  array_add(*visited, false);
    PE8_graph_dfs_helper(g, start, *visited, out);
    array_reset(*visited);
}

PE8_print_visit :: (label: string, v: [..] int) {
    print("  %:", label);
    for v  print(" %", it);
    print("\n");
}

PE8_graph_reset :: (g: *PE8_Graph) {
    for *g.adj  array_reset(it);
    array_reset(*g.adj);
    g.n = 0;
}

PE8_run_section_810 :: () {
    section("810. Small graphs with BFS and DFS");

    sub("Build a small graph");
    g: PE8_Graph;
    PE8_graph_init(*g, 6);
    PE8_graph_add_edge(*g, 0, 1, true);
    PE8_graph_add_edge(*g, 0, 2, true);
    PE8_graph_add_edge(*g, 1, 3, true);
    PE8_graph_add_edge(*g, 1, 4, true);
    PE8_graph_add_edge(*g, 2, 4, true);
    PE8_graph_add_edge(*g, 3, 5, true);
    PE8_graph_add_edge(*g, 4, 5, true);

    sub("BFS from 0");
    order: [..] int;
    PE8_graph_bfs(*g, 0, *order);
    PE8_print_visit("bfs(0)", order);
    array_reset(*order);

    sub("DFS from 0");
    PE8_graph_dfs(*g, 0, *order);
    PE8_print_visit("dfs(0)", order);
    array_reset(*order);

    sub("BFS from node 3");
    PE8_graph_bfs(*g, 3, *order);
    PE8_print_visit("bfs(3)", order);
    array_reset(*order);

    sub("DFS from node 5");
    PE8_graph_dfs(*g, 5, *order);
    PE8_print_visit("dfs(5)", order);
    array_reset(*order);

    PE8_graph_reset(*g);

    sub("Path graph 0-1-2-3-4");
    g2: PE8_Graph;
    PE8_graph_init(*g2, 5);
    PE8_graph_add_edge(*g2, 0, 1, true);
    PE8_graph_add_edge(*g2, 1, 2, true);
    PE8_graph_add_edge(*g2, 2, 3, true);
    PE8_graph_add_edge(*g2, 3, 4, true);

    order2: [..] int;
    PE8_graph_bfs(*g2, 0, *order2);
    PE8_print_visit("path bfs(0)", order2);
    array_reset(*order2);

    PE8_graph_dfs(*g2, 0, *order2);
    PE8_print_visit("path dfs(0)", order2);
    array_reset(*order2);
    PE8_graph_reset(*g2);

    sub("Star graph: 0 connected to 1..5");
    g3: PE8_Graph;
    PE8_graph_init(*g3, 6);
    for i: 1..5  PE8_graph_add_edge(*g3, 0, i, true);

    order3: [..] int;
    PE8_graph_bfs(*g3, 0, *order3);
    PE8_print_visit("star bfs(0)", order3);
    array_reset(*order3);

    PE8_graph_dfs(*g3, 0, *order3);
    PE8_print_visit("star dfs(0)", order3);
    array_reset(*order3);
    PE8_graph_reset(*g3);

    sub("Cycle graph: 0-1-2-3-0");
    g4: PE8_Graph;
    PE8_graph_init(*g4, 4);
    PE8_graph_add_edge(*g4, 0, 1, true);
    PE8_graph_add_edge(*g4, 1, 2, true);
    PE8_graph_add_edge(*g4, 2, 3, true);
    PE8_graph_add_edge(*g4, 3, 0, true);

    order4: [..] int;
    PE8_graph_bfs(*g4, 0, *order4);
    PE8_print_visit("cycle bfs(0)", order4);
    array_reset(*order4);

    PE8_graph_dfs(*g4, 0, *order4);
    PE8_print_visit("cycle dfs(0)", order4);
    array_reset(*order4);
    PE8_graph_reset(*g4);
}


// ============================================================================
// Section 811. Topological sort on a small DAG.
// ============================================================================

PE8_topo_sort :: (g: *PE8_Graph, out: *[..] int) -> bool {
    in_degree: [..] int;
    for 0..g.n-1  array_add(*in_degree, 0);
    for u: 0..g.n-1 {
        for g.adj[u]  in_degree[it] += 1;
    }
    queue: [..] int;
    for u: 0..g.n-1  if in_degree[u] == 0  array_add(*queue, u);
    head := 0;
    while head < queue.count {
        u := queue[head];
        head += 1;
        array_add(out, u);
        for g.adj[u] {
            in_degree[it] -= 1;
            if in_degree[it] == 0  array_add(*queue, it);
        }
    }
    success := out.count == g.n;
    array_reset(*in_degree);
    array_reset(*queue);
    return success;
}

PE8_run_section_811 :: () {
    section("811. Topological sort on a small DAG");

    sub("Linear DAG 0->1->2->3->4");
    g: PE8_Graph;
    PE8_graph_init(*g, 5);
    PE8_graph_add_edge(*g, 0, 1);
    PE8_graph_add_edge(*g, 1, 2);
    PE8_graph_add_edge(*g, 2, 3);
    PE8_graph_add_edge(*g, 3, 4);
    order: [..] int;
    ok := PE8_topo_sort(*g, *order);
    print("  ok=% ", ok);
    PE8_print_visit("topo", order);
    array_reset(*order);
    PE8_graph_reset(*g);

    sub("Branching DAG");
    PE8_graph_init(*g, 6);
    PE8_graph_add_edge(*g, 5, 2);
    PE8_graph_add_edge(*g, 5, 0);
    PE8_graph_add_edge(*g, 4, 0);
    PE8_graph_add_edge(*g, 4, 1);
    PE8_graph_add_edge(*g, 2, 3);
    PE8_graph_add_edge(*g, 3, 1);
    ok2 := PE8_topo_sort(*g, *order);
    print("  ok=% ", ok2);
    PE8_print_visit("topo", order);
    array_reset(*order);
    PE8_graph_reset(*g);

    sub("DAG with separate components");
    PE8_graph_init(*g, 6);
    PE8_graph_add_edge(*g, 0, 1);
    PE8_graph_add_edge(*g, 2, 3);
    PE8_graph_add_edge(*g, 4, 5);
    ok3 := PE8_topo_sort(*g, *order);
    print("  ok=% ", ok3);
    PE8_print_visit("topo", order);
    array_reset(*order);
    PE8_graph_reset(*g);

    sub("Cycle (not a DAG)");
    PE8_graph_init(*g, 3);
    PE8_graph_add_edge(*g, 0, 1);
    PE8_graph_add_edge(*g, 1, 2);
    PE8_graph_add_edge(*g, 2, 0);
    ok4 := PE8_topo_sort(*g, *order);
    print("  ok=% topo-count=% total-n=%\n", ok4, order.count, 3);
    array_reset(*order);
    PE8_graph_reset(*g);
}


// ============================================================================
// Section 812. Union-find / disjoint-set.
// ============================================================================

PE8_DSU :: struct {
    parent: [..] int;
    rank:   [..] int;
}

PE8_dsu_init :: (d: *PE8_DSU, n: int) {
    for 0..n-1 {
        array_add(*d.parent, it);
        array_add(*d.rank,   0);
    }
}

PE8_dsu_find :: (d: *PE8_DSU, x: int) -> int {
    cur := x;
    while d.parent[cur] != cur  cur = d.parent[cur];
    // Path compression
    p := x;
    while d.parent[p] != cur {
        nxt := d.parent[p];
        d.parent[p] = cur;
        p = nxt;
    }
    return cur;
}

PE8_dsu_union :: (d: *PE8_DSU, x: int, y: int) -> bool {
    rx := PE8_dsu_find(d, x);
    ry := PE8_dsu_find(d, y);
    if rx == ry  return false;
    if d.rank[rx] < d.rank[ry] {
        d.parent[rx] = ry;
    } else if d.rank[rx] > d.rank[ry] {
        d.parent[ry] = rx;
    } else {
        d.parent[ry] = rx;
        d.rank[rx] += 1;
    }
    return true;
}

PE8_dsu_reset :: (d: *PE8_DSU) {
    array_reset(*d.parent);
    array_reset(*d.rank);
}

PE8_run_section_812 :: () {
    section("812. Union-find (disjoint-set)");

    sub("Initial state");
    d: PE8_DSU;
    PE8_dsu_init(*d, 8);
    for 0..7  print("  find(%)=%\n", it, PE8_dsu_find(*d, it));

    sub("Union (0,1) and (2,3)");
    u1 := PE8_dsu_union(*d, 0, 1);
    u2 := PE8_dsu_union(*d, 2, 3);
    print("  unions performed = % %\n", u1, u2);
    for 0..7  print("  find(%)=%\n", it, PE8_dsu_find(*d, it));

    sub("Union(1,2): merges {0,1} and {2,3}");
    u3 := PE8_dsu_union(*d, 1, 2);
    print("  union performed = %\n", u3);
    for 0..7  print("  find(%)=%\n", it, PE8_dsu_find(*d, it));

    sub("Union(0,3): now they should already be in the same set");
    u4 := PE8_dsu_union(*d, 0, 3);
    print("  union returned = %\n", u4);

    sub("Union(4,5) and (6,7), then (5,7)");
    PE8_dsu_union(*d, 4, 5);
    PE8_dsu_union(*d, 6, 7);
    PE8_dsu_union(*d, 5, 7);
    for 0..7  print("  find(%)=%\n", it, PE8_dsu_find(*d, it));

    sub("Bring {0..3} and {4..7} together via union(3,4)");
    PE8_dsu_union(*d, 3, 4);
    for 0..7  print("  find(%)=%\n", it, PE8_dsu_find(*d, it));

    PE8_dsu_reset(*d);

    sub("Use DSU to count connected components on a small edge list");
    d2: PE8_DSU;
    PE8_dsu_init(*d2, 6);
    edges := struct {a:int;b:int;}.[
        .{0, 1}, .{1, 2}, .{3, 4}
    ];
    for edges  PE8_dsu_union(*d2, it.a, it.b);
    comp := 0;
    for x: 0..5  if PE8_dsu_find(*d2, x) == x  comp += 1;
    print("  components=%\n", comp);
    PE8_dsu_reset(*d2);
}


// ============================================================================
// Section 813. Simple regex-ish matching of '*' (any chars) and '?'
// (single char) against many sample strings.
// ============================================================================

PE8_glob_match_at :: (s: string, si: int, p: string, pi: int) -> bool {
    if pi >= p.count {
        return si >= s.count;
    }
    pc := p.data[pi];
    if pc == #char "*" {
        // Try matching zero or more chars.
        if PE8_glob_match_at(s, si, p, pi + 1)  return true;
        if si < s.count {
            return PE8_glob_match_at(s, si + 1, p, pi);
        }
        return false;
    }
    if si >= s.count  return false;
    if pc == #char "?"  return PE8_glob_match_at(s, si + 1, p, pi + 1);
    if pc != s.data[si] return false;
    return PE8_glob_match_at(s, si + 1, p, pi + 1);
}

PE8_glob_match :: (s: string, p: string) -> bool {
    return PE8_glob_match_at(s, 0, p, 0);
}

PE8_run_section_813 :: () {
    section("813. Glob-like matching with '*' and '?'");

    Sample :: struct { s: string; p: string; expected: bool; }
    samples := Sample.[
        .{"abc",     "abc",      true},
        .{"abc",     "abd",      false},
        .{"abc",     "a?c",      true},
        .{"abc",     "a?d",      false},
        .{"abcde",   "a*e",      true},
        .{"abcde",   "a*x",      false},
        .{"abcde",   "*",        true},
        .{"",        "*",        true},
        .{"",        "?",        false},
        .{"a",       "?",        true},
        .{"hello",   "h*o",      true},
        .{"hello",   "h*lo",     true},
        .{"hello",   "h*lll",    false},
        .{"banana",  "*ana",     true},
        .{"banana",  "ban*",     true},
        .{"banana",  "*nan*",    true},
        .{"banana",  "*xyz*",    false},
        .{"foo.txt", "*.txt",    true},
        .{"foo.txt", "*.txz",    false},
        .{"foo.txt", "f??.txt",  true},
        .{"foo.txt", "f?.txt",   false},
        .{"abc",     "***",      true},
        .{"abc",     "?*?",      true},
        .{"a",       "?*?",      false},
        .{"ab",      "?*?",      true},
        .{"longer_word", "l*g*r_w*d", true},
        .{"longer_word", "l*g*r_w*x", false},
    ];
    for samples {
        got := PE8_glob_match(it.s, it.p);
        ok  := got == it.expected;
        print("  '%' matches '%' -> got=% expected=% ok=%\n",
            it.s, it.p, got, it.expected, ok);
    }
}


// ============================================================================
// Section 814. Small calculator: tokenizer, parser, evaluator. Tested on
// many expressions.
// ============================================================================

PE8_Tok_Kind :: enum u8 {
    NUM;
    PLUS;
    MINUS;
    STAR;
    SLASH;
    LPAREN;
    RPAREN;
    END;
}

PE8_Tok :: struct {
    kind: PE8_Tok_Kind;
    num: int;
}

PE8_is_digit :: (c: u8) -> bool {
    return c >= #char "0" && c <= #char "9";
}

PE8_tokenize :: (src: string, out: *[..] PE8_Tok) -> bool {
    i := 0;
    while i < src.count {
        c := src.data[i];
        if c == #char " " || c == #char "\t" { i += 1; continue; }
        if PE8_is_digit(c) {
            v := 0;
            while i < src.count && PE8_is_digit(src.data[i]) {
                v = v * 10 + (src.data[i] - #char "0");
                i += 1;
            }
            array_add(out, PE8_Tok.{kind = .NUM, num = v});
            continue;
        }
        if c == #char "+" { array_add(out, PE8_Tok.{kind = .PLUS}); i += 1; continue; }
        if c == #char "-" { array_add(out, PE8_Tok.{kind = .MINUS}); i += 1; continue; }
        if c == #char "*" { array_add(out, PE8_Tok.{kind = .STAR}); i += 1; continue; }
        if c == #char "/" { array_add(out, PE8_Tok.{kind = .SLASH}); i += 1; continue; }
        if c == #char "(" { array_add(out, PE8_Tok.{kind = .LPAREN}); i += 1; continue; }
        if c == #char ")" { array_add(out, PE8_Tok.{kind = .RPAREN}); i += 1; continue; }
        return false;
    }
    array_add(out, PE8_Tok.{kind = .END});
    return true;
}

PE8_Parser :: struct {
    toks: [] PE8_Tok;
    pos:  int;
    error: bool;
}

PE8_peek :: (p: *PE8_Parser) -> PE8_Tok_Kind {
    if p.pos >= p.toks.count  return .END;
    return p.toks[p.pos].kind;
}

PE8_eat :: (p: *PE8_Parser, k: PE8_Tok_Kind) -> bool {
    if p.toks[p.pos].kind != k {
        p.error = true;
        return false;
    }
    p.pos += 1;
    return true;
}

PE8_parse_factor :: (p: *PE8_Parser) -> int {
    if p.error  return 0;
    if p.pos >= p.toks.count  { p.error = true; return 0; }
    t := p.toks[p.pos];
    if t.kind == .NUM {
        p.pos += 1;
        return t.num;
    }
    if t.kind == .LPAREN {
        p.pos += 1;
        v := PE8_parse_expr(p);
        if !PE8_eat(p, .RPAREN)  return 0;
        return v;
    }
    if t.kind == .MINUS {
        p.pos += 1;
        v := PE8_parse_factor(p);
        return -v;
    }
    p.error = true;
    return 0;
}

PE8_parse_term :: (p: *PE8_Parser) -> int {
    if p.error  return 0;
    v := PE8_parse_factor(p);
    while true {
        if p.pos >= p.toks.count  break;
        k := p.toks[p.pos].kind;
        if k == .STAR {
            p.pos += 1;
            rhs := PE8_parse_factor(p);
            v *= rhs;
        } else if k == .SLASH {
            p.pos += 1;
            rhs := PE8_parse_factor(p);
            if rhs == 0 { p.error = true; return 0; }
            v /= rhs;
        } else {
            break;
        }
    }
    return v;
}

PE8_parse_expr :: (p: *PE8_Parser) -> int {
    if p.error  return 0;
    v := PE8_parse_term(p);
    while true {
        if p.pos >= p.toks.count  break;
        k := p.toks[p.pos].kind;
        if k == .PLUS {
            p.pos += 1;
            v += PE8_parse_term(p);
        } else if k == .MINUS {
            p.pos += 1;
            v -= PE8_parse_term(p);
        } else {
            break;
        }
    }
    return v;
}

PE8_calc_eval :: (src: string) -> (value: int, ok: bool) {
    toks: [..] PE8_Tok;
    if !PE8_tokenize(src, *toks) {
        array_reset(*toks);
        return 0, false;
    }
    p: PE8_Parser;
    p.toks.data = toks.data;
    p.toks.count = toks.count;
    p.pos = 0;
    p.error = false;
    v := PE8_parse_expr(*p);
    ok := !p.error && p.toks[p.pos].kind == .END;
    array_reset(*toks);
    return v, ok;
}

PE8_run_section_814 :: () {
    section("814. Calculator: tokenize, parse, evaluate");

    Sample :: struct { src: string; expected: int; ok: bool; }
    samples := Sample.[
        .{"1",                 1,    true},
        .{"42",                42,   true},
        .{"1+2",               3,    true},
        .{"1 + 2",             3,    true},
        .{"1+2*3",             7,    true},
        .{"(1+2)*3",           9,    true},
        .{"2*3+4",             10,   true},
        .{"2*(3+4)",           14,   true},
        .{"10-3",              7,    true},
        .{"10-3-2",            5,    true},
        .{"10-(3-2)",          9,    true},
        .{"20/4",              5,    true},
        .{"20/4/5",            1,    true},
        .{"20/(4/5)",          0,    false},  // division by zero
        .{"-5",                -5,   true},
        .{"-5+10",             5,    true},
        .{"(-5)*(-3)",         15,   true},
        .{"100/5",             20,   true},
        .{"100/5/2",           10,   true},
        .{"100 / 5 / 2",       10,   true},
        .{"1+2+3+4+5",         15,   true},
        .{"5*5*5",             125,  true},
        .{"((1+2)*3+(4-5))*2", 16,   true},
        .{"0",                 0,    true},
        .{"0+0",               0,    true},
        .{"0*123456",          0,    true},
        .{"9999",              9999, true},
        .{"3*3*3*3",           81,   true},
        .{"1 - 2 + 3 - 4 + 5", 3,    true},
    ];
    for samples {
        v, ok := PE8_calc_eval(it.src);
        print("  eval('%') = % ok=%  (expected % ok=%)\n",
            it.src, v, ok, it.expected, it.ok);
    }

    sub("malformed inputs");
    bad := string.[
        "1+",
        "+1",      // unary plus not supported
        "1++2",
        "1**2",
        "(1+2",
        "1+2)",
        "abc",
    ];
    for bad {
        v, ok := PE8_calc_eval(it);
        print("  bad '%' parsed-ok=% value=%\n", it, ok, v);
    }
}


// ============================================================================
// Section 815. Small templating engine: "Hello, {name}! You are {age}."
// ============================================================================

PE8_template_render :: (template: string, names: [] string, values: [] string) -> string {
    sb: String_Builder;
    init_string_builder(*sb);
    i := 0;
    while i < template.count {
        c := template.data[i];
        if c == #char "{" {
            // find closing brace
            j := i + 1;
            while j < template.count && template.data[j] != #char "}"  j += 1;
            if j >= template.count {
                // unmatched; emit literally
                append(*sb, c);
                i += 1;
                continue;
            }
            name : string;
            name.data  = template.data + i + 1;
            name.count = j - i - 1;
            found := false;
            for idx: 0..names.count-1 {
                if PE8_string_eq(names[idx], name) {
                    append(*sb, values[idx]);
                    found = true;
                    break;
                }
            }
            if !found {
                append(*sb, "{");
                append(*sb, name);
                append(*sb, "}");
            }
            i = j + 1;
        } else if c == #char "\\" && i + 1 < template.count && template.data[i + 1] == #char "{" {
            append(*sb, "{");
            i += 2;
        } else {
            append(*sb, c);
            i += 1;
        }
    }
    return builder_to_string(*sb);
}

PE8_run_section_815 :: () {
    section("815. Templating engine");

    sub("Simple template");
    names := string.["name", "age"];
    values := string.["Ada", "30"];
    out := PE8_template_render("Hello, {name}! You are {age}.", names, values);
    print("  %\n", out);

    sub("Repeating variables");
    out2 := PE8_template_render("{x}+{x}={y}", string.["x","y"], string.["7","14"]);
    print("  %\n", out2);

    sub("Missing variable kept as literal");
    out3 := PE8_template_render("Hi {missing}!", string.[], string.[]);
    print("  %\n", out3);

    sub("Escaped brace");
    out4 := PE8_template_render("Literal: \\{not a var}", string.[], string.[]);
    print("  %\n", out4);

    sub("Unmatched open brace");
    out5 := PE8_template_render("Stray { brace", string.[], string.[]);
    print("  %\n", out5);

    sub("Many substitutions");
    big_names := string.["a","b","c","d","e"];
    big_vals  := string.["1","2","3","4","5"];
    out6 := PE8_template_render("{a}-{b}-{c}-{d}-{e}", big_names, big_vals);
    print("  %\n", out6);

    sub("Person card template repeated");
    rows := struct { name: string; role: string; loc: string; }.[
        .{"Ada",  "engineer", "London"},
        .{"Bob",  "designer", "Berlin"},
        .{"Carl", "manager",  "Paris"},
        .{"Dora", "intern",   "Madrid"},
        .{"Eve",  "lead",     "Rome"},
    ];
    for rows {
        nm := string.["name","role","loc"];
        vl := string.[it.name, it.role, it.loc];
        out_row := PE8_template_render("- {name} ({role}) @ {loc}", nm, vl);
        print("  %\n", out_row);
    }
}


// ============================================================================
// Section 816. Comprehensive use of #code and #procedure_of_call.
// ============================================================================

PE8_id_poly :: (x: $T) -> T { return x; }

PE8_add_poly :: (x: $T, y: T) -> T { return x + y; }

PE8_max_poly :: (x: $T, y: T) -> T {
    if x > y  return x;
    return y;
}

PE8_pair_poly :: (a: $A, b: $B) -> A, B { return a, b; }

PE8_dup_poly :: (x: $T) -> T, T { return x, x; }

PE8_run_section_816 :: () {
    section("816. #code and #procedure_of_call");

    sub("Polymorphic id_poly instantiated for multiple types");
    p_id_int   :: #procedure_of_call PE8_id_poly(0);
    p_id_float :: #procedure_of_call PE8_id_poly(0.0);
    p_id_bool  :: #procedure_of_call PE8_id_poly(true);
    p_id_str   :: #procedure_of_call PE8_id_poly("");
    print("  type p_id_int   = %\n", type_of(p_id_int));
    print("  type p_id_float = %\n", type_of(p_id_float));
    print("  type p_id_bool  = %\n", type_of(p_id_bool));
    print("  type p_id_str   = %\n", type_of(p_id_str));
    print("  id_int(5)    = %\n", p_id_int(5));
    print("  id_float(.5) = %\n", p_id_float(0.5));
    print("  id_bool(t)   = %\n", p_id_bool(true));
    print("  id_str('a')  = %\n", p_id_str("a"));

    sub("Polymorphic add_poly for int and float");
    p_add_int   :: #procedure_of_call PE8_add_poly(0, 0);
    p_add_float :: #procedure_of_call PE8_add_poly(0.0, 0.0);
    print("  type p_add_int   = %\n", type_of(p_add_int));
    print("  type p_add_float = %\n", type_of(p_add_float));
    print("  add_int(3,4)     = %\n", p_add_int(3, 4));
    print("  add_float(.5,1.5)= %\n", p_add_float(0.5, 1.5));

    sub("Polymorphic max_poly");
    p_max_int   :: #procedure_of_call PE8_max_poly(0, 0);
    p_max_float :: #procedure_of_call PE8_max_poly(0.0, 0.0);
    print("  max_int(7,3)     = %\n", p_max_int(7, 3));
    print("  max_int(3,7)     = %\n", p_max_int(3, 7));
    print("  max_float(.1,.2) = %\n", p_max_float(0.1, 0.2));

    sub("Polymorphic pair_poly with distinct $A, $B");
    p_pair_ii  :: #procedure_of_call PE8_pair_poly(0, 0);
    p_pair_if  :: #procedure_of_call PE8_pair_poly(0, 0.0);
    p_pair_si  :: #procedure_of_call PE8_pair_poly("", 0);
    print("  type p_pair_ii = %\n", type_of(p_pair_ii));
    print("  type p_pair_if = %\n", type_of(p_pair_if));
    print("  type p_pair_si = %\n", type_of(p_pair_si));
    a1, a2 := p_pair_ii(1, 2);
    b1, b2 := p_pair_if(3, 4.5);
    c1, c2 := p_pair_si("x", 7);
    print("  pair_ii(1,2)    = (%, %)\n", a1, a2);
    print("  pair_if(3,4.5)  = (%, %)\n", b1, b2);
    print("  pair_si('x',7)  = (%, %)\n", c1, c2);

    sub("#code values inserted into multiple places");
    msg_code : Code : #code { print("    [via code] hello\n"); };
    print("  before first insert\n");
    #insert msg_code;
    print("  between inserts\n");
    #insert msg_code;
    print("  after last insert\n");

    sub("Build code via tprint and #insert at compile time");
    EXPR_816 :: #string DONE
1 + 2 * 3;
DONE
    e := #insert EXPR_816;
    print("  inserted-expr-value=%\n", e);

    sub("Insert a switch-case-like block via #expand");
    PE8_insert_dispatch_816 :: (max: int, body: Code) #expand {
        for `which: 1..max  #insert body;
    }
    chooser : Code : #code {
        if which == {
          case 1; print("    chose ONE\n");
          case 2; print("    chose TWO\n");
          case 3; print("    chose THREE\n");
        }
    };
    PE8_insert_dispatch_816(3, chooser);
}


// ============================================================================
// Section 817. Many small structs built at compile time via #run.
// ============================================================================

PE8_Small1 :: struct { a: int; b: int; }
PE8_Small2 :: struct { name: string; weight: float; }
PE8_Small3 :: struct { x, y, z: float; }
PE8_Small4 :: struct { flags: u32; mask: u32; }
PE8_Small5 :: struct { ok: bool; count: int; label: string; }
PE8_Small6 :: struct { values: [4] int; }
PE8_Small7 :: struct { msg: string; len: int; }
PE8_Small8 :: struct { pair: PE8_Small1; tag: u8; }

PE8_CT_S1 :: #run -> PE8_Small1 { s : PE8_Small1; s.a = 7; s.b = 11; return s; };
PE8_CT_S2 :: #run -> PE8_Small2 { s : PE8_Small2; s.name = "compile-time"; s.weight = 1.5; return s; };
PE8_CT_S3 :: #run -> PE8_Small3 { s : PE8_Small3; s.x = 1.0; s.y = 2.0; s.z = 3.0; return s; };
PE8_CT_S4 :: #run -> PE8_Small4 { s : PE8_Small4; s.flags = 0xCAFEBABE; s.mask = 0xFFFF_0000; return s; };
PE8_CT_S5 :: #run -> PE8_Small5 { s : PE8_Small5; s.ok = true; s.count = 42; s.label = "label"; return s; };
PE8_CT_S6 :: #run -> PE8_Small6 { s : PE8_Small6; for i: 0..3  s.values[i] = i * i; return s; };
PE8_CT_S7 :: #run -> PE8_Small7 { s : PE8_Small7; s.msg = "abc"; s.len = 3; return s; };
PE8_CT_S8 :: #run -> PE8_Small8 { s : PE8_Small8; s.pair.a = 99; s.pair.b = 100; s.tag = 7; return s; };

PE8_CT_FIB :: #run -> [10] int {
    out: [10] int;
    out[0] = 0;
    out[1] = 1;
    for i: 2..9  out[i] = out[i-1] + out[i-2];
    return out;
};

PE8_CT_SQUARES :: #run -> [16] int {
    out: [16] int;
    for i: 0..15  out[i] = i * i;
    return out;
};

PE8_CT_CUBES :: #run -> [12] int {
    out: [12] int;
    for i: 0..11  out[i] = i * i * i;
    return out;
};

PE8_CT_PRIMES :: #run -> [10] int {
    out: [10] int;
    out[0] = 2; out[1] = 3; out[2] = 5; out[3] = 7; out[4] = 11;
    out[5] = 13; out[6] = 17; out[7] = 19; out[8] = 23; out[9] = 29;
    return out;
};

PE8_CT_SUM_OF_FIRST_100 :: #run -> int {
    s := 0;
    for i: 1..100  s += i;
    return s;
};

PE8_CT_FACT10 :: #run -> int {
    s := 1;
    for i: 1..10  s *= i;
    return s;
};

PE8_CT_TABLE :: #run -> [8][8] int {
    out: [8][8] int;
    for i: 0..7  for j: 0..7  out[i][j] = (i + 1) * (j + 1);
    return out;
};

PE8_run_section_817 :: () {
    section("817. Many small structs built at compile time via #run");

    sub("Small1");
    print("  PE8_CT_S1: a=% b=%\n", PE8_CT_S1.a, PE8_CT_S1.b);
    sub("Small2");
    print("  PE8_CT_S2: name='%' weight=%\n", PE8_CT_S2.name, PE8_CT_S2.weight);
    sub("Small3");
    print("  PE8_CT_S3: x=% y=% z=%\n", PE8_CT_S3.x, PE8_CT_S3.y, PE8_CT_S3.z);
    sub("Small4");
    print("  PE8_CT_S4: flags=0x% mask=0x%\n",
        formatInt(PE8_CT_S4.flags, base=16),
        formatInt(PE8_CT_S4.mask,  base=16));
    sub("Small5");
    print("  PE8_CT_S5: ok=% count=% label='%'\n",
        PE8_CT_S5.ok, PE8_CT_S5.count, PE8_CT_S5.label);
    sub("Small6");
    print("  PE8_CT_S6:");
    for PE8_CT_S6.values  print(" %", it);
    print("\n");
    sub("Small7");
    print("  PE8_CT_S7: msg='%' len=%\n", PE8_CT_S7.msg, PE8_CT_S7.len);
    sub("Small8");
    print("  PE8_CT_S8: pair.a=% pair.b=% tag=%\n",
        PE8_CT_S8.pair.a, PE8_CT_S8.pair.b, PE8_CT_S8.tag);

    sub("Fibonacci table");
    print(" ");
    for PE8_CT_FIB  print(" %", it);
    print("\n");

    sub("Squares table");
    print(" ");
    for PE8_CT_SQUARES  print(" %", it);
    print("\n");

    sub("Cubes table");
    print(" ");
    for PE8_CT_CUBES  print(" %", it);
    print("\n");

    sub("First ten primes");
    print(" ");
    for PE8_CT_PRIMES  print(" %", it);
    print("\n");

    sub("Sum of 1..100 and 10!");
    print("  sum1to100=% fact10=%\n", PE8_CT_SUM_OF_FIRST_100, PE8_CT_FACT10);

    sub("Compile-time multiplication table 8x8");
    for i: 0..7 {
        print(" ");
        for j: 0..7  print(" %", PE8_CT_TABLE[i][j]);
        print("\n");
    }
}


// ============================================================================
// Section 818. #insert in many forms.
// ============================================================================

PE8_run_section_818 :: () {
    section("818. #insert in many forms");

    sub("Insert variable declarations via string");
    DECLS :: #string DONE
ins_x := 10;
ins_y := 20;
ins_z := ins_x + ins_y;
DONE
    #insert DECLS;
    print("  ins_x=% ins_y=% ins_z=%\n", ins_x, ins_y, ins_z);

    sub("Insert function calls");
    CALLS :: #string DONE
print("    inserted call 1\n");
print("    inserted call 2\n");
print("    inserted call 3\n");
DONE
    #insert CALLS;

    sub("Insert switch case body via #code through #expand");
    PE8_insert_switch_818 :: (max: int, body: Code) #expand {
        for `val: 1..max  #insert body;
    }
    body : Code : #code {
        if val == {
          case 1; print("    matched ONE\n");
          case 2; print("    matched TWO\n");
          case 3; print("    matched THREE\n");
          case;   print("    matched OTHER\n");
        }
    };
    PE8_insert_switch_818(4, body);

    sub("Insert an expression in a context that needs a value");
    EXPR_A :: #string DONE
( 100 + 23 );
DONE
    a := #insert EXPR_A;
    print("  a=%\n", a);

    sub("Insert a struct-typed expression");
    EXPR_S :: #string DONE
( PE8_V2.{42.0, 84.0} );
DONE
    s := #insert EXPR_S;
    print("  s.x=% s.y=%\n", s.x, s.y);

    sub("Insert a loop body via #expand");
    PE8_insert_loop_818 :: (n: int, body: Code) #expand {
        for `it: 0..n-1 {
            `it_index := it;
            #insert body;
        }
    }
    body_loop : Code : #code {
        if it_index % 2 == 0  print("    even idx=% val=%\n", it_index, it);
        else                  print("    odd  idx=% val=%\n", it_index, it);
    };
    PE8_insert_loop_818(6, body_loop);

    sub("Insert a chain of statements");
    CHAIN :: #string DONE
chain_a := 1;
chain_b := chain_a + 1;
chain_c := chain_b * chain_b;
chain_d := chain_c - chain_a;
DONE
    #insert CHAIN;
    print("  chain_a=% chain_b=% chain_c=% chain_d=%\n",
        chain_a, chain_b, chain_c, chain_d);

    sub("Insert a conditional check via #expand");
    PE8_insert_check_818 :: (lo: int, hi: int, body: Code) #expand {
        for `n: lo..hi  #insert body;
    }
    check_pos : Code : #code {
        if n > 0  print("    n positive (%)\n", n);
        else if n < 0  print("    n negative (%)\n", n);
        else  print("    n zero\n");
    };
    PE8_insert_check_818(-2, 2, check_pos);
}


// ============================================================================
// Section 819. Mixed tests using everything from previous sections together.
// ============================================================================

PE8_Item :: struct {
    name: string;
    quantity: int;
    unit_price: float;
}

PE8_Order :: struct {
    customer: string;
    items: [..] PE8_Item;
    total: float;
}

PE8_compute_total :: (o: *PE8_Order) {
    o.total = 0;
    for o.items  o.total += cast(float) it.quantity * it.unit_price;
}

PE8_run_section_819 :: () {
    section("819. Mixed scenario using JSON and YAML on shared data");

    o: PE8_Order;
    o.customer = "Acme";
    array_add(*o.items, .{"widget",  3, 2.50});
    array_add(*o.items, .{"gadget",  1, 9.99});
    array_add(*o.items, .{"doohickey", 5, 0.50});
    PE8_compute_total(*o);

    sub("YAML view of the order");
    print("%\n", PE8_yaml(o));

    sub("JSON view of the order");
    print("%\n", PE8_json(o));

    sub("Same order but different name/quantity (diff)");
    o2 := o;
    // o2 keeps a reference to the same items array; create a new fresh copy.
    fresh: [..] PE8_Item;
    array_add(*fresh, .{"widget",  3, 2.75});       // price differs
    array_add(*fresh, .{"gadget",  2, 9.99});       // qty differs
    array_add(*fresh, .{"doohickey", 5, 0.50});
    o2.items = fresh;
    o2.customer = "Acme2";
    PE8_compute_total(*o2);

    // Diff between orders ignoring the items array (since PE8_struct_diff
    // doesn't descend into [..]).
    PE8_print_diff("o vs o2 (top-level only)", o, o2);

    sub("Cleanup");
    array_reset(*o.items);
    array_reset(*fresh);
}


// ============================================================================
// Section 820. Recursive Any descent — print "shape" of any value as tree.
// ============================================================================

PE8_print_any_shape :: (a: Any, indent: int) {
    info := a.type;
    if info == null  { for 0..indent-1  print(" "); print("(null)\n"); return; }
    tag := info.type;
    for 0..indent-1  print(" ");
    if tag == .STRUCT {
        ti := cast(*Type_Info_Struct) info;
        print("STRUCT '%' (% members)\n", ti.name, ti.members.count);
        for ti.members {
            if it.flags & .CONSTANT  continue;
            if it.flags & .IMPORTED  continue;
            for 0..indent  print(" ");
            print(".%: ", it.name);
            sub_any : Any;
            sub_any.type = it.type;
            sub_any.value_pointer = (cast(*u8) a.value_pointer) + it.offset_in_bytes;
            inner := it.type.type;
            if inner == .STRUCT || inner == .ARRAY {
                print("\n");
                PE8_print_any_shape(sub_any, indent + 4);
            } else {
                PE8_print_any_shape(sub_any, 0);
            }
        }
        return;
    }
    if tag == .ARRAY {
        ti := cast(*Type_Info_Array) info;
        elem_size := ti.element_type.runtime_size;
        base : *u8;
        count: int;
        if ti.array_type == .FIXED {
            base = cast(*u8) a.value_pointer;
            count = ti.array_count;
        } else {
            view_p := cast(*Array_Header) a.value_pointer;
            count = view_p.count;
            base = cast(*u8) view_p.data;
        }
        print("ARRAY (count=%)\n", count);
        for i: 0..count-1 {
            for 0..indent  print(" ");
            print("[%]: ", i);
            sub_any : Any;
            sub_any.type = ti.element_type;
            sub_any.value_pointer = base + i * elem_size;
            inner := ti.element_type.type;
            if inner == .STRUCT || inner == .ARRAY {
                print("\n");
                PE8_print_any_shape(sub_any, indent + 4);
            } else {
                PE8_print_any_shape(sub_any, 0);
            }
        }
        return;
    }
    if tag == .INTEGER {
        ti := cast(*Type_Info_Integer) info;
        v: s64;
        if      ti.runtime_size == 1  { if ti.signed { p := cast(*s8 ) a.value_pointer; v = p.*; } else { p := cast(*u8 ) a.value_pointer; v = p.*; } }
        else if ti.runtime_size == 2  { if ti.signed { p := cast(*s16) a.value_pointer; v = p.*; } else { p := cast(*u16) a.value_pointer; v = p.*; } }
        else if ti.runtime_size == 4  { if ti.signed { p := cast(*s32) a.value_pointer; v = p.*; } else { p := cast(*u32) a.value_pointer; v = p.*; } }
        else if ti.runtime_size == 8  { if ti.signed { p := cast(*s64) a.value_pointer; v = p.*; } else { p := cast(*u64) a.value_pointer; v = cast,no_check(s64) p.*; } }
        print("INT %\n", v);
        return;
    }
    if tag == .FLOAT {
        if      info.runtime_size == 4  { p := cast(*float32) a.value_pointer; print("FLOAT %\n", p.*); }
        else if info.runtime_size == 8  { p := cast(*float64) a.value_pointer; print("FLOAT %\n", p.*); }
        return;
    }
    if tag == .BOOL {
        p := cast(*bool) a.value_pointer;
        print("BOOL %\n", p.*);
        return;
    }
    if tag == .STRING {
        p := cast(*string) a.value_pointer;
        print("STRING '%'\n", p.*);
        return;
    }
    if tag == .POINTER {
        pp := cast(**void) a.value_pointer;
        print("POINTER null=%\n", pp.* == null);
        return;
    }
    if tag == .ENUM {
        ti := cast(*Type_Info_Enum) info;
        v: s64;
        sz := ti.internal_type.runtime_size;
        sgn := ti.internal_type.signed;
        if      sz == 1  { if sgn { p := cast(*s8 ) a.value_pointer; v = p.*; } else { p := cast(*u8 ) a.value_pointer; v = p.*; } }
        else if sz == 2  { if sgn { p := cast(*s16) a.value_pointer; v = p.*; } else { p := cast(*u16) a.value_pointer; v = p.*; } }
        else if sz == 4  { if sgn { p := cast(*s32) a.value_pointer; v = p.*; } else { p := cast(*u32) a.value_pointer; v = p.*; } }
        else if sz == 8  { if sgn { p := cast(*s64) a.value_pointer; v = p.*; } else { p := cast(*u64) a.value_pointer; v = cast,no_check(s64) p.*; } }
        for ti.values  if it == v { print("ENUM %\n", ti.names[it_index]); return; }
        print("ENUM %\n", v);
        return;
    }
    print("(other: %)\n", tag);
}

PE8_run_section_820 :: () {
    section("820. Recursive Any descent: print value shape");

    sub("Person");
    p := PE8_Person.{"Ada", 30, 170.0, true};
    PE8_print_any_shape(p, 0);

    sub("Employee");
    e := PE8_Employee.{
        person  = .{"Bob", 25, 180.0, false},
        address = .{"5 Elm", "Springfield", "00000"},
        employee_id = 1001,
        salary = 50000.0
    };
    PE8_print_any_shape(e, 0);

    sub("Fixed [4] int");
    arr : [4] int = .[10, 20, 30, 40];
    PE8_print_any_shape(arr, 0);

    sub("Polyline (struct with array of struct)");
    pts := PE8_Point.[.{"a", 1, 2}, .{"b", 3, 4}];
    pl := PE8_Polyline.{name="poly", closed=false, pts=pts};
    PE8_print_any_shape(pl, 0);
}


// ============================================================================
// Section 821. Additional Any tests: variadic across mixed Type_Info tags.
// ============================================================================

PE8_Mixed1 :: struct { kind: PE8_Color_Tag; weight: int; }
PE8_Mixed2 :: struct { name: string; value: float; }

PE8_run_section_821 :: () {
