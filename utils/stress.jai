run_extras_7_rle_long :: () {
    section("760. RLE on synthetic long strings");

    // Make some long deterministic strings via builder.
    make :: (pat: string, repeats: int) -> string {
        b: String_Builder;
        init_string_builder(*b);
        for k: 1..repeats  append(*b, pat);
        return builder_to_string(*b);
    }

    inputs := string.[
        make("a", 50),
        make("ab", 25),
        make("aab", 20),
        make("aabb", 15),
        make("xxx", 10),
        make("oxo", 12),
        make("zzzzz", 8),
        make("rl", 30),
    ];

    for s: inputs {
        enc := PE7_rle_compress(s);
        dec := PE7_rle_decompress(enc);
        ok  := dec == s;
        print("  in_len=% enc_len=% ok=%\n", s.count, enc.count, ok);
        print("    enc='%'\n", enc);
    }
}


