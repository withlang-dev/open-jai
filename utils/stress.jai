== 742. Defer in nested while with break
----------------------------------------------------------------
    body i=0 j=0
    defer-in i=0 j=1
    body i=0 j=1
    defer-in i=0 j=2
    body i=0 j=2
    defer-in i=0 j=3
    inner break i=0 j=3
    defer-in i=0 j=3
  defer-out i=1
    body i=1 j=0
    defer-in i=1 j=1
    body i=1 j=1
    defer-in i=1 j=2
    body i=1 j=2
    defer-in i=1 j=3
    inner break i=1 j=3
    defer-in i=1 j=3
  defer-out i=2
    body i=2 j=0
    defer-in i=2 j=1
    body i=2 j=1
    defer-in i=2 j=2
    body i=2 j=2
    defer-in i=2 j=3
    inner break i=2 j=3
    defer-in i=2 j=3
  outer break i=3
  defer-out i=3
  ended at i=3

