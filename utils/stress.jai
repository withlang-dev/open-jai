  decomposed -> ["NETWORK", "INPUT", "GPU", "BLUETOOTH"]

-- PE6_Build
  indices [0,4,5] -> DEBUG_BUILD | TEST_BUILD | BENCHMARK_BUILD
  decomposed -> ["DEBUG_BUILD", "TEST_BUILD", "BENCHMARK_BUILD"]

