----------------------------------------------------------------
== 1104. Extended operator precedence
----------------------------------------------------------------

-- Unary operators
--5 = 5 (double negation)
!!true = true
~0xFF as u8 = 0

-- Member access binds tighter than unary
-v.x = -3
-v.y = 4

-- Subscript binds tight
a[0] + a[1] = 3
a[1+1]      = 3

-- Comparison chain returns bool not number
type_of(5 < 10) = bool

-- Assignment is a statement, not expression
z = 5

-- Mixed bitwise + comparison
0x0F & 0x33 == 0x03 -> true

-- Right-associativity? Most binary ops are left-assoc
100 - 50 - 25 = 25 (expect 25, left-assoc)
100 / 5 / 2   = 10 (expect 10, left-assoc)
1 << 1 << 2   = 8 (expect 8 if left-assoc)

-- Comparison non-associativity
(1 < 2) == (3 < 4) = true
(1 < 2) != (3 > 4) = true

-- Mixing all four operator classes
1 + 2 << 3 | 4 & 5 == 6 = false
(((1 + 2) << 3) | (4 & 5)) == 6 = false

