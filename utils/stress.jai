// ============================================================================
// Stress test for a Jai compiler implementation.
//
// This file has two halves:
//
//   (a) Compile-time half - an embedded metaprogram spawns one sub-workspace
//       per intentional-error snippet so the host compiler emits diagnostics
//       for each.
//
//   (b) Runtime half - a large successful program that exercises a broad
//       cross-section of the language and the standard modules.
//
// To use it:
//
//     jai cleanroom_stress.jai
//     ./cleanroom_stress
//
// The expected combined output of those two steps - compile-time diagnostics
// followed by runtime output - is stored at the bottom of this file in a
// `#string` constant named EXPECTED_OUTPUT. Diff your compiler's output
// against that string to find any discrepancies.
// ============================================================================

#import "Basic";
#import "Compiler";
#import "Math";
#import "Sort";
#import "Random";
#import "String";
#import "Bit_Array";
#import "Hash_Table";
#import "File";
#import "Base64";
#import "Bucket_Array";
#import "Unicode";
#import "Pool";
#import "Flat_Pool";
#import "Hash";
#import "Crc";
Md5 :: #import "md5";
xxHash :: #import "xxHash";

// Local struct used by reflection-based code to read out an array view from
// behind an Any. Same first-16-byte layout that [], [..], and string share.
Array_Header :: struct {
    count: s64;
    data:  *void;
}


// ============================================================================
// Runtime tests. Each procedure prints labelled output via section() / sub();
// main() at the bottom of this half calls every test in turn.
// ============================================================================

// ============================================================================
// Stress test for a Jai compiler implementation.
//
// This single file exercises a broad cross-section of the Jai language and
// the modules/Basic standard library, and prints labelled, deterministic
// output describing what each construct does. The intent is that an
// independent compiler implementation can:
//
//   1) Compile this file.
//   2) Run the resulting executable.
//   3) Diff its output line-by-line against the reference compiler's output.
//
// Any divergence in output identifies a feature mismatch or bug.
//
// ============================================================================


// ----------------------------------------------------------------------------
// Tiny helpers for output framing. These are exported (top-level) so that the
// part files can use them.
// ----------------------------------------------------------------------------

SECTION_RULE :: "----------------------------------------------------------------";

section :: (title: string) {
    print("\n%\n", SECTION_RULE);
    print("== %\n", title);
    print("%\n", SECTION_RULE);
}

sub :: (title: string) {
    print("\n-- %\n", title);
}

// Additional sections live in part files that are loaded below. Each part
// The part files use a wider set of modules than the main file does.

// Render a pointer as either "ptr=null" or "ptr=non-null".
ptr_str :: (p: *void) -> string {
    if p == null  return "ptr=null";
    return "ptr=non-null";
}


// ============================================================================
// 1. Numeric types and literals.
// ============================================================================

test_numeric_types :: () {
    section("1. Numeric types and literals");

    // Unsigned ints
    a_u8 :  u8  = 10;
    a_u16:  u16 = 50;
    a_u32:  u32 = 0x78f;
    a_u64:  u64 = 0xfade_deaf_cafe_babe;

    // Signed ints
    a_s8 :  s8  = -7;
    a_s16:  s16 = 0b1011_0110_1;        // 365
    a_s32:  s32 = -5_069_105;
    a_s64:  s64 = 987_654_321;

    // Aliases
    my_int: int = 7;
    my_flt: float   = 1.25;
    my_64 : float64 = 1.5;
    my_b  : bool = true;

    print("u8  size=% value=%\n", size_of(u8 ), a_u8);
    print("u16 size=% value=%\n", size_of(u16), a_u16);
    print("u32 size=% value=%\n", size_of(u32), a_u32);
    print("u64 size=% value=%\n", size_of(u64), a_u64);
    print("s8  size=% value=%\n", size_of(s8 ), a_s8);
    print("s16 size=% value=%\n", size_of(s16), a_s16);
    print("s32 size=% value=%\n", size_of(s32), a_s32);
    print("s64 size=% value=%\n", size_of(s64), a_s64);
    print("int size=% (alias for s64? %)\n", size_of(int), int == s64);
    print("float   size=% (alias for float32? %)\n", size_of(float), float == float32);
    print("float64 size=% value=%\n", size_of(float64), my_64);
    print("bool size=% value=%\n", size_of(bool), my_b);
    print("my_int=% my_flt=%\n", my_int, my_flt);

    sub("Default-initialized values are zero");
    di_u8 : u8;
    di_int: int;
    di_f  : float;
    di_b  : bool;
    di_s  : string;
    print("default u8=% int=% float=% bool=% string-count=% string-data-null=%\n",
        di_u8, di_int, di_f, di_b, di_s.count, di_s.data == null);

    sub("--- (uninitialized) compiles; assign before reading");
    raw : int = ---;
    raw  = 99;
    print("after assign raw=%\n", raw);

    sub("Constants ( :: ) cannot be reassigned");
    PI64    :: 3.14159265358979;
    HEX_CONST :: 0xCAFE_F00D;
    print("PI64=% HEX_CONST=%\n", PI64, HEX_CONST);

    sub("Hex float literals (0h prefix - IEEE-754 bit pattern)");
    nan32   : float32 = 0h7fbf_ffff;
    neg0_64 : float64 = 0h8000_0000_0000_0000;
    inf32   : float32 = 0h7f80_0000;
    one32   : float32 = 0h3f80_0000;   // 1.0
    print("nan32 (NaN) =% one32=% inf32=% neg0_64=%\n", nan32, one32, inf32, neg0_64);

    sub("Numeric literal underscores allowed for readability");
    big := 1_000_000;
    print("1_000_000 = %\n", big);

    sub("Compile-time numeric literal coercion");
    short_u8: u8 = 200;     // 200 fits in u8
    print("u8 = 200 -> %\n", short_u8);
}

// ============================================================================
// 2. Casts: implicit, explicit, no_check, trunc, force, bit pattern.
// ============================================================================

test_casts :: () {
    section("2. Casts (cast, cast,no_check, cast,trunc, cast,no_check,no_widen)");

    a: u8  = 200;
    b: u16 = a;            // implicit widening: u8 -> u16 ok
    c: s64 = a;            // implicit widening across signs (u8 fits in s64)
    print("u8 a=% -> u16 b=% -> s64 c=%\n", a, b, c);

    // Explicit cast, range-checked at runtime by default.
    big: u32 = 0x1234_5678;
    truncated: u16 = cast,no_check(u16) big;   // 0x5678
    print("cast,no_check truncate 0x1234_5678 -> u16 = %\n", truncated);

    // Explicit cast (range-checked); we keep within range so no failure.
    safe_down: u8 = cast(u8) cast(u16) 250;
    print("cast checked u16(250) -> u8 = %\n", safe_down);

    sub("Sign-extension vs zero-extension on widening");
    sx: s8 = -1;
    as_s32 : s32 = sx;   // sign-extended
    as_u32 : u32 = cast,no_check(u32) sx;  // bit-pattern reinterpret would be 0xFF..FF
    print("s8(-1) widened to s32 = % (sign-extended)\n", as_s32);
    print("s8(-1) bit-reinterpret to u32 = % (0x%)\n",
        as_u32, formatInt(as_u32, base=16));

    sub("Float <-> int conversions");
    fi := cast(int) 3.99;       // truncation toward zero
    fi_neg := cast(int) -3.99;
    if_f := cast(float) 42;     // exact for small ints
    print("int(3.99)=% int(-3.99)=% float(42)=%\n", fi, fi_neg, if_f);
}


// ============================================================================
// 3. Booleans / logical operators / short-circuit eval.
// ============================================================================

g_short_circuit_calls := 0;

side_effect :: (label: string, value: bool) -> bool {
    g_short_circuit_calls += 1;
    print("  side_effect(%) called -> %\n", label, value);
    return value;
}

test_booleans :: () {
    section("3. Booleans and short-circuit logical operators");

    print("true && false  = %\n", true && false);
    print("true || false  = %\n", true || false);
    print("!true          = %\n", !true);
    print("!!42 truthy?   = %\n", !!42);     // any nonzero int is truthy when negated twice

    sub("Short-circuit evaluation (&&)");
    g_short_circuit_calls = 0;
    r1 := side_effect("A=false", false) && side_effect("B should not run", true);
    print("A&&B = %  (calls so far: %)\n", r1, g_short_circuit_calls);

    sub("Short-circuit evaluation (||)");
    g_short_circuit_calls = 0;
    r2 := side_effect("A=true", true) || side_effect("B should not run", false);
    print("A||B = %  (calls so far: %)\n", r2, g_short_circuit_calls);

    sub("Both sides evaluated when needed");
    g_short_circuit_calls = 0;
    r3 := side_effect("A=true", true) && side_effect("B=true", true);
    print("A&&B = %  (calls so far: %)\n", r3, g_short_circuit_calls);
}


// ============================================================================
// 4. Arrays: fixed, view, resizable. Subscript, count/data, for-loops.
// ============================================================================

test_arrays :: () {
    section("4. Arrays: fixed, view, resizable");

    sub("Fixed array [N] T");
    fa: [5] int;
    fa[0] = 100;
    fa[1] = 200;
    fa[4] = 999;
    print("fixed count(implicit via type) = % size_of = %\n", 5, size_of(type_of(fa)));
    for fa  print("  fa[%] = %\n", it_index, it);

    sub("Array views [] T");
    av: [] int = fa;
    print("view count=% size_of=%\n", av.count, size_of(type_of(av)));
    av.count = 3;   // legal: shrink the view; underlying memory unaffected
    print("shrunk view count=% values:\n", av.count);
    for av  print("  av[%] = %\n", it_index, it);

    sub("Resizable arrays [..] T");
    ra: [..] int;
    array_add(*ra, 1);
    array_add(*ra, 4);
    array_add(*ra, 9);
    array_add(*ra, 16);
    array_add(*ra, 25);
    print("resizable count=% allocated>=count? %\n", ra.count, ra.allocated >= ra.count);
    for ra  print("  ra[%] = %\n", it_index, it);

    sub("array_add many elements");
    big: [..] int;
    for i: 1..16  array_add(*big, i*i);
    print("big.count=% values=%\n", big.count, big);

    sub("array_insert_at and array_unordered_remove_by_index");
    arr: [..] int;
    for i: 0..4  array_add(*arr, i*10);
    print("before insert: %\n", arr);
    array_insert_at(*arr, 999, 2);
    print("after  insert at 2: %\n", arr);
    array_unordered_remove_by_index(*arr, 1);
    print("after  unordered-remove idx 1: %\n", arr);

    sub("array_find on []");
    haystack := int.[3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5];
    found, idx := array_find(haystack, 5);
    print("find 5 in [3,1,4,1,5,9,2,6,5,3,5]: found=% first-idx=%\n", found, idx);

    sub("Array literals");
    primes := int.[2, 3, 5, 7, 11, 13, 17, 19];
    print("primes count=% values=%\n", primes.count, primes);

    strings_lit := string.["alpha", "beta", "gamma"];
    print("strings count=% values=%\n", strings_lit.count, strings_lit);

    sub("`for *` iterates by pointer (mutates in place)");
    mutable: [4] int;
    for i: 0..3  mutable[i] = i;
    for * mutable { it.* = it.* * 10; }
    print("after for *: %\n", mutable);

    sub("`for <` iterates in reverse");
    rev: [..] int;
    for < primes  array_add(*rev, it);
    print("reversed primes: %\n", rev);

    sub("`for *<` reverse-by-pointer");
    arr2: [..] int;
    for 0..4 array_add(*arr2, it);
    for *< arr2  it.* += 100;
    print("after for *<: %\n", arr2);

    sub("Range loops with step / named iterator");
    sum := 0;
    for idx: 0..10  sum += idx;
    print("sum of 0..10 inclusive = %\n", sum);

    sub("Strings iterate by byte (u8)");
    s := "abc";
    for s  print("  byte at %: % ('%')\n", it_index, it, to_string(*it, 1));

    sub("Element offsets in fixed array [N] T");
    fa2: [4] s32;
    base := *fa2[0];
    print("element[1]-base = % bytes (expect 4 for s32)\n",
        cast(s64)(*fa2[1]) - cast(s64) base);
    print("element[3]-base = % bytes\n",
        cast(s64)(*fa2[3]) - cast(s64) base);

    sub("size_of of array types");
    print("size_of([5] s32) = %\n", size_of([5] s32));
    print("size_of([] s32)  = %\n", size_of([] s32));
    print("size_of([..] s32)= %\n", size_of([..] s32));

    sub("Bounds checks happen at runtime for [], compile-time for fixed when index is known");
    // Note: runtime out-of-bounds aborts the program; we don't trigger one.
    safe_idx := 4;
    print("primes[%] = % (within bounds)\n", safe_idx, primes[safe_idx]);
}


// ============================================================================
// 5. Strings.
// ============================================================================

test_strings :: () {
    section("5. Strings");

    s := "Hello, Sailor!";
    print("s='%' count=% size_of(string)=% data-non-null=%\n",
        s, s.count, size_of(string), s.data != null);

    sub("Subscript yields u8");
    print("s[0]=% (type %)\n", s[0], type_of(s[0]));

    sub("Substring via .count and .data manipulation (no copy)");
    sub_s := s;
    sub_s.data += 7;
    sub_s.count = 6;
    print("substring='%'\n", sub_s);

    sub("Escape sequences");
    print("backslash[\\\\] tab[\\t] quote[\\\"] newline[next-line]\nzero-byte after this colon:[\\0]\n");
    print("hex escape \\x41 = '%'\n", "\x41");
    print("decimal escape \\d065 = '%'\n", "\d065");

    sub("Here strings (#string)");
    HS :: #string DONE
First line
  indented second line
"quotes" and \backslashes\ verbatim
DONE
    print("here-string content (%-bytes):\n%\n", HS.count, HS);

    sub("sprint allocates");
    fmt := sprint("a=%, b=%, c=%", 1, 2.5, "three");
    print("sprint result='%' count=%\n", fmt, fmt.count);

    sub("tprint goes through temporary storage");
    t := tprint("temp number %", 42);
    print("tprint='%' count=%\n", t, t.count);

    sub("String_Builder");
    builder: String_Builder;
    init_string_builder(*builder);
    append(*builder, "alpha-");
    append(*builder, "beta-");
    print_to_builder(*builder, "n=%", 7);
    result := builder_to_string(*builder);
    print("builder result='%' length=%\n", result, result.count);

    sub("String equality is by content, not by pointer");
    a1 := "hello";
    a2 := "hello";
    print("'hello' == 'hello' -> %\n", a1 == a2);
    print("'hello' == 'helLO' -> %\n", a1 == "helLO");

    sub("formatInt / FormatInt struct");
    n := 0xCAFE_BABE;
    print("hex with min digits and underscores: %\n",
        formatInt(n, base=16, minimum_digits=10, digits_per_comma=4, comma_string="_"));

    fi: FormatInt;
    fi.value          = 42;
    fi.base           = 2;
    fi.minimum_digits = 8;
    fi.padding        = #char "0";
    print("FormatInt 42 in base 2 width 8: %\n", fi);

    sub("formatFloat / FormatFloat struct");
    f := 1234567.89;
    print("default float       : %\n", f);
    print("width=10,trail=4    : %\n", formatFloat(f, width=10, trailing_width=4));
    print("scientific          : %\n", formatFloat(f, mode=.SCIENTIFIC));
    print("shortest            : %\n", formatFloat(f, mode=.SHORTEST));

    sub("formatStruct");
    Point :: struct { x: int; y: int; label: string; }
    p := Point.{3, 4, "origin-ish"};
    print("plain                  : %\n", p);
    print("formatStruct(..., 1, true) (force long-form/newlines):\n%\n",
        formatStruct(p, use_long_form_if_more_than_this_many_members=1, use_newlines_if_long_form=true));
}


// ============================================================================
// 6. Structs: declaration, defaults, anonymous, struct literals, using, #as.
// ============================================================================

Rectangle :: struct {
    x0: float = 0;
    y0: float = 0;
    x1: float = 0;
    y1: float = 0;
    color_name: string = "white";
}

Vec3D :: struct {
    x, y, z: float;   // compound decl
}

Person :: struct {
    name : string;
    age  : int = 0;
    address : struct {
        street: string;
        city  : string;
    };
}

Animal :: struct {
    species: string;
    legs: int;
}

Dog :: struct {
    #as using base: Animal;     // #as makes Dog implicitly cast to Animal
    name: string;
    species = "Canis";          // override default after #as
    legs = 4;
}

test_structs :: () {
    section("6. Structs");

    sub("Defaults applied on default initialization");
    r: Rectangle;
    print("rect default = %\n", r);

    sub("Struct literal Type.{...}");
    r2 := Rectangle.{1, 2, 3, 4, "blue"};
    print("rect literal = %\n", r2);

    sub("Designated struct literal Type.{field=val, ...}");
    r3 := Rectangle.{x1=10, color_name="green"};
    print("designated   = %\n", r3);

    sub("Nested struct access");
    p: Person;
    p.name = "Ada";
    p.age = 36;
    p.address.street = "1 Analytical Engine Lane";
    p.address.city   = "Babbageton";
    print("person = %\n", p);

    sub("Anonymous nested struct field still has named type internally");
    print("type_of(p.address) = %\n", type_of(p.address));

    sub("Vec3D compound declaration");
    v := Vec3D.{1, 2, 3};
    print("v = %\n", v);

    sub("`using` and `#as using`");
    d: Dog;
    d.name = "Rex";
    print("dog=% species=% legs=%\n", d, d.species, d.legs);

    sub("Dog can be passed where Animal is expected (#as)");
    describe :: (a: Animal) {
        print("  animal species=% legs=%\n", a.species, a.legs);
    }
    describe(d);

    sub("Struct sizes and member offsets via type_info");
    info := type_info(Rectangle);
    print("Rectangle name='%' members=% runtime_size=%\n",
        info.name, info.members.count, info.runtime_size);
    for info.members  {
        print("  member '%' type=% offset=%\n",
            it.name, type_to_string(it.type), it.offset_in_bytes);
    }

    sub("Vec3D layout");
    vinfo := type_info(Vec3D);
    print("Vec3D size=%\n", vinfo.runtime_size);
    for vinfo.members  print("  '%' off=%\n", it.name, it.offset_in_bytes);
}


// ============================================================================
// 7. Procedures: returns, named returns, defaults, varargs, named args.
// ============================================================================

// Single return.
square_int_proc :: (x: int) -> int { return x*x; }

// Multiple returns.
divmod :: (a: int, b: int) -> (q: int, r: int) {
    return a / b, a % b;
}

// Defaults + named args.
greet :: (name: string, greeting := "Hello", emphasis := 1) -> string {
    s := tprint("%, %", greeting, name);
    if emphasis > 0 {
        for 1..emphasis  s = tprint("%!", s);
    }
    return s;
}

// Variadic ..T.
sum_ints :: (xs: ..int) -> int {
    total := 0;
    for xs  total += it;
    return total;
}

// Multiple return values, partial use:
two_things :: () -> int, string { return 42, "answer"; }

test_procedures :: () {
    section("7. Procedures");

    sub("Single and multiple return values");
    print("square_int_proc(11) = %\n", square_int_proc(11));
    q, r := divmod(17, 5);
    print("divmod(17,5) = q=% r=%\n", q, r);

    sub("Named-argument call and defaults");
    print("greet('A')              = '%'\n", greet("A"));
    print("greet('A', emphasis=3)  = '%'\n", greet("A", emphasis=3));
    print("greet('A', 'Howdy')     = '%'\n", greet("A", "Howdy"));
    print("greet('A', emphasis=2, greeting='Hi') = '%'\n",
        greet("A", emphasis=2, greeting="Hi"));

    sub("Variadic ..T");
    print("sum_ints(1,2,3,4) = %\n", sum_ints(1,2,3,4));
    nums := int.[10, 20, 30];
    print("sum_ints(..nums)  = %\n", sum_ints(..nums));    // spread

    sub("Multiple return values; drop second");
    n, _ := two_things();
    print("two_things gave n=% (second dropped)\n", n);

    sub("Procedure as a value (function pointer)");
    f := square_int_proc;    // f is a non-constant proc pointer
    print("type_of(f)=%\n", type_of(f));
    print("f(7) = %\n", f(7));

    sub("Inline call");
    print("inline square_int_proc(8) = %\n", inline square_int_proc(8));
}


// ============================================================================
// 8. Polymorphic procedures.
// ============================================================================

poly_square :: (x: $T) -> T {
    return x * x;
}

poly_pair :: (a: $A, b: $B) -> (first: A, second: B) {
    return a, b;
}

// $T as full type and as element of compound type:
poly_first :: (arr: [] $T) -> T {
    assert(arr.count > 0);
    return arr[0];
}

// $$T (baked) and #modify for constraints
poly_increment :: (x: *$T) #modify {
    return true;       // accept anything that supports x.* += 1 in body
}
{
    x.* += 1;
}

// nested polymorph with constants used in body
make_n :: (n: $T, count: int) -> [..] T {
    out: [..] T;
    for 1..count  array_add(*out, n);
    return out;
}

test_polymorph :: () {
    section("8. Polymorphic procedures");

    sub("Same code, different argument types");
    print("poly_square(5_int) = % (%-typed)\n",
        poly_square(5), type_of(poly_square(5)));
    print("poly_square(5.5_f) = % (%-typed)\n",
        poly_square(5.5), type_of(poly_square(5.5)));

    sub("Different $ variables");
    a, b := poly_pair("answer", 42);
    print("poly_pair returned: %, %\n", a, b);

    sub("$T inside compound type ([] $T)");
    arr := int.[10, 20, 30];
    print("poly_first(arr_of_int) = %\n", poly_first(arr));
    strs := string.["apple", "banana"];
    print("poly_first(arr_of_str) = %\n", poly_first(strs));

    sub("Increment via pointer-polymorph");
    x := 5;
    poly_increment(*x);
    y := 2.5;
    poly_increment(*y);
    print("after increment: x=% y=%\n", x, y);

    sub("Polymorph returning [..] T");
    threes := make_n(3, 5);
    words  := make_n("ho", 3);
    print("threes = %\n", threes);
    print("words  = %\n", words);
}


// ============================================================================
// 9. Polymorphic structs (parametric types).
// ============================================================================

Box :: struct(T: Type) {
    value: T;
    label: string = "box";
}

Pair :: struct(A: Type, B: Type) {
    first:  A;
    second: B;
}

test_polymorph_structs :: () {
    section("9. Polymorphic structs");

    bi: Box(int);
    bi.value = 7;
    bs: Box(string);
    bs.value = "seven";
    print("Box(int)    = %\n", bi);
    print("Box(string) = %\n", bs);

    pair: Pair(int, string);
    pair.first  = 1;
    pair.second = "one";
    print("Pair(int,string) = %\n", pair);

    sub("type_info reports correct parameterized name");
    print("Box(int) name from type_info: %\n", (cast(*Type_Info_Struct) type_info(Box(int))).name);
    print("Pair(int,string) name        : %\n", (cast(*Type_Info_Struct) type_info(Pair(int,string))).name);
}


// ============================================================================
// 10. Enums and enum_flags.
// ============================================================================

Color :: enum u8 {
    RED;
    GREEN;
    BLUE;
    ALPHA;
}

Day :: enum u16 #specified {
    MONDAY    :: 1;
    TUESDAY   :: 2;
    WEDNESDAY :: 3;
    THURSDAY  :: 4;
    FRIDAY    :: 5;
    SATURDAY  :: 6;
    SUNDAY    :: 7;
}

Permissions :: enum_flags u8 {
    READ    :: 0x1;
    WRITE   :: 0x2;
    EXEC    :: 0x4;
    SPECIAL :: 0x80;
}

test_enums :: () {
    section("10. Enums and enum_flags");

    c: Color = .GREEN;          // unary dot uses inferred type
    print("color = % size_of(Color) = % internal_type=%\n",
        c, size_of(Color), (type_info(Color)).internal_type.signed);

    sub("Enum names and values via enum_names / enum_values_as_s64");
    print("Color names  : %\n", enum_names(Color));
    print("Color values : %\n", enum_values_as_s64(Color));

    sub("Specified enum");
    d: Day = .FRIDAY;
    print("day=% as integer=%\n", d, cast(int) d);
    print("Day specified flag set? %\n",
        (type_info(Day).enum_type_flags & .SPECIFIED) != 0);

    sub("Enum range");
    lo, hi := enum_range(Day);
    print("Day range = [%, %]\n", lo, hi);

    sub("enum_flags - bitwise ops");
    p: Permissions = .READ | .WRITE;
    print("perm = % (flags=READ|WRITE)\n", p);
    print("has WRITE? %  has EXEC? %\n", (p & .WRITE) != 0, (p & .EXEC) != 0);
    p |= .EXEC;
    print("after |= EXEC: %\n", p);
    p &= ~.READ;
    print("after &= ~READ: %\n", p);

    sub("Iterating enum values as the enum type");
    for v: enum_values_as_enum(Color) {
        print("  color value %: %\n", it_index, v);
    }
}


// ============================================================================
// 11. Control flow: if/else, ifx, if-case, while, break/continue, defer.
// ============================================================================

classify :: (n: int) -> string {
    if n < 0  return "negative";
    else if n == 0  return "zero";
    else  return "positive";
}

test_control_flow :: () {
    section("11. Control flow");

    print("classify(-3) = %\n", classify(-3));
    print("classify(0)  = %\n", classify(0));
    print("classify(99) = %\n", classify(99));

    sub("ifx (expression form)");
    abs_val := (x: int) -> int { return ifx x < 0 then -x else x; };
    print("abs(-7) = %\n", abs_val(-7));
    print("abs(11) = %\n", abs_val(11));

    sub("if-case (switch-like)");
    days := int.[1, 3, 5, 7, 99];
    for d: days {
        name := "?";
        if d == {
          case 1; name = "Mon";
          case 2; name = "Tue";
          case 3; name = "Wed";
          case 4; name = "Thu";
          case 5; name = "Fri";
          case;   name = "Other";
        }
        print("  day %=%\n", d, name);
    }

    sub("if-case with #through (explicit fallthrough)");
    grade :: (g: int) -> string {
        if g == {
          case 1; #through;
          case 2; #through;
          case 3; return "low";
          case 4; #through;
          case 5; return "mid";
          case 6; return "high";
          case;   return "?";
        }
    };
    for g: int.[1, 3, 5, 6, 9]  print("  grade(%) = %\n", g, grade(g));

    sub("while + break + continue");
    i := 0;
    while i < 10 {
        i += 1;
        if i == 3  continue;
        if i == 7  break;
        print("  i=%\n", i);
    }
    print("  ended at i=%\n", i);

    sub("Labelled break/continue with named for-loops");
    outer_count := 0;
    inner_count := 0;
    for outer: 0..3 {
        outer_count += 1;
        for inner: 0..3 {
            inner_count += 1;
            if outer == 2 && inner == 1  break outer;
            if inner == outer            continue outer;
        }
    }
    print("  outer iterations completed: % inner total: %\n", outer_count, inner_count);

    sub("defer runs in reverse order at scope exit");
    {
        defer print("  defer A (printed third)\n");
        defer print("  defer B (printed second)\n");
        print("  body (printed first)\n");
    }
    print("  after block\n");

    sub("defer scope");
    {
        x := 0;
        defer print("  defer sees x=%\n", x);
        x = 42;
    }
}


// ============================================================================
// 12. Pointers, dereference, address-of.
// ============================================================================

test_pointers :: () {
    section("12. Pointers");

    x := 100;
    p := *x;                    // address-of
    print("type_of(p) = %\n", type_of(p));
    print("p is non-null: %\n", p != null);
    print("*p (deref via p.*) = %\n", p.*);
    p.* = 250;
    print("after p.* = 250, x = %\n", x);

    sub("Pointer arithmetic");
    arr: [4] s32;
    for i: 0..3  arr[i] = cast(s32)(i * 11);
    p0 := *arr[0];
    p2 := p0 + 2;
    diff_bytes := cast(s64) p2 - cast(s64) p0;
    print("p0..p2 distance = % bytes (expect 8 for 2x s32)\n", diff_bytes);
    print("p2.* = %\n", p2.*);

    sub("*void casts");
    vp: *void = p0;
    p_back: *s32 = vp;
    print("round-trip through *void preserves value: %\n", p_back.* == arr[0]);

    sub("Null pointer literal");
    np : *int = null;
    print("np == null: %  np != null: %\n", np == null, np != null);
}


// ============================================================================
// 13. defer with allocators / temporary storage.
// ============================================================================

test_temp_storage :: () {
    section("13. Temporary storage / allocators");

    s1 := tprint("temp string 1: %\n", 42);
    s2 := tprint("temp string 2: %\n", 17);
    print("%", s1);
    print("%", s2);

    sub("auto_release_temp scope");
    {
        auto_release_temp();
        // Allocate a bunch of temp strings; they all go away at scope end.
        for 1..3 {
            tmp := tprint("inside-temp-%-%\n", it, "x");
            print("%", tmp);
        }
    }

    sub("push_allocator (here pushes back to temp explicitly)");
    {
        push_allocator(temp);
        // strings allocated here are temp-allocated too
        ts := tprint("under push_allocator, %\n", "ok");
        print("%", ts);
    }
}


// ============================================================================
// 14. Compile-time execution: #run, #if, #assert.
// ============================================================================

COMPILE_TIME_TABLE :: #run -> [16] s32 {
    out: [16] s32;
    for i: 0..15  out[i] = cast(s32)(i * i);
    return out;
};

CT_DOUBLED :: #run 7 * 6;       // bake 42 at compile time

#if size_of(int) == 8 {
    INT_IS_64 :: true;
} else {
    INT_IS_64 :: false;
}

#assert size_of(int) == 8 "int must be 8 bytes on this platform";

test_compile_time :: () {
    section("14. Compile-time execution: #run, #if, #assert");

    sub("Table baked at compile time");
    for COMPILE_TIME_TABLE  print("  CT_TABLE[%] = %\n", it_index, it);

    sub("Constant from #run");
    print("CT_DOUBLED = %\n", CT_DOUBLED);

    sub("#if static branch resolved at compile time");
    print("INT_IS_64 = %\n", INT_IS_64);

    sub("#run a side-effecting block (output appears at compile time only - not here)");
    // The print below will run at compile time only:
    // (we keep it tiny so the build log isn't huge)
    // #run print("[compile-time-only print]\n");
    // -- Intentionally commented; otherwise the compile log is no longer
    //    diff-able for runtime output.
}


// ============================================================================
// 15. Operator overloading.
// ============================================================================

V2 :: struct {
    x, y: float;
}

operator + :: (a: V2, b: V2) -> V2 {
    return V2.{a.x + b.x, a.y + b.y};
}

operator - :: (a: V2, b: V2) -> V2 {
    return V2.{a.x - b.x, a.y - b.y};
}

operator * :: (a: V2, s: float) -> V2 #symmetric {
    return V2.{a.x * s, a.y * s};
}

operator == :: (a: V2, b: V2) -> bool {
    return a.x == b.x && a.y == b.y;
}

operator [] :: (a: V2, i: int) -> float {
    if i == 0 return a.x;
    return a.y;
}

test_operator_overloads :: () {
    section("15. Operator overloading");

    a := V2.{1, 2};
    b := V2.{3, 5};
    print("a + b = %\n", a + b);
    print("b - a = %\n", b - a);
    print("a * 3 = %\n", a * 3.0);
    print("3 * a = %  (#symmetric)\n", 3.0 * a);
    print("a == a = %  a == b = %\n", a == a, a == b);
    print("a[0]=% a[1]=%  (subscript overload)\n", a[0], a[1]);
}


// ============================================================================
// 16. Type as a first-class value.
// ============================================================================

test_types :: () {
    section("16. Types are values");

    t: Type = int;
    print("t = % (Type variable holds 'int')\n", t);
    print("t == int : %\n", t == int);
    print("size_of(int) via Type variable: %\n",
        size_of(int));  // size_of takes a Type at compile time

    sub("type_of() of values");
    x := 3.14;
    print("type_of(3.14) = %\n", type_of(x));

    sub("type_info catalog");
    print_type :: ($T: Type) {
        info := type_info(T);
        print("  T=% tag=% runtime_size=%\n", T, info.type, info.runtime_size);
    }
    print_type(int);
    print_type(float);
    print_type(bool);
    print_type(string);
    print_type(*u8);
    print_type([4] s32);
    print_type([] string);
    print_type([..] int);
    print_type(V2);
    print_type(Color);

    sub("Polymorphic dispatch on $T");
    show_size :: ($T: Type, name: string) {
        print("  size_of(%) = %\n", name, size_of(T));
    }
    show_size(u8, "u8");
    show_size(s64, "s64");
    show_size(float64, "float64");
    show_size(V2, "V2");
    show_size([3] int, "[3] int");
}


// ============================================================================
// 17. The Any type / runtime type introspection.
