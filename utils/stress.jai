    print_tag :: ($T: Type, label: string) {
        info := type_info(T);
        print("  % -> tag=%  size=%\n", label, info.type, info.runtime_size);
    }

    print_tag(s8,      "s8");
    print_tag(s16,     "s16");
    print_tag(s32,     "s32");
    print_tag(s64,     "s64");
    print_tag(u8,      "u8");
    print_tag(u16,     "u16");
    print_tag(u32,     "u32");
    print_tag(u64,     "u64");
    print_tag(int,     "int");
    print_tag(float,   "float");
    print_tag(float32, "float32");
    print_tag(float64, "float64");
    print_tag(bool,    "bool");
    print_tag(string,  "string");
    print_tag(*u8,     "*u8");
    print_tag(*void,   "*void");
    print_tag([3] int, "[3] int");
    print_tag([] int,  "[] int");
    print_tag([..] int,"[..] int");
    print_tag(Type,    "Type");
    print_tag(Any,     "Any");
}


// ----------------------------------------------------------------------------
// 934. polymorphic PE9_Optional(T)/PE9_Result(T,E)
// ----------------------------------------------------------------------------

PE9_Optional :: struct(T: Type) {
    value:    T;
    has_value: bool;
}

opt_some :: ($T: Type, v: T) -> PE9_Optional(T) {
    r: PE9_Optional(T);
    r.value = v;
    r.has_value = true;
    return r;
}

opt_none :: ($T: Type) -> PE9_Optional(T) {
    r: PE9_Optional(T);
    return r;
}

PE9_Result :: struct(T: Type, E: Type) {
    value: T;
    error: E;
    ok:    bool;
}

result_ok :: ($T: Type, $E: Type, v: T) -> PE9_Result(T, E) {
    r: PE9_Result(T, E);
    r.value = v;
    r.ok = true;
    return r;
}

result_err :: ($T: Type, $E: Type, e: E) -> PE9_Result(T, E) {
    r: PE9_Result(T, E);
    r.error = e;
    return r;
}

test_extras_9_934_optional_result :: () {
    section("934. PE9_Optional(T) / PE9_Result(T,E)");

    o1 := opt_some(int, 42);
    o2 := opt_none(int);
    print("  o1 has=% v=%\n", o1.has_value, o1.value);
    print("  o2 has=% v=%\n", o2.has_value, o2.value);

    r1 := result_ok(int, string, 99);
    r2 := result_err(int, string, "bad input");
    print("  r1 ok=% v=% e='%'\n", r1.ok, r1.value, r1.error);
    print("  r2 ok=% v=% e='%'\n", r2.ok, r2.value, r2.error);
}


// ----------------------------------------------------------------------------
// 935. A small JSON-like encoder for a struct via reflection.
// ----------------------------------------------------------------------------

json_encode_any :: (b: *String_Builder, a: Any) {
    if a.type.type == {
      case .INTEGER;
        info := cast(*Type_Info_Integer) a.type;
        if info.signed {
            v := get_s64_from_void_pointer(a.value_pointer, info.runtime_size);
            print_to_builder(b, "%", v);
        } else {
            v := get_u64_from_void_pointer(a.value_pointer, info.runtime_size);
            print_to_builder(b, "%", v);
        }
      case .FLOAT;
        if a.type.runtime_size == 4 {
            f := (cast(*float32) a.value_pointer).*;
            print_to_builder(b, "%", f);
        } else {
            f := (cast(*float64) a.value_pointer).*;
            print_to_builder(b, "%", f);
        }
      case .BOOL;
        v := (cast(*bool) a.value_pointer).*;
        append(b, ifx v then "true" else "false");
      case .STRING;
        v := (cast(*string) a.value_pointer).*;
        append(b, "\"");
        // No escaping - inputs are ASCII-safe in tests.
        append(b, v);
        append(b, "\"");
      case .STRUCT;
        sinfo := cast(*Type_Info_Struct) a.type;
        append(b, "{");
        for sinfo.members {
            if it_index > 0  append(b, ",");
            append(b, "\"");
            append(b, it.name);
            append(b, "\":");
            member_any: Any;
            member_any.type = it.type;
            member_any.value_pointer = a.value_pointer + it.offset_in_bytes;
            json_encode_any(b, member_any);
        }
        append(b, "}");
      case .ARRAY;
        ainfo := cast(*Type_Info_Array) a.type;
        append(b, "[");
        // Only handle fixed and view; resizable matches same layout.
        view: [] u8;
        if ainfo.array_type == .FIXED {
            view.count = ainfo.array_count;
            view.data  = a.value_pointer;
        } else {
            // For [] and [..] the first 16 bytes are count then data ptr.
            view = (cast(*[] u8) a.value_pointer).*;
        }
        elem_size := ainfo.element_type.runtime_size;
        for i: 0..view.count-1 {
            if i > 0  append(b, ",");
            elem_any: Any;
            elem_any.type = ainfo.element_type;
            elem_any.value_pointer = view.data + i * elem_size;
            json_encode_any(b, elem_any);
        }
        append(b, "]");
      case;
        append(b, "null");
    }
}

JEx :: struct {
    name:   string;
    age:    int;
    height: float;
    happy:  bool;
}

test_extras_9_935_json_encode :: () {
    section("935. JSON-like encoder via Any/reflection");

    b: String_Builder;
    init_string_builder(*b);
    p := JEx.{"Ada", 36, 5.7, true};
    json_encode_any(*b, p);
    print("  encoded: %\n", builder_to_string(*b));

    b2: String_Builder;
    init_string_builder(*b2);
    arr := int.[1, 2, 3, 4, 5];
    json_encode_any(*b2, arr);
    print("  encoded: %\n", builder_to_string(*b2));
}


// ----------------------------------------------------------------------------
// 936. defer ordering with returns and breaks.
// ----------------------------------------------------------------------------

defer_demo :: (n: int) -> int {
    defer print("  defer-1 (n=%)\n", n);
    defer print("  defer-2 (n=%)\n", n);
    if n < 0 {
        defer print("  defer-inside-if (n=%)\n", n);
        return -1;
    }
    defer print("  defer-3 (n=%)\n", n);
    return n*n;
}

test_extras_9_936_defer :: () {
    section("936. defer ordering with returns");

    r1 := defer_demo(3);
    print(" returned %\n", r1);
    print("---\n");
    r2 := defer_demo(-2);
    print(" returned %\n", r2);
}


