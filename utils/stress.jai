----------------------------------------------------------------
== 702. Comprehensive defer ordering
----------------------------------------------------------------

-- 702.a Defer in linear block
  enter
  body line
  defer-3 (first out)
  defer-2 (middle out)
  defer-1 (last out)

-- 702.b Defer in if/else branches
  if-then body x=7
  in-if-then defer
  after-if
  if-else2 body x=2
  in-if-else2 defer
  after-if2

-- 702.c Defer inside for body
  for-body i=1
  for-defer i=1 (after-body)
  for-body i=2
  for-defer i=2 (after-body)
  for-body i=3
  for-defer i=3 (after-body)
  after-for

-- 702.d Defer inside while body
  while-body i=1
  while-defer i=2
  while-body i=2
  while-defer i=3
  while-body i=3
  while-defer i=4
  after-while

-- 702.e Defer inside if-case (Jai switch)
    case1 body v=1
    case1 defer
  after-case v=1
    case2 body v=2
    case2 defer
  after-case v=2
    case3 body v=3
    case3 defer
  after-case v=3

-- 702.f Defer in nested blocks
  outer-enter
    inner1-body
      inner2-body
      inner2-defer
    after-inner2
    inner1-defer
  outer-body-tail
  outer-defer (LAST)

-- 702.g Defer visit order with sequence counter
  step 1 : body-1
  step 2 : body-2
  step 3 : body-3
  step 4 : defer-C
  step 5 : defer-B
  step 6 : defer-A
  total_steps=6

-- 702.h Defer with continue
  body i=1
  defer (always) i=1
  body i=2
  defer (always) i=2
  continue at i=3
  defer (always) i=3
  body i=4
  defer (always) i=4
  body i=5
  defer (always) i=5

-- 702.i Defer with break
  body i=1
  defer (always) i=1
  body i=2
  defer (always) i=2
  body i=3
  defer (always) i=3
  break at i=4
  defer (always) i=4

