    print("empty [..] string = %\n", b);

    c: [0] int;
    print("empty [0] int = %\n", c);

    d: [] int;
    print("empty [] int = %\n", d);

    e: string;
    print("empty string = '%'\n", e);

    sub("Hash table count zero");
    t: Table(int, int);
    init(*t);
    defer deinit(*t);
    print("empty table.count = %\n", t.count);
}


// ----------------------------------------------------------------------------
// 488. for-loop over various ranges
// ----------------------------------------------------------------------------

test_488_for_range :: () {
    section("488. for-loop over ranges");

    sub("for 0..0 (inclusive, runs once)");
    n := 0;
    for i: 0..0  n += 1;
    print("count = %\n", n);

    sub("for 0..5");
    s := 0;
    for i: 0..5  s += i;
    print("sum 0..5 = %\n", s);

    sub("for 5..0 doesn't run forward");
    n2 := 0;
    for i: 5..0  n2 += 1;
    print("count = %\n", n2);

    sub("for < (reverse)");
    out: [..] int;
    for < i: 0..4  array_add(*out, i);
    print("for < 0..4: %\n", out);

    sub("Iterator with index access");
    arr := int.[100, 200, 300];
    for v, i: arr  print("[%]=%\n", i, v);
}


// ----------------------------------------------------------------------------
// 489. Comprehensive cast,no_check semantics
// ----------------------------------------------------------------------------

test_489_no_check_casts :: () {
    section("489. cast,no_check at bit-pattern level");

    sub("256 u8 -> s8 mapping");
    for i: 0..255 {
        u: u8 = cast(u8) i;
        s: s8 = cast,no_check(s8) u;
        if i % 16 == 0  print("\n");
        print("%->%  ", u, s);
    }
    print("\n");

    sub("Specific 16/32-bit reinterprets");
    a16: u16 = 0xFFFE;
    s16r: s16 = cast,no_check(s16) a16;
    print("u16 0xFFFE -> s16 %\n", s16r);

    a32: u32 = 0x8000_0001;
    s32r: s32 = cast,no_check(s32) a32;
    print("u32 0x80000001 -> s32 %\n", s32r);
}


// ----------------------------------------------------------------------------
// 490. Float to int casts
// ----------------------------------------------------------------------------

test_490_float_to_int :: () {
    section("490. Float -> int casts (truncation toward zero)");

    inputs := float.[
        0.0, 0.5, 0.99, 1.0, 1.5, 1.99, 2.0,
        -0.5, -0.99, -1.0, -1.5, -1.99, -2.0,
        100.5, -100.5, 1000000.0, -1000000.0,
    ];
    for v: inputs {
        n: int = cast(int) v;
        print("float % -> int %\n", v, n);
    }
}

test_491_int_to_float :: () {
    section("491. Int -> float casts");

    inputs := int.[-1000000, -1, 0, 1, 1000000, 1<<30];
    for v: inputs {
        f: float = cast(float) v;
        d: float64 = cast(float64) v;
        print("int % -> float % / float64 %\n", v, f, d);
    }
}


// ----------------------------------------------------------------------------
// 492. Float-float casts (precision changes)
// ----------------------------------------------------------------------------

test_492_float_float :: () {
    section("492. float32 <-> float64");

    f64s := float64.[0.0, 1.5, 3.14159265358979, 1.0e10, 1.0e-10, -1.5];
    for d: f64s {
        f: float32 = cast(float32) d;
        back: float64 = cast(float64) f;
        print("d=% -> f32=% -> back=%\n", d, f, back);
    }
}


