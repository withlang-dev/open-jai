----------------------------------------------------------------
== 832. Polymorphic instantiations with #procedure_of_call
----------------------------------------------------------------

-- clamp_poly for several types
  clamp_int(5, 0, 10)     = 5
  clamp_int(-5, 0, 10)    = 0
  clamp_int(15, 0, 10)    = 10
  clamp_float(0.5, 0, 1)  = 0.5
  clamp_float(-0.5, 0, 1) = 0
  clamp_float(2.5, 0, 1)  = 1

-- min_poly for several types
  min_int(7,3)=3
  min_flt(.5,.7)=0.5

-- swap_poly for several types
  swap_int(1,2)        = (2, 1)
  swap_str('foo','bar')= ('bar', 'foo')

-- types of all the above
  type clamp_int   = procedure (s64, s64, s64) -> s64
  type clamp_float = procedure (float32, float32, float32) -> float32
  type min_int     = procedure (s64, s64) -> s64
  type min_flt     = procedure (float32, float32) -> float32
  type swap_int    = procedure (s64, s64) -> (s64, s64)
  type swap_str    = procedure (string, string) -> (string, string)

