// ============================================================================
// Stress test EXTRAS 11 - additions from the "next worth adding" list:
//   - the `xx` auto-cast operator
//   - `#add_context` extending the implicit context
//   - `#module_parameters` (via Basic's exposed constants)
//   - `@notes` annotation system on struct members
//   - extended operator precedence + associativity table
//   - struct/array assignment-copy semantics
//   - some compile-time const-folding sanity
//
// Adds sections 1100..1199.
// ============================================================================


// ----------------------------------------------------------------------------
// 1100. The `xx` operator (auto-cast).
// ----------------------------------------------------------------------------

test_extras_11_1100_xx :: () {
    section("1100. xx auto-cast operator");

    sub("xx from int literal");
    a: u8  = xx 200;
    b: u16 = xx 200;
    c: s32 = xx -5;
    print("u8(xx 200)=% u16(xx 200)=% s32(xx -5)=%\n", a, b, c);

    sub("xx from variable");
    src_s64: s64 = 100;
    d: u8 = xx src_s64;
    e: s32 = xx src_s64;
    print("u8(xx s64=100)=% s32(xx s64=100)=%\n", d, e);

    sub("xx narrowing (range-checked at runtime)");
    src2: s32 = 250;
    f: u8 = xx src2;
    print("u8(xx s32=250)=% (in range)\n", f);

    sub("xx between integer and float");
    n: int = 42;
    flt: float = xx n;
    n2: int = xx 7.0;
    print("float(xx int=42)=% int(xx float=7.0)=%\n", flt, n2);
}


// ----------------------------------------------------------------------------
// 1101. #add_context extending the implicit context.
// ----------------------------------------------------------------------------
//
// #add_context adds a field to every context. The field is visible as
// context.<name>. Default value is whatever we declare. Below we add three
// fields with different defaults and access them .

#add_context extras_11_request_id: int = 1234;
#add_context extras_11_user_tag:   string = "anonymous";
#add_context extras_11_depth:      s32;

test_extras_11_1101_add_context :: () {
    section("1101. #add_context");

    sub("Default values after #add_context");
    print("extras_11_request_id = %\n", context.extras_11_request_id);
    print("extras_11_user_tag   = '%'\n", context.extras_11_user_tag);
    print("extras_11_depth      = %\n", context.extras_11_depth);

    sub("Mutate context, observe");
    new_context := context;
    new_context.extras_11_request_id = 999;
    new_context.extras_11_user_tag   = "Ada";
    new_context.extras_11_depth      = 7;
    push_context new_context {
        print("inside push: id=% tag='%' depth=%\n",
            context.extras_11_request_id,
            context.extras_11_user_tag,
            context.extras_11_depth);
    }
    print("after  push: id=% tag='%' depth=% (restored)\n",
        context.extras_11_request_id,
        context.extras_11_user_tag,
        context.extras_11_depth);
}


// ----------------------------------------------------------------------------
// 1102. #module_parameters - read Basic's exposed parameters.
// ----------------------------------------------------------------------------
//
// Basic is imported with default module parameters in this build. The module
// exposes its parameters as constants reachable via the namespace.

test_extras_11_1102_module_parameters :: () {
    section("1102. #module_parameters (Basic's exposed constants)");

    Basic_ns :: #import "Basic";

    print("Basic.MEMORY_DEBUGGER             = %\n", Basic_ns.MEMORY_DEBUGGER);
    print("Basic.ENABLE_ASSERT               = %\n", Basic_ns.ENABLE_ASSERT);
    print("Basic.VISUALIZE_MEMORY_DEBUGGER   = %\n", Basic_ns.VISUALIZE_MEMORY_DEBUGGER);
    print("Basic.TEMP_ALLOCATOR_POISON_FREED_MEMORY = %\n",
        Basic_ns.TEMP_ALLOCATOR_POISON_FREED_MEMORY);
}


// ----------------------------------------------------------------------------
// 1103. @notes on struct members.
// ----------------------------------------------------------------------------

PE11_Annotated :: struct {
    id:    int;     @primary_key @serialize
    name:  string;  @serialize @max_length=128
    score: float;   @hidden
    other: int;
}

test_extras_11_1103_notes :: () {
    section("1103. @notes on struct members");

    info := type_info(PE11_Annotated);
    for info.members {
        if it.notes.count == 0 {
            print("  member '%' has no notes\n", it.name);
        } else {
            print("  member '%' notes:\n", it.name);
            for it.notes  print("    @%\n", it);
        }
    }
}


// ----------------------------------------------------------------------------
// 1104. Extended operator precedence + associativity.
// ----------------------------------------------------------------------------
// A wider table than the one in extras 10.

test_extras_11_1104_precedence :: () {
    section("1104. Extended operator precedence");

    sub("Unary operators");
    print("--5 = % (double negation)\n", - -5);
    print("!!true = %\n", !!true);
    print("~0xFF as u8 = %\n", ~cast(u8) 0xFF);

    sub("Member access binds tighter than unary");
    v := V2.{3, -4};
    print("-v.x = %\n", -v.x);
    print("-v.y = %\n", -v.y);

    sub("Subscript binds tight");
    a := int.[1, 2, 3, 4];
    print("a[0] + a[1] = %\n", a[0] + a[1]);
    print("a[1+1]      = %\n", a[1+1]);

    sub("Comparison chain returns bool not number");
    x_cmp := 5 < 10;
    print("type_of(5 < 10) = %\n", type_of(x_cmp));

    sub("Assignment is a statement, not expression");
    // (so we can't write `y := (z = 5);`)
    z := 5;
    print("z = %\n", z);

    sub("Mixed bitwise + comparison");
    print("0x0F & 0x33 == 0x03 -> %\n", 0x0F & 0x33 == 0x03);

    sub("Right-associativity? Most binary ops are left-assoc");
    print("100 - 50 - 25 = % (expect 25, left-assoc)\n", 100 - 50 - 25);
    print("100 / 5 / 2   = % (expect 10, left-assoc)\n", 100 / 5 / 2);
    print("1 << 1 << 2   = % (expect 8 if left-assoc)\n", 1 << 1 << 2);

    sub("Comparison non-associativity");
    // (Each comparison is a separate boolean)
    print("(1 < 2) == (3 < 4) = %\n", (1 < 2) == (3 < 4));
    print("(1 < 2) != (3 > 4) = %\n", (1 < 2) != (3 > 4));

    sub("Mixing all four operator classes");
    print("1 + 2 << 3 | 4 & 5 == 6 = %\n", 1 + 2 << 3 | 4 & 5 == 6);
    print("(((1 + 2) << 3) | (4 & 5)) == 6 = %\n", (((1 + 2) << 3) | (4 & 5)) == 6);
}


// ----------------------------------------------------------------------------
// 1105. Struct and array assignment / copy semantics.
// ----------------------------------------------------------------------------

PE11_Bag :: struct { a: int; b: int; c: int; }

test_extras_11_1105_copy :: () {
    section("1105. struct / array assignment copy");

    sub("Struct assignment copies");
    s1 := PE11_Bag.{1, 2, 3};
    s2 := s1;
    s2.a = 99;
    print("s1=% s2=% (s1 unchanged after mutating s2)\n", s1, s2);

    sub("Fixed array assignment copies");
    a1: [4] int;
    for i: 0..3  a1[i] = i;
    a2 := a1;
    a2[0] = 99;
    print("a1=% a2=% (a1 unchanged)\n", a1, a2);

    sub("Array view does NOT copy - it's a (data, count) pair");
    src := int.[10, 20, 30];
    v1: [] int = src;
    v2 := v1;
    // v2.data and v1.data point at the same memory
    v2.count = 1;
    print("v1.count=% v2.count=% (mutating one view's count does not affect the other)\n",
        v1.count, v2.count);

    sub("Resizable array assignment copies the count/data/allocator but not the underlying memory");
    ra: [..] int;
    for i: 1..5  array_add(*ra, i);
    rb := ra;
    print("ra.count=% rb.count=% (both views over same data)\n", ra.count, rb.count);
    // We do NOT array_add to either after the alias, to avoid invalidation.
}


// ----------------------------------------------------------------------------
// 1106. Compile-time constant folding sanity.
// ----------------------------------------------------------------------------

PE11_CT_INT    :: 1 + 2 * 3;       // 7
PE11_CT_FLOAT  :: 1.0 / 3.0;       // ~0.333..
PE11_CT_BOOL   :: 1 < 2 && 3 < 4;  // true
PE11_CT_STRING :: "abc";           // "abc"
PE11_CT_LEN    :: #run -> int { return PE11_CT_STRING.count + 0; };

test_extras_11_1106_const_folding :: () {
    section("1106. Compile-time constant folding");

    print("PE11_CT_INT    = %\n", PE11_CT_INT);
    print("PE11_CT_FLOAT  = %\n", PE11_CT_FLOAT);
    print("PE11_CT_BOOL   = %\n", PE11_CT_BOOL);
    print("PE11_CT_STRING = '%'\n", PE11_CT_STRING);
    print("PE11_CT_LEN    = %\n", PE11_CT_LEN);

    #assert PE11_CT_INT == 7;
    #assert PE11_CT_BOOL;
    print("compile-time assertions held\n");
}


// ----------------------------------------------------------------------------
// 1107. ifx then-else as a value-producing expression.
// ----------------------------------------------------------------------------

test_extras_11_1107_ifx :: () {
    section("1107. ifx expression form (extended)");

    pick :: (which: int, a: int, b: int, c: int) -> int {
        return ifx which == 0 then a
               else (ifx which == 1 then b else c);
    }

    for w: int.[0, 1, 2] {
        print("  pick(% , 10, 20, 30) = %\n", w, pick(w, 10, 20, 30));
    }

    sub("ifx without then/else used to abbreviate (a ? b : c) semantics");
    sign :: (n: int) -> int {
        return ifx n > 0 then 1 else ifx n == 0 then 0 else -1;
    }
    for n: int.[-5, -1, 0, 1, 5]  print("  sign(%) = %\n", n, sign(n));
}


// ----------------------------------------------------------------------------
// 1108. Default args at the call site.
// ----------------------------------------------------------------------------

PE11_with_defaults :: (a: int, b: int = 10, c: string = "default", d: bool = true) -> string {
    return tprint("a=%, b=%, c='%', d=%", a, b, c, d);
}

test_extras_11_1108_defaults :: () {
    section("1108. Procedure default arguments");

    print("%\n", PE11_with_defaults(1));
    print("%\n", PE11_with_defaults(1, 2));
    print("%\n", PE11_with_defaults(1, 2, "x"));
    print("%\n", PE11_with_defaults(1, 2, "x", false));

    sub("Named args reordering");
    print("%\n", PE11_with_defaults(d=false, a=1));
    print("%\n", PE11_with_defaults(1, c="explicit"));
    print("%\n", PE11_with_defaults(a=1, b=2, d=false));
}


run_extras_11 :: () {
    test_extras_11_1100_xx();
    test_extras_11_1101_add_context();
    test_extras_11_1102_module_parameters();
    test_extras_11_1103_notes();
    test_extras_11_1104_precedence();
    test_extras_11_1105_copy();
    test_extras_11_1106_const_folding();
    test_extras_11_1107_ifx();
    test_extras_11_1108_defaults();
}


// ============================================================================
// Compile-time error tests. The block below is an embedded metaprogram. At
// compile time it spawns one sub-workspace per snippet so the host compiler
// emits diagnostics for each. Each test is a complete program supposed to
// produce at least one Error / Warning / Info diagnostic.
// ============================================================================

// ============================================================================
// reference Jai compiler-error catalog (single-file metaprogram).
//
// This file is a Jai metaprogram. Compile it normally:
//
//     jai compile_errors_meta.jai
//
// It does NOT produce any executable. Instead, for each entry in TESTS below,
// it spins up a sub-workspace, prints a header, and feeds the snippet to the
// compiler. The compiler's diagnostics get printed to stderr, framed by our
// own "TEST N: ..." headers (which also go to stderr so the ordering matches).
//
// The metaprogram resets each failing workspace's status back to .OK so that
// the overall compile still exits cleanly. The reference agent should compile
// this file and capture stderr.
// ============================================================================


Test :: struct {
    name:   string;
    source: string;
}

// All test sources are complete programs. Put them at column 0 so the
// #string body lays out cleanly. Each test is supposed to produce at least
// one Error, Warning, or Info diagnostic. A handful end with a successful
// compile to demonstrate the no-diagnostic case.

TESTS :: Test.[

// ===========================================================================
// SECTION A. Undeclared / declaration errors.
// ===========================================================================

.{ "undeclared identifier", #string SRC
#import "Basic";
main :: () {
    print("%\n", does_not_exist);
}
SRC},

.{ "undeclared type", #string SRC
#import "Basic";
main :: () {
    x: Made_Up_Type;
}
SRC},

.{ "redeclaration of local", #string SRC
#import "Basic";
main :: () {
    x := 1;
    x := 2;
}
SRC},

.{ "redeclaration of constant", #string SRC
#import "Basic";
N :: 1;
N :: 2;
main :: () { }
SRC},

.{ "redeclaration of struct", #string SRC
#import "Basic";
S :: struct { a: int; }
S :: struct { b: int; }
main :: () {
    s: S;
}
SRC},

.{ "redeclaration of procedure (same signature)", #string SRC
#import "Basic";
f :: () { print("a\n"); }
f :: () { print("b\n"); }
main :: () { f(); }
SRC},

.{ "use of variable before declaration in block scope", #string SRC
#import "Basic";
main :: () {
    print("%\n", later);
    later := 5;
}
SRC},

.{ "shadowing a constant with mismatched type (use after)", #string SRC
#import "Basic";
N :: "hello";
main :: () {
    N := 5;
    n2: string = N;
}
SRC},

// ===========================================================================
// SECTION B. Type mismatches and numeric range.
// ===========================================================================

.{ "string = int", #string SRC
#import "Basic";
main :: () {
    s: string = 42;
}
SRC},

.{ "bool = int", #string SRC
#import "Basic";
main :: () {
    b: bool = 1;
}
SRC},

.{ "int = string", #string SRC
#import "Basic";
main :: () {
    n: int = "hi";
}
SRC},

.{ "float = string", #string SRC
#import "Basic";
main :: () {
    f: float = "hi";
}
SRC},

.{ "*int = int", #string SRC
#import "Basic";
main :: () {
    p: *int = 0;
}
SRC},

.{ "u8 = 256", #string SRC
#import "Basic";
main :: () { x: u8 = 256; }
SRC},

.{ "u8 = -1", #string SRC
#import "Basic";
main :: () { x: u8 = -1; }
SRC},

.{ "u16 = 65536", #string SRC
#import "Basic";
main :: () { x: u16 = 65536; }
SRC},

.{ "u32 = -1", #string SRC
#import "Basic";
main :: () { x: u32 = -1; }
SRC},

.{ "s8 = 128", #string SRC
#import "Basic";
main :: () { x: s8 = 128; }
SRC},

.{ "s8 = -129", #string SRC
#import "Basic";
main :: () { x: s8 = -129; }
SRC},

.{ "s16 = 40000", #string SRC
#import "Basic";
main :: () { x: s16 = 40000; }
SRC},

.{ "assigning u32 to u16 (narrowing without cast)", #string SRC
#import "Basic";
main :: () {
    a: u32 = 5;
    b: u16 = a;
}
SRC},

.{ "assigning s32 to u32 (signed to unsigned without cast)", #string SRC
#import "Basic";
main :: () {
    a: s32 = 5;
    b: u32 = a;
}
SRC},

.{ "assigning *u8 to *s8", #string SRC
#import "Basic";
main :: () {
    a: u8 = 0;
    p: *s8 = *a;
}
SRC},

.{ "assigning *int to *float", #string SRC
#import "Basic";
main :: () {
    a: int = 0;
    p: *float = *a;
}
SRC},

.{ "compile-time cast s8 = cast(s8) 1000", #string SRC
#import "Basic";
main :: () { x: s8 = cast(s8) 1000; }
SRC},

.{ "compile-time cast u8 = cast(u8) -1", #string SRC
#import "Basic";
main :: () { x: u8 = cast(u8) -1; }
SRC},

.{ "compile-time cast u16 = cast(u16) 100_000", #string SRC
#import "Basic";
main :: () { x: u16 = cast(u16) 100_000; }
SRC},

.{ "cast string to int", #string SRC
#import "Basic";
main :: () {
    s := "abc";
    n: int = cast(int) s;
}
SRC},

.{ "cast int to string", #string SRC
#import "Basic";
main :: () {
    n: int = 5;
    s: string = cast(string) n;
}
SRC},

// ===========================================================================
// SECTION C. Procedure calls.
// ===========================================================================

.{ "too few arguments", #string SRC
#import "Basic";
main :: () {
    f :: (a: int, b: int) -> int { return a + b; }
    _ := f(1);
}
SRC},

.{ "too many arguments", #string SRC
#import "Basic";
main :: () {
    f :: (a: int) -> int { return a; }
    _ := f(1, 2);
}
SRC},

.{ "no arguments to procedure that wants one", #string SRC
#import "Basic";
main :: () {
    f :: (a: int) -> int { return a; }
    _ := f();
}
SRC},

.{ "named argument that does not exist", #string SRC
#import "Basic";
main :: () {
    f :: (a: int, b: int) -> int { return a + b; }
    _ := f(a=1, zzz=2);
}
SRC},

.{ "named argument supplied twice", #string SRC
#import "Basic";
main :: () {
    f :: (a: int, b: int) -> int { return a + b; }
    _ := f(a=1, a=2);
}
SRC},

.{ "argument type mismatch", #string SRC
#import "Basic";
main :: () {
    f :: (x: int) -> int { return x; }
    _ := f("hi");
}
SRC},

.{ "wrong return arity (too few)", #string SRC
#import "Basic";
main :: () {
    f :: () -> (int, int) { return 1; }
    a, b := f();
}
SRC},

.{ "wrong return arity (too many)", #string SRC
#import "Basic";
main :: () {
    f :: () -> int { return 1, 2; }
    _ := f();
}
SRC},

.{ "missing return value (warning)", #string SRC
#import "Basic";
main :: () {
    f :: () -> int { }
    _ := f();
}
SRC},

.{ "returning wrong type", #string SRC
#import "Basic";
main :: () {
    f :: () -> int { return "hi"; }
    _ := f();
}
SRC},

.{ "default arg uses non-constant value", #string SRC
#import "Basic";
main :: () {
    x := 5;
    f :: (a := x) -> int { return a; }
    _ := f();
}
SRC},

.{ "destructuring fewer than returns from a multi-return proc - implicit drop is OK; this version uses too many lhs", #string SRC
#import "Basic";
main :: () {
    f :: () -> (int, int) { return 1, 2; }
    a, b, c := f();
}
SRC},

// ===========================================================================
// SECTION D. Constants and reassignment.
// ===========================================================================

.{ "reassign local constant", #string SRC
#import "Basic";
main :: () {
    PI :: 3.14;
    PI = 4.0;
}
SRC},

.{ "reassign global constant", #string SRC
#import "Basic";
N :: 7;
main :: () {
    N = 8;
}
SRC},

.{ "take address of a non-storage constant", #string SRC
#import "Basic";
N :: 7;
main :: () {
    p := *N;
}
SRC},

.{ "take address of an integer literal", #string SRC
#import "Basic";
main :: () {
    p := *42;
}
SRC},

.{ "take address of a temporary expression", #string SRC
#import "Basic";
main :: () {
    p := *(1 + 2);
}
SRC},

.{ "take address of a string literal value", #string SRC
#import "Basic";
main :: () {
    p := *"hello";
}
SRC},

// ===========================================================================
// SECTION E. Pointers and dereferencing.
// ===========================================================================

.{ "dereference a non-pointer", #string SRC
#import "Basic";
main :: () {
    x := 5;
    y := x.*;
}
SRC},

.{ "dereference a string", #string SRC
#import "Basic";
main :: () {
    s := "hi";
    y := s.*;
}
SRC},

.{ "dereference a struct value", #string SRC
#import "Basic";
S :: struct { a: int; }
main :: () {
    s: S;
    y := s.*;
}
SRC},

.{ "compile-time cast pointer to int (without bit_cast)", #string SRC
