== 403. FormatInt: extreme bases (3, 7, 36)
----------------------------------------------------------------
base 3 of 1000         : 1101001
base 7 of 1000         : 2626
base 36 of 1000        : rs
base 36 of 35          : z
base 36 of 36          : 10
base 36 of 9999        : 7pr

----------------------------------------------------------------
== 404. FormatFloat: DECIMAL/SCIENTIFIC/SHORTEST
----------------------------------------------------------------
default                : 1234567.89
DECIMAL                : 1234567.89
SCIENTIFIC             : 1.234568e+06
SHORTEST               : 1.23457e+06

-- Same modes on small number
default                : 0.000125
DECIMAL                : 0.000125
SCIENTIFIC             : 1.25e-04
SHORTEST               : 0.000125

-- On zero
DECIMAL                : 0
SCIENTIFIC             : 0e+00
SHORTEST               : 0

-- On negative
DECIMAL                : -3.14
SCIENTIFIC             : -3.14e+00
SHORTEST               : -3.14

----------------------------------------------------------------
== 405. FormatFloat: width and trailing_width
----------------------------------------------------------------
default                : [3.141593]
width=10 trail=2       : [      3.14]
width=10 trail=4       : [    3.1416]
width=10 trail=6       : [  3.141593]
width=10 trail=0       : [         3]
width=4  trail=3       : [3.142]

-- Trailing width on integer-valued float
1.0  trail=3           : [1    ]
0.0  trail=4           : [0     ]
10.0 trail=2           : [10   ]

----------------------------------------------------------------
== 406. FormatFloat: Zero_Removal
----------------------------------------------------------------
YES (default)          : [1.5     ]
NO                     : [1.500000]
ONE_ZERO_AFTER_DECIMAL : [1.5     ]

-- Integer value with trailing
7.0 YES                : [7       ]
7.0 NO                 : [7.000000]
7.0 ONE_ZERO           : [7.0     ]

----------------------------------------------------------------
== 407. FormatFloat: positive_number_prefix
----------------------------------------------------------------
NONE  on positive      : [3.5]
PLUS  on positive      : [+3.5]
SPACE on positive      : [ 3.5]

-- Same prefix on negative
NONE  on negative      : [-3.5]
PLUS  on negative      : [-3.5]
SPACE on negative      : [-3.5]

-- On zero
NONE  on zero          : [0]
PLUS  on zero          : [+0]
SPACE on zero          : [ 0]

----------------------------------------------------------------
== 408. FormatFloat: separator characters
----------------------------------------------------------------
thousands ','          : 1,234,567.89
thousands '_'          : 1_234_567.89
thousands ' '          : 1 234 567.89
thousands '.'          : 1.234.567.89

-- decimal_separator_character
decimal '.'            : 12.5
decimal ','            : 12,5
decimal ':'            : 12:5

-- exponent_character (scientific)
exp 'e'                : 1.2345e+04
exp 'E'                : 1.2345E+04
exp '@'                : 1.2345@+04

----------------------------------------------------------------
== 409. FormatStruct: short vs long form
----------------------------------------------------------------
default Triple         : {1, 2, 3}
default Six            : {f1 = 10; f2 = 20; f3 = 30; f4 = 40; f5 = 50; f6 = 60; }

-- Force long form (threshold = -1)
long  Triple           : {a = 1; b = 2; c = 3; }
long0 Triple           : {a = 1; b = 2; c = 3; }

-- Force long form on Six
long Six               : {f1 = 10; f2 = 20; f3 = 30; f4 = 40; f5 = 50; f6 = 60; }

-- Threshold above member count keeps short form
short Six              : {10, 20, 30, 40, 50, 60}

