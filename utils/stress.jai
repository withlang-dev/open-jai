== 605. PE6_Box/Pair/Triple/Quad
----------------------------------------------------------------

-- PE6_Box(T)
  box-int   = {10}
  box-float = {2.5}
  box-str   = {"hello"}
  box-vec3  = {{1, 2, 3}}
  type box-int    = PE6_Box(T=s64)
  type box-vec3   = PE6_Box(T=PE6_Vec3)

-- Pair(A,B)
  pair int+str = {1, "one"}
  pair flt+flt = {1.5, 2.5}
  pair v2+v3   = {{1, 2}, {3, 4, 5}}

-- Triple(A,B,C)
  triple = {1, 2.5, "three"}
  triple2 = {"lbl", {0, 1}, BLUE}

-- Quad(A,B,C,D)
  quad uints = {1, 2, 3, 4}
  quad enums = {RED, WED, NORTH, FULL}

----------------------------------------------------------------
== 605a. Map(K,V,CAP)
----------------------------------------------------------------

-- Map(int,string,4)
  put 1=one: ok=true, count=1
  put 2=two: ok=true, count=2
  put 3=three: ok=true, count=3
  put 4=four: ok=true, count=4
  put 5=five (overflow): ok=false, count=4
  get 2: 'two' found=true
  get 7: '' found=false
  put 2=TWO (update): ok=true, count=4
  get 2: 'TWO' found=true
  remove 3: ok=true, count=3
  remove 99: ok=false, count=3
    slot[0]: key=1 val=one
    slot[1]: key=2 val=TWO
    slot[2]: key=4 val=four

-- Map(string,int,4)
  get 'b' = 2 found=true
  get 'z' = 0 found=false
  count = 3

----------------------------------------------------------------
== 605b. Stack(T,CAP)
----------------------------------------------------------------

-- Stack(int,4)
  push 10: ok=true count=1
  push 20: ok=true count=2
  push 30: ok=true count=3
  push 40: ok=true count=4
  push 50: ok=false count=4
  peek -> 40 has=true
  pop -> 40 ok=true count=3
  pop -> 30 ok=true count=2
  pop -> 20 ok=true count=1
  pop -> 10 ok=true count=0
  pop -> 0 ok=false count=0

-- Stack(string,3)
  pop -> c ok=true
  pop -> b ok=true
  pop -> a ok=true

----------------------------------------------------------------
== 605c. Queue(T,CAP)
----------------------------------------------------------------

-- Queue(int,4) FIFO
  push 1: ok=true count=1
  push 2: ok=true count=2
  push 3: ok=true count=3
  push 4: ok=true count=4
  push 5 (overflow): ok=false count=4
  pop -> 1 taken=true count=3
  pop -> 2 taken=true count=2
  pop -> 3 taken=true count=1
  pop -> 4 taken=true count=0
  pop empty -> 0 taken=false

-- Queue(int,3) wrap around
  popped 100
  pop -> 200 taken=true
  pop -> 300 taken=true
  pop -> 400 taken=true

----------------------------------------------------------------
== 605d. Ring(T,CAP)
----------------------------------------------------------------

-- Ring(int,4) accepts overflow by overwriting oldest
  wrote 1: cursor=1 count=1
  wrote 2: cursor=2 count=2
  wrote 3: cursor=3 count=3
  wrote 4: cursor=0 count=4
  wrote 5: cursor=1 count=4
  wrote 6: cursor=2 count=4
  age 0: 6 ok=true
  age 1: 5 ok=true
  age 2: 4 ok=true
  age 3: 3 ok=true
  age 4 (out): 0 ok=false

