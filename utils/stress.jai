// ============================================================================
// 219. #insert: generate struct definitions from a list of names.
// ============================================================================

VEC_AXES :: string.["X", "Y", "Z", "W"];

#insert -> string {
    builder: String_Builder;
    append(*builder, "Synthetic_Vec :: struct {\n");
    for axis: VEC_AXES {
        print_to_builder(*builder, "    %: float;\n", axis);
    }
    append(*builder, "}\n");
    return builder_to_string(*builder);
}

#insert -> string {
    // Generate sum function over the struct fields.
    builder: String_Builder;
    append(*builder, "synthetic_sum :: (v: Synthetic_Vec) -> float {\n");
    append(*builder, "    return ");
    for axis, i: VEC_AXES {
        if i > 0  append(*builder, " + ");
        print_to_builder(*builder, "v.%", axis);
    }
    append(*builder, ";\n}\n");
    return builder_to_string(*builder);
}

test_compile_time_structs :: () {
    section("219. #insert: generate struct definitions");

    v: Synthetic_Vec;
    v.X = 1.0;
    v.Y = 2.0;
    v.Z = 3.0;
    v.W = 4.0;
    print("X=%, Y=%, Z=%, W=%\n", v.X, v.Y, v.Z, v.W);
    print("synthetic_sum(v) = %\n", synthetic_sum(v));

    sub("size of generated struct = 4*size_of(float)");
    print("size_of(Synthetic_Vec) = %\n", size_of(Synthetic_Vec));
    print("expected               = %\n", 4 * size_of(float));
}


// ============================================================================
// 220. Templated PE3_Ring_Buffer(T, CAP) container.
// ============================================================================

PE3_Ring_Buffer :: struct(T: Type, $CAP: int) {
    buffer: [CAP] T;
    head:   int;     // next write
    tail:   int;     // next read
    count:  int;
}

PE3_ring_push :: (rb: *$R/PE3_Ring_Buffer, value: R.T) -> bool {
    if rb.count >= R.CAP  return false;
    rb.buffer[rb.head] = value;
    rb.head = (rb.head + 1) % R.CAP;
    rb.count += 1;
    return true;
}

PE3_ring_pop :: (rb: *$R/PE3_Ring_Buffer) -> (value: R.T, ok: bool) {
    if rb.count <= 0 {
        empty: R.T;
        return empty, false;
    }
    v := rb.buffer[rb.tail];
    rb.tail = (rb.tail + 1) % R.CAP;
    rb.count -= 1;
    return v, true;
}

ring_peek :: (rb: *$R/PE3_Ring_Buffer) -> (value: R.T, ok: bool) {
    if rb.count <= 0 {
        empty: R.T;
        return empty, false;
    }
    return rb.buffer[rb.tail], true;
}

ring_size :: (rb: *$R/PE3_Ring_Buffer) -> int {
    return rb.count;
}

PE3_test_ring_buffer :: () {
    section("220. PE3_Ring_Buffer(T, CAP) templated container");

    rb: PE3_Ring_Buffer(int, 4);

    print("initial size = %\n", ring_size(*rb));

    for x: int.[10, 20, 30, 40] {
        ok := PE3_ring_push(*rb, x);
        print("push % ok=% size=%\n", x, ok, ring_size(*rb));
    }
    overflow := PE3_ring_push(*rb, 99);
    print("push when full -> ok=% size=%\n", overflow, ring_size(*rb));

    sub("pop in order");
    while true {
        v, ok := PE3_ring_pop(*rb);
        if !ok  break;
        print("  popped %  size=%\n", v, ring_size(*rb));
    }

    sub("Mix push/pop to wrap around");
    rb2: PE3_Ring_Buffer(int, 3);
    PE3_ring_push(*rb2, 1);
    PE3_ring_push(*rb2, 2);
    v1, _ := PE3_ring_pop(*rb2);
    PE3_ring_push(*rb2, 3);
    PE3_ring_push(*rb2, 4);
    print("first pop=%\n", v1);
    while true {
        v, ok := PE3_ring_pop(*rb2);
        if !ok  break;
        print("  popped %\n", v);
    }

    sub("PE3_Ring_Buffer(string, 2)");
    rs: PE3_Ring_Buffer(string, 2);
    PE3_ring_push(*rs, "hello");
    PE3_ring_push(*rs, "world");
    s1, _ := PE3_ring_pop(*rs);
    s2, _ := PE3_ring_pop(*rs);
    print("s1='%' s2='%'\n", s1, s2);
}


// ============================================================================
// 221. enum_flags ops: ALL/NONE/popcount.
// ============================================================================

File_Caps :: enum_flags u32 {
    READ      :: 0x01;
    WRITE     :: 0x02;
    EXEC      :: 0x04;
    APPEND    :: 0x08;
    CREATE    :: 0x10;
    TRUNCATE  :: 0x20;
    HIDDEN    :: 0x40;
    SYSTEM    :: 0x80;
}

count_set_flags :: (v: File_Caps) -> int {
    bits := cast(u32) v;
    n := 0;
    while bits != 0 {
        if bits & 1  n += 1;
        bits >>= 1;
    }
    return n;
}

test_enum_flags_ops :: () {
    section("221. enum_flags ops: ALL/NONE/popcount/etc.");

    ALL_FLAGS :: File_Caps.READ | .WRITE | .EXEC | .APPEND | .CREATE | .TRUNCATE | .HIDDEN | .SYSTEM;
    NONE_FLAGS :: cast(File_Caps) 0;

    print("ALL  = 0x%\n", formatInt(cast(u32) ALL_FLAGS, base=16));
    print("NONE = 0x%\n", formatInt(cast(u32) NONE_FLAGS, base=16));
    print("popcount(ALL)  = %\n", count_set_flags(ALL_FLAGS));
    print("popcount(NONE) = %\n", count_set_flags(NONE_FLAGS));

    sub("Add/remove flags using | and &~");
    rw := File_Caps.READ | .WRITE;
    print("rw = %\n", rw);
    print("rw popcount = %\n", count_set_flags(rw));

    rwx := rw | .EXEC;
    print("rwx = %\n", rwx);
    print("rwx popcount = %\n", count_set_flags(rwx));

    rx := rwx & ~File_Caps.WRITE;
    print("rx = %\n", rx);
    print("rx popcount = %\n", count_set_flags(rx));

    sub("flag tests");
    print("rwx has READ?  = %\n", (rwx & .READ) != 0);
    print("rwx has WRITE? = %\n", (rwx & .WRITE) != 0);
    print("rx  has WRITE? = %\n", (rx  & .WRITE) != 0);

    sub("XOR toggle");
    a := File_Caps.READ | .WRITE;
    b := File_Caps.WRITE | .EXEC;
    print("a XOR b = %  popcount=%\n", a ^ b, count_set_flags(a ^ b));
}


// ============================================================================
// 222. Bool conversions: !x, !!x, bool-from-non-bool.
// ============================================================================

test_bool_conversions :: () {
    section("222. Boolean conversion patterns");

    sub("Logical NOT");
    print("!true   = %\n", !true);
    print("!false  = %\n", !false);

    sub("Double negation as truthiness coercion");
    print("!!0           = %\n", !!0);
    print("!!1           = %\n", !!1);
    print("!!42          = %\n", !!42);
    print("!!(-1)        = %\n", !!(-1));

    sub("Conditional uses bool conversion");
    n := 5;
    if n  print("if 5 -> truthy\n");
    if !0  print("if !0 -> truthy\n");

    sub("String/data pointer truthiness via != null");
    s: string;
    print("empty string data is null? %\n", s.data == null);
    if s.data == null  print("if data == null -> matched\n");

    sub("Bool from comparison of ints/floats");
    a := 7;
    b := 5;
    print("a > b = %\n", a > b);
    print("a == b = %\n", a == b);
    print("(1.0 == 1) = %\n", 1.0 == 1);

    sub("Bool conversions for an Any");
    any_val: Any = 42;
    print("Any val type = %\n", any_val.type.type);
}


// ============================================================================
// 223. Integer division corner cases across signed/unsigned combinations.
// ============================================================================

test_int_division :: () {
    section("223. Integer division corner cases");

    sub("Signed division: signs and truncation toward zero");
    {
        a: s32 =  7; b: s32 =  3; print("  s32:  7 /  3 = %    7 mod 3  = %\n", a/b, a%b);
        a = -7;  b =  3; print("  s32: -7 /  3 = %   -7 mod 3 = %\n", a/b, a%b);
        a =  7;  b = -3; print("  s32:  7 / -3 = %    7 mod -3 = %\n", a/b, a%b);
        a = -7;  b = -3; print("  s32: -7 / -3 = %   -7 mod -3 = %\n", a/b, a%b);
    }

    sub("s64 corner cases");
    {
        a: s64 =  9_223_372_036_854_775_807; b: s64 = 2;
        print("  s64 max/2 = %\n", a/b);
        a = -9_223_372_036_854_775_807;
        print("  s64 (-(max))/2 = %\n", a/b);
    }

    sub("Unsigned division: behaves like positive math");
    {
        a: u32 =  10; b: u32 = 3;
        print("  u32: 10 / 3 = %  10 mod 3 = %\n", a/b, a%b);
        a = 4_294_967_295; b = 2;
        print("  u32-max / 2 = %\n", a/b);
        a = 1_000_000; b = 1_000_000;
        print("  u32: 1M / 1M = %\n", a/b);
    }

    sub("u64 max");
    {
        a: u64 = 0xFFFF_FFFF_FFFF_FFFF;
        b: u64 = 2;
        print("  u64-max / 2 = %\n", a/b);
        a = 0xFFFF_FFFF_FFFF_FFFF;
        b = 0xFFFF_FFFF_FFFF_FFFF;
        print("  u64-max / u64-max = %\n", a/b);
    }

    sub("u8 / s8 mixing within explicit casts");
    {
        u: u8 = 200; v: u8 = 7;
        print("  u8:   200 / 7 = %  200 mod 7 = %\n", u/v, u%v);
        s: s8 = -7;  t: s8 = 2;
        print("  s8:    -7 / 2 = %    -7 mod 2 = %\n", s/t, s%t);
    }
}


// ============================================================================
// 224. Function pointer storage in structs (no arithmetic).
// ============================================================================

Calc_Op :: #type (a: int, b: int) -> int;

op_add :: (a: int, b: int) -> int { return a + b; }
op_sub :: (a: int, b: int) -> int { return a - b; }
op_mul :: (a: int, b: int) -> int { return a * b; }
op_div :: (a: int, b: int) -> int { if b == 0 return 0; return a / b; }

Op_Entry :: struct {
    name: string;
    op:   Calc_Op;
}

test_function_pointers :: () {
    section("224. Function pointers stored in structs");

    table: [4] Op_Entry;
    table[0] = .{name="add", op=op_add};
    table[1] = .{name="sub", op=op_sub};
    table[2] = .{name="mul", op=op_mul};
    table[3] = .{name="div", op=op_div};

    a := 24;
    b := 6;
    for e: table {
        print("  %(%, %) = %\n", e.name, a, b, e.op(a, b));
    }

    sub("Procedure pointer in dynamic array");
    arr: [..] Calc_Op;
    array_add(*arr, op_add);
    array_add(*arr, op_sub);
    array_add(*arr, op_mul);
    array_add(*arr, op_div);
    print("count=%\n", arr.count);
    for arr {
        print("  arr[%](10, 4) = %\n", it_index, it(10, 4));
    }

    sub("Procedure pointer assigned then invoked");
    f: Calc_Op = op_add;
    print("f = op_add: f(3, 4) = %\n", f(3, 4));
    f = op_mul;
    print("f = op_mul: f(3, 4) = %\n", f(3, 4));
}


// ============================================================================
// 225. Print formatting edge cases: padding negative numbers, decimal width,
//      FormatStruct with newlines, FormatArray with custom separator.
// ============================================================================

Small :: struct {
    a: int = 1;
    b: int = 2;
    c: int = 3;
}

test_print_format_edge :: () {
    section("225. Print formatting edge cases");

    sub("Pad positive and negative with zero/space");
    print("[%]\n", formatInt(  7, minimum_digits=5));
    print("[%]\n", formatInt(-25, minimum_digits=5));
    print("[%]\n", formatInt( -7, minimum_digits=5, padding=#char " "));
    print("[%]\n", formatInt( 42, minimum_digits=8, padding=#char "0"));

    sub("Hex/binary");
    print("hex: %\n", formatInt(255, base=16));
    print("bin: %\n", formatInt(255, base=2));
    print("oct: %\n", formatInt(255, base=8));

    sub("Hex with comma_string");
    print("hex/4 separator '_': %\n", formatInt(0xDEAD_BEEF, base=16, digits_per_comma=4, comma_string="_"));

    sub("Float formatting");
    print("[%]\n", formatFloat(3.14159, width=10, trailing_width=2));
    print("[%]\n", formatFloat(3.14159, width=10, trailing_width=4));
    print("[%]\n", formatFloat(-2.0,    width=10, trailing_width=3));

    sub("Float with positive prefix");
    fp := FormatFloat.{value=3.14159, width=10, trailing_width=2, positive_number_prefix=.PLUS};
    print("[%]\n", fp);
    fp.positive_number_prefix = .SPACE;
    print("[%]\n", fp);

    sub("Struct in long form, with newlines");
    s := Small.{};
    fs: FormatStruct;
    fs.value = s;
    fs.use_long_form_if_more_than_this_many_members = -1;
    fs.use_newlines_if_long_form = true;
    print("%\n", fs);

    sub("Array with custom separator and brackets");
    arr := int.[10, 20, 30, 40];
    fa: FormatArray;
    fa.value = arr;
    fa.separator = " | ";
    fa.begin_string = "<<";
    fa.end_string   = ">>";
    print("%\n", fa);

    sub("Array with cap and ellipsis");
    big: [..] int;
    for i: 0..49  array_add(*big, i);
    fa2: FormatArray;
    fa2.value = big;
    fa2.stop_printing_after_this_many_elements = 5;
    print("%\n", fa2);
}


// ============================================================================
// 226. type_info for procedure types.
// ============================================================================

example_proc_1 :: (a: int, b: string) -> float { return cast(float) a + cast(float) b.count; }
example_proc_2 :: (x: int) {}
example_proc_3 :: () -> (int, int, int) { return 1, 2, 3; }
example_proc_4 :: () {}

print_proc_info :: (label: string, info: *Type_Info_Procedure) {
    print("%: args=% returns=%\n", label, info.argument_types.count, info.return_types.count);
    for info.argument_types {
        print("  arg %: %\n", it_index, type_to_string(it));
    }
    for info.return_types {
        print("  ret %: %\n", it_index, type_to_string(it));
    }
    flag_count := 0;
    if info.procedure_flags & .IS_COMPILE_TIME_ONLY  flag_count += 1;
    if info.procedure_flags & .IS_POLYMORPHIC  flag_count += 1;
    if info.procedure_flags & .HAS_NO_CONTEXT  flag_count += 1;
    if info.procedure_flags & .IS_C_CALL  flag_count += 1;
    if info.procedure_flags & .IS_INTRINSIC  flag_count += 1;
    print("  flags-set-count = %\n", flag_count);
}

test_procedure_type_info :: () {
    section("226. type_info for procedure types");

    info1 := cast(*Type_Info_Procedure) type_info(type_of(example_proc_1));
    print_proc_info("example_proc_1 (int, string -> float)", info1);

    info2 := cast(*Type_Info_Procedure) type_info(type_of(example_proc_2));
    print_proc_info("example_proc_2 (int)", info2);

    info3 := cast(*Type_Info_Procedure) type_info(type_of(example_proc_3));
    print_proc_info("example_proc_3 (-> 3 ints)", info3);

    info4 := cast(*Type_Info_Procedure) type_info(type_of(example_proc_4));
    print_proc_info("example_proc_4 (void)", info4);
}


