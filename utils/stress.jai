    for items  print("    id=% w=%\n", it.id, it.weight);
}


// ----------------------------------------------------------------------------
// 911. Deterministic checksum over a known byte sequence.
// ----------------------------------------------------------------------------

simple_fnv1a_64 :: (data: [] u8) -> u64 {
    h: u64 = 0xcbf29ce484222325;
    for b: data {
        h ^= cast(u64) b;
        h *= 0x100000001b3;
    }
    return h;
}

test_extras_9_911_checksums :: () {
    section("911. FNV-1a 64-bit checksum (no addresses)");

    inputs := string.["", "a", "ab", "abc", "hello", "Hello, World!",
                      "The quick brown fox jumps over the lazy dog"];

    for s: inputs {
        h := simple_fnv1a_64(cast([]u8) s);
        print("  fnv1a('%') = 0x%\n", s,
            formatInt(h, base=16, minimum_digits=16));
    }
}


// ----------------------------------------------------------------------------
// 912. Sieve of Eratosthenes up to 200.
// ----------------------------------------------------------------------------

test_extras_9_912_sieve :: () {
    section("912. Sieve of Eratosthenes (primes up to 200)");

    N :: 200;
    is_composite: [N+1] bool;
    for i: 2..N {
        if is_composite[i]  continue;
        j := i * i;
        while j <= N {
            is_composite[j] = true;
            j += i;
        }
    }

    primes: [..] int;
    for i: 2..N  if !is_composite[i]  array_add(*primes, i);
    print("count of primes up to % = %\n", N, primes.count);
    print("primes: %\n", primes);
}


