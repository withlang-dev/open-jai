    x := 12a34;
    print("%\n", x);
}
SRC},

.{ "decimal number with multiple dots", #string SRC
#import "Basic";
main :: () {
    x := 1.2.3;
    print("%\n", x);
}
SRC},

.{ "0h literal with non-hex characters", #string SRC
#import "Basic";
main :: () {
    x := 0hGGGG;
    print("%\n", x);
}
SRC},

.{ "integer literal larger than s64 max", #string SRC
#import "Basic";
main :: () {
    x: s64 = 99999999999999999999;
    print("%\n", x);
}
SRC},

.{ "compile-time arithmetic overflow as constant", #string SRC
#import "Basic";
BIG :: 0x7FFF_FFFF_FFFF_FFFF * 2;
main :: () { print("%\n", BIG); }
SRC},

.{ "octal-looking literal with 9", #string SRC
#import "Basic";
