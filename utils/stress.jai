  add 10: ok=true count=1
  add 20: ok=true count=2
  add 30: ok=true count=3
  add 40: ok=true count=4
  add 50: ok=true count=5
  add 60: ok=false count=5
  [0]=10
  [1]=20
  [2]=30
  [3]=40
  [4]=50
