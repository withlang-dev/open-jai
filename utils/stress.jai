----------------------------------------------------------------
== 415b. Sign extension and zero extension
----------------------------------------------------------------

-- Negative to wider signed
s8 -1 to s16 = -1
s8 -1 to s32 = -1
s8 -1 to s64 = -1

-- Negative to wider unsigned (no_check)
s8 -1 to u16 (no_check) = 65535
s8 -1 to u32 (no_check) = 4294967295
s8 -1 to u64 (no_check) = 18446744073709551615

-- u8 max to wider signed (always zero extension)
u8 255 to s16 = 255
u8 255 to s32 = 255
u8 255 to s64 = 255

