// ----------------------------------------------------------------------------
// 714. Symbol table: Hash_Table(string, int) with many ops.
// ----------------------------------------------------------------------------

run_extras_7_symbol_table :: () {
    section("714. Symbol table (Hash_Table(string,int))");

    sym: Table(string, int);
    init(*sym);
    defer deinit(*sym);

    sub("714.a Inserts");
    names := string.["foo", "bar", "baz", "quux", "fred", "wilma", "barney", "betty",
                     "pebbles", "bambam", "dino", "alpha", "beta", "gamma", "delta"];
    for n, idx: names  table_add(*sym, n, idx * 11);

    print("  count after %.: %\n", names.count, sym.count);

    sub("714.b Finds");
    queries := string.["foo", "bar", "missing", "fred", "wilma", "delta", "unknown", "alpha"];
    for q: queries {
        ok, v := table_find(*sym, q);
        print("  find '%' -> ok=% v=%\n", q, ok, v);
    }

    sub("714.c Sorted iteration");
    keys: [..] string;
    for v, k: sym  array_add(*keys, k);
    PE7_str_bubble_sort(keys);
    for keys {
        ok, v := table_find(*sym, it);
        if ok  print("  % => %\n", it, v);
    }

    sub("714.d Remove");
    to_remove := string.["bar", "fred", "dino", "alpha", "missing-x"];
    for r: to_remove {
        table_remove(*sym, r);
        print("  removed '%' (count=%)\n", r, sym.count);
    }

    sub("714.e Re-find after remove");
    for q: queries {
        ok, v := table_find(*sym, q);
        print("  find '%' -> ok=% v=%\n", q, ok, v);
    }

    sub("714.f Final sorted iteration");
    keys2: [..] string;
    for v, k: sym  array_add(*keys2, k);
    PE7_str_bubble_sort(keys2);
    for keys2 {
        ok, v := table_find(*sym, it);
        if ok  print("  % => %\n", it, v);
    }

    sub("714.g Update existing entries");
    for k: keys2 {
        // table_set updates or adds.
        table_set(*sym, k, 999);
    }
    keys3: [..] string;
    for v, k: sym  array_add(*keys3, k);
    PE7_str_bubble_sort(keys3);
    for keys3 {
        ok, v := table_find(*sym, it);
        if ok  print("  updated % => %\n", it, v);
    }
}


// ----------------------------------------------------------------------------
// 715. Finite state machine on input strings.
// ----------------------------------------------------------------------------

PE7_FSM_State :: enum u8 {
    START;
    SEEN_A;
    SEEN_AB;
    ACCEPT;
    DEAD;
}

PE7_fsm_step :: (s: PE7_FSM_State, c: u8) -> PE7_FSM_State {
    if s == .START {
        if c == #char "a" return .SEEN_A;
        return .START;
    }
    if s == .SEEN_A {
        if c == #char "b" return .SEEN_AB;
        if c == #char "a" return .SEEN_A;
        return .START;
    }
    if s == .SEEN_AB {
        if c == #char "c" return .ACCEPT;
        if c == #char "a" return .SEEN_A;
        return .START;
    }
    if s == .ACCEPT  return .ACCEPT;
    return .DEAD;
}

PE7_fsm_run :: (input: string) -> PE7_FSM_State {
    state := PE7_FSM_State.START;
    for i: 0..input.count-1 {
        state = PE7_fsm_step(state, input[i]);
    }
    return state;
}

run_extras_7_fsm :: () {
    section("715. Finite state machine recognizing 'abc' substring");

    inputs := string.[
        "abc",
        "aabc",
        "xabc",
        "ab",
        "ac",
        "ba",
        "abxc",
        "abccba",
        "aaabbbccc",
        "zzabczz",
        "ababc",
        "abab",
        "abca",
        "",
        "c",
        "abcabc",
    ];

    for s: inputs {
        result := PE7_fsm_run(s);
        print("  '%' -> %\n", s, result);
    }

    sub("715.a Step-by-step trace for 'aabcab'");
    state := PE7_FSM_State.START;
    word := "aabcab";
    print("  initial state = %\n", state);
    for i: 0..word.count-1 {
        c := word[i];
        next := PE7_fsm_step(state, c);
        print("  step %: %=>% on '%'\n", i, state, next, to_string(*c, 1));
        state = next;
    }
    print("  final = %\n", state);
}


// ----------------------------------------------------------------------------
// 716. Expression evaluator (+, -, *, /, parentheses).
// ----------------------------------------------------------------------------

PE7_Lexer :: struct {
    src: string;
    pos: int;
}

PE7_TokKind :: enum u8 {
    END;
    NUM;
    PLUS;
    MINUS;
    STAR;
    SLASH;
    LPAREN;
    RPAREN;
    BAD;
}

PE7_Tok :: struct {
    kind: PE7_TokKind;
    num: int;
}

PE7_lex_skip_space :: (lx: *PE7_Lexer) {
    while lx.pos < lx.src.count && lx.src[lx.pos] == #char " "  lx.pos += 1;
}

PE7_lex_next :: (lx: *PE7_Lexer) -> PE7_Tok {
    PE7_lex_skip_space(lx);
    if lx.pos >= lx.src.count  return PE7_Tok.{.END, 0};
    c := lx.src[lx.pos];
    if c >= #char "0" && c <= #char "9" {
        n := 0;
        while lx.pos < lx.src.count && lx.src[lx.pos] >= #char "0" && lx.src[lx.pos] <= #char "9" {
            n = n * 10 + cast(int)(lx.src[lx.pos] - #char "0");
            lx.pos += 1;
        }
        return PE7_Tok.{.NUM, n};
    }
    lx.pos += 1;
    if c == #char "+"  return PE7_Tok.{.PLUS,   0};
    if c == #char "-"  return PE7_Tok.{.MINUS,  0};
    if c == #char "*"  return PE7_Tok.{.STAR,   0};
    if c == #char "/"  return PE7_Tok.{.SLASH,  0};
    if c == #char "("  return PE7_Tok.{.LPAREN, 0};
    if c == #char ")"  return PE7_Tok.{.RPAREN, 0};
    return PE7_Tok.{.BAD, 0};
}

PE7_lex_peek :: (lx: *PE7_Lexer) -> PE7_Tok {
    save := lx.pos;
    t := PE7_lex_next(lx);
    lx.pos = save;
    return t;
}

PE7_parse_factor :: (lx: *PE7_Lexer) -> int {
    t := PE7_lex_next(lx);
    if t.kind == .NUM   return t.num;
    if t.kind == .MINUS {
        return -PE7_parse_factor(lx);
    }
    if t.kind == .LPAREN {
        v := PE7_parse_expr(lx);
        // consume ')'
        rp := PE7_lex_next(lx);
        // ignore mismatched paren
        _ = rp;
        return v;
    }
    return 0;
}

PE7_parse_term :: (lx: *PE7_Lexer) -> int {
    left := PE7_parse_factor(lx);
    while true {
        t := PE7_lex_peek(lx);
        if t.kind == .STAR {
            _ = PE7_lex_next(lx);
            right := PE7_parse_factor(lx);
            left = left * right;
        } else if t.kind == .SLASH {
            _ = PE7_lex_next(lx);
            right := PE7_parse_factor(lx);
            if right == 0  return 0;
            left = left / right;
        } else {
            break;
        }
    }
    return left;
}

PE7_parse_expr :: (lx: *PE7_Lexer) -> int {
    left := PE7_parse_term(lx);
    while true {
        t := PE7_lex_peek(lx);
        if t.kind == .PLUS {
            _ = PE7_lex_next(lx);
            right := PE7_parse_term(lx);
            left = left + right;
        } else if t.kind == .MINUS {
            _ = PE7_lex_next(lx);
            right := PE7_parse_term(lx);
            left = left - right;
        } else {
            break;
        }
    }
    return left;
}

PE7_eval :: (expr: string) -> int {
    lx := PE7_Lexer.{expr, 0};
    return PE7_parse_expr(*lx);
}

