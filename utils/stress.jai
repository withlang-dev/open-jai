-- Convert each codepoint to UTF-8 (we count bytes, not addresses)
U+0041 bytes=1 bytes-hex=41
U+007a bytes=1 bytes-hex=7a
U+00a9 bytes=2 bytes-hex=c2a9
U+03b1 bytes=2 bytes-hex=ceb1
U+20ac bytes=3 bytes-hex=e282ac
U+4e2d bytes=3 bytes-hex=e4b8ad
U+1f600 bytes=4 bytes-hex=f09f9880

-- Iterate a UTF-8 string and decode it byte-by-byte (no addresses)
input.count (bytes) = 11
  codepoint = U+0041
  codepoint = U+00a9
  codepoint = U+03b1
  codepoint = U+20ac
  codepoint = U+4e2d

-- character_utf8_to_utf32 raw bytes -> codepoints
  bytes=1 code=U+0041
  bytes=2 code=U+00a9
  bytes=2 code=U+03b1
  bytes=3 code=U+20ac
  bytes=3 code=U+4e2d

