    table_add(*t, "a", 10);
    table_add(*t, "b", 20);
    table_add(*t, "c", 30);
    table_add(*t, "d", 40);

    total := 0;
    for v, k: t  total += v;
    print("sum  = %\n", total);
    print("count= %\n", t.count);
}


