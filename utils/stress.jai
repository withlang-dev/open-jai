    ];
    counts := int.[
        type_info(PE6_Color).names.count,
        type_info(PE6_Tone).names.count,
        type_info(PE6_Day).names.count,
        type_info(PE6_Month).names.count,
        type_info(PE6_Compass).names.count,
        type_info(PE6_Phase).names.count,
        type_info(PE6_Permission).names.count,
        type_info(PE6_Capability).names.count,
        type_info(PE6_Build).names.count,
        type_info(PE6_VM_Opcode).names.count,
    ];
    sizes := int.[
        size_of(PE6_Color),
        size_of(PE6_Tone),
        size_of(PE6_Day),
        size_of(PE6_Month),
        size_of(PE6_Compass),
        size_of(PE6_Phase),
        size_of(PE6_Permission),
        size_of(PE6_Capability),
        size_of(PE6_Build),
        size_of(PE6_VM_Opcode),
