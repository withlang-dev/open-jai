    defer deinit(*t);

    inputs := string.["alpha", "beta", "gamma", "delta", "epsilon",
                      "zeta", "eta", "theta", "iota", "kappa"];

    for s, i: inputs  table_add(*t, s, i + 100);

    print("count after adds = %\n", t.count);

    sub("find each");
    for s, i: inputs {
        ok, v := table_find(*t, s);
        print("  find('%') ok=% v=% (expected %)\n", s, ok, v, i + 100);
    }

    sub("not-found");
    ok, v := table_find(*t, "MISSING");
    print("  find('MISSING') ok=% v=%\n", ok, v);

    sub("table_set updates existing");
    table_set(*t, "beta", 9999);
    ok2, v2 := table_find(*t, "beta");
    print("  after set, find('beta') ok=% v=%\n", ok2, v2);

    sub("table_remove");
    removed := table_remove(*t, "gamma");
    print("  removed 'gamma': %\n", removed);
    print("  count now      = %\n", t.count);
    ok3, v3 := table_find(*t, "gamma");
    print("  find('gamma') after remove ok=% v=%\n", ok3, v3);
}


