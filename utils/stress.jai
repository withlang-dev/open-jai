// ----------------------------------------------------------------------------
// 917. Linked list implemented with polymorphic struct + pointers.
// ----------------------------------------------------------------------------

PE9_LL_Node :: struct(T: Type) {
    value: T;
    next: *PE9_LL_Node(T);
}

PE9_ll_push_front :: (head_ptr: **PE9_LL_Node($T), v: T) {
    n := New(PE9_LL_Node(T));
    n.value = v;
    n.next  = head_ptr.*;
    head_ptr.* = n;
}

PE9_ll_print :: (head: *PE9_LL_Node($T), label: string) {
    print("  %: ", label);
    cur := head;
    while cur != null {
        print("% ", cur.value);
        cur = cur.next;
    }
    print("\n");
}

ll_count :: (head: *PE9_LL_Node($T)) -> int {
    n := 0;
    cur := head;
    while cur != null { n += 1; cur = cur.next; }
    return n;
}

test_extras_9_917_linked_list :: () {
    section("917. Polymorphic linked list");

    head_int: *PE9_LL_Node(int) = null;
    for n: 1..5  PE9_ll_push_front(*head_int, n);
    PE9_ll_print(head_int, "int list (push-front gives reverse order)");
    print("  count = %\n", ll_count(head_int));

    head_str: *PE9_LL_Node(string) = null;
    for w: string.["alpha", "beta", "gamma"]  PE9_ll_push_front(*head_str, w);
    PE9_ll_print(head_str, "str list");
    print("  count = %\n", ll_count(head_str));
}


// ----------------------------------------------------------------------------
// 918. Binary tree of ints: insert + in-order traversal.
// ----------------------------------------------------------------------------

BT_Node :: struct {
    value: int;
    left:  *BT_Node;
    right: *BT_Node;
}

bt_insert :: (root_ptr: **BT_Node, v: int) {
    if root_ptr.* == null {
        n := New(BT_Node);
        n.value = v;
        root_ptr.* = n;
        return;
    }
    if v < root_ptr.*.value  bt_insert(*root_ptr.*.left, v);
    else                     bt_insert(*root_ptr.*.right, v);
}

bt_inorder :: (root: *BT_Node) {
    if root == null  return;
    bt_inorder(root.left);
    print("% ", root.value);
    bt_inorder(root.right);
}

test_extras_9_918_bst :: () {
    section("918. Binary search tree with in-order traversal");

    root: *BT_Node = null;
    inputs := int.[5, 3, 8, 1, 4, 7, 9, 2, 6, 0];
    for v: inputs  bt_insert(*root, v);

    print("  in-order: ");
    bt_inorder(root);
    print("\n");
}


