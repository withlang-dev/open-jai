        PE6_stack_push(*st, .{value=.RED});
        PE6_stack_push(*st, .{value=.GREEN});
        PE6_stack_push(*st, .{value=.BLUE});
        for 0..st.count-1 {
            print("  [%]=%\n", it, st.data[it]);
        }
        v, ok := PE6_stack_peek(st);
