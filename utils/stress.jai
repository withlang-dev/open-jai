// ============================================================================
// 34. Defer ordering inside loops.
// ============================================================================

test_defer_loop :: () {
    section("34. Defer ordering inside loops");

    for i: 0..2 {
        defer print("  defer i=%\n", i);
        print("  body i=%\n", i);
    }
}


// ============================================================================
// 35. #procedure_of_call (extract proc from poly call).
// ============================================================================

test_procedure_of_call :: () {
    section("35. #procedure_of_call");

    // 'square_poly' is polymorphic; bake out the int version.
    square_poly :: (x: $T) -> T { return x * x; }
    p_int   :: #procedure_of_call square_poly(0);
    p_float :: #procedure_of_call square_poly(0.0);

    print("p_int(7)    = %\n", p_int(7));
    print("p_float(.5) = %\n", p_float(0.5));
    print("type_of(p_int)   = %\n", type_of(p_int));
    print("type_of(p_float) = %\n", type_of(p_float));
}


// ============================================================================
// 36. #insert (compile-time code injection).
// ============================================================================

test_insert :: () {
    section("36. #insert");

    // Build a sequence of declarations via a string.
    CODE :: #string DONE
ct_a := 1;
ct_b := 2;
ct_c := ct_a + ct_b;
DONE
    #insert CODE;
    print("ct_a=% ct_b=% ct_c=%\n", ct_a, ct_b, ct_c);
}


// ============================================================================
// 37. SOA via #place (overlay struct-of-arrays).
// ============================================================================

XYZ :: struct {
    x: float;
    y: float;
    z: float;
}

test_place :: () {
    section("37. #overlay (memory alias of struct fields)");

    // Two views over the same memory using #overlay. The fields x/y/z
    // alias the same storage as r/g/b.
    Color3 :: struct {
        r, g, b: float;

        #overlay (r) x: float = ---;
        #overlay (g) y: float = ---;
        #overlay (b) z: float = ---;
    }

    c: Color3;
    c.x = 1; c.y = 2; c.z = 3;
    print("via rgb: r=% g=% b=%\n", c.r, c.g, c.b);
    print("via xyz: x=% y=% z=%\n", c.x, c.y, c.z);
}


// ============================================================================
// 38. Procedure types as struct fields (callbacks).
// ============================================================================

Comparator :: #type (a: int, b: int) -> int;

ascending  :: (a: int, b: int) -> int { return a - b; }
descending :: (a: int, b: int) -> int { return b - a; }

simple_sort :: (arr: *[..] int, cmp: Comparator) {
    for i: 0..arr.count-2 {
        for j: 0..arr.count-2-i {
            if cmp(arr.*[j], arr.*[j+1]) > 0 {
                tmp := arr.*[j];
                arr.*[j] = arr.*[j+1];
                arr.*[j+1] = tmp;
            }
        }
    }
}

test_callbacks :: () {
    section("38. Callbacks / function-typed parameters");

    arr: [..] int;
    for n: int.[4, 1, 3, 5, 2]  array_add(*arr, n);
    print("before     : %\n", arr);

    simple_sort(*arr, ascending);
    print("ascending  : %\n", arr);

    simple_sort(*arr, descending);
    print("descending : %\n", arr);
}


// ============================================================================
// 39. ifx (expression form) and case-expression-like patterns.
// ============================================================================

test_ifx :: () {
    section("39. ifx expression form");

    sign :: (n: int) -> int { return ifx n > 0 then 1 else (ifx n < 0 then -1 else 0); };
    for n: int.[-5, 0, 7] {
        print("  sign(%) = %\n", n, sign(n));
    }
}


// ============================================================================
// 40. More math: trig, log/exp, modulo, integer division semantics.
// ============================================================================

test_math_more :: () {
    section("40. More math (extended)");

    sub("Trig identities (should be very close to expected values)");
    print("sin(PI/2)        = %\n", sin(PI/2));
    print("cos(PI)          = %\n", cos(PI));
    print("tan(PI/4)        = %\n", tan(PI/4));
    print("atan2(1,1)/PI    = %\n", atan2(1.0, 1.0) / PI);    // 1/4
    print("asin(1)/PI       = %\n", asin(1.0) / PI);          // 1/2

    sub("Exp / log");
    print("exp(1)           = %\n", exp(1.0));
    print("log(exp(2.5))    = %\n", log(exp(2.5)));   // natural log
    print("log(1000)/log(10) = %\n", log(1000.0) / log(10.0));

    sub("Floor, ceil, round");
    print("floor(2.7) = %\n", floor(2.7));
    print("ceil (2.3) = %\n", ceil (2.3));
    print("floor(-2.3) = %\n", floor(-2.3));
    print("ceil (-2.7) = %\n", ceil (-2.7));

    sub("Integer division and modulo for negative numbers");
    a := -7;
    b :=  3;
    print("-7 / 3 = % (truncates toward zero)\n", a / b);
    print("-7 mod 3 = % (sign follows dividend)\n", a % b);
    print("7 mod -3 = %\n", 7 % -3);
    print("-7 mod -3 = %\n", -7 % -3);

    sub("Min/max/clamp");
    print("min(3,7,2,9,4) = %\n", min(3, 7, 2, 9, 4));
    print("max(3,7,2,9,4) = %\n", max(3, 7, 2, 9, 4));
    print("clamp(15, 0, 10) = %\n", clamp(15, 0, 10));
    print("clamp(-5, 0, 10) = %\n", clamp(-5, 0, 10));
    print("clamp(5,  0, 10) = %\n", clamp(5,  0, 10));
}


// ============================================================================
// 41. Sort module
// ============================================================================


test_sort :: () {
    section("41. Sort module: quick_sort, bubble_sort");

    nums: [..] int;
    for n: int.[5, 2, 8, 1, 9, 3, 7, 4, 6]  array_add(*nums, n);

    quick_sort(nums, (a: int, b: int) -> int { return a - b; });
    print("quick_sort ascending : %\n", nums);

    quick_sort(nums, (a: int, b: int) -> int { return b - a; });
    print("quick_sort descending: %\n", nums);

    sub("sort with custom comparator (by string length)");
    words: [..] string;
    for s: string.["pear", "fig", "blueberry", "kiwi"]  array_add(*words, s);
    quick_sort(words, (a: string, b: string) -> int { return a.count - b.count; });
    print("by length: %\n", words);
}


