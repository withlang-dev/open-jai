        s, p, mn, mx := 0, 1, a[0], a[0];
        for a {
            s += it;
            p *= it;
            if it < mn  mn = it;
            if it > mx  mx = it;
        }
        print("  count=% sum=% prod=% min=% max=%\n", a.count, s, p, mn, mx);
    }

    sub("[] int via fixed-array conversion");
    {
        fa := int.[5, 3, 9, 1, 7];
        av: [] int = fa;
        s := 0;
        for av  s += it;
        print("  view count=% sum=%\n", av.count, s);
    }

    sub("[N] float");
