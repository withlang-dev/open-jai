// ----------------------------------------------------------------------------
// 771. Bigger Hash_Table stress: hash int values.
// ----------------------------------------------------------------------------

run_extras_7_int_table_stress :: () {
    section("771. Hash_Table(int,int) stress");

    t: Table(int, int);
    init(*t);
    defer deinit(*t);

    // Insert 1..30 -> square
    for i: 1..30  table_add(*t, i, i*i);

    sub("771.a Count");
    print("  count=%\n", t.count);

    sub("771.b Find all expected");
    for i: 1..30 {
        ok, v := table_find(*t, i);
        print("  find(%) ok=% v=%\n", i, ok, v);
    }

    sub("771.c Find missing");
    for i: int.[0, 31, 100, -5] {
        ok, v := table_find(*t, i);
        print("  find(%) ok=% v=%\n", i, ok, v);
    }

    sub("771.d Remove every 3rd");
    for i: 1..30  if i % 3 == 0  table_remove(*t, i);
    print("  count after = %\n", t.count);

    sub("771.e Verify removal");
    for i: 1..30 {
        ok, v := table_find(*t, i);
        if !ok  print("  removed %\n", i);
        else    print("  still %=%\n", i, v);
    }
}


