----------------------------------------------------------------
== 1001. Operator precedence matrix
----------------------------------------------------------------

-- Arithmetic precedence
1 + 2 * 3        = 7  (expect 7)
(1 + 2) * 3      = 9  (expect 9)
8 / 2 / 2        = 2  (left-assoc, expect 2)
8 / (2 / 2)      = 8  (expect 8)
2 + 3 * 4 - 1    = 13  (expect 13)
-2 + 3           = 1  (unary minus)
-(2 + 3)         = -5
2 * -3           = -6
10 mod 3 * 2     = 4  (mod tighter than mul? expect 2)

-- Shift vs arithmetic
1 << 2 + 3       = 7  (expect 32)
(1 << 2) + 3     = 7  (expect 7)
8 >> 1 + 1       = 5  (expect 2)

-- Bitwise vs arithmetic
1 | 2 + 4        = 7  (expect 7)
0b1010 & 0b1100  = 8  (expect 8)
0b1010 ^ 0b0101  = 15  (expect 15)
1 | 2 & 4        = 0  (& tighter than |, expect 1)

-- Comparison and logical
1 < 2 && 3 < 4   = true
1 < 2 || 5 < 3   = true
!(1 < 2)         = false
1 + 2 == 3       = true
1 == 2 || 3 == 3 = true

-- Short-circuit vs arithmetic
true && (1 + 2)  truthy? = true
false || (1 + 2) truthy? = true

-- Member access vs unary
p.x + p.y          = 7
-(p.x + p.y)       = -7

-- Mixed precedence chain
1 + 2 * 3 << 1     = 13  (parses as ((1) + (2*3)) << 1 = 14)
1 << 2 * 3         = 12  (parses as 1 << (2*3) = 64)

