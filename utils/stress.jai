== 838. Final combination tests
----------------------------------------------------------------

-- employee card 'Engineer A'
  json:
  {"person":{"name":"Engineer A","age":,"height_cm":175,"likes_cats":true},"address":{"street":"1 Main","city":"Zenith","zip":"00001"},"employee_id":1,"salary":70000}
  yaml:
person: 
  name: "Engineer A"
  age: 28
  height_cm: 175
  likes_cats: true
address: 
  street: "1 Main"
  city: "Zenith"
  zip: "00001"
employee_id: 1
salary: 70000

-- employee card 'Designer B'
  json:
  {"person":{"name":"Designer B","age":,"height_cm":165,"likes_cats":false},"address":{"street":"2 Oak","city":"Nimbus","zip":"00002"},"employee_id":2,"salary":65000}
  yaml:
person: 
  name: "Designer B"
  age: 33
  height_cm: 165
  likes_cats: false
address: 
  street: "2 Oak"
  city: "Nimbus"
  zip: "00002"
employee_id: 2
salary: 65000

-- diff between e1 and e2
diff 'e1 vs e2':
  DIFFER person.name  A='Engineer A' B='Designer B'
  DIFFER person.age  A=28 B=33
  DIFFER person.height_cm  A=175 B=165
  DIFFER person.likes_cats  A=true B=false
  DIFFER address.street  A='1 Main' B='2 Oak'
  DIFFER address.city  A='Zenith' B='Nimbus'
  DIFFER address.zip  A='00001' B='00002'
  DIFFER employee_id  A=1 B=2
  DIFFER salary  A=70000 B=65000

-- regen the diff after copying e1 to e3 and changing one field
diff 'e1 vs e3':
  EQUAL  person.name= 'Engineer A'
  EQUAL  person.age= 28
  EQUAL  person.height_cm= 175
  EQUAL  person.likes_cats= true
  EQUAL  address.street= '1 Main'
  EQUAL  address.city= 'Zenith'
  EQUAL  address.zip= '00001'
  EQUAL  employee_id= 1
  DIFFER salary  A=70000 B=71000

-- Render e1 with templating
  Engineer A works in Zenith earning 70000

