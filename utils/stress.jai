// ============================================================================
// 28. Print formatting deep-dive.
// ============================================================================

test_print_formatting :: () {
    section("28. Print formatting deep-dive");

    sub("Mixed positional substitution: % in order");
    print("%, % and %\n", "tic", "tac", "toe");

    sub("%1, %2, ... positional indexing");
    print("%2 then %1, then %1 again\n", "first", "second");

    sub("Literal percent: write \\% to print a literal %");
    print("100\% done\n");

    sub("Format arrays");
    arr := int.[10, 20, 30];
    print("default array: %\n", arr);

    fa: FormatArray;
    fa.value        = arr;
    fa.separator    = " | ";
    fa.begin_string = "<<";
    fa.end_string   = ">>";
    print("custom array: %\n", fa);

    sub("Format struct with custom prefix");
    v := V2.{3, 4};
    fs: FormatStruct;
    fs.value        = v;
    fs.draw_type_name = true;
    print("with type name: %\n", fs);

    sub("Format floats");
    print("default 1/3 = %\n", 1.0/3.0);
    print("scientific  = %\n", formatFloat(1.0/3.0, mode=.SCIENTIFIC));
    print("shortest    = %\n", formatFloat(1.0/3.0, mode=.SHORTEST));

    sub("Format ints in various bases");
    n := 1234;
    print("base 10 : %\n", n);
    print("base 16 : %\n", formatInt(n, base=16));
    print("base 2  : %\n", formatInt(n, base=2));
    print("base 8  : %\n", formatInt(n, base=8));
    print("padded  : %\n", formatInt(n, base=10, minimum_digits=8));
    print("commas  : %\n", formatInt(1_234_567_890, base=10,
                                     digits_per_comma=3, comma_string=","));
}


// ============================================================================
// 29. Integer overflow / wrapping behavior with explicit casts.
// ============================================================================

test_overflow :: () {
    section("29. Integer overflow / explicit wrapping");

    u8_max : u8  = 255;
    u16_max: u16 = 0xFFFF;
    u32_max: u32 = 0xFFFF_FFFF;
    print("u8_max=% u16_max=% u32_max=%\n", u8_max, u16_max, u32_max);

    sub("Truncating cast wraps the bit pattern");
    big_fits : u32 = 0xFFFF_FFFF;
    wrap: u8 = cast,no_check(u8) big_fits;
    print("u32(0xFFFF_FFFF) -> u8 wrap = % (expect 255)\n", wrap);

    sub("Signed s8 ranges");
    s8_min : s8 = -128;
    s8_max : s8 =  127;
    print("s8 range = [%, %]\n", s8_min, s8_max);
}


// ============================================================================
// 30. Bit operations.
// ============================================================================

test_bitops :: () {
    section("30. Bit operations");

    a: u8 = 0b1010_1010;
    b: u8 = 0b0101_1111;

    print("a    = %\n", formatInt(a, base=2, minimum_digits=8));
    print("b    = %\n", formatInt(b, base=2, minimum_digits=8));
    print("a&b  = %\n", formatInt(a & b, base=2, minimum_digits=8));
    print("a|b  = %\n", formatInt(a | b, base=2, minimum_digits=8));
    print("a^b  = %\n", formatInt(a ^ b, base=2, minimum_digits=8));
    print("~a   = %\n", formatInt(~a, base=2, minimum_digits=8));
    print("a<<2 = %\n", formatInt(a << 2, base=2, minimum_digits=10));
    print("a>>2 = %\n", formatInt(a >> 2, base=2, minimum_digits=8));

    sub("Signed shift: arithmetic right shift");
    s : s8 = -8;       // 0b1111_1000
    sh := s >> 2;
    print("s=-8 >> 2 = % (arithmetic; sign-extended)\n", sh);
}


// ============================================================================
// 31. Compile-time string literal stuff
// ============================================================================

test_string_literal_features :: () {
    section("31. String literal features");

    sub("Zero-terminated literal: cast to *u8 works for string CONSTANT");
    LIT :: "hello";
    p : *u8 = LIT.data;
    n: int = 0;
    while p[n] != 0 { n += 1; }
    print("strlen of constant '%' via terminating zero = %\n", LIT, n);

    sub("Unicode escapes in strings");
    smiley :: "☺";
    print("\\u263A as bytes:");
    for c: cast([]u8) smiley  print(" 0x%", formatInt(c, base=16, minimum_digits=2));
    print("\n");

    sub("Newline normalization in #string,cr (carriage-return line endings)");
    CR :: #string,cr END
line1
line2
END
    print("bytes in CR string (should contain \\r\\n):");
    for c: cast([]u8) CR  print(" %", formatInt(c, base=16, minimum_digits=2));
    print("\n");
}


