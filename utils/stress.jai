== 131. Bit manipulation tricks: popcount, parity, byte swap, bit reverse
----------------------------------------------------------------

-- popcount and parity
popcount(0x00000000) = 0  parity = 0
popcount(0x00000001) = 1  parity = 1
popcount(0x00000002) = 1  parity = 1
popcount(0x00000003) = 2  parity = 0
popcount(0x00000007) = 3  parity = 1
popcount(0x000000ff) = 8  parity = 0
popcount(0xcafebabe) = 22  parity = 0
popcount(0xffffffff) = 32  parity = 0
popcount(0x80000000) = 1  parity = 1

-- byte_swap_u32
0x01020304 -> 0x04030201
0xdeadbeef -> 0xefbeadde
0x12345678 -> 0x78563412
0x00000001 -> 0x01000000

-- bit_reverse_u8
0x00 -> 0x00
0x01 -> 0x80
0x02 -> 0x40
0x03 -> 0xc0
0x80 -> 0x01
0xf0 -> 0x0f
0x0f -> 0xf0
0xff -> 0xff

-- Power of two detection: (x & (x - 1)) == 0 for x > 0
is_pot(0) = false
is_pot(1) = true
is_pot(2) = true
is_pot(3) = false
is_pot(4) = true
is_pot(6) = false
is_pot(8) = true
is_pot(15) = false
is_pot(16) = true
