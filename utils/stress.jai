// ----------------------------------------------------------------------------
// 466d. enum_flags from u8
// ----------------------------------------------------------------------------

E466d_Mode :: enum_flags u8 {
    NONE     :: 0x00;
    READ     :: 0x01;
    WRITE    :: 0x02;
    APPEND   :: 0x04;
    TRUNCATE :: 0x08;
    BINARY   :: 0x10;
    TEXT     :: 0x20;
    CREATE   :: 0x40;
    EXCL     :: 0x80;
}

test_466d_mode_flags :: () {
    section("466d. enum_flags u8 with 8 explicit flags");

    rw: E466d_Mode = .READ | .WRITE;
    rwc: E466d_Mode = .READ | .WRITE | .CREATE;
    all: E466d_Mode = .READ | .WRITE | .APPEND | .TRUNCATE | .BINARY | .TEXT | .CREATE | .EXCL;

    print("rw  = %\n", formatInt(cast(u8) rw, base=2, minimum_digits=8));
    print("rwc = %\n", formatInt(cast(u8) rwc, base=2, minimum_digits=8));
    print("all = %\n", formatInt(cast(u8) all, base=2, minimum_digits=8));

    sub("Tests");
    for v: enum_values_as_enum(E466d_Mode) {
        if v == 0  continue;
        print("rwc & %  -> %\n", v, (rwc & v) != 0);
    }
}


