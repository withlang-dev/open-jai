// ----------------------------------------------------------------------------
// 768. Word counting and frequency in a small fixed text.
// ----------------------------------------------------------------------------

PE7_split_words :: (s: string) -> [..] string {
    out: [..] string;
    n := s.count;
    i := 0;
    while i < n {
        while i < n && s[i] == #char " "  i += 1;
        start := i;
        while i < n && s[i] != #char " "  i += 1;
        if i > start {
            w: string;
            w.data = s.data + start;
            w.count = i - start;
            array_add(*out, w);
        }
    }
    return out;
}

run_extras_7_words :: () {
    section("768. Word splitting and frequency");

    sentences := string.[
        "the quick brown fox jumps over the lazy dog",
        "to be or not to be that is the question",
        "all happy families are alike all unhappy families are unhappy",
        "alpha beta alpha gamma alpha",
        "x x x y y z",
    ];

    for s: sentences {
        ws := PE7_split_words(s);
        defer array_free(ws);
        print("  sentence='%'\n", s);
        print("  words=%\n", ws.count);
        // Frequency via Table
        t: Table(string, int);
        init(*t);
        defer deinit(*t);
        for w: ws {
            ok, v := table_find(*t, w);
            if ok  table_set(*t, w, v + 1);
            else   table_add(*t, w, 1);
        }
        keys: [..] string;
        for v, k: t  array_add(*keys, k);
        defer array_free(keys);
        PE7_str_bubble_sort(keys);
        for k: keys {
            ok, v := table_find(*t, k);
            if ok  print("    % -> %\n", k, v);
        }
    }
}


// ----------------------------------------------------------------------------
// 769. Defer in an early-return procedure.
// ----------------------------------------------------------------------------

PE7_early_return :: (n: int) -> int {
    defer print("  defer-A always for n=%\n", n);
    if n < 0 {
        defer print("  defer-B inside neg-return for n=%\n", n);
        print("  early return for n=%\n", n);
        return -1;
    }
    defer print("  defer-C for n=%\n", n);
    if n == 0 {
        print("  zero path n=%\n", n);
        return 0;
    }
    print("  normal path n=%\n", n);
    return n * 10;
}

run_extras_7_early_return :: () {
    section("769. Defer in early-return procedure");

    for v: int.[-1, 0, 1, 5] {
        r := PE7_early_return(v);
        print("returned r=%\n", r);
    }
}


