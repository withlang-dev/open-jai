SRC},

// ===========================================================================
// SECTION CL. #run and metaprogram misuse.
// ===========================================================================

.{ "#run that recurses into itself", #string SRC
#import "Basic";
recurse :: () -> int #expand { return recurse(); }
N :: #run recurse();
main :: () { print("%\n", N); }
SRC},

.{ "macro defer escaping caller scope", #string SRC
#import "Basic";
leak :: () #expand {
    defer print("deferred\n");
}
main :: () {
    leak();
    print("after macro\n");
}
SRC},

.{ "#expand body with mismatched return arity", #string SRC
#import "Basic";
m :: () -> int, int #expand {
    return 1;
}
main :: () {
    a, b := m();
    print("% %\n", a, b);
}
SRC},

.{ "inline directive on procedure pointer variable", #string SRC
#import "Basic";
add :: (a: int, b: int) -> int { return a + b; }
main :: () {
    p: inline (a: int, b: int) -> int = add;
    print("%\n", p(1, 2));
}
SRC},

.{ "calling inline with non-constant where constant required", #string SRC
#import "Basic";
pick :: inline (n: int) -> int {
    #if n > 0 return 1;
    else return 0;
}
main :: () {
    x := 5;
    _ := pick(x);
}
SRC},

// ===========================================================================
// SECTION CM. Self-reference / cross-workspace.
// ===========================================================================

.{ "struct using Self name in method-like signature", #string SRC
#import "Basic";
S :: struct {
    next: *Self;
    value: int;
}
main :: () { s: S; print("%\n", s.value); }
SRC},

.{ "use of __command_line_arguments at compile time top level", #string SRC
#import "Basic";
N :: #run __command_line_arguments.count;
main :: () { print("%\n", N); }
SRC},

// ===========================================================================
// SECTION CN. Field type depending on runtime, side effects, bogus directives.
// ===========================================================================

.{ "struct field array length depends on runtime variable", #string SRC
#import "Basic";
main :: () {
    n := 10;
    S :: struct { arr: [n] int; }
    s: S;
    print("%\n", s.arr.count);
}
SRC},

.{ "struct field default calls procedure with side effects", #string SRC
#import "Basic";
counter := 0;
bump :: () -> int { counter += 1; return counter; }
S :: struct { x: int = bump(); }
main :: () { s: S; print("%\n", s.x); }
SRC},

.{ "procedure with unknown directive #no_aoc", #string SRC
#import "Basic";
f :: () #no_aoc { print("hi\n"); }
main :: () { f(); }
SRC},

.{ "unknown top-level directive", #string SRC
#import "Basic";
#totally_made_up_directive
main :: () { }
SRC},

.{ "scope_export followed by private access from another file (single-file proxy)", #string SRC
#import "Basic";
#scope_export
PUBLIC :: 1;
#scope_file
PRIVATE :: 2;
main :: () { print("%\n", PRIVATE + PUBLIC); }
SRC},

// ===========================================================================
// SECTION CO. Hash tables, sorting, comparisons.
// ===========================================================================

.{ "hash table with key type lacking hashable trait", #string SRC
#import "Basic";
#import "Hash_Table";
S :: struct { a: int; b: int; }
main :: () {
    t: Table(S, int);
    init(*t);
    k: S;
    table_add(*t, k, 1);
}
SRC},

.{ "sort array of types that are not ordered", #string SRC
#import "Basic";
#import "Sort";
S :: struct { a: int; b: int; }
main :: () {
    arr: [3] S;
    quick_sort(arr);
}
SRC},

.{ "float equality comparison (compiler may warn)", #string SRC
#import "Basic";
main :: () {
    a: float = 0.1 + 0.2;
    if a == 0.3 print("equal\n");
    else        print("not equal\n");
}
SRC},

.{ "mixed integer and float comparison without cast", #string SRC
#import "Basic";
main :: () {
    i: s32 = 5;
    f: float64 = 5.0;
    if i == f print("eq\n");
}
SRC},

// ===========================================================================
// SECTION CP. Cast and conversion oddities.
// ===========================================================================

.{ "cast string to integer with plain cast", #string SRC
#import "Basic";
main :: () {
    s: string = "hello";
    x: int = cast(int) s;
    print("%\n", x);
}
SRC},

.{ "cast struct value to string", #string SRC
#import "Basic";
S :: struct { a: int; b: int; }
main :: () {
    s: S;
    str := cast(string) s;
    print("%\n", str);
}
SRC},

.{ "cast integer to procedure type", #string SRC
#import "Basic";
main :: () {
    x: int = 0;
    p := cast((a: int) -> int) x;
    _ := p(5);
}
SRC},

// ===========================================================================
// SECTION CQ. Excessive allocations & assertion misuse.
// ===========================================================================

.{ "huge stack array (10 billion elements)", #string SRC
#import "Basic";
main :: () {
    a: [10_000_000_000] int;
    print("%\n", a.count);
}
SRC},

.{ "#assert with non-bool expression (integer)", #string SRC
#import "Basic";
#assert 5;
main :: () { }
SRC},

.{ "#assert with non-bool expression (string)", #string SRC
#import "Basic";
#assert "true";
main :: () { }
SRC},

// ===========================================================================
// SECTION CR. #bake_arguments and Code-value confusion.
// ===========================================================================

.{ "#bake_arguments with wrong type for parameter", #string SRC
#import "Basic";
add :: (a: int, b: int) -> int { return a + b; }
baked :: #bake_arguments add(a="hello");
main :: () { _ := baked(b=2); }
SRC},

.{ "#bake_arguments on a fully baked procedure", #string SRC
#import "Basic";
add :: (a: int, b: int) -> int { return a + b; }
baked  :: #bake_arguments add(a=1, b=2);
baked2 :: #bake_arguments baked(a=3);
main :: () { _ := baked2(); }
SRC},

.{ "Code value passed where string expected", #string SRC
#import "Basic";
takes_string :: (s: string) { print("%\n", s); }
main :: () {
    c: Code = #code { x := 1; };
    takes_string(c);
}
SRC},

.{ "Code parameter used as runtime value", #string SRC
#import "Basic";
#import "Compiler";
takes_code :: (c: Code) -> int { return c; }
main :: () {
    n := takes_code(#code 5);
    print("%\n", n);
}
SRC},

.{ "#code body with malformed contents", #string SRC
#import "Basic";
main :: () {
    c: Code = #code { x := };
    print("%\n", c);
}
SRC},

// ===========================================================================
// SECTION CS. Final mixed.
// ===========================================================================

.{ "comma expression in initializer", #string SRC
#import "Basic";
main :: () {
    x: int = (1, 2, 3);
    print("%\n", x);
}
SRC},

.{ "comma in if condition where boolean expected", #string SRC
#import "Basic";
main :: () {
    if (true, false) {
        print("hi\n");
    }
}
SRC},

.{ "return with comma list but proc returns one value", #string SRC
#import "Basic";
f :: () -> int { return 1, 2; }
main :: () { _ := f(); }
SRC},

.{ "if-then with stray semicolon between condition and body", #string SRC
#import "Basic";
main :: () {
    if true; { print("hi\n"); }
}
SRC},

];


// ============================================================================
// Expected combined output produced by this file.
//
// `jai cleanroom_stress.jai && ./cleanroom_stress` should print the
// runtime half exactly as below. The compile-time half (compiler
// diagnostics from the embedded error catalog) is intentionally not
// reproduced verbatim - run the file to observe your compiler's diagnostics.
// ============================================================================

EXPECTED_OUTPUT :: #string EXPECTED_OUTPUT_END
========================== COMPILE-TIME OUTPUT =========================
(omitted - compiler diagnostics are not reproduced verbatim)
============================ RUNTIME OUTPUT ============================

----------------------------------------------------------------
== 1. Numeric types and literals
----------------------------------------------------------------
u8  size=1 value=10
u16 size=2 value=50
u32 size=4 value=1935
u64 size=8 value=18077130800918084286
s8  size=1 value=-7
s16 size=2 value=365
s32 size=4 value=-5069105
s64 size=8 value=987654321
int size=8 (alias for s64? true)
float   size=4 (alias for float32? true)
float64 size=8 value=1.5
bool size=1 value=true
my_int=7 my_flt=1.25

-- Default-initialized values are zero
default u8=0 int=0 float=0 bool=false string-count=0 string-data-null=true

-- --- (uninitialized) compiles; assign before reading
after assign raw=99

-- Constants ( :: ) cannot be reassigned
PI64=3.141593 HEX_CONST=3405705229

-- Hex float literals (0h prefix - IEEE-754 bit pattern)
nan32 (NaN) =NaN one32=1 inf32=Inf neg0_64=-0

-- Numeric literal underscores allowed for readability
1_000_000 = 1000000

-- Compile-time numeric literal coercion
u8 = 200 -> 200

----------------------------------------------------------------
== 2. Casts (cast, cast,no_check, cast,trunc, cast,no_check,no_widen)
----------------------------------------------------------------
u8 a=200 -> u16 b=200 -> s64 c=200
cast,no_check truncate 0x1234_5678 -> u16 = 22136
cast checked u16(250) -> u8 = 250

-- Sign-extension vs zero-extension on widening
s8(-1) widened to s32 = -1 (sign-extended)
s8(-1) bit-reinterpret to u32 = 4294967295 (0xffffffff)

-- Float <-> int conversions
int(3.99)=3 int(-3.99)=-3 float(42)=42

----------------------------------------------------------------
== 3. Booleans and short-circuit logical operators
----------------------------------------------------------------
true && false  = false
true || false  = true
!true          = false
!!42 truthy?   = true

-- Short-circuit evaluation (&&)
  side_effect(A=false) called -> false
A&&B = false  (calls so far: 1)

-- Short-circuit evaluation (||)
  side_effect(A=true) called -> true
A||B = true  (calls so far: 1)

-- Both sides evaluated when needed
  side_effect(A=true) called -> true
  side_effect(B=true) called -> true
A&&B = true  (calls so far: 2)

----------------------------------------------------------------
== 4. Arrays: fixed, view, resizable
----------------------------------------------------------------

-- Fixed array [N] T
fixed count(implicit via type) = 5 size_of = 40
  fa[0] = 100
  fa[1] = 200
  fa[2] = 0
  fa[3] = 0
  fa[4] = 999

-- Array views [] T
view count=5 size_of=16
shrunk view count=3 values:
  av[0] = 100
  av[1] = 200
  av[2] = 0

-- Resizable arrays [..] T
resizable count=5 allocated>=count? true
  ra[0] = 1
  ra[1] = 4
  ra[2] = 9
  ra[3] = 16
  ra[4] = 25

-- array_add many elements
