// ----------------------------------------------------------------------------
// 481c. Hierarchy field shadowing
// ----------------------------------------------------------------------------

L481c_Animal :: struct {
    name: string = "anonymous-animal";
    sound: string = "silent";
}

L481c_Cow :: struct {
    #as using base: L481c_Animal;
    name = "cow";
    sound = "moo";
    eats_grass: bool = true;
}

test_481c_hierarchy_fields :: () {
    section("481c. Hierarchy field defaults override");

    a: L481c_Animal;
    print("animal = %\n", a);

    c: L481c_Cow;
    print("cow    = %\n", c);

    sub("Explicit construction");
    c2 := L481c_Cow.{};
    print("cow {} = %\n", c2);

    c3 := L481c_Cow.{base=.{name="Bessie", sound="MOO!"}, eats_grass=false};
    print("designated cow = %\n", c3);
}


// ----------------------------------------------------------------------------
// 458b. Random with seed 0xDEADBEEF
// ----------------------------------------------------------------------------

test_458b_random_long :: () {
    section("458b. Random seed 0xDEADBEEF (200 values mod 64)");

    random_seed(cast(u64) 0xDEADBEEF);
    for i: 0..199 {
        v := random_get() % 64;
        print("r[%]=%\n", i, v);
    }
}


// ----------------------------------------------------------------------------
// 459b. Random sequence reproducibility (re-seed)
// ----------------------------------------------------------------------------

test_459b_random_reseed :: () {
    section("459b. Re-seed reproducibility");

    a: [..] u64;
    random_seed(cast(u64) 123);
    for i: 0..9  array_add(*a, random_get());

    b: [..] u64;
    random_seed(cast(u64) 123);
    for i: 0..9  array_add(*b, random_get());

    all_eq := true;
    for i: 0..a.count-1 {
        if a[i] != b[i]  all_eq = false;
        print("a[%]=% b[%]=%\n", i, a[i], i, b[i]);
    }
    print("all equal = %\n", all_eq);
}


// ----------------------------------------------------------------------------
// 477c. Iteration: zip-like pairing
// ----------------------------------------------------------------------------

test_477c_zip_like :: () {
    section("477c. Manual zip iteration");

    a := int.[10, 20, 30, 40, 50];
    b := string.["A", "B", "C", "D", "E"];
    n := min(a.count, b.count);
    for i: 0..n-1
        print("(%, '%')\n", a[i], b[i]);
}


// ----------------------------------------------------------------------------
// 488f. Range step via while
// ----------------------------------------------------------------------------

test_488f_while_loops :: () {
    section("488f. While loops with various conditions");

    sub("Sum doubling until > 1000");
    n := 1;
    sum := 0;
    while n < 1000 {
        sum += n;
        n *= 2;
    }
    print("sum = % final n = %\n", sum, n);

    sub("Collatz step counts (3n+1)");
    for start: int.[1, 2, 3, 5, 7, 11, 27] {
        x := start;
        steps := 0;
        while x != 1 && steps < 100 {
            if x % 2 == 0  x = x / 2;
            else           x = 3 * x + 1;
            steps += 1;
        }
        print("start=% steps=%\n", start, steps);
    }
}


// ----------------------------------------------------------------------------
// 472d. Logger usage (avoid actual output)
// ----------------------------------------------------------------------------

test_472d_logger_present :: () {
    section("472d. Logger nullity stable");

    print("logger is null? %\n", context.logger == null);
    print("logger_data is null? %\n", context.logger_data == null);
    print("assertion_failed null? %\n", context.assertion_failed == null);

    sub("Replace assertion handler temporarily? (no)");
    print("(skipping actual replace to avoid behavior change)\n");
}


// ----------------------------------------------------------------------------
// 410g. Print with tprint composition
// ----------------------------------------------------------------------------

test_410g_compose_strings :: () {
    section("410g. Compose strings via tprint");

    pieces: [..] string;
    for i: 0..4  array_add(*pieces, tprint("item%", i));
    joined := join(..pieces, separator=" / ");
    print("joined = '%'\n", joined);

    sub("Build a CSV-like row");
    rows: [..] string;
    for r: 0..3 {
        cols: [..] string;
        for c: 0..2  array_add(*cols, tprint("%-%", r, c));
        array_add(*rows, join(..cols, separator=","));
    }
    for r, i: rows  print("row %: '%'\n", i, r);
}


// ----------------------------------------------------------------------------
// 419c. Selected u64 operations table
// ----------------------------------------------------------------------------

test_419c_u64_table :: () {
    section("419c. u64 op table");

    a: u64 = 0x0123_4567_89AB_CDEF;
    b: u64 = 0xFEDC_BA98_7654_3210;
    print("a = %\n", formatInt(a, base=16, minimum_digits=16));
    print("b = %\n", formatInt(b, base=16, minimum_digits=16));
    print("a + b = %\n", formatInt(a + b, base=16, minimum_digits=16));
    print("a - b = %\n", formatInt(a - b, base=16, minimum_digits=16));
    print("b - a = %\n", formatInt(b - a, base=16, minimum_digits=16));
    print("a ^ b = %\n", formatInt(a ^ b, base=16, minimum_digits=16));
}


