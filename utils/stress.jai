    fa_v3  : [2] PE6_Vec3;

    PE6_print_array_info_for("[5]s32", type_info(type_of(fa_s32)));
    PE6_print_array_info_for("[3]int", type_info(type_of(fa_int)));
    PE6_print_array_info_for("[2]PE6_Vec3", type_info(type_of(fa_v3)));

    sub("Array views");
    vi : [] int    = int.[1,2,3];
    vu : [] u8     = u8.[1,2,3,4];
    vv : [] PE6_Vec2;
    PE6_print_array_info_for("[]int", type_info(type_of(vi)));
    PE6_print_array_info_for("[]u8",  type_info(type_of(vu)));
    PE6_print_array_info_for("[]PE6_Vec2", type_info(type_of(vv)));

    sub("Resizable arrays");
    ra : [..] int;
    rs : [..] string;
    PE6_print_array_info_for("[..]int",    type_info(type_of(ra)));
    PE6_print_array_info_for("[..]string", type_info(type_of(rs)));

    sub("Nested arrays");
    fa_2d : [3][4] int;
    PE6_print_array_info_for("[3][4]int",
                            type_info(type_of(fa_2d)));
}

