  pair 0=(1, 2)
  pair 1=(1, 3)
  pair 2=(1, 4)
  pair 3=(2, 3)
  pair 4=(2, 4)
  pair 5=(3, 4)

----------------------------------------------------------------
== 705. Complex number operator overloads
----------------------------------------------------------------

-- 705.a Pairwise sums and differences
  (1,2)+(1,2) = (2,4) ; - = (0,0)
  (1,2)+(3,-1) = (4,1) ; - = (-2,3)
  (1,2)+(0,4) = (1,6) ; - = (1,-2)
  (1,2)+(-2,0) = (-1,2) ; - = (3,2)
  (1,2)+(5,5) = (6,7) ; - = (-4,-3)
  (1,2)+(1.5,2.5) = (2.5,4.5) ; - = (-0.5,-0.5)
  (3,-1)+(1,2) = (4,1) ; - = (2,-3)
  (3,-1)+(3,-1) = (6,-2) ; - = (0,0)
  (3,-1)+(0,4) = (3,3) ; - = (3,-5)
  (3,-1)+(-2,0) = (1,-1) ; - = (5,-1)
  (3,-1)+(5,5) = (8,4) ; - = (-2,-6)
  (3,-1)+(1.5,2.5) = (4.5,1.5) ; - = (1.5,-3.5)
  (0,4)+(1,2) = (1,6) ; - = (-1,2)
  (0,4)+(3,-1) = (3,3) ; - = (-3,5)
  (0,4)+(0,4) = (0,8) ; - = (0,0)
  (0,4)+(-2,0) = (-2,4) ; - = (2,4)
  (0,4)+(5,5) = (5,9) ; - = (-5,-1)
  (0,4)+(1.5,2.5) = (1.5,6.5) ; - = (-1.5,1.5)
  (-2,0)+(1,2) = (-1,2) ; - = (-3,-2)
  (-2,0)+(3,-1) = (1,-1) ; - = (-5,1)
  (-2,0)+(0,4) = (-2,4) ; - = (-2,-4)
  (-2,0)+(-2,0) = (-4,0) ; - = (0,0)
  (-2,0)+(5,5) = (3,5) ; - = (-7,-5)
  (-2,0)+(1.5,2.5) = (-0.5,2.5) ; - = (-3.5,-2.5)
  (5,5)+(1,2) = (6,7) ; - = (4,3)
  (5,5)+(3,-1) = (8,4) ; - = (2,6)
  (5,5)+(0,4) = (5,9) ; - = (5,1)
  (5,5)+(-2,0) = (3,5) ; - = (7,5)
  (5,5)+(5,5) = (10,10) ; - = (0,0)
  (5,5)+(1.5,2.5) = (6.5,7.5) ; - = (3.5,2.5)
  (1.5,2.5)+(1,2) = (2.5,4.5) ; - = (0.5,0.5)
  (1.5,2.5)+(3,-1) = (4.5,1.5) ; - = (-1.5,3.5)
  (1.5,2.5)+(0,4) = (1.5,6.5) ; - = (1.5,-1.5)
  (1.5,2.5)+(-2,0) = (-0.5,2.5) ; - = (3.5,2.5)
  (1.5,2.5)+(5,5) = (6.5,7.5) ; - = (-3.5,-2.5)
  (1.5,2.5)+(1.5,2.5) = (3,5) ; - = (0,0)

