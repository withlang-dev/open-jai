    if true {
        print("hi\n");
}
SRC},

.{ "extra closing brace at end of file", #string SRC
#import "Basic";
main :: () {
    print("hi\n");
}
}
SRC},

// ===========================================================================
// SECTION CC. Procedure parameter / return syntax problems.
// ===========================================================================

.{ "procedure parameter with no name", #string SRC
#import "Basic";
f :: (: int) -> int { return 0; }
main :: () { _ := f(5); }
SRC},

.{ "procedure parameter with no type or value", #string SRC
#import "Basic";
f :: (a:) -> int { return 0; }
main :: () { _ := f(5); }
SRC},

.{ "procedure return spec with stray parens around name", #string SRC
#import "Basic";
f :: () -> (int) { return 0; }
main :: () { _ := f(); }
SRC},

.{ "procedure with no body and no directive", #string SRC
#import "Basic";
f :: ()
main :: () { f(); }
SRC},

.{ "procedure body replaced with semicolon", #string SRC
#import "Basic";
f :: () -> int;
main :: () { _ := f(); }
SRC},

.{ "procedure with trailing comma in parameter list", #string SRC
#import "Basic";
f :: (a: int, b: int,) -> int { return a + b; }
main :: () { _ := f(1, 2); }
SRC},

.{ "procedure call with trailing comma in argument list", #string SRC
#import "Basic";
f :: (a: int, b: int) -> int { return a + b; }
main :: () { _ := f(1, 2,); }
SRC},

.{ "procedure return list with leading comma", #string SRC
#import "Basic";
f :: () -> ( , int) { return 0; }
main :: () { _ := f(); }
SRC},

// ===========================================================================
// SECTION CD. C-style loop & conditional shapes.
// ===========================================================================

.{ "C-style for with three semicolons", #string SRC
#import "Basic";
main :: () {
    for i := 0; i < 10; i += 1 {
        print("%\n", i);
    }
}
SRC},

.{ "C-style empty for with semicolons", #string SRC
#import "Basic";
main :: () {
    for ; ; { break; }
}
SRC},

.{ "while with C-style empty condition", #string SRC
#import "Basic";
main :: () {
    while (;;) { break; }
}
SRC},

.{ "if with C-style parens being mandatory (should not be)", #string SRC
#import "Basic";
main :: () {
    if (true) print("hello\n");
}
SRC},

.{ "if missing condition entirely", #string SRC
#import "Basic";
main :: () {
    if { print("hi\n"); }
}
SRC},

